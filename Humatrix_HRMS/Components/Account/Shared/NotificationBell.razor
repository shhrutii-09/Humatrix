@* Components/Shared/NotificationBell.razor *@
@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Infrastructure.Services
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.SignalR.Client
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject NotificationEngine NotificationEngine
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav

<div class="dropdown notification-bell-container">

    <!-- BELL BUTTON -->
    <button class="btn btn-light position-relative border"
            type="button"
            data-bs-toggle="dropdown"
            aria-expanded="false"
            aria-label="Notifications">
        <i class="bi bi-bell fs-5"></i>
        @if (unreadCount > 0)
        {
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                  style="font-size: 0.65rem;">
                @(unreadCount > 99 ? "99+" : unreadCount.ToString())
            </span>
        }
    </button>

    <!-- DROPDOWN -->
    <div class="dropdown-menu dropdown-menu-end shadow border-0 p-0 notification-dropdown">

        <!-- HEADER -->
        <div class="d-flex justify-content-between align-items-center px-3 py-2 border-bottom bg-light sticky-top">
            <span class="fw-bold">Notifications</span>
            <div class="d-flex gap-2">
                @if (notifications.Any(x => !x.IsRead))
                {
                    <button class="btn btn-sm btn-link text-primary text-decoration-none p-0"
                            @onclick="MarkAllRead">
                        Mark all read
                    </button>
                }
                @if (notifications.Any())
                {
                    <button class="btn btn-sm btn-link text-danger text-decoration-none p-0"
                            @onclick="ClearAll">
                        Clear all
                    </button>
                }
            </div>
        </div>

        <!-- FILTER TABS -->
        <div class="d-flex border-bottom px-2 pt-1 bg-white sticky-top" style="top:41px;">
            @foreach (var tab in new[] { "All", "Unread" })
            {
                <button class="btn btn-sm me-1 mb-1 @(activeTab == tab ? "btn-primary" : "btn-light")"
                        @onclick="() => SetTab(tab)">
                    @tab
                </button>
            }
        </div>

        <!-- LIST -->
        <div style="max-height: 400px; overflow-y: auto;">
            @{
                var visible = activeTab == "Unread"
                ? notifications.Where(x => !x.IsRead).ToList()
                : notifications;
            }

            @if (!visible.Any())
            {
                <div class="text-center text-muted p-4">
                    <i class="bi bi-bell-slash fs-4 d-block mb-2"></i>
                    No notifications
                </div>
            }
            else
            {
                @foreach (var n in visible)
                {
                    <div class="notification-item border-bottom d-flex align-items-start p-3 @(!n.IsRead ? "notification-item--unread" : "")"
                         style="cursor: pointer"
                         @onclick="() => Open(n)">

                        <!-- TYPE ICON -->
                        <div class="notification-icon me-2 flex-shrink-0">
                            <i class="bi @GetIcon(n.NotificationType) @GetIconColor(n.NotificationType)"></i>
                        </div>

                        <!-- CONTENT -->
                        <div class="flex-grow-1 overflow-hidden">
                            <div class="fw-semibold text-truncate">@n.Title</div>
                            <small class="text-muted d-block">@n.Message</small>
                            <div class="small text-muted mt-1">
                                @TimeAgo(n.CreatedAt)
                            </div>
                        </div>

                        <!-- DELETE -->
                        <button class="btn btn-sm text-muted ms-1 flex-shrink-0"
                                title="Dismiss"
                                @onclick:stopPropagation="true"
                                @onclick="() => Delete(n.NotificationId)">
                            <i class="bi bi-x"></i>
                        </button>
                    </div>
                }
            }
        </div>

        <!-- FOOTER -->
        <div class="border-top text-center py-2 bg-light">
            <a href="/notifications" class="small text-primary text-decoration-none">
                View all notifications
            </a>
        </div>
    </div>
</div>

<style>
    .notification-dropdown {
        width: 380px;
        border-radius: 12px;
    }

    .notification-item:hover {
        background-color: #f8f9fa;
    }

    .notification-item--unread {
        background-color: #f0f7ff;
    }

        .notification-item--unread:hover {
            background-color: #e8f2ff;
        }
</style>

@code {
    private HubConnection? _hub;
    private List<NotificationDto> notifications = new();
    private int unreadCount;
    private string? currentUserId;
    private bool _connected;
    private string activeTab = "All";

    protected override async Task OnInitializedAsync()
    {
        await LoadUser();
        await LoadNotifications();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _connected || string.IsNullOrEmpty(currentUserId))
            return;

        _connected = true;

        _hub = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/notificationHub"))
            .WithAutomaticReconnect()
            .Build();

        // Receive full payload — no DB reload needed
        _hub.On<NotificationPushDto>("ReceiveNotification", async push =>
        {
            try
            {
                // Prepend to local list without hitting DB
                notifications.Insert(0, new NotificationDto
                {
                    NotificationId = push.NotificationId,
                    Title = push.Title,
                    Message = push.Message,
                    RedirectUrl = push.RedirectUrl,
                    NotificationType = push.NotificationType,
                    Priority = push.Priority,
                    CreatedAt = push.CreatedAt,
                    IsRead = false
                });

                unreadCount = push.NewUnreadCount;

                // Show toast + sound (respect preferences — check sound toggle)
                await JS.InvokeVoidAsync("showToastNotification",
                    push.Title, push.Message, push.RedirectUrl, push.Priority);
                await JS.InvokeVoidAsync("playNotificationSound");

                await InvokeAsync(StateHasChanged);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[NotificationBell] Push handler error: {ex.Message}");
            }
        });

        await _hub.StartAsync();
        await _hub.SendAsync("JoinUserGroup", currentUserId);
    }

    private async Task LoadUser()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        currentUserId = auth.User
            .FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    }

    private async Task LoadNotifications()
    {
        if (string.IsNullOrEmpty(currentUserId)) return;
        notifications = await NotificationEngine.GetMyNotificationsAsync(currentUserId);
        unreadCount = notifications.Count(x => !x.IsRead);
        StateHasChanged();
    }

    private async Task Open(NotificationDto n)
    {
        if (!n.IsRead)
        {
            await NotificationEngine.MarkAsReadAsync(n.NotificationId, currentUserId!);
            n.IsRead = true;
            unreadCount = Math.Max(0, unreadCount - 1);
            StateHasChanged();
        }
        if (!string.IsNullOrWhiteSpace(n.RedirectUrl))
            Nav.NavigateTo(n.RedirectUrl, forceLoad: false);
    }

    private async Task Delete(int id)
    {
        await NotificationEngine.DeleteAsync(id, currentUserId!);
        notifications.RemoveAll(x => x.NotificationId == id);
        unreadCount = notifications.Count(x => !x.IsRead);
        StateHasChanged();
    }

    private async Task MarkAllRead()
    {
        await NotificationEngine.MarkAllReadAsync(currentUserId!);
        notifications.ForEach(x => { x.IsRead = true; x.ReadAt = DateTime.UtcNow; });
        unreadCount = 0;
        StateHasChanged();
    }

    private async Task ClearAll()
    {
        await NotificationEngine.ClearAllAsync(currentUserId!);
        notifications.Clear();
        unreadCount = 0;
        StateHasChanged();
    }

    private void SetTab(string tab)
    {
        activeTab = tab;
        StateHasChanged();
    }

    private static string GetIcon(string type) => type switch
    {
        var t when t.StartsWith("leave") => "bi-calendar-check",
        var t when t.StartsWith("wfh") => "bi-house-check",
        var t when t.StartsWith("overtime") => "bi-clock-history",
        var t when t.StartsWith("attendance") => "bi-person-check",
        var t when t.StartsWith("task") => "bi-check2-square",
        _ => "bi-bell"
    };

    private static string GetIconColor(string type) => type switch
    {
        var t when t.Contains("approved") => "text-success",
        var t when t.Contains("rejected") => "text-danger",
        _ => "text-primary"
    };

    private static string TimeAgo(DateTime dt)
    {
        var diff = DateTime.UtcNow - dt.ToUniversalTime();
        if (diff.TotalMinutes < 1) return "just now";
        if (diff.TotalHours < 1) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalDays < 1) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        return dt.ToString("dd MMM");
    }

    public async ValueTask DisposeAsync()
    {
        if (_hub is not null) await _hub.DisposeAsync();
    }
}