@* Components/Shared/NotificationBell.razor *@
@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Infrastructure.Services
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.SignalR.Client
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject NotificationEngine NotificationEngine
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav

<div class="dropdown notification-bell-container">

    <button class="btn btn-light position-relative border"
            type="button"
            data-bs-toggle="dropdown"
            aria-expanded="false"
            aria-label="Notifications">
        <i class="bi bi-bell fs-5"></i>
        @if (unreadCount > 0)
        {
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                  style="font-size: 0.65rem;">
                @(unreadCount > 99 ? "99+" : unreadCount.ToString())
            </span>
        }
    </button>

    <div class="dropdown-menu dropdown-menu-end shadow border-0 p-0 notification-dropdown">

        <div class="d-flex justify-content-between align-items-center px-3 py-2-5 border-bottom bg-light sticky-top layout-header-node" style="height: 48px;">
            <span class="fw-bold text-dark m-0" style="font-size: 0.9rem;">Notifications</span>
            <div class="d-flex align-items-center header-action-pills">
                @if (notifications.Any(x => !x.IsRead))
                {
                    <button class="btn btn-sm btn-link text-primary text-decoration-none p-0 custom-header-action"
                            @onclick="MarkAllRead" @onclick:stopPropagation="true">
                        Mark all read
                    </button>
                }
                @if (notifications.Any(x => !x.IsRead) && notifications.Any())
                {
                    <span class="text-muted mx-2 action-separator">|</span>
                }
                @if (notifications.Any())
                {
                    <button class="btn btn-sm btn-link text-danger text-decoration-none p-0 custom-header-action"
                            @onclick="ClearAll" @onclick:stopPropagation="true">
                        Clear all
                    </button>
                }
            </div>
        </div>

        <div class="notification-scroll-body" style="max-height: 380px; overflow-y: auto;">
            @if (!notifications.Any())
            {
                <div class="text-center text-muted p-4 py-5">
                    <i class="bi bi-bell-slash fs-4 d-block mb-2 text-secondary"></i>
                    <span class="small fw-medium">No notifications available</span>
                </div>
            }
            else
            {
                @foreach (var n in notifications)
                {
                    <div class="notification-item border-bottom d-flex align-items-start p-3 @(!n.IsRead ? "notification-item--unread" : "")"
                         style="cursor: pointer"
                         @onclick="() => Open(n)">

                        <div class="notification-icon-container me-2 flex-shrink-0">
                            <i class="bi @GetIcon(n.NotificationType) @GetIconColor(n.NotificationType) fs-5"></i>
                        </div>

                        <div class="flex-grow-1 overflow-hidden pe-1">
                            <div class="fw-semibold text-truncate text-dark" style="font-size: 0.85rem;">@n.Title</div>
                            <small class="text-muted d-block text-wrap-message">@n.Message</small>
                            <div class="text-muted mt-1 timestamp-meta">
                                <i class="bi bi-clock me-1"></i>@TimeAgo(n.CreatedAt)
                            </div>
                        </div>

                        <button class="btn btn-sm text-muted ms-1 flex-shrink-0 item-dismiss-cross"
                                title="Dismiss"
                                @onclick:stopPropagation="true"
                                @onclick="() => Delete(n.NotificationId)">
                            <i class="bi bi-x fs-5"></i>
                        </button>
                    </div>
                }
            }
        </div>

        <div class="border-top text-center py-2 bg-light">
            <a href="/notifications" class="small text-primary text-decoration-none fw-semibold">
                View all notifications
            </a>
        </div>
    </div>
</div>

<style>
    /* Strict Layout Control Blocks */
    .notification-dropdown {
        width: 340px !important;
        border-radius: 12px !important;
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12) !important;
        border: 1px solid #e2e8f0 !important;
    }

    /* Top Action Buttons Typo Sizing */
    .custom-header-action {
        font-size: 11.5px !important;
        font-weight: 600 !important;
        display: inline-block;
        line-height: 1 !important;
    }

    .action-separator {
        font-size: 11px;
        opacity: 0.5;
        user-select: none;
    }

    /* Core List Item Styling Constraints */
    .notification-item {
        transition: background-color 0.1s ease;
    }

        .notification-item:hover {
            background-color: #f8fafc;
        }

    .notification-item--unread {
        background-color: #f4f7ff !important;
        border-left: 3px solid #5c4ac7;
    }

    .text-wrap-message {
        font-size: 11.5px;
        line-height: 1.4;
        color: #64748b;
        margin-top: 1px;
    }

    .timestamp-meta {
        font-size: 10.5px;
    }

    .item-dismiss-cross {
        padding: 0px 4px !important;
        line-height: 1 !important;
        opacity: 0.5;
    }

        .item-dismiss-cross:hover {
            opacity: 1;
            background-color: #e2e8f0 !important;
            border-radius: 4px;
        }
</style>

@code {
    private HubConnection? _hub;
    private List<NotificationDto> notifications = new();
    private int unreadCount;
    private string? currentUserId;
    private bool _connected;

    protected override async Task OnInitializedAsync()
    {
        await LoadUser();
        await LoadNotifications();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _connected || string.IsNullOrEmpty(currentUserId))
            return;

        _connected = true;

        _hub = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/notificationHub"))
            .WithAutomaticReconnect()
            .Build();

        _hub.On<NotificationPushDto>("ReceiveNotification", async push =>
        {
            try
            {
                notifications.Insert(0, new NotificationDto
                {
                    NotificationId = push.NotificationId,
                    Title = push.Title,
                    Message = push.Message,
                    RedirectUrl = push.RedirectUrl,
                    NotificationType = push.NotificationType,
                    Priority = push.Priority,
                    CreatedAt = push.CreatedAt,
                    IsRead = false
                });

                unreadCount = push.NewUnreadCount;

                await JS.InvokeVoidAsync("showToastNotification",
                    push.Title, push.Message, push.RedirectUrl, push.Priority);
                await JS.InvokeVoidAsync("playNotificationSound");

                await InvokeAsync(StateHasChanged);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[NotificationBell] Push handler error: {ex.Message}");
            }
        });

        await _hub.StartAsync();
        await _hub.SendAsync("JoinUserGroup", currentUserId);
    }

    private async Task LoadUser()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        currentUserId = auth.User
            .FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    }

    private async Task LoadNotifications()
    {
        if (string.IsNullOrEmpty(currentUserId)) return;
        notifications = await NotificationEngine.GetMyNotificationsAsync(currentUserId);
        unreadCount = notifications.Count(x => !x.IsRead);
        StateHasChanged();
    }

    private async Task Open(NotificationDto n)
    {
        if (!n.IsRead)
        {
            await NotificationEngine.MarkAsReadAsync(n.NotificationId, currentUserId!);
            n.IsRead = true;
            unreadCount = Math.Max(0, unreadCount - 1);
            StateHasChanged();
        }
        if (!string.IsNullOrWhiteSpace(n.RedirectUrl))
            Nav.NavigateTo(n.RedirectUrl, forceLoad: false);
    }

    private async Task Delete(int id)
    {
        await NotificationEngine.DeleteAsync(id, currentUserId!);
        notifications.RemoveAll(x => x.NotificationId == id);
        unreadCount = notifications.Count(x => !x.IsRead);
        StateHasChanged();
    }

    private async Task MarkAllRead()
    {
        await NotificationEngine.MarkAllReadAsync(currentUserId!);
        notifications.ForEach(x => { x.IsRead = true; x.ReadAt = DateTime.UtcNow; });
        unreadCount = 0;
        StateHasChanged();
    }

    private async Task ClearAll()
    {
        await NotificationEngine.ClearAllAsync(currentUserId!);
        notifications.Clear();
        unreadCount = 0;
        StateHasChanged();
    }

    private static string GetIcon(string type) => type switch
    {
        var t when t.StartsWith("leave") => "bi-calendar-check",
        var t when t.StartsWith("wfh") => "bi-house-check",
        var t when t.StartsWith("overtime") => "bi-clock-history",
        var t when t.StartsWith("attendance") => "bi-person-check",
        var t when t.StartsWith("task") => "bi-check2-square",
        _ => "bi-bell"
    };

    private static string GetIconColor(string type) => type switch
    {
        var t when t.Contains("approved") => "text-success",
        var t when t.Contains("rejected") => "text-danger",
        _ => "text-primary"
    };

    private static string TimeAgo(DateTime dt)
    {
        var utcDateTime = DateTime.SpecifyKind(dt, DateTimeKind.Utc);
        var indiaZone = TimeZoneInfo.FindSystemTimeZoneById(
            OperatingSystem.IsWindows() ? "India Standard Time" : "Asia/Kolkata");

        var indiaTime = TimeZoneInfo.ConvertTimeFromUtc(utcDateTime, indiaZone);
        var nowIndia = TimeZoneInfo.ConvertTimeFromUtc(DateTime.UtcNow, indiaZone);
        var diff = nowIndia - indiaTime;

        if (diff.TotalSeconds < 60) return "just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";

        return indiaTime.ToString("dd MMM");
    }

    public async ValueTask DisposeAsync()
    {
        if (_hub is not null) await _hub.DisposeAsync();
    }
}