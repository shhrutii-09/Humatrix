@page "/Account/Logout"
@using Microsoft.AspNetCore.Identity
@using Humatrix_HRMS.Data
@using Microsoft.AspNetCore.Mvc
@attribute [IgnoreAntiforgeryToken]

@inject SignInManager<ApplicationUser> SignInManager
@inject NavigationManager NavigationManager

@code {
    // Add this to catch the parameter the form is trying to send
    [Parameter]
    [SupplyParameterFromForm]
    public string? ReturnUrl { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await SignInManager.SignOutAsync();

        // Use the ReturnUrl if it exists, otherwise go to Login
        var destination = !string.IsNullOrEmpty(ReturnUrl) ? ReturnUrl : "/Account/Login";
        NavigationManager.NavigateTo(destination, true);
    }
}