@rendermode InteractiveServer
@using Humatrix_HRMS.Services.AI
@using System.Text.RegularExpressions

@inject AiAssistantService AiService
@inject IJSRuntime JsRuntime
@inject NavigationManager NavigationManager
<div class="ai-chat-container">
    @if (!IsOpen)
    {
        <button class="ai-chat-button" @onclick="ToggleChat" title="AI HR Assistant">
            <span class="ai-chat-icon">🤖</span>
            @if (UnseenHint)
            {
                <span class="ai-chat-ping"></span>
            }
        </button>
    }
    else
    {
        <div class="ai-chat-window">
            <div class="ai-chat-header">
                <div class="ai-chat-header-title">
                    <span class="ai-chat-avatar">🤖</span>
                    <div>
                        <div class="ai-chat-name">Humatrix AI Assistant</div>
                        <div class="ai-chat-status">
                            <span class="ai-status-dot"></span> Online
                        </div>
                    </div>
                </div>
                <button class="ai-chat-close" @onclick="ToggleChat">×</button>
            </div>

            <div class="ai-chat-messages" @ref="MessagesContainer">
                @foreach (var msg in Messages)
                {
                    <div class="message @(msg.IsUser ? "user" : "assistant")">
                        @if (!msg.IsUser)
                        {
                            <div class="message-avatar">🤖</div>
                        }
                        <div class="message-bubble">
                            <div class="message-content">@((MarkupString)FormatMessage(msg.Content))</div>
                            <div class="message-time">@msg.Timestamp.ToString("HH:mm")</div>

                            @if (msg.RequiresConfirmation && msg == Messages.LastOrDefault(m => !m.IsUser))
                            {
                                <div class="confirm-actions">
                                    <button class="confirm-btn yes" @onclick="@(() => QuickReply("Yes"))" disabled="@IsThinking">
                                        ✅ Yes, proceed
                                    </button>
                                    <button class="confirm-btn no" @onclick="@(() => QuickReply("No"))" disabled="@IsThinking">
                                        ❌ No, cancel
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (IsThinking)
                {
                    <div class="message assistant">
                        <div class="message-avatar">🤖</div>
                        <div class="message-bubble">
                            <div class="typing-indicator">
                                <span></span><span></span><span></span>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (Messages.Count <= 1 && !IsThinking)
            {
                <div class="ai-quick-actions">
                    @foreach (var suggestion in QuickSuggestions)
                    {
                        <button class="quick-action-chip" @onclick="@(() => QuickReply(suggestion))">
                            @suggestion
                        </button>
                    }
                </div>
            }

            <div class="ai-chat-input">
                <input type="text"
                       placeholder="Type a message..."
                       value="@CurrentQuery"
                       @oninput="@(e => CurrentQuery = e.Value?.ToString() ?? string.Empty)"
                       @onkeydown="HandleKeyDown"
                       disabled="@IsThinking" />
                <button @onclick="SendQuery" disabled="@(IsThinking || string.IsNullOrWhiteSpace(CurrentQuery))" title="Send">
                    @if (IsThinking)
                    {
                        <span class="send-spinner"></span>
                    }
                    else
                    {
                        <span>➤</span>
                    }
                </button>
            </div>
        </div>
    }
</div>

<style>
    .ai-chat-container {
        position: fixed;
        bottom: 20px;
        right: 20px;
        z-index: 1050;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    }

    /* ---------- Launcher Button ---------- */
    .ai-chat-button {
        position: relative;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        color: white;
        font-size: 28px;
        cursor: pointer;
        box-shadow: 0 4px 18px rgba(102, 126, 234, 0.45);
        transition: transform 0.2s, box-shadow 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .ai-chat-button:hover {
            transform: scale(1.07);
            box-shadow: 0 6px 22px rgba(102, 126, 234, 0.55);
        }

    .ai-chat-ping {
        position: absolute;
        top: -2px;
        right: -2px;
        width: 14px;
        height: 14px;
        background: #ff5b5b;
        border: 2px solid white;
        border-radius: 50%;
        animation: aiPing 1.6s infinite;
    }

    @@keyframes aiPing {
        0% {
            transform: scale(1);
            opacity: 1;
        }

        70% {
            transform: scale(1.4);
            opacity: 0.4;
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }

    /* ---------- Chat Window ---------- */
    .ai-chat-window {
        width: 380px;
        height: 600px;
        max-height: calc(100vh - 100px);
        background: #ffffff;
        border-radius: 16px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.25);
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .ai-chat-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 14px 16px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .ai-chat-header-title {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .ai-chat-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: rgba(255,255,255,0.18);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
    }

    .ai-chat-name {
        font-weight: 600;
        font-size: 14px;
        line-height: 1.2;
    }

    .ai-chat-status {
        font-size: 11px;
        opacity: 0.85;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .ai-status-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: #4ade80;
        display: inline-block;
    }

    .ai-chat-close {
        background: none;
        border: none;
        color: white;
        font-size: 26px;
        line-height: 1;
        cursor: pointer;
        opacity: 0.85;
        padding: 0 4px;
    }

        .ai-chat-close:hover {
            opacity: 1;
        }

    /* ---------- Messages ---------- */
    .ai-chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 16px;
        background: #f4f5f9;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .message {
        display: flex;
        gap: 8px;
        max-width: 100%;
    }

        .message.user {
            flex-direction: row-reverse;
        }

    .message-avatar {
        width: 28px;
        height: 28px;
        flex-shrink: 0;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
    }

    .message-bubble {
        max-width: 78%;
        display: flex;
        flex-direction: column;
    }

    .message.user .message-bubble {
        align-items: flex-end;
    }

    .message-content {
        padding: 10px 14px;
        border-radius: 14px;
        background: white;
        box-shadow: 0 1px 2px rgba(0,0,0,0.08);
        font-size: 13.5px;
        line-height: 1.5;
        word-break: break-word;
    }

        .message-content strong {
            font-weight: 700;
        }

        .message-content ul {
            margin: 4px 0 0 0;
            padding-left: 18px;
        }

    .message.user .message-content {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-radius: 14px 14px 4px 14px;
    }

    .message.assistant .message-content {
        border-radius: 14px 14px 14px 4px;
    }

    .message-time {
        font-size: 10px;
        color: #9aa0ac;
        margin-top: 3px;
        padding: 0 4px;
    }

    /* ---------- Confirmation Buttons ---------- */
    .confirm-actions {
        display: flex;
        gap: 8px;
        margin-top: 8px;
    }

    .confirm-btn {
        border: none;
        border-radius: 20px;
        padding: 7px 16px;
        font-size: 12.5px;
        font-weight: 600;
        cursor: pointer;
        transition: transform 0.15s, opacity 0.15s;
    }

        .confirm-btn:hover {
            transform: translateY(-1px);
        }

        .confirm-btn:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .confirm-btn.yes {
            background: #16a34a;
            color: white;
        }

        .confirm-btn.no {
            background: #fff;
            color: #ef4444;
            border: 1px solid #ef4444;
        }

    /* ---------- Typing Indicator ---------- */
    .typing-indicator {
        display: flex;
        gap: 4px;
        padding: 12px 14px;
        background: white;
        border-radius: 14px 14px 14px 4px;
        box-shadow: 0 1px 2px rgba(0,0,0,0.08);
    }

        .typing-indicator span {
            width: 7px;
            height: 7px;
            background: #b6b9c2;
            border-radius: 50%;
            animation: aiTyping 1.4s infinite;
        }

            .typing-indicator span:nth-child(2) {
                animation-delay: 0.2s;
            }

            .typing-indicator span:nth-child(3) {
                animation-delay: 0.4s;
            }

    @@keyframes aiTyping {
        0%, 60%, 100% {
            transform: translateY(0);
        }

        30% {
            transform: translateY(-6px);
        }
    }

    /* ---------- Quick Actions ---------- */
    .ai-quick-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        padding: 10px 14px;
        background: #f4f5f9;
        border-top: 1px solid #e9eaf0;
    }

    .quick-action-chip {
        border: 1px solid #d8d9e3;
        background: white;
        border-radius: 16px;
        padding: 6px 12px;
        font-size: 12px;
        color: #4b4f5b;
        cursor: pointer;
        transition: background 0.15s, border-color 0.15s;
    }

        .quick-action-chip:hover {
            background: #ece9ff;
            border-color: #a5a6f6;
            color: #4338ca;
        }

    /* ---------- Input Bar ---------- */
    .ai-chat-input {
        display: flex;
        padding: 12px;
        border-top: 1px solid #e9eaf0;
        background: white;
        gap: 8px;
    }

        .ai-chat-input input {
            flex: 1;
            padding: 10px 14px;
            border: 1px solid #dfe1e8;
            border-radius: 22px;
            outline: none;
            font-size: 13.5px;
        }

            .ai-chat-input input:focus {
                border-color: #8b8ff0;
            }

        .ai-chat-input button {
            width: 42px;
            height: 42px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 50%;
            cursor: pointer;
            font-size: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

            .ai-chat-input button:disabled {
                opacity: 0.5;
                cursor: not-allowed;
            }

    .send-spinner {
        width: 14px;
        height: 14px;
        border: 2px solid rgba(255,255,255,0.4);
        border-top-color: white;
        border-radius: 50%;
        display: inline-block;
        animation: aiSpin 0.7s linear infinite;
    }

    @@keyframes aiSpin {
        to {
            transform: rotate(360deg);
        }
    }

    /* ---------- Mobile ---------- */
    @@media (max-width: 480px) {
        .ai-chat-window {
            width: calc(100vw - 24px);
            height: calc(100vh - 100px);
        }

        .ai-chat-container {
            right: 12px;
            bottom: 12px;
        }
    }
</style>

@code {
    private bool IsOpen = false;
    private bool UnseenHint = true;
    private string CurrentQuery = "";
    private bool IsThinking = false;
    private ElementReference MessagesContainer;
    private List<ChatMessage> Messages = new();

    private static readonly string[] QuickSuggestions = new[]
    {
        "Check my leave balance",
        "Apply for casual leave",
        "Show my pending tasks",
        "What's my attendance today?"
    };

    protected override async Task OnInitializedAsync()
    {
        Messages.Add(new ChatMessage
        {
            Content = "👋 Hi! I'm your AI HR Assistant.\n\nI can help you with:\n• 📅 Apply for / check leave\n• 🏠 Request work from home\n• ⏰ Overtime & missing punch\n• 📋 Tasks & today's attendance\n• 📄 Missing documents\n• ❌ Resignation\n\nJust type what you need, or tap a suggestion below.",
            IsUser = false,
            Timestamp = DateTime.Now
        });
    }

    private async Task ToggleChat()
    {
        Console.WriteLine("BUTTON CLICKED");

        await JsRuntime.InvokeVoidAsync("alert", "BUTTON CLICKED");

        IsOpen = !IsOpen;

        StateHasChanged();
    }

    private async Task QuickReply(string text)
    {
        CurrentQuery = text;
        await SendQuery();
    }

    private async Task SendQuery()
    {
        if (string.IsNullOrWhiteSpace(CurrentQuery) || IsThinking)
            return;

        var query = CurrentQuery.Trim();
        CurrentQuery = "";

        Messages.Add(new ChatMessage
        {
            Content = query,
            IsUser = true,
            Timestamp = DateTime.Now
        });

        IsThinking = true;
        await InvokeAsync(StateHasChanged);
        await ScrollToBottom();

        try
        {
            var response = await AiService.ProcessQueryAsync(query);

            Messages.Add(new ChatMessage
            {
                Content = response.ResponseText,
                IsUser = false,
                Timestamp = DateTime.Now,
                RequiresConfirmation = response.RequiresConfirmation
            });
        }
        catch (Exception ex)
        {
            Messages.Add(new ChatMessage
            {
                Content = $"❌ Sorry, something went wrong: {ex.Message}",
                IsUser = false,
                Timestamp = DateTime.Now
            });
        }
        finally
        {
            IsThinking = false;
            await InvokeAsync(StateHasChanged);
            await ScrollToBottom();
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await SendQuery();
    }

    private async Task ScrollToBottom()
    {
        await JsRuntime.InvokeVoidAsync("scrollToBottom", MessagesContainer);
    }

    /// <summary>
    /// Very small markdown-ish formatter: escapes HTML, then converts
    /// **bold**, "• " bullet lines into a &lt;ul&gt;, and newlines to &lt;br/&gt;.
    /// </summary>
    private static string FormatMessage(string content)
    {
        if (string.IsNullOrEmpty(content))
            return string.Empty;

        // 1. Escape any HTML the AI/user might have typed
        var escaped = System.Net.WebUtility.HtmlEncode(content);

        // 2. Bold: **text** -> <strong>text</strong>
        escaped = Regex.Replace(escaped, @"\*\*(.+?)\*\*", "<strong>$1</strong>");

        // 3. Convert consecutive "• " lines into a <ul><li>
        var lines = escaped.Split('\n');
        var sb = new System.Text.StringBuilder();
        var inList = false;

        foreach (var rawLine in lines)
        {
            var line = rawLine.TrimEnd('\r');

            if (line.TrimStart().StartsWith("•"))
            {
                if (!inList)
                {
                    sb.Append("<ul>");
                    inList = true;
                }

                var item = line.TrimStart().TrimStart('•').Trim();
                sb.Append($"<li>{item}</li>");
            }
            else
            {
                if (inList)
                {
                    sb.Append("</ul>");
                    inList = false;
                }

                if (sb.Length > 0)
                    sb.Append("<br/>");

                sb.Append(line);
            }
        }

        if (inList)
            sb.Append("</ul>");

        return sb.ToString();
    }

    private class ChatMessage
    {
        public string Content { get; set; } = string.Empty;
        public bool IsUser { get; set; }
        public DateTime Timestamp { get; set; }
        public bool RequiresConfirmation { get; set; }
    }
}
