@inherits LayoutComponentBase

<div class="page">
    <!-- Left Sidebar Menu -->
    <div class="sidebar">
        <NavMenu />
    </div>

    <!-- Right Side Dynamic Content Area -->
    <main class="main-content-wrapper">

        <!-- 🌐 GLOBAL TOP NAVBAR -->
        <header class="global-top-navbar d-flex justify-content-between align-items-center px-4 shadow-sm">

            <!-- Left Side: App Context -->
            <div class="navbar-left-brand">
                <span class="text-muted small fw-medium">Humatrix Operational Portal</span>
            </div>

            <!-- Right Side: Interactive Action Container -->
            <TopNavbarActions />

        </header>

        <!-- DYNAMIC PAGE BODY CONTENT -->
        <article class="content">
            @Body
        </article>

    </main>
</div>
