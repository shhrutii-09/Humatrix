<script>
    function confirmLogout() {
        return confirm("Are you sure you want to logout?");
    }
</script>

<style>
    /* SIDEBAR */
    .sidebar-header {
        padding: 18px 20px;
        font-size: 1.3rem;
        font-weight: 700;
        color: white;
        background: linear-gradient(180deg, #1c1f4a, #4b1d6b);
    }

    .logo-text {
        letter-spacing: 1px;
    }

    /* NAV AREA */
    .nav-scrollable {
        height: calc(100vh - 60px);
        overflow-y: auto;
        background: linear-gradient(180deg, #1c1f4a, #4b1d6b);
        padding-top: 10px;
    }

    /* NAV ITEM */
    .nav-item-custom {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 18px;
        margin: 4px 10px;
        border-radius: 8px;
        text-decoration: none;
        font-size: 0.95rem;
        color: rgba(255,255,255,0.75);
        transition: all 0.2s ease;
    }

        .nav-item-custom i {
            width: 22px;
            text-align: center;
            font-size: 1.2rem;
        }

        .nav-item-custom span {
            white-space: nowrap;
        }

        .nav-item-custom:hover {
            background: rgba(255,255,255,0.08);
            color: #fff;
        }

        .nav-item-custom.active {
            background: white;
            color: #5c4ac7 !important;
            font-weight: 600;
        }

    /* FOOTER */
    .sidebar-footer {
        margin-top: 15px;
        padding: 15px;
        border-top: 1px solid rgba(255,255,255,0.1);
    }

    .user-info-custom {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 0.88rem;
        padding: 6px 10px;
        color: #ffffff !important;
    }

    .user-name-text {
        color: #ffffff !important;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 170px;
    }

    /* LOGOUT */
    .logout-btn {
        width: 100%;
        border: none;
        background: none;
        color: rgba(255,255,255,0.75);
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px;
        border-radius: 6px;
        transition: 0.2s;
        cursor: pointer;
    }

        .logout-btn:hover {
            background: rgba(255,255,255,0.08);
            color: white;
        }
</style>

@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose() => NavigationManager.LocationChanged -= OnLocationChanged;

    private async Task ConfirmLogout()
    {
        var confirm = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to logout?");
        if (confirm)
        {
            await JS.InvokeVoidAsync("submitLogoutForm");
        }
    }
}