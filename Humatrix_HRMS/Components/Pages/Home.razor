        color: #64748b;
        margin: 0;
        line-height: 1.45;
    }

    /* RESPONSIVE RENDERING MATRIX LAYOUT */
    @@media (max-width: 992px) {
        .split-viewport-container

    {
        flex-direction: column !important;
        overflow-y: auto !important;
    }

    .hero-canvas-pane, .banners-canvas-pane {
        width: 100% !important;
        height: auto !important;
        padding: 3rem 2rem !important;
    }

    ::deep .content, ::deep main, ::deep .page, html, body {
        overflow: auto !important;
    }

    .interactive-vector-scene {
        display: none;
    }

    }
