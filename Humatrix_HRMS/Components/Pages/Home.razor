        margin-bottom: 1.5rem;
        line-height: 1.6;
    }

    .btn-main-cta {
        background-color: #5c4ac7;
        color: white;
        text-decoration: none;
        padding: 14px 38px;
        border-radius: 10px;
        font-weight: 700;
        font-size: 1rem;
        display: inline-block;
        transition: background-color 0.2s ease, transform 0.2s ease;
    }

        .btn-main-cta:hover {
            background-color: #4a3ab0;
            color: white;
            transform: translateY(-1px);
        }

   
    .interactive-vector-scene {
        width: 100%;
        height: calc(100vh - 360px); 
        min-height: 220px;
        max-height: 380px;
        margin-top: auto;
        display: flex;
        align-items: flex-end;
    }

        .interactive-vector-scene svg {
            width: 100%;
            height: 100%;
        }

    /* RIGHT CANVAS PANEL */
    .banners-canvas-pane {
        width: 45%;
        background-color: #f8fafc;
        border-left: 1px solid #e2e8f0;
        height: 100vh;
    }

    .landscape-banner-plate {
        background: #ffffff;
        border-radius: 18px;
        width: 100%;
        max-width: 520px;
        margin-right: auto;
        margin-left: auto;
        border: 1px solid #e2e8f0;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .landscape-banner-plate:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 20px -8px rgba(0, 0, 0, 0.06) !important;
        }

    .banner-vector-art-left {
        flex-shrink: 0;
        margin-right: 1.25rem;
