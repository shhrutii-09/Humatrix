<style>
    /* FORCE BLAZER MAIN LAYOUTS TO SURRENDER SPACE */
    ::deep .sidebar,
    ::deep nav,
    ::deep .top-row,
    ::deep header,
    ::deep #sidebar {
        display: none !important;
    }

    /* PREVENT BLANK CANVAS MARGINS - FORCE 100% SCREEN VIEWPORT FILL */
    ::deep .content,
    ::deep main,
    ::deep .page,
    html, body {
        padding: 0 !important;
        margin: 0 !important;
        max-width: 100% !important;
        width: 100% !important;
        height: 100% !important;
        overflow: hidden !important;
        font-family: 'Inter', system-ui, sans-serif;
        background-color: #ffffff !important;
    }

    /* GLOBAL BOX-SIZING FIX */
    *, *::before, *::after {
        box-sizing: border-box !important;
    }

    /* ABSOLUTE CANVAS EXPANSION CONTAINER */
    .full-viewport-app {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        z-index: 999999;
        background-color: #ffffff;
        overflow: hidden;
    }

    .split-viewport-container {
        height: 100vh;
        width: 100vw;
    }

    /* LEFT CONTENT BLOCK - HERO CONTEXT AND GRAPHIC INTERFACE */
    .hero-canvas-pane {
        width: 55%;
        background-color: #ffffff;
        padding: 4.5rem 4rem 0 5rem; /* Tucked padding in slightly to protect layout */
        overflow: hidden;
        height: 100vh;
    }

    .enterprise-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background-color: #f1f5f9;
        color: #475569;
        padding: 6px 14px;
        border-radius: 30px;
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .pulse-indicator {
        width: 6px;
        height: 6px;
        background-color: #10b981;
        border-radius: 50%;
    }

    .main-headline {
