@page "/org/holidays"
@rendermode InteractiveServer

@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize(Roles = "OrgAdmin,HR")]

@inject HolidayService HolidayService
@inject NavigationManager Nav

<PageTitle>Holidays | Humatrix</PageTitle>

@* Premium Floating Notifications Container with 4 Sec Auto-Dismiss *@
<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 9999;">
    @if (showToast)
    {
        <div class="toast show premium-side-toast animate-slide-in @(isError ? "toast-danger-border" : "toast-success-border")" role="alert">
            <div class="toast-body d-flex align-items-center gap-3 p-3">
                <div class="toast-icon-circle @(isError ? "bg-light-danger text-danger" : "bg-light-success text-success")">
                    <i class="bi @(isError ? "bi-shield-fill-x" : "bi-check-circle-fill") fs-5"></i>
                </div>
                <div class="flex-grow-1">
                    <h6 class="mb-0 fw-bold @(isError ? "text-danger" : "text-success")" style="font-size: 13.5px;">
                        @(isError ? "Execution Failure" : "Action Completed")
                    </h6>
                    <small class="text-secondary d-block mt-0.5" style="font-size: 12px; line-height: 1.3;">@toastMessage</small>
                </div>
                <button type="button" class="btn-close shadow-none ms-auto" @onclick="CloseToast"></button>
            </div>
        </div>
    }
</div>

<div class="container-fluid px-4 mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom row-gap-3 flex-wrap">
        <div>
            <h2 class="fw-bold tracking-tight text-dark mb-1">Holiday Calendar</h2>
            <p class="text-muted small mb-0">Manage and configure public holidays, optional leaves, and corporate calendar events.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-import-holiday d-flex align-items-center gap-2 shadow-sm" @onclick="ImportSystemHolidays" disabled="@isImporting">
                @if (isImporting)
                {
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                    <span>IMPORTING...</span>
                }
                else
                {
                    <i class="bi bi-cloud-download"></i>
                    <span>IMPORT REAL HOLIDAYS</span>
                }
            </button>

            <button class="btn btn-add-holiday d-flex align-items-center gap-2 shadow-sm" @onclick="Open">
                <i class="bi bi-plus-circle"></i>
                ADD HOLIDAY
            </button>
            <button class="btn btn-interactive-back shadow-sm" @onclick="GoToDashboard">
                <i class="bi bi-speedometer2"></i>
                DASHBOARD
            </button>
        </div>
    </div>

    <div class="card border-0 shadow-sm panel-container-card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4 text-secondary small fw-bold tracking-wider py-3">DATE</th>
                        <th class="text-secondary small fw-bold tracking-wider py-3">HOLIDAY NAME</th>
                        <th class="text-secondary small fw-bold tracking-wider py-3">TYPE</th>
                        <th class="text-secondary small fw-bold tracking-wider py-3 text-end pe-4" style="width: 160px;">ACTIONS</th>
                    </tr>
                </thead>
                <tbody>
                    @if (holidays == null)
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5">
                                <div class="spinner-border text-primary" style="width: 2rem; height: 2rem;" role="status"></div>
                                <p class="mt-2 text-muted small mb-0">Loading calendar stream...</p>
                            </td>
                        </tr>
                    }
                    else if (holidays.Count == 0)
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <div class="fs-2 text-light mb-2"><i class="bi bi-calendar-x"></i></div>
                                <span class="fw-medium">No holidays configured yet.</span>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var h in holidays.OrderBy(x => x.Date))
                        {
                            <tr class="table-row-interactive">
                                <td class="ps-4 text-secondary small fw-medium">@h.Date.ToString("dd MMM yyyy")</td>
                                <td class="fw-bold text-dark text-heading-field">@h.Name</td>
                                <td>
                                    <span class="status-indicator-pill @(h.IsOptional ? "pill-inactive" : "pill-active")">
                                        @(h.IsOptional ? "Optional" : "Mandatory")
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-flex gap-2 justify-content-end">
                                        <button class="btn btn-sm btn-action-edit" title="Edit Holiday" @onclick="() => Edit(h)">
                                            <i class="bi bi-pencil-square"></i>
                                        </button>
                                        <button class="btn btn-sm btn-action-delete" title="Delete Holiday" @onclick="() => Delete(h.HolidayId)">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (showModal)
    {
        <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.45); backdrop-filter: blur(4px);">
            <div class="modal-dialog modal-dialog-centered modal-md">
                <div class="modal-content border-0 shadow-lg rounded-3">

                    <div class="modal-header border-bottom bg-light px-4 py-3">
                        <h5 class="modal-title fw-bold text-dark tracking-tight">
                            @(isEditing ? "✏️ Edit Holiday" : "✨ Add Holiday")
                        </h5>
                        <button class="btn-close shadow-none" @onclick="Close"></button>
                    </div>

                    <div class="modal-body p-4">

                        @if (!string.IsNullOrEmpty(modalError))
                        {
                            <div class="alert alert-premium-danger d-flex align-items-center mb-4 border-0" role="alert">
                                <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
                                <div class="small fw-medium"><strong>Error:</strong> @modalError</div>
                            </div>
                        }

                        <div class="row g-4">
                            <div class="col-12">
                                <label class="form-label small fw-bold text-secondary tracking-wider mb-2">HOLIDAY DATE <span class="text-danger">*</span></label>
                                <InputDate class="form-control premium-form-input-lg w-100" @bind-Value="model.Date" />
                            </div>

                            <div class="col-12">
                                <label class="form-label small fw-bold text-secondary tracking-wider mb-2">HOLIDAY NAME <span class="text-danger">*</span></label>
                                <InputText class="form-control premium-form-input-lg w-100" placeholder="e.g., Diwali, New Year's Day" @bind-Value="model.Name" />
                            </div>

                            <div class="col-12 mt-4">
                                <div class="form-check form-switch protocol-switch bg-light p-3 ps-5 rounded-3 border d-inline-block w-100 flex-row align-items-center">
                                    <InputCheckbox class="form-check-input fs-5" id="isOptionalSwitch" @bind-Value="model.IsOptional" style="margin-left: -1.8em; margin-top: 1px;" />
                                    <label class="form-check-label fw-semibold text-dark pt-0.5 ms-2" for="isOptionalSwitch">Mark as Optional Holiday</label>
                                </div>
                                <div class="text-muted small mt-2 ps-1">
                                    <i class="bi bi-info-circle me-1"></i> Optional holidays are NOT auto-excluded from leave calculation matrices.
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="modal-footer bg-light border-top px-4 py-3">
                        <button type="button" class="btn btn-action-cancel" @onclick="Close">Cancel</button>
                        <button type="button" class="btn btn-action-submit px-4 shadow-sm" @onclick="Save">
                            @(isEditing ? "Update Holiday" : "Save & Publish")
                        </button>
                    </div>

                </div>
            </div>
        </div>
    }
</div>

<style>
    /* Premium Designations Style Toast Variables */
    .premium-side-toast {
        background: #ffffff !important;
        border: none;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08) !important;
        min-width: 320px;
        max-width: 380px;
        overflow: hidden;
    }

    .toast-success-border {
        border-left: 4px solid #10b981 !important;
    }

    .toast-danger-border {
        border-left: 4px solid #ef4444 !important;
    }

    .toast-icon-circle {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .bg-light-success {
        background-color: rgba(16, 185, 129, 0.1);
    }

    .bg-light-danger {
        background-color: rgba(239, 68, 68, 0.1);
    }

    .animate-slide-in {
        animation: toastSlideIn 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    @@keyframes toastSlideIn {
        from

    {
        transform: translateX(100%) translateY(-10px);
        opacity: 0;
    }

    to {
        transform: translateX(0) translateY(0);
        opacity: 1;
    }

    }

    .tracking-tight {
        letter-spacing: -0.025em;
    }

    .tracking-wider {
        letter-spacing: 0.04em;
        font-size: 11px;
        text-transform: uppercase;
    }

    .panel-container-card {
        border-radius: 14px;
        background-color: #ffffff;
        overflow: hidden;
    }

    .table thead th {
        background-color: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
    }

    .table-row-interactive:hover {
        background-color: #f8fafc;
    }

    .text-heading-field {
        font-size: 14px;
        color: #1e293b !important;
    }

    .premium-form-input-lg {
        font-size: 15px;
        padding: 10px 14px;
        border-radius: 10px;
        border: 1px solid #cbd5e1;
        background-color: #ffffff !important;
        color: #1e293b;
        transition: all 0.2s ease;
    }

        .premium-form-input-lg:focus {
            border-color: #5c4ac7 !important;
            box-shadow: 0 0 0 4px rgba(92, 74, 199, 0.12) !important;
            outline: none;
        }

    .btn-import-holiday {
        background-color: #10b981 !important;
        color: #ffffff !important;
        border: none !important;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.02em;
        transition: all 0.2s ease;
    }

        .btn-import-holiday:hover:not(:disabled) {
            background-color: #059669 !important;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(16, 185, 129, 0.2) !important;
        }

    .btn-add-holiday {
        background-color: #5c4ac7 !important;
        color: #ffffff !important;
        border: none !important;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.02em;
        transition: all 0.2s ease;
    }

        .btn-add-holiday:hover {
            background-color: #4b3ba6 !important;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(92, 74, 199, 0.2) !important;
        }

    .btn-interactive-back {
        background: #ffffff !important;
        border: 1px solid #e5e7eb !important;
        color: #4b5563 !important;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
        transition: all 0.2s ease;
    }

        .btn-interactive-back:hover {
            background-color: #f8fafc !important;
            border-color: #5c4ac7 !important;
            color: #5c4ac7 !important;
            transform: translateY(-1px);
        }

    .btn-action-edit {
        background: #f1f5f9;
        border: 1px solid #e2e8f0;
        color: #475569;
        border-radius: 8px;
        padding: 5px 10px;
    }

        .btn-action-edit:hover {
            background: rgba(92, 74, 199, 0.08);
            border-color: rgba(92, 74, 199, 0.25);
            color: #5c4ac7;
        }

    .btn-action-delete {
        background: #fff5f5;
        border: 1px solid #fee2e2;
        color: #ef4444;
        border-radius: 8px;
        padding: 5px 10px;
    }

        .btn-action-delete:hover {
            background: #fee2e2;
            color: #dc2626;
        }

    .btn-action-submit {
        background-color: #5c4ac7 !important;
        color: #ffffff !important;
        border: none !important;
        padding: 10px 20px;
        border-radius: 10px;
        font-size: 13.5px;
        font-weight: 600;
        transition: all 0.2s ease;
    }

        .btn-action-submit:hover {
            background-color: #4b3ba6 !important;
            box-shadow: 0 4px 12px rgba(92, 74, 199, 0.2) !important;
        }

    .btn-action-cancel {
        background-color: #ffffff;
        color: #475569;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 10px 20px;
        font-size: 13.5px;
    }

        .btn-action-cancel:hover {
            background-color: #f1f5f9;
            color: #1e293b;
        }

    .protocol-switch .form-check-input {
        width: 2.3em;
        height: 1.15em;
        cursor: pointer;
        background-color: #cbd5e1;
        border-color: transparent;
    }

        .protocol-switch .form-check-input:checked {
            background-color: #5c4ac7;
        }

    .status-indicator-pill {
        font-size: 11px;
        font-weight: 600;
        padding: 2px 8px;
        border-radius: 6px;
        display: inline-block;
        min-width: 60px;
        text-align: center;
    }

    .pill-active {
        background-color: #ecfdf5;
        color: #065f46;
    }

    .pill-inactive {
        background-color: #fef2f2;
        color: #991b1b;
    }

    .alert-premium-danger {
        background-color: #fef2f2;
        color: #991b1b;
        border-left: 4px solid #ef4444 !important;
        border-radius: 8px;
        padding: 12px 16px;
    }
</style>

@code {
    private List<Holiday>? holidays;
    private Holiday model = new();
    private bool showModal = false;
    private bool isEditing = false;
    private bool isImporting = false;
    private string? modalError;

    // Synced Local Toast Notification Engine State
    private string? toastMessage;
    private bool isError;
    private bool showToast = false;

    protected override async Task OnInitializedAsync()
    {
        // Deep integration with query string checks if redirected with state parameters
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        if (Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query).TryGetValue("success", out var value))
        {
            await TriggerToast(value.ToString(), false);
        }
        await Load();
    }

    private async Task Load() => holidays = await HolidayService.GetAllAsync();

    private void Open()
    {
        model = new Holiday { Date = DateTime.Today };
        isEditing = false;
        modalError = null;
        showModal = true;
    }

    private void Edit(Holiday h)
    {
        model = new Holiday
        {
            HolidayId = h.HolidayId,
            Name = h.Name,
            Date = h.Date,
            IsOptional = h.IsOptional,
            OrganizationId = h.OrganizationId
        };
        isEditing = true;
        modalError = null;
        showModal = true;
    }

    private void Close() => showModal = false;

    // Toast Trigger Method sync with 4 Sec Auto Dismiss Delay
    private async Task TriggerToast(string message, bool errorState)
    {
        toastMessage = message;
        isError = errorState;
        showToast = true;
        StateHasChanged();

        await Task.Delay(4000);
        CloseToast();
    }

    private void CloseToast()
    {
        showToast = false;
        StateHasChanged();
    }

    private async Task Save()
    {
        try
        {
            modalError = null;

            if (string.IsNullOrWhiteSpace(model.Name))
            {
                modalError = "Holiday Name description field is compulsory and cannot be left blank.";
                return;
            }
            if (model.Date == default)
            {
                modalError = "A valid calendar target Date assignment is compulsory.";
                return;
            }

            if (isEditing)
            {
                await HolidayService.UpdateAsync(model);
                showModal = false;
                await TriggerToast($"Holiday structures for '{model.Name}' successfully modified.", false);
            }
            else
            {
                await HolidayService.CreateAsync(model);
                showModal = false;
                await TriggerToast($"Holiday '{model.Name}' successfully configured and published.", false);
            }

            await Load();
        }
        catch (Exception ex)
        {
            modalError = ex.Message;
            await TriggerToast($"Operation failed: {ex.Message}", true);
        }
    }

    private async Task Delete(Guid id)
    {
        try
        {
            await HolidayService.DeleteAsync(id);
            await TriggerToast("Holiday configuration profile has been successfully deleted from archives.", false);
            await Load();
        }
        catch (Exception ex)
        {
            await TriggerToast($"Failed to execute deletion stream: {ex.Message}", true);
        }
    }

    private async Task ImportSystemHolidays()
    {
        try
        {
            isImporting = true;
            int currentYear = DateTime.Today.Year;

            int importedCount = await HolidayService.ImportPublicHolidaysAsync(currentYear, "IN");

            if (importedCount > 0)
            {
                await TriggerToast($"Successfully imported {importedCount} official holidays for {currentYear} timeline!", false);
            }
            else
            {
                await TriggerToast("No new configurations detected. Your system calendar matrix is already up-to-date.", false);
            }

            await Load();
        }
        catch (Exception ex)
        {
            await TriggerToast($"Integration Error: {ex.Message}", true);
        }
        finally
        {
            isImporting = false;
        }
    }

    private void GoToDashboard() => Nav.NavigateTo("/org/dashboard");
}