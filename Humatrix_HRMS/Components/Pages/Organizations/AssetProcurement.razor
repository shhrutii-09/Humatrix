@code {
    private bool loading = true;
    private bool submitting = false;
    private bool showReviewModal = false;
    private bool showFulfillModal = false;
    private bool approveDecision = false;
    private string reviewNotes = "";
    private string errorMessage = "";
    private string successMessage = "";

    private Guid orgId;
    private string userId = "";

    private List<ProcurementRequestDto> allRequests = new();
    private List<ProcurementRequestDto> filteredRequests = new();
    private List<DepartmentDto> departments = new();
    private ProcurementRequestDto? selectedRequest;
    private FulfilProcurementDto fulfillDto = new();

    private int pendingCount, approvedCount, fulfilledCount, rejectedCount;
    private int remainingQuantity => selectedRequest != null
        ? selectedRequest.QuantityRequested - selectedRequest.QuantityFulfilled
        : 0;

    // Properties with setters that trigger filter
    private string _selectedStatus = "";
    private string selectedStatus
    {
        get => _selectedStatus;
        set
        {
            _selectedStatus = value;
            FilterRequests();
            StateHasChanged();
        }
    }

    private string _selectedDepartmentId = "";
    private string selectedDepartmentId
    {
        get => _selectedDepartmentId;
        set
        {
            _selectedDepartmentId = value;
            FilterRequests();
            StateHasChanged();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var ctx = await CurrentUserService.GetOrgDashboardContextAsync();
        orgId = ctx.OrganizationId;
        userId = ctx.UserId;

        await LoadDepartmentsAsync();
        await LoadProcurementRequestsAsync();
    }

    private void BackToList() => Nav.NavigateTo("/org/assets");


    private async Task LoadDepartmentsAsync()
    {
        departments = await DepartmentService.GetDepartmentsByOrganizationAsync(orgId);
    }

    private async Task LoadProcurementRequestsAsync()
    {
        loading = true;
        StateHasChanged();

        try
        {
            allRequests = await AssetService.GetProcurementRequestsAsync(
                organizationId: orgId,
                status: null,
                departmentId: null,
                callerRole: "OrgAdmin",
                callerDepartmentId: null
            );

            // Update counts
            pendingCount = allRequests.Count(r => r.Status == ProcurementStatus.Pending);
            approvedCount = allRequests.Count(r => r.Status == ProcurementStatus.Approved);
            fulfilledCount = allRequests.Count(r => r.Status == ProcurementStatus.Fulfilled);
            rejectedCount = allRequests.Count(r => r.Status == ProcurementStatus.Rejected);

            FilterRequests();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading procurement requests: {ex.Message}");
            errorMessage = ex.Message;
        }
        finally
        {
            loading = false;
            StateHasChanged();
        }
    }

    private void FilterRequests()
    {
        var query = allRequests.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(selectedStatus))
        {
            query = query.Where(r => r.Status == selectedStatus);
        }

        if (!string.IsNullOrWhiteSpace(selectedDepartmentId) && Guid.TryParse(selectedDepartmentId, out var deptId))
        {
            query = query.Where(r => r.DepartmentId == deptId);
        }

        filteredRequests = query.OrderByDescending(r => r.RequestedAt).ToList();
    }

    private async Task RefreshAsync()
    {
        await LoadProcurementRequestsAsync();
        ShowSuccess("Refreshed successfully");
    }

    private void ClearFilters()
    {
        selectedStatus = "";
        selectedDepartmentId = "";
        FilterRequests();
        StateHasChanged();
    }

    private void OpenReviewModal(ProcurementRequestDto request)
    {
        selectedRequest = request;
        reviewNotes = "";
        errorMessage = "";
        showReviewModal = true;
        StateHasChanged();
    }

    private void OpenFulfillModal(ProcurementRequestDto request)
    {
        Console.WriteLine($"Opening fulfill modal - Request Status: {request.Status}");

        if (request.Status != ProcurementStatus.Approved)
        {
            errorMessage = $"Cannot fulfill request with status '{request.Status}'. Only Approved requests can be fulfilled.";
            StateHasChanged();
            return;
        }

        selectedRequest = request;
        errorMessage = "";
        fulfillDto = new FulfilProcurementDto
        {
            ProcurementRequestId = request.ProcurementRequestId,
            AssetName = request.AssetName ?? "",
            QuantityToCreate = remainingQuantity,
            Brand = "",
            Model = "",
            PurchasePrice = null,
            PurchaseDate = null,
            WarrantyExpiryDate = null
        };
        showFulfillModal = true;
        StateHasChanged();
    }

    private async Task SubmitReview(bool approve)
    {
        if (selectedRequest == null) return;

        submitting = true;
        approveDecision = approve;
        StateHasChanged();

        try
        {
            Console.WriteLine($"=== SUBMITTING REVIEW ===");
            Console.WriteLine($"Request ID: {selectedRequest.ProcurementRequestId}");
            Console.WriteLine($"Approve: {approve}");

            var reviewDto = new ReviewProcurementDto
            {
                ProcurementRequestId = selectedRequest.ProcurementRequestId,
                Approve = approve,
                Notes = reviewNotes
            };

            await AssetService.ReviewProcurementAsync(orgId, reviewDto, userId);

            Console.WriteLine($"Review completed. Reloading data...");

            CloseModals();
            await LoadProcurementRequestsAsync();

            ShowSuccess(approve ? "Request approved successfully" : "Request rejected");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            Console.WriteLine($"Error reviewing procurement: {ex.Message}");
            StateHasChanged();
        }
        finally
        {
            submitting = false;
        }
    }

    private async Task SubmitFulfillAsync()
    {
        if (selectedRequest == null) return;

        submitting = true;
        errorMessage = "";

        try
        {
            if (fulfillDto.QuantityToCreate < 1 || fulfillDto.QuantityToCreate > remainingQuantity)
            {
                errorMessage = $"Quantity must be between 1 and {remainingQuantity}";
                StateHasChanged();
                return;
            }

            if (string.IsNullOrWhiteSpace(fulfillDto.AssetName))
            {
                errorMessage = "Asset Name is required";
                StateHasChanged();
                return;
            }

            fulfillDto.ProcurementRequestId = selectedRequest.ProcurementRequestId;

            Console.WriteLine($"=== FULFILL PROCUREMENT ===");
            Console.WriteLine($"OrganizationId: {orgId}");
            Console.WriteLine($"Category: {selectedRequest.AssetCategory}");
            Console.WriteLine($"Quantity to create: {fulfillDto.QuantityToCreate}");
            Console.WriteLine($"Asset Name: {fulfillDto.AssetName}");

            var createdAssets = await AssetService.FulfilProcurementAsync(orgId, fulfillDto, userId);

            Console.WriteLine($"Successfully created {createdAssets.Count} assets");

            CloseModals();
            await LoadProcurementRequestsAsync();
            ShowSuccess($"Successfully created {fulfillDto.QuantityToCreate} asset(s)");
        }
        catch (DbUpdateException ex)
        {
            var innerMessage = ex.InnerException?.Message ?? ex.Message;
            errorMessage = $"Database error: {innerMessage}";
            Console.WriteLine($"DbUpdateException: {innerMessage}");
            Console.WriteLine($"Stack trace: {ex.StackTrace}");
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            Console.WriteLine($"Error fulfilling procurement: {ex.Message}");
            Console.WriteLine($"Stack trace: {ex.StackTrace}");
            StateHasChanged();
        }
        finally
        {
            submitting = false;
        }
    }

    private void CloseModals()
    {
        showReviewModal = false;
        showFulfillModal = false;
        selectedRequest = null;
        errorMessage = "";
    }

    private async void ShowSuccess(string msg)
    {
        successMessage = msg;
        StateHasChanged();
        await Task.Delay(3000);
        successMessage = "";
        StateHasChanged();
    }

    private string GetStatusClass(string status) => status switch
    {
        ProcurementStatus.Pending => "proc-status-pending",
        ProcurementStatus.Approved => "proc-status-approved",
        ProcurementStatus.Fulfilled => "proc-status-fulfilled",
        ProcurementStatus.Rejected => "proc-status-rejected",
        _ => "proc-status-pending"
    };
}