@page "/org/workweeks"
@rendermode InteractiveServer

@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize(Roles = "OrgAdmin")]

@inject WorkWeekService WorkWeekService

<PageTitle>Work Week | Humatrix</PageTitle>

<div class="container-fluid px-4 mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
        <div>
            <h2 class="fw-bold text-dark mb-1">
                <i class="bi bi-calendar3-week text-primary me-2"></i>Work Week Settings
            </h2>
            <p class="text-muted mb-0">Define and customize the operating schedule for your organization</p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-start border-4 border-success d-flex align-items-center" role="alert">
            <i class="bi bi-check-circle-fill me-2 fs-5"></i>
            <div>@message</div>
            <button class="btn-close" @onclick="() => message = null" aria-label="Close"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(error))
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm border-start border-4 border-danger d-flex align-items-center" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
            <div>@error</div>
            <button class="btn-close" @onclick="() => error = null" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-body p-4 p-md-5">

            @if (model == null)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary mb-3" role="status" style="width: 3rem; height: 3rem;"></div>
                    <p class="text-muted fw-medium">Loading organization configuration...</p>
                </div>
            }
            else
            {
                <EditForm Model="model" OnValidSubmit="Save">
                    <div class="row g-5">

                        <div class="col-lg-7">
                            <div class="mb-3">
                                <h5 class="fw-bold text-dark mb-1">Operational Days</h5>
                                <p class="text-muted small">Toggle the active working days for standard rosters.</p>
                            </div>

                            <div class="d-flex flex-column gap-2">
                                @foreach (var day in GetDayConfigurations())
                                {
                                    <label class="form-check-label w-100 p-3 rounded-3 border d-flex align-items-center justify-content-between cursor-pointer transition-all @(day.IsWorking ? "bg-light-success border-success-subtle" : "bg-white border-light-subtle")"
                                           style="cursor: pointer; transition: all 0.2s ease;">
                                        <div class="d-flex align-items-center gap-3">
                                            <InputCheckbox @bind-Value="day.PropertyBinding" class="form-check-input checkbox-lg border-secondary-subtle" />
                                            <span class="fw-semibold @(day.IsWorking ? "text-success" : "text-dark")">@day.DayName</span>
                                        </div>
                                        <span class="badge rounded-pill @(day.IsWorking ? "bg-success text-white" : "bg-secondary-subtle text-muted") px-3 py-2 fs-7">
                                            @(day.IsWorking ? "Active Working Day" : "Weekend / Rest Day")
                                        </span>
                                    </label>
                                }
                            </div>
                        </div>

                        <div class="col-lg-5">
                            <div class="position-sticky" style="top: 2rem;">
                                <h5 class="fw-bold text-dark mb-3">Configuration Overview</h5>

                                <div class="card bg-light border-0 rounded-3 mb-4">
                                    <div class="card-body p-4 text-center">
                                        <div class="display-4 fw-bold text-primary mb-1">@WorkingDaysCount</div>
                                        <div class="text-uppercase tracking-wider fw-bold text-muted small mb-2">Total Working Days</div>
                                        <div class="progress progress-sm rounded-pill mx-auto mb-2" style="max-width: 200px; height: 6px;">
                                            <div class="progress-bar bg-primary rounded-pill" style="width: @((WorkingDaysCount / 7.0) * 100)%"></div>
                                        </div>
                                    </div>
                                </div>

                                <div class="card border-light-subtle rounded-3 shadow-2xs mb-3">
                                    <div class="card-body p-3">
                                        <div class="d-flex gap-3 align-items-start">
                                            <div class="bg-primary-subtle text-primary p-2 rounded-3">
                                                <i class="bi bi-info-circle-fill fs-5"></i>
                                            </div>
                                            <div>
                                                <h6 class="fw-bold text-dark mb-1">System Impact</h6>
                                                <p class="text-muted small mb-0">These rules dynamically calculate automatic leaves, track daily attendance, and validate system-wide work schedules.</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <span class="text-muted small d-block text-center mt-3 bg-light p-2 rounded">
                                    <i class="bi bi-shield-lock me-1"></i> Default setup usually implies a Monday–Friday timeline.
                                </span>
                            </div>
                        </div>

                    </div>

                    <div class="mt-5 pt-4 border-top d-flex justify-content-end">
                        <button type="submit" class="btn btn-primary btn-lg px-5 shadow-sm fw-medium d-inline-flex align-items-center justify-content-center" disabled="@saving">
                            @if (saving)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                <span>Saving Configurations...</span>
                            }
                            else
                            {
                                <i class="bi bi-cloud-check-fill me-2"></i>
                                <span>Save Changes</span>
                            }
                        </button>
                    </div>
                </EditForm>
            }

        </div>
    </div>

</div>

<style>
    .bg-light-success {
        background-color: rgba(25, 135, 84, 0.05) !important;
    }

    .checkbox-lg {
        width: 1.25rem;
        height: 1.25rem;
    }

    .fs-7 {
        font-size: 0.785rem;
    }
</style>

@code {

    private WorkWeek? model;

    private string? message;
    private string? error;

    private bool saving = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            model = await WorkWeekService.GetAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private int WorkingDaysCount =>
        (model?.IsMondayWorking == true ? 1 : 0) +
        (model?.IsTuesdayWorking == true ? 1 : 0) +
        (model?.IsWednesdayWorking == true ? 1 : 0) +
        (model?.IsThursdayWorking == true ? 1 : 0) +
        (model?.IsFridayWorking == true ? 1 : 0) +
        (model?.IsSaturdayWorking == true ? 1 : 0) +
        (model?.IsSundayWorking == true ? 1 : 0);

    // Helper wrapper pattern to optimize structural looping inside templates safely
    private List<DayConfig> GetDayConfigurations()
    {
        if (model == null) return new();

        return new List<DayConfig>
        {
            new("Monday", model.IsMondayWorking, val => model.IsMondayWorking = val),
            new("Tuesday", model.IsTuesdayWorking, val => model.IsTuesdayWorking = val),
            new("Wednesday", model.IsWednesdayWorking, val => model.IsWednesdayWorking = val),
            new("Thursday", model.IsThursdayWorking, val => model.IsThursdayWorking = val),
            new("Friday", model.IsFridayWorking, val => model.IsFridayWorking = val),
            new("Saturday", model.IsSaturdayWorking, val => model.IsSaturdayWorking = val),
            new("Sunday", model.IsSundayWorking, val => model.IsSundayWorking = val)
        };
    }

    private async Task Save()
    {
        try
        {
            saving = true;
            await WorkWeekService.SaveAsync(model!);
            message = "Work week configurations updated seamlessly.";
            error = null;
        }
        catch (Exception ex)
        {
            error = ex.Message;
            message = null;
        }
        finally
        {
            saving = false;
        }
    }

    // Helper class structure to handle cleaner UI loop logic mapping values cleanly back to model properties
    private class DayConfig
    {
        public string DayName { get; }
        public bool IsWorking { get; }
        private readonly Action<bool> _setter;

        public DayConfig(string name, bool isWorking, Action<bool> setter)
        {
            DayName = name;
            IsWorking = isWorking;
            _setter = setter;
        }

        public bool PropertyBinding
        {
            get => IsWorking;
            set => _setter(value);
        }
    }
}