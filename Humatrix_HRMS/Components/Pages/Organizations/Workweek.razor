@page "/org/workweeks"
@rendermode InteractiveServer

@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize(Roles = "OrgAdmin")]

@inject WorkWeekService WorkWeekService

<PageTitle>Work Week | Humatrix</PageTitle>

<div class="container-fluid px-4 mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-semibold mb-0">Work Week Settings</h2>
            <small class="text-muted">Define working days for your organization</small>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert alert-success alert-dismissible fade show">
            @message
            <button class="btn-close" @onclick="() => message = null"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(error))
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @error
            <button class="btn-close" @onclick="() => error = null"></button>
        </div>
    }

    <!-- CARD -->
    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">

            @if (model == null)
            {
                <div class="text-center py-5">
                    <div class="spinner-border"></div>
                    <p class="text-muted mt-2">Loading settings...</p>
                </div>
            }
            else
            {
                <div class="row g-4">

                    <!-- WORKING DAYS -->
                    <div class="col-md-6">
                        <h6 class="fw-semibold mb-3">Working Days</h6>

                        <div class="form-check mb-2">
                            <InputCheckbox @bind-Value="model.IsMondayWorking" class="form-check-input" />
                            <label class="form-check-label">Monday</label>
                        </div>

                        <div class="form-check mb-2">
                            <InputCheckbox @bind-Value="model.IsTuesdayWorking" class="form-check-input" />
                            <label class="form-check-label">Tuesday</label>
                        </div>

                        <div class="form-check mb-2">
                            <InputCheckbox @bind-Value="model.IsWednesdayWorking" class="form-check-input" />
                            <label class="form-check-label">Wednesday</label>
                        </div>

                        <div class="form-check mb-2">
                            <InputCheckbox @bind-Value="model.IsThursdayWorking" class="form-check-input" />
                            <label class="form-check-label">Thursday</label>
                        </div>

                        <div class="form-check mb-2">
                            <InputCheckbox @bind-Value="model.IsFridayWorking" class="form-check-input" />
                            <label class="form-check-label">Friday</label>
                        </div>

                        <div class="form-check mb-2">
                            <InputCheckbox @bind-Value="model.IsSaturdayWorking" class="form-check-input" />
                            <label class="form-check-label">Saturday</label>
                        </div>

                        <div class="form-check mb-3">
                            <InputCheckbox @bind-Value="model.IsSundayWorking" class="form-check-input" />
                            <label class="form-check-label">Sunday</label>
                        </div>
                    </div>

                    <!-- SUMMARY -->
                    <div class="col-md-6">
                        <h6 class="fw-semibold mb-3">Summary</h6>

                        <div class="border rounded p-3 bg-light">

                            <div class="mb-2">
                                <strong>Total Working Days:</strong>
                                @WorkingDaysCount
                            </div>

                            <div class="small text-muted">
                                This configuration affects:
                                <ul class="mb-0 ps-3">
                                    <li>Leave calculations</li>
                                    <li>Work From Home validation</li>
                                    <li>Attendance tracking</li>
                                </ul>
                            </div>

                        </div>

                        <div class="mt-3 text-muted small">
                            Default: Monday–Friday working. Adjust based on organization policy.
                        </div>
                    </div>

                </div>

                <!-- SAVE BUTTON -->
                <div class="mt-4">
                    <button class="btn btn-success px-4"
                            disabled="@saving"
                            @onclick="Save">
                        @if (saving)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Save Changes
                    </button>
                </div>
            }

        </div>
    </div>

</div>

@code {

    private WorkWeek? model;

    private string? message;
    private string? error;

    private bool saving = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            model = await WorkWeekService.GetAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private int WorkingDaysCount =>
        (model?.IsMondayWorking == true ? 1 : 0) +
        (model?.IsTuesdayWorking == true ? 1 : 0) +
        (model?.IsWednesdayWorking == true ? 1 : 0) +
        (model?.IsThursdayWorking == true ? 1 : 0) +
        (model?.IsFridayWorking == true ? 1 : 0) +
        (model?.IsSaturdayWorking == true ? 1 : 0) +
        (model?.IsSundayWorking == true ? 1 : 0);

    private async Task Save()
    {
        try
        {
            saving = true;

            await WorkWeekService.SaveAsync(model!);

            message = "Work week updated successfully";
            error = null;
        }
        catch (Exception ex)
        {
            error = ex.Message;
            message = null;
        }
        finally
        {
            saving = false;
        }
    }
}