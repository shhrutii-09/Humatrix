@page "/org/workweeks"
@rendermode InteractiveServer

@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize(Roles = "OrgAdmin")]

@inject WorkWeekService WorkWeekService
@inject NavigationManager NavigationManager

<PageTitle>Work Week | Humatrix HRMS</PageTitle>

<div class="position-fixed top-0 end-0 p-3" style="z-index: 1080;">
    @if (!string.IsNullOrEmpty(message))
    {
        <div class="toast show align-items-center border-0 shadow-lg mb-2" role="alert" style="background-color: #f0fdf4; color: #166534; border-left: 4px solid #10b981 !important; border-radius: 10px;">
            <div class="d-flex p-3">
                <div class="toast-body d-flex align-items-center p-0">
                    <i class="bi bi-check-circle-fill me-2 fs-5" style="color: #10b981;"></i>
                    <span class="small fw-medium">@message</span>
                </div>
                <button type="button" class="btn-close m-auto me-0 shadow-none" @onclick="() => message = null"></button>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(error))
    {
        <div class="toast show align-items-center border-0 shadow-lg mb-2" role="alert" style="background-color: #fef2f2; color: #991b1b; border-left: 4px solid #ef4444 !important; border-radius: 10px;">
            <div class="d-flex p-3">
                <div class="toast-body d-flex align-items-center p-0">
                    <i class="bi bi-exclamation-triangle-fill me-2 fs-5" style="color: #ef4444;"></i>
                    <span class="small fw-medium"><strong>Error:</strong> @error</span>
                </div>
                <button type="button" class="btn-close m-auto me-0 shadow-none" @onclick="() => error = null"></button>
            </div>
        </div>
    }
</div>

<div class="container-fluid px-4 mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom row-gap-3 flex-wrap">
        <div>
            <h2 class="fw-bold tracking-tight text-dark mb-1">
                Work Week Settings
            </h2>
            <p class="text-muted small mb-0">Set up your company's standard working days to manage shifts and attendance.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-interactive-back shadow-sm d-flex align-items-center gap-2" @onclick="NavigateToDashboard">
                <i class="bi bi-speedometer2"></i>
                DASHBOARD
            </button>
        </div>
    </div>

    <div class="card border-0 shadow-sm panel-container-card">
        <div class="card-body p-4 p-md-5">

            @if (model == null)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-premium mb-3" role="status" style="width: 2.5rem; height: 2.5rem;"></div>
                    <p class="text-muted small mb-0">Loading system architecture configurations...</p>
                </div>
            }
            else
            {
                <EditForm Model="model" OnValidSubmit="Save">
                    <div class="row g-4 lg-grid-divider">

                        <div class="col-lg-7 pe-lg-4">
                            <div class="mb-4">
                                <h5 class="fw-bold text-dark mb-1">Working Days Setup</h5>
                                <p class="text-muted small">Select the active working days for your regular business operations.</p>
                            </div>

                            <div class="d-flex flex-column gap-3">
                                @foreach (var day in GetDayConfigurations())
                                {
                                    <label class="day-config-card p-3 rounded-3 border d-flex align-items-center justify-content-between @(day.IsWorking ? "card-active-working" : "card-inactive-rest")">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="custom-premium-checkbox">
                                                <InputCheckbox @bind-Value="day.PropertyBinding" class="form-check-input shadow-none" />
                                            </div>
                                            <span class="day-title-text fw-bold">@day.DayName</span>
                                        </div>

                                        <span class="status-indicator-pill @(day.IsWorking ? "pill-active" : "pill-inactive")">
                                            <i class="bi @(day.IsWorking ? "bi-briefcase-fill" : "bi-moon-stars-fill") me-2 small"></i>
                                            @(day.IsWorking ? "Active Duty" : "Rest / Weekend")
                                        </span>
                                    </label>
                                }
                            </div>
                        </div>

                        <div class="col-lg-5 ps-lg-4 mt-5 mt-lg-0">
                            <div class="position-sticky" style="top: 2rem;">
                                <h5 class="fw-bold text-dark mb-3">Configuration Analysis</h5>

                                <div class="card bg-premium-soft border-0 rounded-3 mb-4 text-center p-4">
                                    <div class="display-3 fw-black text-premium mb-1">@WorkingDaysCount</div>
                                    <div class="text-uppercase tracking-wider fw-bold text-premium-muted small mb-3">Total Assigned Days</div>
                                    <div class="progress custom-premium-progress mx-auto" style="max-width: 220px;">
                                        <div class="progress-bar" role="progressbar" style="width: @((WorkingDaysCount / 7.0) * 100)%" aria-valuenow="@WorkingDaysCount" aria-valuemin="0" aria-valuemax="7"></div>
                                    </div>
                                </div>

                                <div class="card border-dashed rounded-3 bg-white p-3 mb-4">
                                    <div class="d-flex gap-3 align-items-start">
                                        <div class="bg-premium-icon text-premium p-2 rounded-3">
                                            <i class="bi bi-info-circle-fill fs-5"></i>
                                        </div>
                                        <div>
                                            <h6 class="fw-bold text-dark mb-1">Why this matters?</h6>
                                            <p class="text-muted small mb-0">These settings automatically control how employee leaves are calculated, daily attendance is tracked, and weekend payroll is processed.</p>
                                        </div>
                                    </div>
                                </div>

                                <div class="alert alert-premium-info border-0 d-flex align-items-center gap-2 p-3 rounded-3">
                                    <i class="bi bi-lightbulb-fill fs-6"></i>
                                    <span class="small fw-medium">Tip: Most organizations follow a standard Monday to Friday work schedule.</span>
                                </div>
                            </div>
                        </div>

                    </div>

                    <div class="mt-4 pt-4 border-top d-flex justify-content-end">
                        <button type="submit" class="btn btn-action-submit px-5 shadow-sm fw-semibold" disabled="@saving">
                            @if (saving)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                <span>Synchronizing Settings...</span>
                            }
                            else
                            {
                                <i class="bi bi-cloud-arrow-up-fill me-2"></i>
                                <span>Save Changes</span>
                            }
                        </button>
                    </div>
                </EditForm>
            }

        </div>
    </div>
</div>

<style>
    /* Premium Dashboard Button */
    .btn-interactive-back {
        background: #ffffff !important;
        border: 1px solid #e5e7eb !important;
        color: #4b5563 !important;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
        transition: all 0.2s ease;
    }

        .btn-interactive-back:hover {
            background-color: #f8fafc !important;
            border-color: #5c4ac7 !important;
            color: #5c4ac7 !important;
            transform: translateY(-1px);
        }

    .text-premium {
        color: #5c4ac7 !important;
    }

    .fw-black {
        font-weight: 800;
    }

    .tracking-tight {
        letter-spacing: -0.025em;
    }

    .tracking-wider {
        letter-spacing: 0.05em;
        font-size: 11px;
    }

    .panel-container-card {
        border-radius: 16px;
        background-color: #ffffff;
        border: 1px solid #e2e8f0 !important;
    }

    .day-config-card {
        cursor: pointer;
        transition: all 0.2s ease;
        border: 1px solid #e2e8f0 !important;
    }

        .day-config-card:hover {
            transform: translateX(4px);
        }

    .card-active-working {
        background-color: #f8fafc !important;
        border-left: 4px solid #5c4ac7 !important;
    }

    .card-inactive-rest {
        background-color: #ffffff !important;
        opacity: 0.85;
    }

    .day-title-text {
        font-size: 14.5px;
        color: #1e293b;
    }

    .custom-premium-checkbox .form-check-input {
        width: 1.35rem;
        height: 1.35rem;
        cursor: pointer;
        border: 1.5px solid #cbd5e1;
        transition: all 0.15s ease;
    }

        .custom-premium-checkbox .form-check-input:checked {
            background-color: #5c4ac7;
            border-color: #5c4ac7;
        }

    .status-indicator-pill {
        font-size: 11px;
        font-weight: 600;
        padding: 4px 12px;
        border-radius: 20px;
        display: inline-flex;
        align-items: center;
    }

    .pill-active {
        background-color: rgba(92, 74, 199, 0.08);
        color: #5c4ac7;
    }

    .pill-inactive {
        background-color: #f1f5f9;
        color: #64748b;
    }

    .bg-premium-soft {
        background-color: rgba(92, 74, 199, 0.03) !important;
        border: 1px solid rgba(92, 74, 199, 0.06);
    }

    .text-premium-muted {
        color: #8a81d9;
    }

    .bg-premium-icon {
        background-color: rgba(92, 74, 199, 0.08);
    }

    .custom-premium-progress {
        height: 7px;
        background-color: #e2e8f0;
        border-radius: 10px;
        overflow: hidden;
    }

        .custom-premium-progress .progress-bar {
            background-color: #5c4ac7;
            border-radius: 10px;
        }

    .border-dashed {
        border: 1px dashed #cbd5e1 !important;
    }

    .alert-premium-info {
        background-color: #f0f9ff;
        color: #0369a1;
        border: 1px solid #b3e0ff !important;
    }

    .btn-action-submit {
        background-color: #5c4ac7 !important;
        color: #ffffff !important;
        border: none !important;
        padding: 12px 28px;
        border-radius: 10px;
        font-size: 14px;
        transition: all 0.2s ease;
    }

        .btn-action-submit:hover:not(:disabled) {
            background-color: #4b3ba6 !important;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(92, 74, 199, 0.2) !important;
        }

    @@media (min-width: 992px) {
        .lg-grid-divider {
            --bs-gutter-x: 3rem;
        }

            .lg-grid-divider > div:first-child {
                border-right: 1px solid #f1f5f9;
            }
    }
</style>

@code {
    private WorkWeek? model;
    private string? message;
    private string? error;
    private bool saving = false;

    protected override async Task OnInitializedAsync()
    {
        try { model = await WorkWeekService.GetAsync(); }
        catch (Exception ex) { error = ex.Message; }
    }

    private void NavigateToDashboard() => NavigationManager.NavigateTo("/org/dashboard");

    private int WorkingDaysCount =>
        (model?.IsMondayWorking == true ? 1 : 0) +
        (model?.IsTuesdayWorking == true ? 1 : 0) +
        (model?.IsWednesdayWorking == true ? 1 : 0) +
        (model?.IsThursdayWorking == true ? 1 : 0) +
        (model?.IsFridayWorking == true ? 1 : 0) +
        (model?.IsSaturdayWorking == true ? 1 : 0) +
        (model?.IsSundayWorking == true ? 1 : 0);

    private List<DayConfig> GetDayConfigurations()
    {
        if (model == null) return new();
        return new List<DayConfig>
        {
            new("Monday", model!.IsMondayWorking, val => model!.IsMondayWorking = val),
            new("Tuesday", model!.IsTuesdayWorking, val => model!.IsTuesdayWorking = val),
            new("Wednesday", model!.IsWednesdayWorking, val => model!.IsWednesdayWorking = val),
            new("Thursday", model!.IsThursdayWorking, val => model!.IsThursdayWorking = val),
            new("Friday", model!.IsFridayWorking, val => model!.IsFridayWorking = val),
            new("Saturday", model!.IsSaturdayWorking, val => model!.IsSaturdayWorking = val),
            new("Sunday", model!.IsSundayWorking, val => model!.IsSundayWorking = val)
        };
    }

    private async Task Save()
    {
        try
        {
            saving = true;
            await WorkWeekService.SaveAsync(model!);
            message = "Work week configurations synchronized seamlessly.";
            error = null;
        }
        catch (Exception ex) { error = ex.Message; message = null; }
        finally { saving = false; }
    }

    private class DayConfig
    {
        public string DayName { get; }
        public bool IsWorking { get; }
        private readonly Action<bool> _setter;
        public DayConfig(string name, bool isWorking, Action<bool> setter)
        {
            DayName = name;
            IsWorking = isWorking;
            _setter = setter;
        }
        public bool PropertyBinding { get => IsWorking; set => _setter(value); }
    }
}