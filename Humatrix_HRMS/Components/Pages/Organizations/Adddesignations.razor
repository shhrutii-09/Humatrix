@page "/org/designations"
@rendermode InteractiveServer
@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms

@attribute [Authorize(Roles = "OrgAdmin")]

@inject DesignationService DesignationService
@inject DepartmentService DeptService

<h3>Designations</h3>

<div class="card p-3 mb-3">
    @* We use EditContext instead of Model directly for better control over validation state *@
    @if (editContext != null)
    {
        <EditForm EditContext="editContext" OnValidSubmit="CreateDesignation" FormName="designationForm">
            @* <DataAnnotationsValidator /> *@

            <div class="mb-2">
                <label class="form-label">Designation Name</label>
                @* Removed oninput to avoid validation flickering; standard binding is safer *@
                <InputText @bind-Value="model.Name"
                           placeholder="Designation Name"
                           class="form-control" />
                <ValidationMessage For="@(() => model.Name)" class="text-danger" />
            </div>

            <div class="mb-2">
                <label class="form-label">Department</label>
                @* <InputSelect @bind-Value="model.DepartmentId" class="form-control">
                    <option value="">-- Select Department --</option>
                    @foreach (var dept in departments)
                    {
                        <option value="@dept.DepartmentId">@dept.Name</option>
                    }
                </InputSelect> *@
                <InputSelect @bind-Value="model.DepartmentId" class="form-control">
                    <option value="@Guid.Empty">-- Select Department --</option>
                    @foreach (var dept in departments)
                    {
                        <option value="@dept.DepartmentId">@dept.Name</option>
                    }
                </InputSelect>
                <ValidationMessage For="@(() => model.DepartmentId)" class="text-danger" />
            </div>

            <button type="submit" class="btn btn-primary">Add Designation</button>
        </EditForm>
    }
</div>

@if (designations == null)
{
    <p>Loading...</p>
}
else if (!designations.Any())
{
    <p>No designations added yet.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Department</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var d in designations)
            {
                <tr>
                    <td>@d.Name</td>
                    <td>@d.Department</td>
                    <td>
                        <button class="btn btn-sm btn-warning"
                                @onclick="() => EditDesignation(d)">
                            Edit
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private CreateDesignationDto model = new();
    private EditContext? editContext;
    private List<DesignationDto> designations = new();
    private List<DepartmentDto> departments = new();

    private Guid? editingId = null;
    private bool isEditMode = false;

    protected override async Task OnInitializedAsync()
    {
        // Initialize the EditContext with our model
        editContext = new EditContext(model);

        departments = await DeptService.GetAllAsync(); 
        designations = await DesignationService.GetAllAsync(); 
    }

    private async Task CreateDesignation()
    {
        try
        {
            await DesignationService.CreateAsync(model);

            designations = await DesignationService.GetAllAsync();
            model = new CreateDesignationDto();
            editContext = new EditContext(model);

            StateHasChanged(); 
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}"); 
        }
    }
    private void EditDesignation(DesignationDto d)
    {
        isEditMode = true;
        editingId = d.DesignationId;

        model = new CreateDesignationDto
        {
            Name = d.Name,
            DepartmentId = departments
                .FirstOrDefault(dep => dep.Name == d.Department)?.DepartmentId ?? Guid.Empty
        };

        editContext = new EditContext(model);
    }
}