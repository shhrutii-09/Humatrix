@* Pages/Org/UploadDocument.razor *@
@page "/org/documents/upload"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "OrgAdmin,HR")]
@using Humatrix_HRMS.Data
@using Humatrix_HRMS.Models.Documents
@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Microsoft.EntityFrameworkCore
@using Humatrix_HRMS.Services.Documents
@using Humatrix_HRMS.DTOs.Documents
@using Microsoft.AspNetCore.Authorization
@using Humatrix_HRMS.DTOs.Documents
@using Microsoft.AspNetCore.Components.Forms
@using System.IO
@inject IOrgDocumentGenerationService DocumentService
@inject CurrentUserService CurrentUserService

<PageTitle>Document Management | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4">

    <!-- Header -->
    <div class="page-header mb-4">
        <div>
            <h2 class="fw-bold mb-1">
                <i class="bi bi-file-earmark-arrow-up me-2"></i>
                Document Management
            </h2>

            <p class="text-muted mb-0">
                Upload and manage employee documents securely
            </p>
        </div>

        <div>
            <span class="badge bg-primary px-3 py-2">
                @eligibleEmployeesWithRoles.Count Employees
            </span>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="loading-container">
            <div class="spinner-border text-primary"></div>
            <p class="mt-3">Loading documents...</p>
        </div>
    }
    else
    {
        <div class="row g-4">

            <!-- Left -->
            <div class="col-xl-8">

                @if (dashboardSuggestions.Any())
                {
                    <div class="card dashboard-card mb-4">
                        <div class="card-header-custom">
                            <h6>
                                Recommendations
                                <span class="badge bg-primary ms-2">
                                    @dashboardSuggestions.Count
                                </span>
                            </h6>
                        </div>

                        <div class="card-body">

                            @foreach (var suggestion in dashboardSuggestions.OrderByDescending(x => x.Priority))
                            {
                                <div class="suggestion-item">

                                    <div>
                                        <div class="fw-semibold">
                                            @suggestion.DocumentType
                                        </div>

                                        <small class="text-muted">
                                            @suggestion.EmployeeName
                                            •
                                            @suggestion.Department
                                        </small>

                                        <div class="small text-secondary mt-1">
                                            @suggestion.Reason
                                        </div>
                                    </div>

                                    <button class="btn btn-primary btn-sm"
                                            @onclick="() => PrefillForm(suggestion)">
                                        Upload
                                    </button>

                                </div>
                            }

                        </div>
                    </div>
                }

                <div class="card dashboard-card">

                    <div class="card-header-custom">
                        <h5 class="mb-0">
                            Upload Document
                        </h5>
                    </div>

                    <div class="card-body">

                        <EditForm Model="@uploadModel"
                                  OnValidSubmit="HandleUpload"
                                  FormName="uploadForm">

                            <DataAnnotationsValidator />

                            <div class="row">

                                <div class="col-md-12 mb-3">
                                    <label class="form-label">
                                        Employee
                                    </label>

                                    <select class="form-select form-control-modern"
                                            @bind="uploadModel.RecipientEmployeeId">

                                        <option value="@Guid.Empty">
                                            Select Employee
                                        </option>

                                        @foreach (var emp in eligibleEmployeesWithRoles.OrderBy(x => x.DepartmentName).ThenBy(x => x.FirstName))
                                        {
                                            if (emp.IsHR)
                                            {
                                                <option value="@emp.EmployeeId" style="background-color: floralwhite;">
                                                    @emp.DisplayName - @emp.DepartmentName (HR)
                                                </option>
                                            }
                                            else if (emp.IsOrgAdmin)
                                            {
                                                <option value="@emp.EmployeeId" style="background-color: #d1ecf1;">
                                                    @emp.DisplayName - @emp.DepartmentName (Admin)
                                                </option>
                                            }
                                            else
                                            {
                                                <option value="@emp.EmployeeId">
                                                    @emp.DisplayName - @emp.DepartmentName
                                                </option>
                                            }
                                        }

                                    </select>

                                    @* @if (eligibleEmployeesWithRoles.Any(e => e.IsHR))
                                    {
                                        <small class="text-muted mt-1 d-block">
                                            <span class="badge bg-warning text-dark">HR</span> = HR Staff
                                        </small>
                                    } *@
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label class="form-label">
                                        Document Name
                                    </label>

                                    <InputText class="form-control form-control-modern"
                                               @bind-Value="uploadModel.DocumentName" />
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label class="form-label">
                                        Category
                                    </label>

                                    <InputSelect class="form-select form-control-modern"
                                                 @bind-Value="uploadModel.Category">

                                        <option value="">Select</option>
                                        <option value="HR">HR</option>
                                        <option value="Finance">Finance</option>
                                        <option value="Legal">Legal</option>
                                        <option value="General">General</option>

                                    </InputSelect>
                                </div>

                                <div class="col-12 mb-3">
                                    <label class="form-label">
                                        Description
                                    </label>

                                    <InputTextArea class="form-control form-control-modern"
                                                   rows="4"
                                                   @bind-Value="uploadModel.Description" />
                                </div>

                                <!-- Drag Drop Upload -->
                                <div class="col-12 mb-4">

                                    <label class="form-label">
                                        Upload File
                                    </label>

                                    <div class="upload-zone">

                                        <i class="bi bi-cloud-arrow-up upload-icon"></i>

                                        <h6>
                                            Drag & Drop File
                                        </h6>

                                        <small class="text-muted">
                                            PDF, DOCX, JPG, PNG
                                        </small>

                                        <InputFile class="form-control mt-3"
                                                   OnChange="OnFileSelected" />

                                        @if (!string.IsNullOrWhiteSpace(selectedFileName))
                                        {
                                            <div class="selected-file">
                                                📄 @selectedFileName
                                            </div>
                                        }

                                    </div>

                                </div>

                                <div class="col-12 mb-3">

                                    <div class="form-check form-switch">

                                        <InputCheckbox class="form-check-input"
                                                       @bind-Value="uploadModel.RequiresAcknowledgment" />

                                        <label class="form-check-label">
                                            Requires Employee Acknowledgment
                                        </label>

                                    </div>

                                </div>

                                <div class="col-12 mb-4">

                                    <label class="form-label">
                                        Internal Remarks
                                    </label>

                                    <InputTextArea class="form-control form-control-modern"
                                                   rows="3"
                                                   @bind-Value="uploadModel.Remarks" />

                                </div>

                                @if (!string.IsNullOrWhiteSpace(resultMessage))
                                {
                                    <div class="col-12 mb-3">

                                        <div class="alert @(isSuccess ? "alert-success" : "alert-danger")">

                                            @resultMessage

                                        </div>

                                    </div>
                                }

                                <div class="col-12">

                                    <button type="submit"
                                            class="btn btn-primary btn-lg"
                                            disabled="@isUploading">

                                        @if (isUploading)
                                        {
                                            <span class="spinner-border spinner-border-sm me-2"></span>
                                        }

                                        Upload Document

                                    </button>

                                    <button type="button"
                                            class="btn btn-outline-secondary ms-2"
                                            @onclick="ResetForm">

                                        Reset

                                    </button>

                                </div>

                            </div>

                        </EditForm>

                    </div>

                </div>

            </div>

            <!-- Right Sidebar -->
            <div class="col-xl-4">

                <div class="card dashboard-card mb-4">

                    <div class="card-header-custom">
                        Upload Guidelines
                    </div>

                    <div class="card-body">

                        <ul class="list-unstyled small">

                            <li>✔ Supported file size: 10 MB</li>
                            <li>✔ Secure document storage</li>
                            <li>✔ Employee notifications</li>
                            <li>✔ Audit tracking enabled</li>
                            <li>✔ Online acknowledgments</li>

                        </ul>

                    </div>

                </div>

                <div class="card dashboard-card">

                    <div class="card-header-custom">
                        Statistics
                    </div>

                    <div class="card-body">

                        <div class="stat-box">
                            <h4>@eligibleEmployeesWithRoles.Count</h4>  <!-- Changed from eligibleEmployees -->
                            <span>Eligible Employees</span>
                        </div>

                        <div class="stat-box mt-3">
                            <h4>@dashboardSuggestions.Count</h4>
                            <span> Suggestions</span>
                        </div>

                    </div>

                </div>

            </div>

        </div>
    }

</div>
}


<style>

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .dashboard-card {
        border: none;
        border-radius: 18px;
        box-shadow: 0 4px 20px rgba(0,0,0,.08);
    }

    .card-header-custom {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid #eef1f4;
        font-weight: 600;
        background: #fff;
    }

    .form-control-modern {
        border-radius: 12px;
        min-height: 48px;
    }

    .upload-zone {
        border: 2px dashed #d6dbe1;
        border-radius: 16px;
        padding: 40px;
        text-align: center;
        background: #fafbfc;
        transition: .3s;
    }

        .upload-zone:hover {
            border-color: #0d6efd;
            background: #f6f9ff;
        }

    .upload-icon {
        font-size: 3rem;
        color: #0d6efd;
    }

    .selected-file {
        margin-top: 10px;
        background: #e8f4ff;
        padding: 10px;
        border-radius: 10px;
    }

    .suggestion-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px;
        border: 1px solid #ececec;
        border-radius: 12px;
        margin-bottom: 10px;
    }

    .loading-container {
        text-align: center;
        padding: 100px 0;
    }

    .stat-box {
        background: #f8f9fa;
        border-radius: 14px;
        padding: 15px;
        text-align: center;
    }

</style>

@code {
    private class UploadDocumentModel
    {
        public Guid RecipientEmployeeId { get; set; }
        public string DocumentName { get; set; } = string.Empty;
        public string? Description { get; set; }
        public string? Category { get; set; }
        public string? Remarks { get; set; }
        public bool RequiresAcknowledgment { get; set; } = true;
    }

    private UploadDocumentModel uploadModel = new();
    private List<EmployeeWithRoleDto> eligibleEmployeesWithRoles = new();  // CHANGED: Use the DTO type
    private List<DashboardDocumentSuggestion> dashboardSuggestions = new();
    private IBrowserFile? selectedFile;
    private string selectedFileName = string.Empty;

    private bool isLoading = true;
    private bool isUploading = false;
    private bool isOrgAdmin = false;
    private bool isSuccess = false;
    private string resultMessage = "";

    private ApplicationUser? _currentUser;
    private string _currentUserRole = "HR";

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        try
        {
            isLoading = true;
            _currentUser = await CurrentUserService.GetUserAsync();

            if (_currentUser?.OrganizationId == null)
            {
                ShowError("Your session has expired. Please log in again.");
                return;
            }

            isOrgAdmin = await CurrentUserService.IsInRoleAsync("OrgAdmin");
            _currentUserRole = isOrgAdmin ? "OrgAdmin" : "HR";

            var orgId = _currentUser.OrganizationId.Value;

            // Use the new method that includes role information
            eligibleEmployeesWithRoles = await DocumentService.GetEligibleRecipientsWithRolesAsync(
                orgId, _currentUser.Id, _currentUserRole);

            dashboardSuggestions = await DocumentService.GetDashboardSuggestionsAsync(
                orgId, _currentUser.Id, _currentUserRole);
        }
        catch (Exception ex)
        {
            ShowError($"Error loading data: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        selectedFileName = selectedFile?.Name ?? string.Empty;
        await Task.CompletedTask;
    }

    private async Task HandleUpload()
    {
        if (uploadModel.RecipientEmployeeId == Guid.Empty)
        {
            ShowError("Please select an employee.");
            return;
        }

        if (string.IsNullOrWhiteSpace(uploadModel.DocumentName))
        {
            ShowError("Please enter a document name.");
            return;
        }

        if (selectedFile == null)
        {
            ShowError("Please select a file to upload.");
            return;
        }

        isUploading = true;
        resultMessage = "";

        try
        {
            using var memoryStream = new MemoryStream();
            await selectedFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(memoryStream);
            var fileBytes = memoryStream.ToArray();

            var dto = new ManualDocumentUploadDto
            {
                RecipientEmployeeId = uploadModel.RecipientEmployeeId,
                DocumentName = uploadModel.DocumentName,
                Description = uploadModel.Description,
                Category = uploadModel.Category,
                Remarks = uploadModel.Remarks,
                RequiresAcknowledgment = uploadModel.RequiresAcknowledgment
            };

            var result = await DocumentService.UploadDocumentManuallyAsync(
                dto,
                _currentUser!.OrganizationId!.Value,
                _currentUser.Id,
                _currentUserRole,
                selectedFile.Name,
                selectedFile.ContentType,
                fileBytes);

            ShowSuccess($"✅ Document '{result.DocumentTypeName}' uploaded successfully for {result.EmployeeName}.");
            await RefreshSuggestions();
            ResetForm();
        }
        catch (DbUpdateException ex)
        {
            var innerMessage = ex.InnerException?.Message ?? ex.Message;
            ShowError($"Database error: {innerMessage}");
            Console.WriteLine($"Full error: {ex}");
        }
        catch (UnauthorizedAccessException ex)
        {
            ShowError($"Permission denied: {ex.Message}");
        }
        catch (Exception ex)
        {
            ShowError($"{ex.Message}");
            Console.WriteLine($"Full error: {ex}");
        }
        finally
        {
            isUploading = false;
        }
    }

    private void PrefillForm(DashboardDocumentSuggestion suggestion)
    {
        uploadModel.DocumentName = suggestion.DocumentType;
        uploadModel.RecipientEmployeeId = suggestion.EmployeeId;

        if (suggestion.SuggestedData != null && suggestion.SuggestedData.Any())
        {
            uploadModel.Description = $"Auto-suggested: {suggestion.Reason}. " +
                                      string.Join("; ", suggestion.SuggestedData.Select(kv => $"{kv.Key}: {kv.Value}"));
        }
        else
        {
            uploadModel.Description = suggestion.Reason;
        }

        StateHasChanged();
    }

    private async Task RefreshSuggestions()
    {
        try
        {
            dashboardSuggestions = await DocumentService.GetDashboardSuggestionsAsync(
                _currentUser!.OrganizationId!.Value, _currentUser.Id, _currentUserRole);
        }
        catch { }
    }

    private void ResetForm()
    {
        uploadModel = new UploadDocumentModel();
        selectedFile = null;
        selectedFileName = string.Empty;
        StateHasChanged();
    }

    private void ShowSuccess(string msg) { resultMessage = msg; isSuccess = true; }
    private void ShowError(string msg) { resultMessage = msg; isSuccess = false; }
}