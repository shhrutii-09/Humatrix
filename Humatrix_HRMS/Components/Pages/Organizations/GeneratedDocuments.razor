@page "/org/documents/generate"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "OrgAdmin,HR")]
@using Humatrix_HRMS.Models.Documents
@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Humatrix_HRMS.Services.Documents
@using Humatrix_HRMS.Services.AI
@using Humatrix_HRMS.DTOs.Documents
@using Microsoft.AspNetCore.Authorization
@inject IOrgDocumentGenerationService DocumentService
@inject EmployeeService EmployeeService
@inject CurrentUserService CurrentUserService

<h3>📄 Generate Organization Document</h3>

<div class="row mt-4">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Document Generator</h5>
                @if (isOrgAdmin)
                {
                    <button class="btn btn-sm btn-light" @onclick="AutoGenerateDocuments" disabled="@isAutoGenerating">
                        @if (isAutoGenerating)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        🤖 Auto-Generate Missing
                    </button>
                }
            </div>
            <div class="card-body">
                @if (isLoading)
                {
                    <div class="text-center py-5">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p>Loading...</p>
                    </div>
                }
                else
                {
                    <!-- AI Suggestions Section -->
                    @if (selectedEmployeeId != null && selectedEmployeeId != "" && aiSuggestions.Any())
                    {
                        <div class="alert alert-info mb-3">
                            <strong>🤖 AI Suggestions:</strong>
                            <ul class="mb-0 mt-2">
                                @foreach (var suggestion in aiSuggestions)
                                {
                                    <li>
                                        <strong>@suggestion.DocumentType</strong> - @suggestion.Reason
                                        <button class="btn btn-sm btn-outline-primary ms-2" @onclick="() => UseSuggestion(suggestion)">
                                            Generate
                                        </button>
                                    </li>
                                }
                            </ul>
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label fw-bold">Select Document Template</label>
                        <select @bind="selectedTemplateId" class="form-select">
                            <option value="">-- Select Template --</option>
                            @foreach (var template in templates)
                            {
                                <option value="@template.TemplateId">@template.Name (@template.Category)</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Select Employee</label>
                        <select @bind="selectedEmployeeId" class="form-select">
                            <option value="">-- Select Employee --</option>
                            @foreach (var emp in eligibleEmployees)
                            {
                                <option value="@emp.EmployeeId">@emp.FirstName @emp.LastName (@emp.EmployeeCode)</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Custom Data (Optional)</label>
                        <textarea @bind="customDataJson" class="form-control" rows="6"
                                  placeholder='{
              "JoiningDate": "2024-06-15",
              "Designation": "Software Engineer",
              "Department": "Engineering"
            }'></textarea>
                        <small class="text-muted">Enter JSON key-value pairs for template placeholders. Example: {"key": "value"}</small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Remarks (Internal Notes)</label>
                        <textarea @bind="remarks" class="form-control" rows="2"></textarea>
                    </div>

                    <div class="btn-group w-100">
                        <button class="btn btn-primary" @onclick="GenerateDocument" disabled="@isGenerating">
                            @if (isGenerating)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                            }
                            @(isGenerating ? "Generating..." : "Generate Document")
                        </button>

                        <button class="btn btn-success" @onclick="GenerateDocumentWithAI" disabled="@isGenerating">
                            @if (isGenerating)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                            }
                            ✨ Generate with AI
                        </button>
                    </div>

                    @if (!string.IsNullOrEmpty(resultMessage))
                    {
                        <div class="alert @(resultMessage.Contains("✅") ? "alert-success" : "alert-danger") mt-3">
                            @resultMessage
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0">📋 Available Placeholders</h5>
            </div>
            <div class="card-body">
                <p class="small text-muted">Common placeholders you can use:</p>
                <ul class="small">
                    <li><code>{{EmployeeName}}</code> - Full name</li>
                    <li><code>{{FirstName}}</code> - First name</li>
                    <li><code>{{LastName}}</code> - Last name</li>
                    <li><code>{{EmployeeCode}}</code> - Employee ID</li>
                    <li><code>{{Designation}}</code> - Job title</li>
                    <li><code>{{Department}}</code> - Department name</li>
                    <li><code>{{JoiningDate}}</code> - Joining date</li>
                    <li><code>{{CurrentDate}}</code> - Today's date</li>
                    <li><code>{{OrganizationName}}</code> - Company name</li>
                    <li><code>{{GeneratedBy}}</code> - Your name</li>
                </ul>
                <hr />
                <p class="small text-muted">Custom placeholders depend on the template selected.</p>
            </div>
        </div>

        @if (selectedEmployeeId != null && selectedEmployeeId != "" && aiSuggestions.Any())
        {
            <div class="card border-success">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">🤖 AI Smart Recommendations</h5>
                </div>
                <div class="card-body">
                    <p class="small">Based on employee data, AI recommends:</p>
                    <ul class="list-unstyled">
                        @foreach (var suggestion in aiSuggestions)
                        {
                            <li class="mb-2">
                                <span class="badge bg-primary me-2">Priority @suggestion.Priority</span>
                                <strong>@suggestion.DocumentType</strong>
                                <br />
                                <small class="text-muted">@suggestion.Reason</small>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private List<OrgDocumentTemplate> templates = new();
    private List<Employee> eligibleEmployees = new();
    private List<AIDocumentSuggestion> aiSuggestions = new();
    private string selectedTemplateId = "";
    private string selectedEmployeeId = "";
    private string customDataJson = "";
    private string remarks = "";
    private bool isLoading = true;
    private bool isGenerating = false;
    private bool isAutoGenerating = false;
    private bool isOrgAdmin = false;
    private string resultMessage = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            isLoading = true;
            var user = await CurrentUserService.GetUserAsync();
            if (user?.OrganizationId == null)
            {
                resultMessage = "User not authenticated. Please login again.";
                return;
            }

            isOrgAdmin = await CurrentUserService.IsInRoleAsync("OrgAdmin");
            var roles = isOrgAdmin ? "OrgAdmin" : "HR";

            templates = await DocumentService.GetAllTemplatesAsync(user.OrganizationId.Value);
            eligibleEmployees = await DocumentService.GetEligibleRecipientsForDocumentAsync(
                user.OrganizationId.Value, user.Id, roles);
        }
        catch (Exception ex)
        {
            resultMessage = $"Error loading data: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    // Handle employee selection without @onchange
    // We'll use a separate method that gets called when selectedEmployeeId changes
    // Add this property to detect changes
    private string _previousEmployeeId = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender && _previousEmployeeId != selectedEmployeeId)
        {
            _previousEmployeeId = selectedEmployeeId;
            if (!string.IsNullOrEmpty(selectedEmployeeId))
            {
                await LoadAISuggestions();
                StateHasChanged();
            }
            else
            {
                aiSuggestions.Clear();
                StateHasChanged();
            }
        }
        await base.OnAfterRenderAsync(firstRender);
    }

    private async Task LoadAISuggestions()
    {
        try
        {
            aiSuggestions = await DocumentService.GetAIDocumentSuggestionsAsync(Guid.Parse(selectedEmployeeId));
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading AI suggestions: {ex.Message}");
            aiSuggestions = new List<AIDocumentSuggestion>();
        }
    }

    private async Task UseSuggestion(AIDocumentSuggestion suggestion)
    {
        // Find template ID for the suggested document type
        var template = templates.FirstOrDefault(t => t.Name == suggestion.DocumentType);
        if (template != null)
        {
            selectedTemplateId = template.TemplateId.ToString();

            // Pre-fill custom data from suggestion
            if (suggestion.SuggestedData.Any())
            {
                customDataJson = System.Text.Json.JsonSerializer.Serialize(suggestion.SuggestedData, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
            }

            // Auto-generate with AI
            await GenerateDocumentWithAI();
        }
        else
        {
            resultMessage = $"❌ Template '{suggestion.DocumentType}' not found. Please create it first.";
        }
    }

    private async Task GenerateDocument()
    {
        if (string.IsNullOrEmpty(selectedTemplateId))
        {
            resultMessage = "Please select a template";
            return;
        }

        if (string.IsNullOrEmpty(selectedEmployeeId))
        {
            resultMessage = "Please select an employee";
            return;
        }

        isGenerating = true;
        resultMessage = "";

        try
        {
            var user = await CurrentUserService.GetUserAsync();
            if (user?.OrganizationId == null)
            {
                resultMessage = "User not authenticated";
                return;
            }

            var isOrgAdminUser = await CurrentUserService.IsInRoleAsync("OrgAdmin");
            var roles = isOrgAdminUser ? "OrgAdmin" : "HR";

            Dictionary<string, string>? customData = null;
            if (!string.IsNullOrEmpty(customDataJson))
            {
                try
                {
                    var cleanedJson = System.Text.RegularExpressions.Regex.Replace(
                        customDataJson,
                        @",(\s*[}\]])",
                        "$1");
                    customData = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, string>>(cleanedJson);
                }
                catch (Exception jsonEx)
                {
                    resultMessage = $"Invalid JSON format. Error: {jsonEx.Message}";
                    return;
                }
            }

            var dto = new OrgDocumentGenerationDto
            {
                TemplateId = Guid.Parse(selectedTemplateId),
                RecipientEmployeeId = Guid.Parse(selectedEmployeeId),
                CustomData = customData,
                Remarks = remarks,
                SendEmailNotification = true
            };

            var result = await DocumentService.GenerateDocumentAsync(
                dto, user.OrganizationId.Value, user.Id, roles);

            resultMessage = $"✅ Document generated successfully! Document ID: {result.DocumentId}";

            // Reset form
            selectedTemplateId = "";
            selectedEmployeeId = "";
            customDataJson = "";
            remarks = "";
            aiSuggestions.Clear();

            await LoadData();
        }
        catch (Exception ex)
        {
            resultMessage = $"❌ Error: {ex.Message}";
        }
        finally
        {
            isGenerating = false;
        }
    }

    private async Task GenerateDocumentWithAI()
    {
        if (string.IsNullOrEmpty(selectedTemplateId))
        {
            resultMessage = "Please select a template";
            return;
        }

        if (string.IsNullOrEmpty(selectedEmployeeId))
        {
            resultMessage = "Please select an employee";
            return;
        }

        isGenerating = true;
        resultMessage = "";

        try
        {
            var user = await CurrentUserService.GetUserAsync();
            if (user?.OrganizationId == null)
            {
                resultMessage = "User not authenticated";
                return;
            }

            var isOrgAdminUser = await CurrentUserService.IsInRoleAsync("OrgAdmin");
            var roles = isOrgAdminUser ? "OrgAdmin" : "HR";

            Dictionary<string, string>? customData = null;
            if (!string.IsNullOrEmpty(customDataJson))
            {
                try
                {
                    var cleanedJson = System.Text.RegularExpressions.Regex.Replace(
                        customDataJson,
                        @",(\s*[}\]])",
                        "$1");
                    customData = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, string>>(cleanedJson);
                }
                catch (Exception jsonEx)
                {
                    resultMessage = $"Invalid JSON format. Error: {jsonEx.Message}";
                    return;
                }
            }

            var result = await DocumentService.GenerateDocumentWithAIAsync(
                Guid.Parse(selectedTemplateId),
                Guid.Parse(selectedEmployeeId),
                user.Id,
                roles,
                customData,
                true);

            resultMessage = $"✨ AI-generated document successfully! Document ID: {result.DocumentId}";

            // Reset form
            selectedTemplateId = "";
            selectedEmployeeId = "";
            customDataJson = "";
            remarks = "";
            aiSuggestions.Clear();

            await LoadData();
        }
        catch (Exception ex)
        {
            resultMessage = $"❌ AI Generation Error: {ex.Message}";
        }
        finally
        {
            isGenerating = false;
        }
    }

    private async Task AutoGenerateDocuments()
    {
        isAutoGenerating = true;
        resultMessage = "";

        try
        {
            var user = await CurrentUserService.GetUserAsync();
            if (user?.OrganizationId == null)
            {
                resultMessage = "User not authenticated";
                return;
            }

            var result = await DocumentService.AutoGenerateRequiredDocumentsAsync(user.OrganizationId.Value);
            resultMessage = $"✅ Auto-generated {result} documents for employees!";

            // Refresh data
            await LoadData();
        }
        catch (Exception ex)
        {
            resultMessage = $"❌ Auto-generation Error: {ex.Message}";
        }
        finally
        {
            isAutoGenerating = false;
        }
    }
}