@* Pages/Org/GeneratedDocuments.razor *@
@page "/org/documents/generate"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "OrgAdmin,HR")]
@using Humatrix_HRMS.Data
@using Humatrix_HRMS.Models.Documents
@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Humatrix_HRMS.Services.Documents
@using Humatrix_HRMS.Services.AI
@using Humatrix_HRMS.DTOs.Documents
@using Microsoft.AspNetCore.Authorization
@inject IOrgDocumentGenerationService DocumentService
@inject CurrentUserService CurrentUserService

<PageTitle>Generate Document — Humatrix HRMS</PageTitle>

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="mb-0 fw-semibold">Generate Organization Document</h4>
        <small class="text-muted">Issue official documents to employees</small>
    </div>
    @if (isOrgAdmin)
    {
        <a href="/org/documents/history" class="btn btn-outline-secondary btn-sm">
            View Document History
        </a>
    }
</div>

@if (isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-2 text-muted">Loading...</p>
    </div>
}
else
{
    <div class="row g-4">

        <!-- Left: Form -->
        <div class="col-lg-7">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="mb-0 fw-semibold">Document Details</h6>
                </div>
                <div class="card-body">

                    <!-- Template selector -->
                    <div class="mb-3">
                        <label class="form-label fw-medium">Document Template <span class="text-danger">*</span></label>
                        <select class="form-select" @bind="selectedTemplateId">
                            <option value="">— Select a template —</option>
                            @foreach (var grp in templates.GroupBy(t => t.Category).OrderBy(g => g.Key))
                            {
                                <optgroup label="@grp.Key">
                                    @foreach (var t in grp.OrderBy(x => x.DisplayOrder))
                                    {
                                        <option value="@t.TemplateId">@t.Name</option>
                                    }
                                </optgroup>
                            }
                        </select>
                    </div>

                    <!-- Employee selector — uses @onchange so AI suggestions load immediately -->
                    <div class="mb-3">
                        <label class="form-label fw-medium">Recipient Employee <span class="text-danger">*</span></label>
                        <select class="form-select"
                                value="@selectedEmployeeId"
                                @onchange="OnEmployeeChanged">
                            <option value="">— Select an employee —</option>
                            @foreach (var emp in eligibleEmployees)
                            {
                                <option value="@emp.EmployeeId">
                                    @emp.FirstName @emp.LastName — @(emp.Department?.Name ?? "No Dept") (@emp.EmployeeCode)
                                </option>
                            }
                        </select>
                    </div>

                    <!-- AI Suggestions (shown inline when an employee is selected) -->
                    @if (aiSuggestions.Any() && !string.IsNullOrEmpty(selectedEmployeeId))
                    {
                        <div class="alert alert-info border-0 py-2 mb-3" style="background:#f0f7ff">
                            <div class="d-flex align-items-center mb-2">
                                <span class="me-2">✨</span>
                                <strong class="small">AI Suggestions for this employee</strong>
                            </div>
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var s in aiSuggestions.OrderByDescending(x => x.Priority))
                                {
                                    <button class="btn btn-sm btn-outline-primary"
                                            title="@s.Reason"
                                            @onclick="() => ApplySuggestion(s)">
                                        @s.DocumentType
                                    </button>
                                }
                            </div>
                        </div>
                    }

                    <!-- Custom data (collapsed by default) -->
                    <div class="mb-3">
                        <label class="form-label fw-medium d-flex align-items-center gap-2">
                            Custom Placeholder Data
                            <small class="text-muted fw-normal">(optional — JSON format)</small>
                        </label>
                        <textarea class="form-control font-monospace"
                                  @bind="customDataJson"
                                  rows="5"
                                  placeholder='{&#10;  "ConfirmationDate": "15 Jun 2025",&#10;  "Achievement": "Outstanding Q2 Performance"&#10;}'></textarea>
                        <div class="form-text">
                            Provide extra values for template placeholders not auto-filled.
                            Use <code>&#123;&#123;Key&#125;&#125;</code> syntax in your template.
                        </div>
                    </div>

                    <!-- Remarks -->
                    <div class="mb-4">
                        <label class="form-label fw-medium">Internal Remarks <small class="text-muted fw-normal">(not shown to employee)</small></label>
                        <textarea class="form-control" @bind="remarks" rows="2"></textarea>
                    </div>

                    <!-- Result message -->
                    @if (!string.IsNullOrEmpty(resultMessage))
                    {
                        <div class="alert @(isSuccess ? "alert-success" : "alert-danger") d-flex align-items-start gap-2 mb-4">
                            <span>@(isSuccess ? "✅" : "❌")</span>
                            <div>@resultMessage</div>
                        </div>
                    }

                    <!-- Actions -->
                    <div class="d-flex gap-2">
                        <button class="btn btn-primary flex-fill"
                                @onclick="GenerateDocument"
                                disabled="@isGenerating">
                            @if (isGenerating)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                            }
                            Generate from Template
                        </button>

                        <button class="btn btn-success flex-fill"
                                @onclick="GenerateWithAI"
                                disabled="@isGenerating">
                            @if (isGenerating)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                            }
                            ✨ Generate with AI
                        </button>
                    </div>

                </div>
            </div>
        </div>

        <!-- Right: Reference -->
        <div class="col-lg-5">

            <!-- Placeholder reference -->
            <div class="card shadow-sm border-0 mb-3">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="mb-0 fw-semibold">Available Placeholders</h6>
                </div>
                <div class="card-body small">
                    <p class="text-muted mb-2">These are always available in every template:</p>
                    <table class="table table-sm table-borderless mb-0">
                        <tbody>
                            @foreach (var (placeholder, description) in StandardPlaceholders)
                            {
                                <tr>
                                    <td class="py-1"><code class="text-primary">&#123;&#123;@placeholder&#125;&#125;</code></td>
                                    <td class="py-1 text-muted">@description</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Template preview — shows selected template's name/category -->
            @if (!string.IsNullOrEmpty(selectedTemplateId) && Guid.TryParse(selectedTemplateId, out var tId))
            {
                var selected = templates.FirstOrDefault(t => t.TemplateId == tId);
                if (selected != null)
                {
                    <div class="card shadow-sm border-0 border-start border-4 border-primary">
                        <div class="card-body py-3">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <div class="fw-semibold">@selected.Name</div>
                                    <small class="text-muted">@selected.Category</small>
                                </div>
                                @if (selected.RequiresAcknowledgment)
                                {
                                    <span class="badge bg-warning text-dark small">Requires Acknowledgment</span>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(selected.Description))
                            {
                                <p class="text-muted small mt-2 mb-0">@selected.Description</p>
                            }
                        </div>
                    </div>
                }
            }

        </div>

    </div>
}

@code {
    // ── State ──────────────────────────────────────────────────────────
    private List<OrgDocumentTemplate> templates = new();
    private List<Employee> eligibleEmployees = new();
    private List<AIDocumentSuggestion> aiSuggestions = new();

    private string selectedTemplateId = "";
    private string selectedEmployeeId = "";
    private string customDataJson = "";
    private string remarks = "";

    private bool isLoading = true;
    private bool isGenerating = false;
    private bool isOrgAdmin = false;
    private bool isSuccess = false;
    private string resultMessage = "";

    private ApplicationUser? _currentUser;
    private string _currentUserRole = "HR";

    // ── Standard placeholder reference ────────────────────────────────
    private static readonly (string Placeholder, string Description)[] StandardPlaceholders =
    {
        ("EmployeeName",     "Full name"),
        ("FirstName",        "First name"),
        ("LastName",         "Last name"),
        ("EmployeeCode",     "Employee ID"),
        ("Designation",      "Job title"),
        ("Department",       "Department name"),
        ("JoiningDate",      "Joining date"),
        ("CurrentDate",      "Today's date"),
        ("OrganizationName", "Company name"),
        ("GeneratedBy",      "Issuer's name"),
    };

    // ── Lifecycle ──────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        try
        {
            isLoading = true;
            _currentUser = await CurrentUserService.GetUserAsync();

            if (_currentUser?.OrganizationId == null)
            {
                ShowError("Your session has expired. Please log in again.");
                return;
            }

            isOrgAdmin = await CurrentUserService.IsInRoleAsync("OrgAdmin");
            _currentUserRole = isOrgAdmin ? "OrgAdmin" : "HR";

            templates = await DocumentService.GetAllTemplatesAsync(_currentUser.OrganizationId.Value);
            eligibleEmployees = await DocumentService.GetEligibleRecipientsForDocumentAsync(
                _currentUser.OrganizationId.Value, _currentUser.Id, _currentUserRole);
        }
        catch (Exception ex)
        {
            ShowError($"Error loading data: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    // ── Employee change handler ────────────────────────────────────────
    private async Task OnEmployeeChanged(ChangeEventArgs e)
    {
        selectedEmployeeId = e.Value?.ToString() ?? "";
        aiSuggestions.Clear();

        if (!string.IsNullOrEmpty(selectedEmployeeId) && Guid.TryParse(selectedEmployeeId, out var empId))
        {
            try
            {
                aiSuggestions = await DocumentService.GetAIDocumentSuggestionsAsync(empId);
            }
            catch
            {
                // AI suggestions are non-critical; silently swallow errors.
                aiSuggestions = new();
            }
        }
    }

    // ── Suggestion quick-apply ────────────────────────────────────────
    private void ApplySuggestion(AIDocumentSuggestion suggestion)
    {
        var match = templates.FirstOrDefault(t => t.Name == suggestion.DocumentType);
        if (match == null)
        {
            ShowError($"Template '{suggestion.DocumentType}' not found. Please create it first.");
            return;
        }

        selectedTemplateId = match.TemplateId.ToString();

        if (suggestion.SuggestedData.Any())
            customDataJson = System.Text.Json.JsonSerializer.Serialize(
                suggestion.SuggestedData,
                new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
    }

    // ── Generate from template ────────────────────────────────────────
    private async Task GenerateDocument()
    {
        if (!ValidateForm()) return;

        isGenerating = true;
        resultMessage = "";

        try
        {
            var (customData, error) = ParseCustomData();
            if (error != null) { ShowError(error); return; }

            var dto = new OrgDocumentGenerationDto
            {
                TemplateId = Guid.Parse(selectedTemplateId),
                RecipientEmployeeId = Guid.Parse(selectedEmployeeId),
                CustomData = customData,
                Remarks = remarks.Trim(),
                SendEmailNotification = false
            };

            var result = await DocumentService.GenerateDocumentAsync(
                dto, _currentUser!.OrganizationId!.Value, _currentUser.Id, _currentUserRole);

            ShowSuccess($"Document '{result.DocumentTypeName}' issued to {result.EmployeeName} successfully.");
            ResetForm();
        }
        catch (Exception ex)
        {
            ShowError(ex.Message);
        }
        finally
        {
            isGenerating = false;
        }
    }

    // ── Generate with AI ─────────────────────────────────────────────
    private async Task GenerateWithAI()
    {
        if (!ValidateForm()) return;

        isGenerating = true;
        resultMessage = "";

        try
        {
            var (customData, error) = ParseCustomData();
            if (error != null) { ShowError(error); return; }

            var result = await DocumentService.GenerateDocumentWithAIAsync(
                Guid.Parse(selectedTemplateId),
                Guid.Parse(selectedEmployeeId),
                _currentUser!.Id,
                _currentUserRole,
                customData);

            ShowSuccess($"AI-generated document '{result.DocumentTypeName}' issued to {result.EmployeeName} successfully.");
            ResetForm();
        }
        catch (Exception ex)
        {
            ShowError(ex.Message);
        }
        finally
        {
            isGenerating = false;
        }
    }

    // ── Shared helpers ────────────────────────────────────────────────

    private bool ValidateForm()
    {
        if (string.IsNullOrEmpty(selectedTemplateId))
        {
            ShowError("Please select a document template.");
            return false;
        }
        if (string.IsNullOrEmpty(selectedEmployeeId))
        {
            ShowError("Please select an employee.");
            return false;
        }
        return true;
    }

    private (Dictionary<string, string>? data, string? error) ParseCustomData()
    {
        if (string.IsNullOrWhiteSpace(customDataJson))
            return (null, null);

        try
        {
            // Strip trailing commas before closing braces/brackets for forgiveness.
            var cleaned = System.Text.RegularExpressions.Regex.Replace(
                customDataJson.Trim(), @",(\s*[}\]])", "$1");

            var data = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, string>>(cleaned);
            return (data, null);
        }
        catch
        {
            return (null, "Custom data is not valid JSON. Example: { \"Key\": \"Value\" }");
        }
    }

    private void ResetForm()
    {
        selectedTemplateId = "";
        selectedEmployeeId = "";
        customDataJson = "";
        remarks = "";
        aiSuggestions.Clear();
    }

    private void ShowSuccess(string msg) { resultMessage = msg; isSuccess = true; }
    private void ShowError(string msg) { resultMessage = msg; isSuccess = false; }
}
