@page "/org/dashboard"
@rendermode InteractiveServer

@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize(Roles = "OrgAdmin")]

@inject OrgDashboardService DashboardService
@inject NavigationManager Nav

<PageTitle>Admin Dashboard | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-0">Organization Overview</h2>
            <p class="text-muted mb-0">Welcome back, Admin. Here is what's happening today.</p>
        </div>
        <div class="d-flex gap-2">
            @* Fixed the syntax error on line 22 by removing backslashes and ensuring proper lambda format *@
            <button class="btn btn-white border shadow-sm btn-sm py-2 px-3" @onclick='() => Nav.NavigateTo("/org/settings")'>
                <i class="bi bi-gear me-2"></i>SETTINGS
            </button>
        </div>
    </div>

    @if (data == null)
    {
        <div class="d-flex justify-content-center align-items-center" style="height: 300px;">
            <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;"></div>
        </div>
    }
    else
    {
        <div class="row g-4 mb-5">
            <div class="col-xl-3 col-md-6">
                <div class="card border-0 shadow-sm h-100 overflow-hidden">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0 bg-soft-primary p-3 rounded-3 me-3">
                                <i class="bi bi-people-fill text-primary fs-4"></i>
                            </div>
                            <div>
                                <h6 class="text-muted small fw-bold mb-1 uppercase-tracking">TOTAL WORKERS</h6>
                                <h3 class="fw-bold mb-0">@data.TotalEmployees</h3>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0 bg-soft-success p-3 rounded-3 me-3">
                                <i class="bi bi-person-check-fill text-success fs-4"></i>
                            </div>
                            <div>
                                <h6 class="text-muted small fw-bold mb-1 uppercase-tracking">ACTIVE STAFF</h6>
                                <h3 class="fw-bold mb-0">@data.ActiveEmployees</h3>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0 bg-soft-info p-3 rounded-3 me-3">
                                <i class="bi bi-shield-lock-fill text-info fs-4"></i>
                            </div>
                            <div>
                                <h6 class="text-muted small fw-bold mb-1 uppercase-tracking">HR MANAGERS</h6>
                                <h3 class="fw-bold mb-0">@data.TotalHR</h3>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0 bg-soft-warning p-3 rounded-3 me-3">
                                <i class="bi bi-building text-warning fs-4"></i>
                            </div>
                            <div>
                                <h6 class="text-muted small fw-bold mb-1 uppercase-tracking">DEPARTMENTS</h6>
                                <h3 class="fw-bold mb-0">@data.TotalDepartments</h3>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-8">
                <h6 class="fw-bold text-muted mb-3 uppercase-tracking ps-1">SYSTEM CONFIGURATION</h6>
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="card h-100 border-0 shadow-sm hover-card" @onclick="GoDepartments">
                            <div class="card-body p-4">
                                <i class="bi bi-diagram-3 fs-3 text-primary mb-3"></i>
                                <h5 class="fw-bold">Department Setup</h5>
                                <p class="text-muted small">Structure your organization by creating and auditing business units.</p>
                                <span class="text-primary small fw-bold">Open Management <i class="bi bi-arrow-right ms-1"></i></span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card h-100 border-0 shadow-sm hover-card" @onclick="GoDesignations">
                            <div class="card-body p-4">
                                <i class="bi bi-briefcase fs-3 text-primary mb-3"></i>
                                <h5 class="fw-bold">Job Roles</h5>
                                <p class="text-muted small">Configure designations and job titles for staff.</p>
                                <span class="text-primary small fw-bold">Open Management <i class="bi bi-arrow-right ms-1"></i></span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-12">
                        <div class="card border-0 shadow-sm hover-card" @onclick="GoEmployees">
                            <div class="card-body p-4 d-flex align-items-center">
                                <div class="me-4">
                                    <i class="bi bi-people fs-1 text-primary"></i>
                                </div>
                                <div>
                                    <h5 class="fw-bold mb-1">Employee Directory</h5>
                                    <p class="text-muted small mb-0">View centralized records and profile management for all personnel.</p>
                                </div>
                                <div class="ms-auto text-primary">
                                    <i class="bi bi-chevron-right fs-4"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <h6 class="fw-bold text-muted mb-3 uppercase-tracking ps-1">QUICK ACTIONS</h6>
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-3">
                        <button class="btn btn-light w-100 text-start py-3 mb-2 border-0 ps-3" @onclick='() => Nav.NavigateTo("/org/add-hr")'>
                            <i class="bi bi-person-plus me-3 text-primary"></i> Onboard HR Manager
                        </button>
                        <button class="btn btn-light w-100 text-start py-3 mb-2 border-0 ps-3" @onclick='() => Nav.NavigateTo("/org/create-department")'>
                            <i class="bi bi-plus-square me-3 text-primary"></i> New Department
                        </button>
                        <button class="btn btn-light w-100 text-start py-3 border-0 ps-3" @onclick='() => Nav.NavigateTo("/org/add-employee")'>
                            <i class="bi bi-person-badge me-3 text-primary"></i> Add Employee
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .bg-soft-primary {
        background-color: rgba(92, 74, 199, 0.1);
    }

    .bg-soft-success {
        background-color: rgba(25, 135, 84, 0.1);
    }

    .bg-soft-info {
        background-color: rgba(13, 202, 240, 0.1);
    }

    .bg-soft-warning {
        background-color: rgba(255, 193, 7, 0.1);
    }

    .uppercase-tracking {
        text-transform: uppercase;
        letter-spacing: 1px;
        font-size: 0.75rem;
    }

    .hover-card {
        cursor: pointer;
        transition: all 0.2s ease-in-out;
    }

        .hover-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 1rem 3rem rgba(0,0,0,.1) !important;
        }

    .btn-white {
        background: white;
        color: #333;
    }

    .text-primary {
        color: #5c4ac7 !important;
    }
</style>

@code {
    private OrgDashboardDto? data;

    protected override async Task OnInitializedAsync()
    {
        data = await DashboardService.GetDashboardDataAsync();
    }

    void GoDepartments() => Nav.NavigateTo("/org/departments");
    void GoDesignations() => Nav.NavigateTo("/org/designations");
    void GoEmployees() => Nav.NavigateTo("/org/employees");
}