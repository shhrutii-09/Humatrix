@page "/admin/shifts"
@rendermode InteractiveServer
@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "OrgAdmin")]
@inject ShiftService ShiftService
@inject NavigationManager Nav

<PageTitle>Shift Management | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom row-gap-3 flex-wrap">
        <div>
            <h2 class="fw-bold tracking-tight text-dark mb-1">Shift Management</h2>
            <p class="text-muted small mb-0">Configure corporate work schedules, operational parameters, grace windows, and daily attendance rules.</p>
        </div>
        <button class="btn btn-interactive-back shadow-sm" @onclick="GoToDashboard">
            DASHBOARD
        </button>
    </div>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert @(isError ? "alert-premium-danger" : "alert-premium-success") alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
            <i class="bi @(isError ? "bi-exclamation-triangle-fill" : "bi-check-circle-fill") me-2 fs-5"></i>
            <span class="small fw-medium">@message</span>
            <button type="button" class="btn-close shadow-none" @onclick="() => message = null"></button>
        </div>
    }

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 stat-panel-card">
                <div class="card-body py-3 d-flex align-items-center gap-3">
                    <div class="stat-icon-wrapper bg-soft-primary text-primary">
                        <i class="bi bi-layers-half"></i>
                    </div>
                    <div>
                        <small class="text-secondary small fw-bold tracking-wider text-uppercase d-block mb-1">Total Shifts</small>
                        <h3 class="mb-0 fw-bold text-dark">@shifts.Count</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm border-0 stat-panel-card">
                <div class="card-body py-3 d-flex align-items-center gap-3">
                    <div class="stat-icon-wrapper bg-soft-info text-info">
                        <i class="bi bi-clock-history"></i>
                    </div>
                    <div>
                        <small class="text-secondary small fw-bold tracking-wider text-uppercase d-block mb-1">Standard Full Day</small>
                        <h3 class="mb-0 fw-bold text-dark">
                            @(shifts.FirstOrDefault()?.MinimumHoursForFullDay ?? 0) <span class="fs-6 text-muted fw-normal">Hrs</span>
                        </h3>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm form-container-card mb-4" style="border-left: 4px solid @(isEditing ? "#ffc107" : "#5c4ac7") !important;">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="mb-0 fw-bold text-dark tracking-tight">
                    @(isEditing ? "Edit Shift Configuration" : "Configure New Shift Profile")
                </h5>
                @if (isEditing)
                {
                    <button class="btn btn-sm btn-action-cancel px-3" @onclick="CancelEdit">
                        <i class="bi bi-x-circle me-1"></i> Cancel Edit
                    </button>
                }
            </div>

            <EditForm Model="shiftModel" OnValidSubmit="HandleSubmit" FormName="ShiftForm">
                <DataAnnotationsValidator />

                <div class="row g-3 mb-4">
                    <div class="col-xl-3 col-md-6">
                        <label class="form-label-custom">Shift Profile Name</label>
                        <InputText @bind-Value="shiftModel.Name" class="form-control premium-form-input" placeholder="e.g. Standard Morning Shift" />
                        <ValidationMessage For="@(() => shiftModel.Name)" class="text-danger small mt-1 d-block" />
                    </div>
                    <div class="col-xl-3 col-md-6">
                        <label class="form-label-custom">Shift Start Time</label>
                        <input type="time" @bind="startTime" class="form-control premium-form-input" />
                    </div>
                    <div class="col-xl-3 col-md-6">
                        <label class="form-label-custom">Shift End Time</label>
                        <input type="time" @bind="endTime" class="form-control premium-form-input" />
                    </div>
                    <div class="col-xl-3 col-md-6">
                        <label class="form-label-custom">Late Grace Window (Minutes)</label>
                        <InputNumber @bind-Value="shiftModel.LateAllowanceMinutes" class="form-control premium-form-input" />
                        <ValidationMessage For="@(() => shiftModel.LateAllowanceMinutes)" class="text-danger small mt-1 d-block" />
                    </div>
                </div>

                <div class="row g-3 align-items-end">
                    <div class="col-xl-3 col-md-6">
                        <label class="form-label-custom">Full Day Compliance Threshold (Hrs)</label>
                        <InputNumber @bind-Value="shiftModel.MinimumHoursForFullDay" class="form-control premium-form-input" step="0.5" />
                        <ValidationMessage For="@(() => shiftModel.MinimumHoursForFullDay)" class="text-danger small mt-1 d-block" />
                    </div>
                    <div class="col-xl-3 col-md-6">
                        <label class="form-label-custom">Half Day Compliance Threshold (Hrs)</label>
                        <InputNumber @bind-Value="shiftModel.MinimumHoursForHalfDay" class="form-control premium-form-input" step="0.5" />
                        <ValidationMessage For="@(() => shiftModel.MinimumHoursForHalfDay)" class="text-danger small mt-1 d-block" />
                    </div>
                    <div class="col-xl-6 col-md-12 text-end">
                        <button type="submit" class="btn @(isEditing ? "btn-warning-premium" : "btn-primary-premium") px-5 shadow-sm">
                            <i class="bi @(isEditing ? "bi-check-circle-fill" : "bi-plus-circle-fill") me-2"></i>
                            @(isEditing ? "UPDATE SHIFT METRICS" : "SAVE SHIFT CONFIGURATION")
                        </button>
                    </div>
                </div>
            </EditForm>
        </div>
    </div>

    <div class="card border-0 shadow-sm panel-container-card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4 text-secondary small fw-bold tracking-wider py-3">SHIFT NAME</th>
                        <th class="text-secondary small fw-bold tracking-wider py-3">TIMING WINDOW</th>
                        <th class="text-secondary small fw-bold tracking-wider py-3 text-center">GRACE PERIOD</th>
                        <th class="text-secondary small fw-bold tracking-wider py-3 text-center">FULL DAY REQ.</th>
                        <th class="text-secondary small fw-bold tracking-wider py-3 text-center">HALF DAY REQ.</th>
                        <th class="text-secondary small fw-bold tracking-wider py-3 text-end pe-4" style="width: 140px;">ACTIONS</th>
                    </tr>
                </thead>
                <tbody>
                    @if (shifts == null || !shifts.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <div class="fs-2 text-light mb-2"><i class="bi bi-clock"></i></div>
                                <span class="fw-medium">No shifts defined or active in the corporate registry.</span>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var shift in shifts)
                        {
                            <tr class="table-row-interactive @(editingShiftId == shift.ShiftId ? "table-active-edit" : "")">
                                <td class="ps-4">
                                    <span class="fw-bold text-dark text-heading-field">@shift.Name</span>
                                </td>
                                <td>
                                    <span class="badge premium-soft-timing-badge">
                                        <i class="bi bi-clock me-1 small"></i>
                                        @DateTime.Today.Add(shift.StartTime).ToString("hh:mm tt")
                                        <span class="mx-1 text-secondary opacity-50">•</span>
                                        @DateTime.Today.Add(shift.EndTime).ToString("hh:mm tt")
                                    </span>
                                </td>
                                <td class="text-center">
                                    <span class="text-dark fw-medium small">@shift.LateAllowanceMinutes <span class="text-muted text-lowercase">mins</span></span>
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-light text-secondary border fw-medium px-3 py-1.5 rounded-3">@shift.MinimumHoursForFullDay hrs</span>
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-light text-secondary border fw-medium px-3 py-1.5 rounded-3">@shift.MinimumHoursForHalfDay hrs</span>
                                </td>
                                <td class="text-end pe-4">
                                    <button class="btn btn-sm btn-action-edit" title="Edit Shift Parameters" @onclick="() => StartEdit(shift)">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    /* Framework Design Tokens */
    .tracking-tight {
        letter-spacing: -0.025em;
    }

    .tracking-wider {
        letter-spacing: 0.05em;
        font-size: 11px !important;
    }

    .panel-container-card, .form-container-card {
        border-radius: 14px;
        background-color: #ffffff;
        overflow: hidden;
    }

    .stat-panel-card {
        border-radius: 12px;
        background-color: #ffffff;
    }

    /* Minimalist Decorative Indicators */
    .stat-icon-wrapper {
        width: 44px;
        height: 44px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
    }

    .bg-soft-primary {
        background-color: rgba(92, 74, 199, 0.08);
    }

    .bg-soft-info {
        background-color: rgba(13, 202, 240, 0.12);
    }

    /* Core Data Presentation Grids */
    .table thead th {
        background-color: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
    }

    .table-row-interactive {
        transition: background-color 0.15s ease;
    }

        .table-row-interactive:hover {
            background-color: #f8fafc;
        }

    .text-heading-field {
        font-size: 14px;
        color: #1e293b !important;
    }

    /* Soft Structural Timing Ribbon */
    .premium-soft-timing-badge {
        background-color: rgba(92, 74, 199, 0.06) !important;
        color: #5c4ac7 !important;
        font-size: 12px !important;
        font-weight: 600 !important;
        padding: 6px 12px !important;
        border-radius: 8px !important;
        border: 1px solid rgba(92, 74, 199, 0.1);
    }

    /* Premium Typography Form Inputs */
    .form-label-custom {
        font-size: 11px;
        font-weight: 700;
        color: #475569;
        text-transform: uppercase;
        letter-spacing: 0.03em;
        margin-bottom: 0.5rem;
        display: block;
    }

    .premium-form-input {
        font-size: 14px;
        padding: 9px 12px;
        border-radius: 10px;
        border: 1px solid #cbd5e1;
        background-color: #f8fafc !important;
        color: #1e293b;
        transition: all 0.2s ease;
    }

        .premium-form-input:focus {
            border-color: #5c4ac7 !important;
            background-color: #ffffff !important;
            box-shadow: 0 0 0 4px rgba(92, 74, 199, 0.12) !important;
        }

    /* Navigation Action Triggers */
    .btn-interactive-back {
        background: #ffffff !important;
        border: 1px solid #e5e7eb !important;
        color: #4b5563 !important;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
        transition: all 0.2s ease;
    }

        .btn-interactive-back:hover {
            background-color: #f8fafc !important;
            border-color: #5c4ac7 !important;
            color: #5c4ac7 !important;
            transform: translateY(-1px);
        }

    /* Operation Actions Buttons Configuration */
    .btn-primary-premium {
        background-color: #5c4ac7 !important;
        color: #ffffff !important;
        border: none !important;
        padding: 10px 24px;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 0.02em;
        transition: all 0.2s ease;
    }

        .btn-primary-premium:hover {
            background-color: #4b3ba6 !important;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(92, 74, 199, 0.2) !important;
        }

    .btn-warning-premium {
        background-color: #ffc107 !important;
        color: #000000 !important;
        border: none !important;
        padding: 10px 24px;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 0.02em;
        transition: all 0.2s ease;
    }

        .btn-warning-premium:hover {
            background-color: #e0a800 !important;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(255, 193, 7, 0.2) !important;
        }

    .btn-action-edit {
        background: #f1f5f9;
        border: 1px solid #e2e8f0;
        color: #475569;
        border-radius: 8px;
        padding: 6px 12px;
        transition: all 0.15s ease;
    }

        .btn-action-edit:hover {
            background: rgba(92, 74, 199, 0.08);
            border-color: rgba(92, 74, 199, 0.25);
            color: #5c4ac7;
        }

    .btn-action-cancel {
        background-color: #ffffff;
        color: #475569;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        font-size: 12.5px;
        font-weight: 500;
        padding: 5px 12px;
        transition: all 0.15s ease;
    }

        .btn-action-cancel:hover {
            background-color: #f1f5f9;
            color: #1e293b;
        }

    .table-active-edit {
        background-color: rgba(255, 193, 7, 0.04) !important;
    }

    /* System Status Alerts Styling */
    .alert-premium-success {
        background-color: #ecfdf5;
        color: #065f46;
        border-left: 4px solid #10b981 !important;
        border-radius: 8px;
    }

    .alert-premium-danger {
        background-color: #fef2f2;
        color: #991b1b;
        border-left: 4px solid #ef4444 !important;
        border-radius: 8px;
    }
</style>

@code {
    private List<Shift> shifts = new();
    private Shift shiftModel = new();

    private bool isEditing = false;
    private Guid? editingShiftId = null;

    private DateTime startTime = DateTime.Today.AddHours(9);
    private DateTime endTime = DateTime.Today.AddHours(18);

    private string? message;
    private bool isError;

    protected override async Task OnInitializedAsync()
    {
        await LoadShifts();
    }

    private async Task LoadShifts()
    {
        var rawShifts = await ShiftService.GetAllShiftsAsync();
        if (rawShifts != null)
        {
            // Reverse ordering collection array chain to execute pure LIFO data stream rendering (Newest First)
            shifts = rawShifts.AsEnumerable().Reverse().ToList();
        }
    }

    // Direct Route Rule back to primary administrative tracking workspace
    private void GoToDashboard() => Nav.NavigateTo("/org/dashboard");

    private void StartEdit(Shift shift)
    {
        isEditing = true;
        editingShiftId = shift.ShiftId;

        shiftModel = new Shift
        {
            Name = shift.Name,
            LateAllowanceMinutes = shift.LateAllowanceMinutes,
            MinimumHoursForFullDay = shift.MinimumHoursForFullDay,
            MinimumHoursForHalfDay = shift.MinimumHoursForHalfDay
        };

        startTime = DateTime.Today.Add(shift.StartTime);
        endTime = DateTime.Today.Add(shift.EndTime);
        message = null;
    }

    private void CancelEdit()
    {
        isEditing = false;
        editingShiftId = null;
        shiftModel = new Shift();
        startTime = DateTime.Today.AddHours(9);
        endTime = DateTime.Today.AddHours(18);
    }

    private async Task HandleSubmit()
    {
        try
        {
            isError = false;
            message = "";

            shiftModel.StartTime = startTime.TimeOfDay;
            shiftModel.EndTime = endTime.TimeOfDay;

            if (isEditing && editingShiftId.HasValue)
            {
                await ShiftService.UpdateShiftAsync(editingShiftId.Value, shiftModel);
                message = "Shift profile parameters updated successfully.";
            }
            else
            {
                await ShiftService.CreateShiftAsync(shiftModel);
                message = "New shift profile registered successfully.";
            }

            CancelEdit();
            await LoadShifts();
        }
        catch (Exception ex)
        {
            isError = true;
            message = ex.Message;
        }
    }
}