@page "/org/employees"
@page "/hr/employees"
@rendermode InteractiveServer

@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Data
@using Humatrix_HRMS.Services
@using Humatrix_HRMS.Models
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity

@attribute [Authorize(Roles = "OrgAdmin,HR")]

@inject EmployeeService EmployeeService
@inject DepartmentService DeptService
@inject DesignationService DesignationService
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider

<h3>@(isHR ? "Add Employee (HR)" : "Add Employee / HR")</h3>

<div class="card p-4 shadow-sm">
    <EditForm Model="model" OnValidSubmit="CreateEmployee" FormName="CreateEmployeeForm">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-2">
            <label>First Name</label>
            <InputText @bind-Value="model.FirstName" class="form-control" placeholder="First Name" />
        </div>
        <div class="mb-2">
            <label>Last Name</label>
            <InputText @bind-Value="model.LastName" class="form-control" placeholder="Last Name" />
        </div>
        <div class="mb-2">
            <label>Email</label>
            <InputText @bind-Value="model.Email" class="form-control" placeholder="Email" />
        </div>

        <div class="mb-2">
            <label>Department</label>
            @if (!isHR)
            {
                <select class="form-control" value="@model.DepartmentId" @onchange="OnDepartmentChanged">
                    <option value="">-- Select Department --</option>
                    @foreach (var dept in departments)
                    {
                        <option value="@dept.DepartmentId">@dept.Name</option>
                    }
                </select>
            }
            else
            {
                <input class="form-control" value="@hrDepartmentName" readonly />
            }
        </div>

        <div class="mb-2">
            <label>Designation</label>
            @* 2. Ensure the InputSelect is enabled only when a department is selected *@
            <InputSelect TValue="Guid?" @bind-Value="model.DesignationId" class="form-control" disabled="@(model.DepartmentId == null)">
                <option value="">-- Select Designation --</option>
                @if (designations != null)
                {
                    @foreach (var d in designations)
                    {
                        <option value="@d.DesignationId">@d.Name</option>
                    }
                }
            </InputSelect>
        </div>

        @if (!isHR)
        {
            <div class="mb-3">
                <label>Role</label>
                <InputSelect @bind-Value="model.Role" class="form-control">
                    <option value="Employee">Employee</option>
                    <option value="HR">HR</option>
                </InputSelect>
            </div>
        }

        <button type="submit" class="btn btn-success" disabled="@isSubmitting">
            @(isSubmitting ? "Creating..." : "Create & Generate Link")
        </button>
    </EditForm>
</div>

@if (!string.IsNullOrEmpty(link))
{
    <div class="alert alert-info mt-3">
        <strong>Invite Link:</strong>
        <input class="form-control" value="@link" readonly />
    </div>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-3">@errorMessage</div>
}

@code {
    private CreateEmployeeDto model = new() { Role = "Employee" };
    private List<DepartmentDto> departments = new();
    private List<DesignationDto> designations = new();

    private bool isHR = false;
    private bool isSubmitting = false;
    private string? link;
    private string? errorMessage;
    private string? hrDepartmentName;

    protected override async Task OnInitializedAsync()
    {
        departments = await DeptService.GetAllAsync();

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);

        if (user == null) return;

        var roles = await UserManager.GetRolesAsync(user);
        isHR = roles.Contains("HR");

        if (isHR && user.DepartmentId.HasValue)
        {
            model.DepartmentId = user.DepartmentId;
            hrDepartmentName = departments.FirstOrDefault(d => d.DepartmentId == user.DepartmentId)?.Name;

            designations = await DesignationService.GetByDepartmentAsync(user.DepartmentId.Value);
        }
    }


    private async Task OnDepartmentChanged(ChangeEventArgs e)
    {
        var selectedValue = e.Value?.ToString();

        if (Guid.TryParse(selectedValue, out var deptId))
        {
            model.DepartmentId = deptId;
            model.DesignationId = null;

            designations = await DesignationService.GetByDepartmentAsync(deptId);
        }
        else
        {
            designations.Clear();
            model.DepartmentId = null;
            model.DesignationId = null;
        }

        StateHasChanged();
    }
    private async Task CreateEmployee()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            link = await EmployeeService.CreateEmployeeAsync(model);

            model = new() { Role = "Employee" };

            if (isHR)
            {
                var authState = await AuthStateProvider.GetAuthenticationStateAsync();
                var user = await UserManager.GetUserAsync(authState.User);
                model.DepartmentId = user?.DepartmentId;
            }
            else
            {
                designations.Clear();
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }
}