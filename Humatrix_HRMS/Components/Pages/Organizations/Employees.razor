@page "/org/employees"
@page "/hr/employees"

@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Data
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity

@attribute [Authorize(Roles = "OrgAdmin,HR")]

@inject EmployeeService EmployeeService
@inject DepartmentService DeptService
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider

<h3>@(isHR ? "Create Employee (HR)" : "Create Employee / HR (Org Admin)")</h3>

<div class="card p-4 shadow-sm">

    <EditForm Model="model" OnValidSubmit="CreateEmployee" FormName="empForm">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <InputText @bind-Value="model.FirstName" placeholder="First Name" class="form-control mb-2" />
        <InputText @bind-Value="model.LastName" placeholder="Last Name" class="form-control mb-2" />
        <InputText @bind-Value="model.Email" placeholder="Email" class="form-control mb-2" />

        <!-- Department -->
        @* <InputSelect @bind-Value="model.DepartmentId" class="form-control mb-2">
            <option value="">-- Select Department --</option>
            @foreach (var dept in departments)
            {
                <option value="@dept.DepartmentId">@dept.Name</option>
            }
        </InputSelect> *@
        @if (!isHR)
        {
            <label class="form-label">Department</label>
            <InputSelect @bind-Value="model.DepartmentId" class="form-control mb-2">
                <option value="">-- Select Department --</option>
                @foreach (var dept in departments)
                {
                    <option value="@dept.DepartmentId">@dept.Name</option>
                }
            </InputSelect>
        }

        else
        {
            <div class="mb-2">
                <label class="form-label">Department</label>
                <input class="form-control" value="@hrDepartmentName" readonly />
                <small class="text-muted">You can only add employees to your own department.</small>
            </div>
        }

        <!-- Role (Only for OrgAdmin) -->
        @if (!isHR)
        {
            <InputSelect @bind-Value="model.Role" class="form-control mb-2">
                <option value="Employee">Employee</option>
                <option value="HR">HR</option>
            </InputSelect>
        }

        <button class="btn btn-success" disabled="@isSubmitting">
            @(isSubmitting ? "Creating..." : "Create & Generate Link")
        </button>
    </EditForm>

</div>

@if (!string.IsNullOrEmpty(link))
{
    <div class="alert alert-info mt-3">
        <p>Send this link:</p>
        <input class="form-control" value="@link" readonly />
    </div>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-3">
        @errorMessage
    </div>
}

@code {
    [SupplyParameterFromForm]
    public CreateEmployeeDto model { get; set; } = new()
    {
        Role = "Employee"
    };

    private List<DepartmentDto> departments = new();
    private string? link;
    private bool isHR = false;
    private bool isSubmitting = false;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        departments = await DeptService.GetAllAsync();

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);
        var roles = await UserManager.GetRolesAsync(user);

        isHR = roles.Contains("HR");

        if (isHR && user != null)
        {
            model.DepartmentId = user.DepartmentId;
            hrDepartmentName = departments.FirstOrDefault(d => d.DepartmentId == user.DepartmentId)?.Name;
        }
    }

    private async Task CreateEmployee()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            if (isHR)
            {
                model.Role = "Employee"; // 🔥 Force for HR
            }

            link = await EmployeeService.CreateEmployeeAsync(model);

            model = new() { Role = "Employee" };
        }
        catch (Exception ex)
        {
            errorMessage = "Something went wrong. Please try again.";
        }
        finally
        {
            isSubmitting = false;
        }
    }


    private string? hrDepartmentName;

    // protected override async Task OnInitializedAsync()
    // {
    //     departments = await DeptService.GetAllAsync();

    //     var authState = await AuthStateProvider.GetAuthenticationStateAsync();
    //     var user = await UserManager.GetUserAsync(authState.User);
    //     var roles = await UserManager.GetRolesAsync(user);

    //     isHR = roles.Contains("HR");

    //     If HR, pre-set the department model and get the name for the UI
        
    // }
}