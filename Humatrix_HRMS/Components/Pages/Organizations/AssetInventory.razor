@page "/assets"

@attribute [Authorize(Roles = "OrgAdmin,HR")]

@rendermode InteractiveServer

@using Humatrix_HRMS.DTOs.Asset
@using Humatrix_HRMS.Infrastructure.Constants
@using Humatrix_HRMS.Infrastructure.Services
@using Humatrix_HRMS.Models
@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization

@inject AssetService AssetService
@inject CurrentUserService CurrentUser
@inject NavigationManager Nav

<PageTitle>Assets</PageTitle>

<div class="container-fluid py-4 px-4">

    <!-- PAGE HEADER -->

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h3 class="fw-bold mb-1">
                Asset Inventory
            </h3>

            <p class="text-muted mb-0">
                Manage organization assets, assignments and lifecycle.
            </p>
        </div>

        <div class="d-flex gap-2">

            @if (_isOrgAdmin)
            {
                <button class="btn btn-primary"
                        @onclick="OpenCreateAsset">

                    <i class="bi bi-plus-lg me-2"></i>
                    Add Asset
                </button>
            }

            <button class="btn btn-outline-secondary">

                <i class="bi bi-download me-2"></i>
                Export

            </button>

        </div>

    </div>

    <!-- ALERTS -->
    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger alert-dismissible fade show">

            @_error

            <button class="btn-close"
                    @onclick="(() => _error = null)">
            </button>

        </div>
    }

    <!-- FILTER CARD -->

    <div class="card border-0 shadow-sm mb-4">

        <div class="card-body">

            <div class="row g-3">

                <!-- SEARCH -->

                <div class="col-md-4">

                    <label class="form-label small fw-semibold">
                        Search
                    </label>

                    <input type="text"
                           class="form-control"
                           placeholder="Search asset name, code, brand..."
                           @bind="_filter.SearchTerm"
                           @bind:event="oninput" />

                </div>

                <!-- STATUS -->

                <div class="col-md-2">

                    <label class="form-label small fw-semibold">
                        Status
                    </label>

                    <select class="form-select"
                            @bind="_filter.Status">

                        <option value="">All</option>

                        @foreach (var status in AssetStatuses.All)
                        {
                            <option value="@status">
                                @status
                            </option>
                        }

                    </select>

                </div>

                <!-- CATEGORY -->

                <div class="col-md-2">

                    <label class="form-label small fw-semibold">
                        Category
                    </label>

                    <select class="form-select"
                            @bind="_filter.Category">

                        <option value="">All</option>

                        @foreach (var category in AssetCategories.All)
                        {
                            <option value="@category">
                                @category
                            </option>
                        }

                    </select>

                </div>

                <!-- FILTER ACTIONS -->

                <div class="col-md-4 d-flex align-items-end gap-2">

                    <button class="btn btn-primary"
                            @onclick="ApplyFilters">

                        Apply Filters

                    </button>

                    <button class="btn btn-outline-secondary"
                            @onclick="ClearFilters">

                        Reset

                    </button>

                </div>

            </div>

        </div>

    </div>

    <!-- TABLE CARD -->

    <div class="card border-0 shadow-sm">

        <div class="card-body p-0">

            @if (_loading)
            {
                <div class="text-center py-5">

                    <div class="spinner-border text-primary"></div>

                </div>
            }
            else if (!_assets.Items.Any())
            {
                <div class="text-center py-5">

                    <i class="bi bi-inbox fs-1 text-muted"></i>

                    <h5 class="mt-3">
                        No Assets Found
                    </h5>

                    <p class="text-muted">
                        Try changing filters or add a new asset.
                    </p>

                </div>
            }
            else
            {
                <div class="table-responsive">

                    <table class="table table-hover align-middle mb-0">

                        <thead class="table-light">

                            <tr>

                                <th>Code</th>
                                <th>Asset</th>
                                <th>Category</th>
                                <th>Status</th>
                                <th>Assigned To</th>
                                <th>Warranty</th>
                                <th class="text-end">Actions</th>

                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var asset in _assets.Items)
                            {
                                <tr>

                                    <td>
                                        <code>
                                            @asset.AssetCode
                                        </code>
                                    </td>

                                    <td>

                                        <div class="fw-semibold">
                                            @asset.AssetName
                                        </div>

                                        <small class="text-muted">

                                            @asset.Brand
                                            @asset.Model

                                        </small>

                                    </td>

                                    <td>
                                        @asset.Category
                                    </td>

                                    <td>

                                        @RenderStatus(asset.Status)

                                    </td>

                                    <td>

                                        @if (!string.IsNullOrWhiteSpace(asset.CurrentEmployeeName))
                                        {
                                            <div>
                                                @asset.CurrentEmployeeName
                                            </div>

                                            <small class="text-muted">
                                                @asset.CurrentEmployeeCode
                                            </small>
                                        }
                                        else
                                        {
                                            <span class="text-muted">
                                                —
                                            </span>
                                        }

                                    </td>

                                    <td>

                                        @if (asset.WarrantyExpiry.HasValue)
                                        {
                                            @asset.WarrantyExpiry.Value.ToString("dd MMM yyyy")
                                        }
                                        else
                                        {
                                            <span class="text-muted">
                                                —
                                            </span>
                                        }

                                    </td>

                                    <td class="text-end">

                                        <button class="btn btn-sm btn-outline-primary"
                                                @onclick="(() => ViewDetails(asset.AssetId))">

                                            View

                                        </button>

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>

                <!-- PAGINATION -->

                <div class="d-flex justify-content-between align-items-center p-3 border-top">

                    <small class="text-muted">

                        Showing
                        @((_assets.Page - 1) * _assets.PageSize + 1)

                        to

                        @Math.Min(_assets.Page * _assets.PageSize, _assets.TotalCount)

                        of

                        @_assets.TotalCount records

                    </small>

                    <div class="btn-group">

                        <button class="btn btn-outline-secondary"
                                disabled="@(!_assets.HasPreviousPage)"
                                @onclick="PrevPage">

                            Previous

                        </button>

                        <button class="btn btn-outline-secondary"
                                disabled="@(!_assets.HasNextPage)"
                                @onclick="NextPage">

                            Next

                        </button>

                    </div>

                </div>
            }

        </div>

    </div>

</div>

@code {

    private PagedResult<AssetDto> _assets = new();

    private AssetFilterDto _filter = new()
    {
        Page = 1,
        PageSize = 10
    };

    private bool _loading = true;

    private string? _error;

    private bool _isOrgAdmin;

    private Guid? _departmentId;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _isOrgAdmin =
                await CurrentUser.IsInRoleAsync("OrgAdmin");

            var user =
                await CurrentUser.GetUserAsync();

            _filter.OrganizationId =
                user?.OrganizationId ?? Guid.Empty;

            await LoadAssets();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task LoadAssets()
    {
        _loading = true;

        try
        {
            _assets = await AssetService.GetAssetsAsync(
                _filter,
                _isOrgAdmin ? "OrgAdmin" : "HR",
                _departmentId);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }

        _loading = false;
    }

    private async Task ApplyFilters()
    {
        _filter.Page = 1;

        await LoadAssets();
    }

    private async Task ClearFilters()
    {
        _filter = new AssetFilterDto
        {
            OrganizationId = _filter.OrganizationId,
            Page = 1,
            PageSize = 10
        };

        await LoadAssets();
    }

    private async Task NextPage()
    {
        _filter.Page++;

        await LoadAssets();
    }

    private async Task PrevPage()
    {
        _filter.Page--;

        await LoadAssets();
    }

    private void OpenCreateAsset()
    {

    }

    private void ViewDetails(Guid assetId)
    {
        Nav.NavigateTo($"/assets/details/{assetId}");
    }

    private MarkupString RenderStatus(string status)
    {
        return status switch
        {
            "Available" => new MarkupString("<span class='badge bg-success'>Available</span>"),

            "Assigned" => new MarkupString("<span class='badge bg-primary'>Assigned</span>"),

            "In Repair" => new MarkupString("<span class='badge bg-warning text-dark'>In Repair</span>"),

            "Retired" => new MarkupString("<span class='badge bg-secondary'>Retired</span>"),

            _ => new MarkupString($"<span class='badge bg-light text-dark'>{status}</span>")
        };
    }

}