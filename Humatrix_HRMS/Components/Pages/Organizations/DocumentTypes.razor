@page "/org/document-types"
@rendermode InteractiveServer

@using Humatrix_HRMS.Models.Documents
@using Humatrix_HRMS.Services
@using Humatrix_HRMS.Services.Documents
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize(Roles = "OrgAdmin")]

@inject IDocumentTypeService DocumentTypeService
@inject CurrentUserService CurrentUserService
@inject NavigationManager Nav

<PageTitle>Document Types | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <h2 class="fw-bold">Document Types</h2>
            <p class="text-muted small mb-0">
                Configure employee document requirements.
            </p>
        </div>

        <button class="btn btn-secondary"
                @onclick="GoBack">
            Dashboard
        </button>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">

            <h5 class="mb-3">Add / Edit Document Type</h5>

            <div class="row g-3">

                <div class="col-md-4">
                    <InputText class="form-control"
                               @bind-Value="newType.Name"
                               placeholder="Document Name" />
                </div>

                <div class="col-md-3">
                    <InputSelect class="form-select"
                                 @bind-Value="newType.Category">
                        <option value="Personal">Personal</option>
                        <option value="Organization">Organization</option>
                        <option value="Compliance">Compliance</option>
                    </InputSelect>
                </div>

                <div class="col-md-3">
                    <InputText class="form-control"
                               @bind-Value="newType.Description"
                               placeholder="Description" />
                </div>

                <div class="col-md-2">
                    <button class="btn btn-primary w-100"
                            @onclick="CreateDocumentType">
                        @(newType.DocumentTypeId == Guid.Empty ? "Add" : "Update")
                    </button>
                </div>

            </div>

            <div class="row mt-3 align-items-center">

                <div class="col-md-3">
                    <div class="form-check">
                        <InputCheckbox class="form-check-input"
                                       @bind-Value="newType.IsMandatory"
                                       id="chkMandatory" />
                        <label class="form-check-label" for="chkMandatory">
                            Mandatory
                        </label>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="form-check">
                        <InputCheckbox class="form-check-input"
                                       @bind-Value="newType.RequiresVerification"
                                       id="chkVerification" />
                        <label class="form-check-label" for="chkVerification">
                            Verification Required
                        </label>
                    </div>
                </div>

                @* INTEGRATED CLAUDE'S TOGGLE OPTION HERE *@
                <div class="col-md-4">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox"
                               @bind="newType.IsOrganizationGenerated"
                               id="chkOrgGenerated" />
                        <label class="form-check-label" for="chkOrgGenerated">
                            Organisation-Generated
                            <small class="text-muted d-block" style="font-size: 0.75rem;">
                                Only HR/OrgAdmin can issue this type — employees cannot upload it.
                            </small>
                        </label>
                    </div>
                </div>

            </div>

        </div>
    </div>

    <div class="mb-3">
        <input class="form-control"
               placeholder="Search document type..."
               @bind="SearchText" />
    </div>

    <div class="card shadow-sm border-0">

        <div class="table-responsive">

            <table class="table table-hover align-middle">

                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Mandatory</th>
                        <th>Verification</th>
                        <th>Org-Generated</th>
                        <th>Status</th>
                        <th style="width:180px;">Actions</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in FilteredDocumentTypes)
                    {
                        <tr>
                            <td>@item.Name</td>
                            <td>@item.Category</td>

                            <td>
                                @(item.IsMandatory ? "Yes" : "No")
                            </td>

                            <td>
                                @(item.RequiresVerification ? "Yes" : "No")
                            </td>

                            @* DISPLAY THE VALUE IN THE TABLE COLUMNS *@
                            <td>
                                @if (item.IsOrganizationGenerated)
                                {
                                    <span class="badge bg-info text-dark">Org-Generated</span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-muted border">Standard</span>
                                }
                            </td>

                            <td>
                                @(item.IsActive ? "Active" : "Inactive")
                            </td>

                            <td>
                                <button class="btn btn-sm btn-warning me-1"
                                        @onclick="() => Edit(item)">
                                    Edit
                                </button>

                                <button class="btn btn-sm btn-secondary me-1"
                                        @onclick="() => Toggle(item)">
                                    Toggle
                                </button>

                                <button class="btn btn-sm btn-danger"
                                        @onclick="() => Delete(item)">
                                    Delete
                                </button>
                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>

@code {

    private Guid organizationId;

    private List<DocumentType> documentTypes = new();

    private string SearchText = "";

    private DocumentType newType = new();

    private IEnumerable<DocumentType> FilteredDocumentTypes =>
        string.IsNullOrWhiteSpace(SearchText)
            ? documentTypes
            : documentTypes.Where(x =>
                x.Name.Contains(SearchText,
                    StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        var ctx = await CurrentUserService.GetOrgDashboardContextAsync();
        organizationId = ctx.OrganizationId;
        await LoadData();
    }

    private async Task LoadData()
    {
        documentTypes = await DocumentTypeService.GetOrganizationDocumentTypesAsync(organizationId);
    }

    private async Task CreateDocumentType()
    {
        newType.OrganizationId = organizationId;

        // Automatically configure defaults when marking as Org-Generated to protect integrity
        if (newType.IsOrganizationGenerated)
        {
            newType.IsEmployeeUploadAllowed = false;
            newType.IsHRUploadAllowed = true;
        }
        else
        {
            newType.IsEmployeeUploadAllowed = true;
            newType.IsHRUploadAllowed = false;
        }

        // If your page handles both Create and Update seamlessly through service hooks
        await DocumentTypeService.CreateAsync(newType);

        newType = new DocumentType();
        await LoadData();
    }

    private async Task Toggle(DocumentType item)
    {
        await DocumentTypeService.ToggleStatusAsync(item.DocumentTypeId, organizationId);
        await LoadData();
    }

    private async Task Delete(DocumentType item)
    {
        await DocumentTypeService.DeleteAsync(item.DocumentTypeId, organizationId);
        await LoadData();
    }

    private void Edit(DocumentType item)
    {
        newType = new DocumentType
        {
            DocumentTypeId = item.DocumentTypeId,
            OrganizationId = item.OrganizationId,
            Name = item.Name,
            Description = item.Description,
            Category = item.Category,
            IsMandatory = item.IsMandatory,
            TrackExpiry = item.TrackExpiry,
            RequiresVerification = item.RequiresVerification,
            AllowedFileTypes = item.AllowedFileTypes,
            MaxFileSizeMB = item.MaxFileSizeMB,
            IsEmployeeUploadAllowed = item.IsEmployeeUploadAllowed,
            IsHRUploadAllowed = item.IsHRUploadAllowed,
            DisplayOrder = item.DisplayOrder,

            // KEY FIX: Ensure the edit model grabs the flag when loading into fields
            IsOrganizationGenerated = item.IsOrganizationGenerated
        };
    }

    private void GoBack()
    {
        Nav.NavigateTo("/org/dashboard");
    }
}