@page "/org/departments"
@rendermode InteractiveServer

@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize(Roles = "OrgAdmin")]

@inject DepartmentService DeptService
@inject NavigationManager Nav

<PageTitle>Departments | Humatrix HRMS</PageTitle>

<div class="position-fixed top-0 end-0 p-3" style="z-index: 1080;">
    @if (!string.IsNullOrEmpty(message))
    {
        <div class="toast show align-items-center border-0 shadow-lg mb-2" role="alert" style="background-color: #f0fdf4; color: #166534; border-left: 4px solid #10b981 !important; border-radius: 10px;">
            <div class="d-flex p-3">
                <div class="toast-body d-flex align-items-center p-0">
                    <i class="bi bi-check-circle-fill me-2 fs-5" style="color: #10b981;"></i>
                    <span class="small fw-medium">@message</span>
                </div>
                <button type="button" class="btn-close m-auto me-0 shadow-none" @onclick="() => message = null"></button>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(error))
    {
        <div class="toast show align-items-center border-0 shadow-lg mb-2" role="alert" style="background-color: #fef2f2; color: #991b1b; border-left: 4px solid #ef4444 !important; border-radius: 10px;">
            <div class="d-flex p-3">
                <div class="toast-body d-flex align-items-center p-0">
                    <i class="bi bi-exclamation-triangle-fill me-2 fs-5" style="color: #ef4444;"></i>
                    <span class="small fw-medium"><strong>Error:</strong> @error</span>
                </div>
                <button type="button" class="btn-close m-auto me-0 shadow-none" @onclick="() => error = null"></button>
            </div>
        </div>
    }
</div>

<div class="container-fluid px-4 mt-4">

    @* Header Section *@
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom row-gap-3 flex-wrap">
        <div>
            <h2 class="fw-bold tracking-tight text-dark mb-1">Departments</h2>
            <p class="text-muted small mb-0">Configure, structure, and audit organization business units.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-add-dept d-flex align-items-center gap-2 shadow-sm" @onclick="GoToCreate">
                <i class="bi bi-plus-circle"></i>
                ADD DEPARTMENT
            </button>

            <button class="btn btn-interactive-back shadow-sm" @onclick="GoBack">
                DASHBOARD
            </button>
        </div>
    </div>

    @* Summary Widgets *@
    <div class="row g-3 mb-4">
        <div class="col-md-3 col-sm-6">
            <div class="card border-0 shadow-sm metric-panel-card" style="border-left: 4px solid #5c4ac7 !important;">
                <div class="card-body d-flex align-items-center justify-content-between p-3">
                    <div>
                        <span class="text-secondary small fw-bold tracking-wider text-uppercase d-block mb-1">Total Departments</span>
                        <h3 class="fw-bold text-dark mb-0">@totalCount</h3>
                    </div>
                    <div class="metric-icon-box" style="background-color: rgba(92, 74, 199, 0.08); color: #5c4ac7;">
                        <i class="bi bi-building"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="card border-0 shadow-sm metric-panel-card" style="border-left: 4px solid #ef4444 !important;">
                <div class="card-body d-flex align-items-center justify-content-between p-3">
                    <div>
                        <span class="text-secondary small fw-bold tracking-wider text-uppercase d-block mb-1">Inactive Units</span>
                        <h3 class="fw-bold text-dark mb-0">@inactiveCount</h3>
                    </div>
                    <div class="metric-icon-box" style="background-color: rgba(239, 68, 68, 0.08); color: #ef4444;">
                        <i class="bi bi-building-exclamation"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Live Search Bar *@
    <div class="mb-3 position-relative search-wrapper">
        <i class="bi bi-search search-icon text-muted"></i>
        <input type="text"
               class="form-control premium-search-input"
               placeholder="Search department by name or description instantly..."
               @bind-value="SearchQuery"
               @bind-value:event="oninput" />
        @if (!string.IsNullOrEmpty(SearchQuery))
        {
            <button class="btn btn-clear-search" @onclick="ClearSearch">
                <i class="bi bi-x-circle-fill"></i>
            </button>
        }
    </div>

    @* Main Table View *@
    <div class="card border-0 shadow-sm panel-container-card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4 text-secondary small fw-bold tracking-wider py-3">DEPARTMENT NAME</th>
                        <th class="text-secondary small fw-bold tracking-wider py-3">DESCRIPTION</th>
                        <th class="text-secondary small fw-bold tracking-wider py-3 text-center" style="width: 180px;">STATUS</th>
                        <th class="text-secondary small fw-bold tracking-wider py-3 text-end pe-4" style="width: 160px;">ACTIONS</th>
                    </tr>
                </thead>
                <tbody>
                    @if (departments == null)
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5">
                                <div class="spinner-border text-primary" style="width: 2rem; height: 2rem;" role="status"></div>
                                <p class="mt-2 text-muted small mb-0">Loading system data...</p>
                            </td>
                        </tr>
                    }
                    else if (!FilteredDepartments.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <div class="fs-2 text-light mb-2"><i class="bi bi-search"></i></div>
                                <span class="fw-medium">No records found matching your search query.</span>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var d in PagedDepartments)
                        {
                            <tr class="table-row-interactive">
                                <td class="ps-4">
                                    @if (editId == d.DepartmentId)
                                    {
                                        <InputText class="form-control premium-edit-input" @bind-Value="editName" />
                                    }
                                    else
                                    {
                                        <div class="fw-bold text-dark text-heading-field">@d.Name</div>
                                    }
                                </td>

                                <td>
                                    @if (editId == d.DepartmentId)
                                    {
                                        <InputText class="form-control premium-edit-input" @bind-Value="editDesc" />
                                    }
                                    else
                                    {
                                        <span class="text-muted row-description-text">
                                            @(string.IsNullOrEmpty(d.Description) ? "—" : d.Description)
                                        </span>
                                    }
                                </td>

                                <td class="text-center">
                                    <div class="form-check form-switch d-inline-flex align-items-center gap-2 justify-content-center protocol-switch">
                                        <input class="form-check-input shadow-none"
                                               type="checkbox"
                                               checked="@d.IsActive"
                                               @onchange="(e) => ToggleDeptStatus(d, e)" />

                                        <span class="status-indicator-pill @(d.IsActive ? "pill-active" : "pill-inactive")">
                                            @(d.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </div>
                                </td>

                                <td class="text-end pe-4">
                                    @if (editId == d.DepartmentId)
                                    {
                                        <button class="btn btn-sm btn-action-save me-1" @onclick="() => SaveEdit(d.DepartmentId)">
                                            Save
                                        </button>
                                        <button class="btn btn-sm btn-action-cancel" @onclick="CancelEdit">
                                            Cancel
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-action-edit" @onclick="() => StartEdit(d)" title="Edit Unit">
                                            <i class="bi bi-pencil-square"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        @* PREMIUM MINIMALIST RIGHT-ALIGNED PAGINATION PANEL *@
        <div class="d-flex justify-content-end align-items-center p-3 border-top bg-light pe-4">
            <div class="d-flex align-items-center gap-1 core-pagination-wrapper shadow-sm rounded-3 p-1 bg-white border">

                @* Left Arrow Button (Previous Page) *@
                <button class="btn btn-paging-arrow @(CurrentPage == 1 ? "disabled" : "")"
                        @onclick="() => ChangePage(CurrentPage - 1)"
                        title="Previous Page">
                    <i class="bi bi-chevron-left"></i>
                </button>

                @* Center Dynamic State: Page X/Y Counter *@
                <div class="premium-page-state-text px-2 fw-semibold text-secondary select-none">
                    Page <span class="text-indigo-premium">@CurrentPage</span>/<span>@(TotalPages == 0 ? 1 : TotalPages)</span>
                </div>

                @* Right Arrow Button (Next Page) *@
                <button class="btn btn-paging-arrow @(CurrentPage >= TotalPages || TotalPages == 0 ? "disabled" : "")"
                        @onclick="() => ChangePage(CurrentPage + 1)"
                        title="Next Page">
                    <i class="bi bi-chevron-right"></i>
                </button>

            </div>
        </div>
    </div>
</div>

<style>
