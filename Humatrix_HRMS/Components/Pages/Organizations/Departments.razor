    }

    .pill-inactive {
        background-color: #fef2f2;
        color: #991b1b;
    }
</style>

@code {
    private List<DepartmentDto> departments = new();
    private string _searchQuery = string.Empty;

    private string SearchQuery
    {
        get => _searchQuery;
        set
        {
            if (_searchQuery != value)
            {
                _searchQuery = value;
                CurrentPage = 1;
            }
        }
    }

    private string? message;
    private string? error;

    private Guid? editId;
    private string? editName;
    private string? editDesc;

    // Counters
    private int totalCount = 0;
    private int inactiveCount = 0;

    // Paging Configuration Variables
    private int CurrentPage { get; set; } = 1;
    private int PageSize { get; set; } = 10;
    private int TotalPages => (int)Math.Ceiling((double)FilteredDepartments.Count() / PageSize);

    private IEnumerable<DepartmentDto> FilteredDepartments =>
        string.IsNullOrWhiteSpace(SearchQuery)
            ? departments
            : departments.Where(d => d.Name.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) ||
                                     (d.Description != null && d.Description.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)));

    private IEnumerable<DepartmentDto> PagedDepartments =>
        FilteredDepartments.Skip((CurrentPage - 1) * PageSize).Take(PageSize);

    protected override async Task OnInitializedAsync()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        if (Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query).TryGetValue("success", out var value))
        {
            message = value.ToString();
        }

        await LoadDepartments();
    }

    private async Task LoadDepartments()
    {
        var rawData = await DeptService.GetAllAsync();
        if (rawData != null)
        {
            departments = rawData;

            totalCount = departments.Count;
            inactiveCount = departments.Count(d => !d.IsActive);

            if (CurrentPage > TotalPages && TotalPages > 0)
            {
                CurrentPage = TotalPages;
            }
        }
    }

    private void ChangePage(int pageNumber)
    {
        if (pageNumber >= 1 && pageNumber <= TotalPages)
        {
            CurrentPage = pageNumber;
        }
    }

    private void ClearSearch()
    {
        SearchQuery = string.Empty;
        CurrentPage = 1;
    }

    void GoToCreate() => Nav.NavigateTo("/org/create-department");
    void GoBack() => Nav.NavigateTo("/org/dashboard");

    void StartEdit(DepartmentDto dept)
    {
        editId = dept.DepartmentId;
        editName = dept.Name;
        editDesc = dept.Description;
    }

    void CancelEdit() => editId = null;

    async Task SaveEdit(Guid id)
    {
        if (string.IsNullOrWhiteSpace(editName)) return;

        try
        {
            await DeptService.UpdateAsync(id, editName!, editDesc);
            editId = null;
            message = "Department details updated successfully.";
            error = null;
            await LoadDepartments();
        }
        catch (Exception ex)
        {
            error = ex.Message;
            message = null;
        }
    }

    private async Task ToggleDeptStatus(DepartmentDto d, ChangeEventArgs e)
    {
        var isActive = (bool)e.Value!;
        d.IsActive = isActive;

        try
        {
            await DeptService.ToggleStatusAsync(d.DepartmentId, isActive);
            message = $"Department state changed to {(isActive ? "Active" : "Inactive")}.";
            error = null;
            await LoadDepartments();
        }
        catch (Exception ex)
        {
            error = ex.Message;
            message = null;
        }
    }
}