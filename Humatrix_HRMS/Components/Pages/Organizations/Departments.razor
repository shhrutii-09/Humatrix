@page "/org/departments"
@rendermode InteractiveServer

@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize(Roles = "OrgAdmin")]

@inject DepartmentService DeptService
@inject NavigationManager Nav

<PageTitle>Departments</PageTitle>

<div class="container-fluid px-4 mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-normal">Departments</h2>
            <p class="text-muted small">Manage organization departments</p>
        </div>

        <button class="btn btn-primary shadow-sm"
                style="background-color:#5c4ac7;border:none;"
                @onclick="GoToCreate">
            <i class="bi bi-plus-circle me-2"></i>
            ADD DEPARTMENT
        </button>
    </div>

    <!-- TABLE -->
    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">

                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 text-muted small">DEPARTMENT</th>
                        <th class="text-muted small">DESCRIPTION</th>
                        <th class="text-muted small text-center">STATUS</th>
                        <th class="text-muted small text-end pe-4">ACTIONS</th>
                    </tr>
                </thead>

                <tbody>
                    @if (departments == null)
                    {
                        <tr>
                            <td colspan="4" class="text-center py-4">Loading...</td>
                        </tr>
                    }
                    else if (!departments.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5">
                                <span class="text-muted">No departments found</span>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var d in departments)
                        {
                            <tr>

                                <!-- NAME -->
                                <td class="ps-4">
                                    @if (editId == d.DepartmentId)
                                    {
                                        <InputText class="form-control bg-light"
                                                   @bind-Value="editName" />
                                    }
                                    else
                                    {
                                        <div class="fw-bold">@d.Name</div>
                                    }
                                </td>

                                <!-- DESCRIPTION -->
                                <td>
                                    @if (editId == d.DepartmentId)
                                    {
                                        <InputText class="form-control bg-light"
                                                   @bind-Value="editDesc" />
                                    }
                                    else
                                    {
                                        <span class="text-muted">
                                            @(string.IsNullOrEmpty(d.Description) ? "—" : d.Description)
                                        </span>
                                    }
                                </td>

                                <!-- STATUS -->
                                <td class="text-center">
                                    <div class="form-check form-switch d-inline-block">
                                        <input class="form-check-input shadow-none"
                                               type="checkbox"
                                               checked="@d.IsActive"
                                               @onchange="(e) => ToggleDeptStatus(d, e)" />

                                        <span class="small @(d.IsActive ? "text-success" : "text-danger") ms-2">
                                            @(d.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </div>
                                </td>

                                <!-- ACTIONS -->
                                <td class="text-end pe-4">
                                    @if (editId == d.DepartmentId)
                                    {
                                        <button class="btn btn-sm btn-success me-2"
                                                @onclick="() => SaveEdit(d.DepartmentId)">
                                            Save
                                        </button>

                                        <button class="btn btn-sm btn-light border"
                                                @onclick="CancelEdit">
                                            Cancel
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-light border text-primary me-1"
                                                @onclick="() => StartEdit(d)">
                                            <i class="bi bi-pencil-square"></i>
                                        </button>
                                    }
                                </td>

                            </tr>
                        }
                    }
                </tbody>

            </table>
        </div>
    </div>

    <!-- BACK -->
    <button class="btn btn-light mt-3"
            @onclick="GoBack">
        ← Back
    </button>

</div>

<style>
    .form-switch .form-check-input {
        width: 2.5em;
        height: 1.25em;
        cursor: pointer;
    }

    .form-control:focus {
        border-color: #5c4ac7;
        box-shadow: 0 0 0 0.2rem rgba(92,74,199,0.1);
    }
</style>

@code {
    private List<DepartmentDto> departments = new();

    private Guid? editId;
    private string? editName;
    private string? editDesc;

    protected override async Task OnInitializedAsync()
    {
        await LoadDepartments();
    }

    private async Task LoadDepartments()
    {
        departments = await DeptService.GetAllAsync();
    }

    void GoToCreate() => Nav.NavigateTo("/org/create-department");
    void GoBack() => Nav.NavigateTo("/org/dashboard");

    void StartEdit(DepartmentDto dept)
    {
        editId = dept.DepartmentId;
        editName = dept.Name;
        editDesc = dept.Description;
    }

    void CancelEdit()
    {
        editId = null;
    }

    async Task SaveEdit(Guid id)
    {
        if (string.IsNullOrWhiteSpace(editName))
            return;

        await DeptService.UpdateAsync(id, editName!, editDesc);
        editId = null;

        await LoadDepartments();
    }

    private async Task ToggleDeptStatus(DepartmentDto d, ChangeEventArgs e)
    {
        var isActive = (bool)e.Value;

        // ✅ update instantly for UI responsiveness
        d.IsActive = isActive;

        await DeptService.ToggleStatusAsync(d.DepartmentId, isActive);

        // reload to sync with DB
        await LoadDepartments();
    }
}