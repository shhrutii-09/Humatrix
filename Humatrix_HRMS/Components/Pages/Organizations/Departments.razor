        letter-spacing: -0.025em;
    }

    .tracking-wider {
        letter-spacing: 0.04em;
        font-size: 11px;
    }

    .panel-container-card {
        border-radius: 14px;
        background-color: #ffffff;
        overflow: hidden;
    }

    .metric-panel-card {
        border-radius: 12px;
        background-color: #ffffff;
        overflow: hidden;
    }

    .metric-icon-box {
        width: 42px;
        height: 42px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
    }

    .search-wrapper {
        max-width: 450px;
    }

    .search-icon {
        position: absolute;
        top: 50%;
