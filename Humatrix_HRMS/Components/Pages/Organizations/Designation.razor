@page "/org/designations"
@rendermode InteractiveServer

@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize(Roles = "OrgAdmin")]

@inject DesignationService DesignationService
@inject DepartmentService DepartmentService
@inject NavigationManager Nav

<PageTitle>Designations | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom row-gap-3 flex-wrap">
        <div>
            <h2 class="fw-bold tracking-tight text-dark mb-1">Designations</h2>
            <p class="text-muted small mb-0">Configure professional job titles, operational ranks, and department alignments.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-add-designation d-flex align-items-center gap-2 shadow-sm" @onclick="GoToCreate">
                <i class="bi bi-plus-circle"></i>
                ADD DESIGNATION
            </button>
            <button class="btn btn-interactive-back shadow-sm" @onclick="GoBack">
                DASHBOARD
            </button>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-4 col-sm-6">
            <div class="filter-group-wrapper shadow-sm">
                <label class="form-label small fw-bold text-secondary tracking-wider mb-1 ps-1">FILTER BY DEPARTMENT</label>
                <div class="input-group dropdown-box-wrapper">
                    <span class="input-group-text bg-white border-end-0 text-muted">
                        <i class="bi bi-filter-square"></i>
                    </span>
                    <select class="form-select border-start-0 ps-0 premium-dropdown-select shadow-none" @bind="SelectedDepartment">
                        <option value="">All Departments</option>
                        @if (departments != null)
                        {
                            @foreach (var dept in departments)
                            {
                                <option value="@dept.Name">@dept.Name</option>
                            }
                        }
                    </select>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm panel-container-card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4 text-secondary small fw-bold tracking-wider py-3">DESIGNATION NAME</th>
                        <th class="text-secondary small fw-bold tracking-wider py-3">DEPARTMENT</th>
                        <th class="text-secondary small fw-bold tracking-wider py-3 text-center" style="width: 180px;">STATUS</th>
                        <th class="text-secondary small fw-bold tracking-wider py-3 text-end pe-4" style="width: 160px;">ACTIONS</th>
                    </tr>
                </thead>
                <tbody>
                    @if (designations == null)
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5">
                                <div class="spinner-border text-primary" style="width: 2rem; height: 2rem;" role="status"></div>
                                <p class="mt-2 text-muted small mb-0">Loading system data stream...</p>
                            </td>
                        </tr>
                    }
                    else if (!FilteredDesignations.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <div class="fs-2 text-light mb-2"><i class="bi bi-briefcase"></i></div>
                                <span class="fw-medium">No designations found for the selected filter.</span>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var d in FilteredDesignations)
                        {
                            <tr class="table-row-interactive">

                                <td class="ps-4">
                                    @if (editId == d.DesignationId)
                                    {
                                        <InputText class="form-control premium-edit-input" @bind-Value="editName" />
                                    }
                                    else
                                    {
                                        <span class="fw-bold text-dark text-heading-field">@d.Name</span>
                                    }
                                </td>

                                <td>
                                    <span class="badge premium-soft-dept-badge">
                                        <i class="bi bi-building me-1 small"></i> @d.Department
                                    </span>
                                </td>

                                <td class="text-center">
                                    <div class="form-check form-switch d-inline-flex align-items-center gap-2 justify-content-center protocol-switch">
                                        <input class="form-check-input shadow-none"
                                               type="checkbox"
                                               checked="@d.IsActive"
                                               @onchange="(e) => ToggleStatus(d, e)" />

                                        <span class="status-indicator-pill @(d.IsActive ? "pill-active" : "pill-inactive")">
                                            @(d.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </div>
                                </td>

                                <td class="text-end pe-4">
                                    @if (editId == d.DesignationId)
                                    {
                                        <button class="btn btn-sm btn-action-save me-1" @onclick="() => SaveEdit(d.DesignationId)">
                                            Save
                                        </button>
                                        <button class="btn btn-sm btn-action-cancel" @onclick="CancelEdit">
                                            Cancel
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-action-edit" title="Edit Designation" @onclick="() => StartEdit(d)">
                                            <i class="bi bi-pencil-square"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    /* Framework Design Tokens */
    .tracking-tight {
        letter-spacing: -0.025em;
    }

    .tracking-wider {
        letter-spacing: 0.04em;
        font-size: 11px;
    }

    .panel-container-card {
        border-radius: 14px;
        background-color: #ffffff;
        overflow: hidden;
    }

    /* Premium Dropdown Wrapper Framework */
    .filter-group-wrapper {
        display: flex;
        flex-direction: column;
    }

    .dropdown-box-wrapper {
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid #cbd5e1;
        background-color: #ffffff;
        transition: all 0.2s ease;
    }

        .dropdown-box-wrapper:focus-within {
            border-color: #5c4ac7;
            box-shadow: 0 0 0 4px rgba(92, 74, 199, 0.12) !important;
        }

    .premium-dropdown-select {
        font-size: 13.5px;
        padding: 9px 12px;
        border: none;
        color: #1e293b;
        cursor: pointer;
        background-color: transparent;
    }

        .premium-dropdown-select:focus {
            border: none;
            box-shadow: none;
            background-color: transparent;
        }

    .dropdown-box-wrapper .input-group-text {
        font-size: 14px;
        padding-left: 14px;
        padding-right: 10px;
    }

    /* Core Data Presentation Grids */
    .table thead th {
        background-color: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
    }

    .table-row-interactive {
        transition: background-color 0.15s ease;
    }

        .table-row-interactive:hover {
            background-color: #f8fafc;
        }

    .text-heading-field {
        font-size: 14px;
        color: #1e293b !important;
    }

    /* Soft Structural Alignment Pill */
    .premium-soft-dept-badge {
        background-color: rgba(92, 74, 199, 0.08) !important;
        color: #5c4ac7 !important;
        font-size: 11.5px !important;
        font-weight: 500 !important;
        padding: 5px 10px !important;
        border-radius: 6px !important;
        border: 1px solid rgba(92, 74, 199, 0.12);
    }

    /* Action Trigger Architecture */
    .btn-add-designation {
        background-color: #5c4ac7 !important;
        color: #ffffff !important;
        border: none !important;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.02em;
        transition: all 0.2s ease;
    }

        .btn-add-designation:hover {
            background-color: #4b3ba6 !important;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(92, 74, 199, 0.2) !important;
        }

    .btn-interactive-back {
        background: #ffffff !important;
        border: 1px solid #e5e7eb !important;
        color: #4b5563 !important;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
        transition: all 0.2s ease;
    }

        .btn-interactive-back:hover {
            background-color: #f8fafc !important;
            border-color: #5c4ac7 !important;
            color: #5c4ac7 !important;
            transform: translateY(-1px);
        }

    /* Operational Actions Mini Configuration Buttons */
    .btn-action-edit {
        background: #f1f5f9;
        border: 1px solid #e2e8f0;
        color: #475569;
        border-radius: 8px;
        padding: 5px 10px;
        transition: all 0.15s ease;
    }

        .btn-action-edit:hover {
            background: rgba(92, 74, 199, 0.08);
            border-color: rgba(92, 74, 199, 0.25);
            color: #5c4ac7;
        }

    .btn-action-save {
        background-color: #10b981;
        color: white;
        border: none;
        border-radius: 6px;
        padding: 4px 12px;
        font-size: 12.5px;
        font-weight: 500;
    }

    .btn-action-cancel {
        background-color: #f1f5f9;
        color: #475569;
        border: 1px solid #e2e8f0;
        border-radius: 6px;
        padding: 4px 12px;
        font-size: 12.5px;
    }

    /* Premium Inline Input Framework Override */
    .premium-edit-input {
        font-size: 13.5px;
        padding: 5px 10px;
        border-radius: 8px;
        border: 1px solid #cbd5e1;
    }

        .premium-edit-input:focus {
            border-color: #5c4ac7;
            box-shadow: 0 0 0 3px rgba(92, 74, 199, 0.12);
            background-color: #ffffff !important;
        }

    /* Switch Component Mechanics & Badging Protocol */
    .protocol-switch .form-check-input {
        width: 2.3em;
        height: 1.15em;
        cursor: pointer;
        background-color: #cbd5e1;
        border-color: transparent;
    }

        .protocol-switch .form-check-input:checked {
            background-color: #10b981;
        }

    .status-indicator-pill {
        font-size: 11px;
        font-weight: 600;
        padding: 2px 8px;
        border-radius: 6px;
        display: inline-block;
        min-width: 60px;
    }

    .pill-active {
        background-color: #ecfdf5;
        color: #065f46;
    }

    .pill-inactive {
        background-color: #fef2f2;
        color: #991b1b;
    }
</style>

@code {
    private List<DesignationDto>? designations;
    private List<DepartmentDto>? departments;

    private Guid? editId;
    private Guid? editDepartmentId;
    private string? editName;

    // Dropdown value container property
    private string SelectedDepartment { get; set; } = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadDesignations(), LoadDepartments());
    }

    private async Task LoadDesignations()
    {
        var rawDesignations = await DesignationService.GetAllAsync();
        if (rawDesignations != null)
        {
            // Reverse ordering array logic to execute strict LIFO data sorting (Newest First)
            designations = rawDesignations.AsEnumerable().Reverse().ToList();
        }
    }

    private async Task LoadDepartments()
    {
        // Loading dynamic departments to bind with the premium select component
        departments = await DepartmentService.GetAllAsync();
    }

    // Computed Property to handle dynamic LIFO data filtering based on Dropdown Selection
    private IEnumerable<DesignationDto> FilteredDesignations
    {
        get
        {
            if (designations == null) return Enumerable.Empty<DesignationDto>();

            if (string.IsNullOrWhiteSpace(SelectedDepartment)) return designations;

            return designations.Where(x =>
                x.Department != null && x.Department.Equals(SelectedDepartment, StringComparison.OrdinalIgnoreCase)
            );
        }
    }

    void GoToCreate() => Nav.NavigateTo("/org/create-designation");
    void GoBack() => Nav.NavigateTo("/org/dashboard");

    void StartEdit(DesignationDto d)
    {
        editId = d.DesignationId;
        editName = d.Name;
        editDepartmentId = d.DepartmentId;
    }

    void CancelEdit() => editId = null;

    async Task SaveEdit(Guid id)
    {
        try
        {
            if (string.IsNullOrWhiteSpace(editName)) return;

            await DesignationService.UpdateAsync(id, new CreateDesignationDto
            {
                Name = editName,
                DepartmentId = editDepartmentId ?? Guid.Empty
            });

            editId = null;
            await LoadDesignations();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating designation: {ex.Message}");
        }
    }

    private async Task ToggleStatus(DesignationDto d, ChangeEventArgs e)
    {
        var isActive = (bool)(e.Value ?? false);
        d.IsActive = isActive;

        await DesignationService.ToggleStatusAsync(d.DesignationId, isActive);
        await LoadDesignations();
    }
}