@page "/org/designations"
@rendermode InteractiveServer

@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize(Roles = "OrgAdmin")]

@inject DesignationService DesignationService
@inject DepartmentService DepartmentService
@inject NavigationManager Nav

<PageTitle>Designations | Humatrix HRMS</PageTitle>

@* Premium Floating Notifications Container with 4 Sec Auto-Dismiss *@
<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 9999;">
    @if (showToast)
    {
        <div class="toast show premium-side-toast animate-slide-in @(isError ? "toast-danger-border" : "toast-success-border")" role="alert">
            <div class="toast-body d-flex align-items-center gap-3 p-3">
                <div class="toast-icon-circle @(isError ? "bg-light-danger text-danger" : "bg-light-success text-success")">
                    <i class="bi @(isError ? "bi-shield-fill-x" : "bi-check-circle-fill") fs-5"></i>
                </div>
                <div class="flex-grow-1">
                    <h6 class="mb-0 fw-bold @(isError ? "text-danger" : "text-success")" style="font-size: 13.5px;">
                        @(isError ? "Execution Failure" : "Action Completed")
                    </h6>
                    <small class="text-secondary d-block mt-0.5" style="font-size: 12px; line-height: 1.3;">@toastMessage</small>
                </div>
                <button type="button" class="btn-close shadow-none ms-auto" @onclick="CloseToast"></button>
            </div>
        </div>
    }
</div>

<div class="container-fluid px-4 mt-4">

    @* Header Section with Department Style Buttons *@
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom row-gap-3 flex-wrap">
        <div>
            <h2 class="fw-bold tracking-tight text-dark mb-1">Designations</h2>
            <p class="text-muted small mb-0">Configure professional job titles, operational ranks, and department alignments.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-add-designation d-flex align-items-center gap-2 shadow-sm" @onclick="GoToCreate">
                <i class="bi bi-plus-circle"></i>
                ADD DESIGNATION
            </button>

            <button class="btn btn-interactive-dashboard d-flex align-items-center gap-2 shadow-sm" @onclick="GoBack">
                <i class="bi bi-speedometer2"></i>
                DASHBOARD
            </button>
        </div>
    </div>

    @* REAL-TIME METRICS SUMMARY COUNTERS CARDS *@
    <div class="row g-3 mb-4">
        <div class="col-md-3 col-sm-6">
            <div class="card border-0 shadow-sm metric-card p-3 d-flex flex-row align-items-center justify-content-between bg-white" style="border-left: 4px solid #5c4ac7 !important;">
                <div>
                    <span class="text-secondary small fw-bold tracking-wider mb-1 d-block">TOTAL DESIGNATIONS</span>
                    <h3 class="fw-bold text-dark mb-0">@totalCount</h3>
                </div>
                <div class="metric-icon-box text-primary" style="background-color: rgba(92, 74, 199, 0.08);">
                    <i class="bi bi-briefcase-fill"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="card border-0 shadow-sm metric-card p-3 d-flex flex-row align-items-center justify-content-between bg-white" style="border-left: 4px solid #ef4444 !important;">
                <div>
                    <span class="text-secondary small fw-bold tracking-wider mb-1 d-block">INACTIVE DESIGNATIONS</span>
                    <h3 class="fw-bold text-dark mb-0">@inactiveCount</h3>
                </div>
                <div class="metric-icon-box text-danger" style="background-color: rgba(239, 68, 68, 0.08);">
                    <i class="bi bi-slash-circle-fill"></i>
                </div>
            </div>
        </div>
    </div>

    @* Search & Filter Controls *@
    <div class="row g-3 mb-4 align-items-end">
        <div class="col-md-5 col-sm-12">
            <div class="position-relative search-wrapper">
                <i class="bi bi-search search-icon text-muted"></i>
                <input type="text"
                       class="form-control premium-search-input"
                       placeholder="Search designation title instantly..."
                       @bind-value="SearchQuery"
                       @bind-value:event="oninput" />
                @if (!string.IsNullOrEmpty(SearchQuery))
                {
                    <button class="btn btn-clear-search" @onclick="ClearSearch">
                        <i class="bi bi-x-circle-fill"></i>
                    </button>
                }
            </div>
        </div>
        <div class="col-md-4 col-sm-6">
            <div class="filter-group-wrapper shadow-sm">
                <label class="form-label small fw-bold text-secondary tracking-wider mb-1 ps-1">FILTER BY DEPARTMENT</label>
                <div class="input-group dropdown-box-wrapper">
                    <span class="input-group-text bg-white border-end-0 text-muted">
                        <i class="bi bi-filter-square"></i>
                    </span>
                    <select class="form-select border-start-0 ps-0 premium-dropdown-select shadow-none" @bind="SelectedDepartment">
                        <option value="">All Departments</option>
                        @if (departments != null)
                        {
                            @foreach (var dept in departments)
                            {
                                <option value="@dept.Name">@dept.Name</option>
                            }
                        }
                    </select>
                </div>
            </div>
        </div>
    </div>

    @* Main Table Card View *@
    <div class="card border-0 shadow-sm panel-container-card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4 text-secondary small fw-bold tracking-wider py-3">DESIGNATION NAME</th>
                        <th class="text-secondary small fw-bold tracking-wider py-3">DEPARTMENT</th>
                        <th class="text-secondary small fw-bold tracking-wider py-3 text-center" style="width: 180px;">STATUS</th>
                        <th class="text-secondary small fw-bold tracking-wider py-3 text-end pe-4" style="width: 160px;">ACTIONS</th>
                    </tr>
                </thead>
                <tbody>
                    @if (designations == null)
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5">
                                <div class="spinner-border text-primary" style="width: 2rem; height: 2rem;" role="status"></div>
                                <p class="mt-2 text-muted small mb-0">Loading data stream...</p>
                            </td>
                        </tr>
                    }
                    else if (!FilteredDesignations.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <div class="fs-2 text-light mb-2"><i class="bi bi-briefcase"></i></div>
                                <span class="fw-medium">No designations found.</span>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var d in PagedDesignations)
                        {
                            <tr class="table-row-interactive">
                                <td class="ps-4">
                                    @if (editId == d.DesignationId)
                                    {
                                        <input type="text" class="form-control premium-edit-input" @bind="editName" />
                                    }
                                    else
                                    {
                                        <span class="fw-bold text-dark text-heading-field">@d.Name</span>
                                    }
                                </td>

                                <td>
                                    <span class="badge premium-soft-dept-badge">
                                        <i class="bi bi-building me-1 small"></i> @d.Department
                                    </span>
                                </td>

                                <td class="text-center">
                                    <div class="form-check form-switch d-inline-flex align-items-center gap-2 justify-content-center protocol-switch">
                                        <input class="form-check-input shadow-none"
                                               type="checkbox"
                                               checked="@d.IsActive"
                                               @onchange="(e) => ToggleStatus(d, e)" />

                                        <span class="status-indicator-pill @(d.IsActive ? "pill-active" : "pill-inactive")">
                                            @(d.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </div>
                                </td>

                                <td class="text-end pe-4">
                                    @if (editId == d.DesignationId)
                                    {
                                        <button class="btn btn-sm btn-action-save me-1" @onclick="() => SaveEdit(d.DesignationId)">Save</button>
                                        <button class="btn btn-sm btn-action-cancel" @onclick="CancelEdit">Cancel</button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-action-edit" title="Edit Designation" @onclick="() => StartEdit(d)">
                                            <i class="bi bi-pencil-square"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        @* COMPACT PAGINATION SYSTEM *@
        <div class="d-flex justify-content-end align-items-center p-3 border-top bg-light pe-4">
            <div class="d-flex align-items-center gap-1 core-pagination-wrapper shadow-sm rounded-3 p-1 bg-white border">
                <button class="btn btn-paging-arrow @(CurrentPage == 1 ? "disabled" : "")"
                        @onclick="() => ChangePage(CurrentPage - 1)">
                    <i class="bi bi-chevron-left"></i>
                </button>

                <div class="premium-page-state-text px-2 fw-semibold text-secondary user-select-none">
                    Page <span class="text-indigo-premium">@CurrentPage</span>/<span>@(TotalPages == 0 ? 1 : TotalPages)</span>
                </div>

                <button class="btn btn-paging-arrow @(CurrentPage >= TotalPages || TotalPages == 0 ? "disabled" : "")"
                        @onclick="() => ChangePage(CurrentPage + 1)">
                    <i class="bi bi-chevron-right"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    /* Synced Premium Toast Layout Variables */
    .premium-side-toast {
        background: #ffffff !important;
        border: none;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08) !important;
        min-width: 320px;
        max-width: 380px;
        overflow: hidden;
    }

    .toast-success-border {
        border-left: 4px solid #10b981 !important;
    }

    .toast-danger-border {
        border-left: 4px solid #ef4444 !important;
    }

    .toast-icon-circle {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .bg-light-success {
        background-color: rgba(16, 185, 129, 0.1);
    }

    .bg-light-danger {
        background-color: rgba(239, 68, 68, 0.1);
    }

    .animate-slide-in {
        animation: toastSlideIn 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    
    .animate-slide-in {
        animation: toastSlideIn 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    @@keyframes toastSlideIn {
        from {
            transform: translateX(100%) translateY(-10px);
            opacity: 0;
        }

        to {
            transform: translateX(0) translateY(0);
            opacity: 1;
        }
    }

    .tracking-tight {
        letter-spacing: -0.025em;
    }

    .tracking-wider {
        letter-spacing: 0.04em;
        font-size: 11px;
        text-transform: uppercase;
    }

    .panel-container-card {
        border-radius: 14px;
        background-color: #ffffff;
        overflow: hidden;
    }

    .metric-card {
        border-radius: 12px;
        min-width: 240px;
        border: 1px solid #e2e8f0 !important;
    }

    .metric-icon-box {
        width: 44px;
        height: 44px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
    }

    .search-wrapper {
        position: relative;
    }

    .search-icon {
        position: absolute;
        top: 50%;
        left: 14px;
        transform: translateY(-50%);
        font-size: 14px;
        pointer-events: none;
    }

    .premium-search-input {
        padding: 9px 40px 9px 38px;
        font-size: 13.5px;
        border-radius: 10px;
        border: 1px solid #cbd5e1;
        height: 42px;
    }

        .premium-search-input:focus {
            border-color: #5c4ac7;
            box-shadow: 0 0 0 4px rgba(92, 74, 199, 0.12);
        }

    .btn-clear-search {
        position: absolute;
        top: 50%;
        right: 8px;
        transform: translateY(-50%);
        background: none;
        border: none;
        color: #94a3b8;
    }

    .dropdown-box-wrapper {
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid #cbd5e1;
    }

    .premium-dropdown-select {
        font-size: 13.5px;
        padding: 9px 12px;
        border: none;
        height: 40px;
        cursor: pointer;
    }

    .table thead th {
        background-color: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
    }

    .table-row-interactive:hover {
        background-color: #f8fafc;
    }

    .text-heading-field {
        font-size: 14px;
        color: #1e293b !important;
    }

    .premium-soft-dept-badge {
        background-color: rgba(92, 74, 199, 0.08) !important;
        color: #5c4ac7 !important;
        font-size: 11.5px;
        font-weight: 500;
        padding: 5px 10px;
        border-radius: 6px;
    }

    .btn-interactive-dashboard {
        background-color: #ffffff !important;
        color: #4b5563 !important;
        border: 1px solid #e5e7eb !important;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
        transition: all 0.2s ease;
    }

        .btn-interactive-dashboard:hover {
            background-color: #f8fafc !important;
            border-color: #5c4ac7 !important;
            color: #5c4ac7 !important;
            transform: translateY(-1px);
        }

    .btn-add-designation {
        background-color: #5c4ac7 !important;
        color: #ffffff;
        border: none;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
        transition: all 0.2s ease;
    }

        .btn-add-designation:hover {
            background-color: #4c3ca3 !important;
            transform: translateY(-1px);
        }

    .btn-action-edit {
        background: #f1f5f9;
        border: 1px solid #e2e8f0;
