    }

    .premium-edit-input {
        font-size: 13.5px;
        padding: 4px 10px;
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        max-width: 280px;
    }

    .core-pagination-wrapper {
        background-color: #ffffff;
    }

    .btn-paging-arrow {
        border: none;
        background: transparent;
        color: #475569;
        padding: 4px 10px;
        border-radius: 6px;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .btn-paging-arrow:hover {
