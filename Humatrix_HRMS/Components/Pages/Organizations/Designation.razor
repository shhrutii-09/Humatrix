        color: #991b1b;
    }

    .protocol-switch .form-check-input:checked {
        background-color: #10b981;
    }
</style>

@code {
    private List<DesignationDto>? designations;
    private List<DepartmentDto>? departments;
    private string _selectedDepartment = string.Empty;
    private string _searchQuery = string.Empty;

    // Toast Notification System variables
    private string? toastMessage;
    private bool isError;
    private bool showToast = false;

    private Guid? editId;
    private string? editName;
    private Guid? editDepartmentId;

    // Counters State Variables
    private int totalCount = 0;
    private int inactiveCount = 0;

    // Pagination Configuration
    private int CurrentPage { get; set; } = 1;
    private int PageSize { get; set; } = 10;
    private int TotalPages => (int)Math.Ceiling((double)FilteredDesignations.Count() / PageSize);

    private string SelectedDepartment
    {
        get => _selectedDepartment;
        set { if (_selectedDepartment != value) { _selectedDepartment = value; CurrentPage = 1; } }
    }

    private string SearchQuery
    {
        get => _searchQuery;
        set { if (_searchQuery != value) { _searchQuery = value; CurrentPage = 1; } }
    }

    protected override async Task OnInitializedAsync()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        if (Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query).TryGetValue("success", out var value))
        {
            await TriggerToast(value.ToString(), false);
        }
        await Task.WhenAll(LoadDesignations(), LoadDepartments());
    }

    private async Task LoadDesignations()
    {
        var raw = await DesignationService.GetAllAsync();
        if (raw != null)
        {
            designations = raw;
            totalCount = designations.Count;
            inactiveCount = designations.Count(x => !x.IsActive);

            if (CurrentPage > TotalPages && TotalPages > 0) CurrentPage = TotalPages;
        }
    }

    private async Task LoadDepartments() => departments = await DepartmentService.GetAllAsync();

    private IEnumerable<DesignationDto> FilteredDesignations =>
        designations == null ? Enumerable.Empty<DesignationDto>() :
        designations.Where(x => (string.IsNullOrWhiteSpace(SelectedDepartment) || x.Department == SelectedDepartment) &&
                                (string.IsNullOrWhiteSpace(SearchQuery) || x.Name.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)));

    private IEnumerable<DesignationDto> PagedDesignations =>
        FilteredDesignations.Skip((CurrentPage - 1) * PageSize).Take(PageSize);

    private void ChangePage(int pageIndex)
    {
        if (pageIndex >= 1 && pageIndex <= TotalPages) CurrentPage = pageIndex;
    }

    private void ClearSearch() { SearchQuery = string.Empty; CurrentPage = 1; }

    void GoToCreate() => Nav.NavigateTo("/org/create-designation");
    void GoBack() => Nav.NavigateTo("/org/dashboard");

    void StartEdit(DesignationDto d) { editId = d.DesignationId; editName = d.Name; editDepartmentId = d.DepartmentId; }
    void CancelEdit() => editId = null;

    // Trigger Toast with 4 Seconds Auto Dismiss Delay
    private async Task TriggerToast(string message, bool errorState)
    {
        toastMessage = message;
        isError = errorState;
        showToast = true;
        StateHasChanged();

        await Task.Delay(4000);
        CloseToast();
    }

    private void CloseToast()
    {
        showToast = false;
        StateHasChanged();
    }

    async Task SaveEdit(Guid id)
    {
        if (string.IsNullOrWhiteSpace(editName)) return;
        try
        {
            await DesignationService.UpdateAsync(id, new CreateDesignationDto { Name = editName, DepartmentId = editDepartmentId ?? Guid.Empty });
            editId = null;
            await TriggerToast("Designation structures updated smoothly in corporate archives.", false);
            await LoadDesignations();
        }
        catch (Exception ex)
        {
            await TriggerToast(ex.Message, true);
        }
    }

    private async Task ToggleStatus(DesignationDto d, ChangeEventArgs e)
    {
        bool isActive = (bool)(e.Value ?? false);
        try
        {
            await DesignationService.ToggleStatusAsync(d.DesignationId, isActive);
            await TriggerToast($"Status updated to {(isActive ? "Active" : "Inactive")}.", false);
            await LoadDesignations();
        }
        catch (Exception ex)
        {
            await TriggerToast(ex.Message, true);
            await LoadDesignations(); // Force reload/reset visual state
        }
    }
}