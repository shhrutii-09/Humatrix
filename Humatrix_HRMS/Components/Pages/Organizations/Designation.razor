            color: #1e293b;
        }

        .btn-paging-arrow.disabled {
            color: #cbd5e1;
            background: transparent;
            pointer-events: none;
        }

    .premium-page-state-text {
        font-size: 12.5px;
        min-width: 70px;
        text-align: center;
    }

    .text-indigo-premium {
        color: #5c4ac7;
        font-weight: 700;
    }

    .status-indicator-pill {
        font-size: 11px;
        font-weight: 600;
        padding: 2px 8px;
        border-radius: 6px;
        display: inline-block;
        min-width: 60px;
        text-align: center;
    }

    .pill-active {
        background-color: #ecfdf5;
        color: #065f46;
    }

    .pill-inactive {
