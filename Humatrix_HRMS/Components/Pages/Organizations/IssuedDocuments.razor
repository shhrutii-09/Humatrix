@* Pages/Org/IssuedDocuments.razor *@
@page "/org/documents/issued"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "OrgAdmin,HR")]
@using Humatrix_HRMS.Data
@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Models.Documents
@using Humatrix_HRMS.Services
@using Humatrix_HRMS.Services.Documents
@using Humatrix_HRMS.DTOs.Documents
@using Microsoft.AspNetCore.Authorization
@inject IOrgDocumentGenerationService DocumentService
@inject CurrentUserService CurrentUserService
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Issued Documents — Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">

    {{!-- ── Header ──}}
    <div class="d-flex align-items-center justify-content-between mb-4 border-bottom pb-3">
        <div>
            <h2 class="fw-bold mb-0">Issued Documents</h2>
            <p class="text-muted small mb-0">All documents issued by your organisation to employees</p>
        </div>
        <div class="d-flex gap-2">
            <a href="/org/documents/upload" class="btn btn-primary btn-sm">
                📤 Issue New Document
            </a>
            <button class="btn btn-outline-secondary btn-sm" @onclick='() => Nav.NavigateTo("/org/dashboard")'>
                ← Dashboard
            </button>
        </div>
    </div>

    {{!-- ── Stats row ──}}
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm p-3 h-100 border-start border-4 border-primary">
                <div class="text-muted small fw-bold text-uppercase">Total Issued</div>
                <div class="fs-2 fw-bold">@allDocs.Count</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm p-3 h-100 border-start border-4 border-warning">
                <div class="text-muted small fw-bold text-uppercase">Pending Ack.</div>
                <div class="fs-2 fw-bold text-warning">@allDocs.Count(d => d.Status == "Issued" && d.AcknowledgedAt == null)</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm p-3 h-100 border-start border-4 border-success">
                <div class="text-muted small fw-bold text-uppercase">Acknowledged</div>
                <div class="fs-2 fw-bold text-success">@allDocs.Count(d => d.Status == "Acknowledged")</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm p-3 h-100 border-start border-4 border-danger">
                <div class="text-muted small fw-bold text-uppercase">Revoked</div>
                <div class="fs-2 fw-bold text-danger">@allDocs.Count(d => d.Status == "Revoked")</div>
            </div>
        </div>
    </div>

    {{!-- ── Filters ──}}
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body py-3">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label small fw-bold mb-1">Search</label>
                    <input type="text" class="form-control form-control-sm"
                           placeholder="Employee name, doc name..."
                           @bind="searchText" @bind:event="oninput" />
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold mb-1">Status</label>
                    <select class="form-select form-select-sm" @bind="statusFilter">
                        <option value="">All Statuses</option>
                        <option value="Issued">Issued (Pending Ack.)</option>
                        <option value="Acknowledged">Acknowledged</option>
                        <option value="Revoked">Revoked</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold mb-1">Category</label>
                    <select class="form-select form-select-sm" @bind="categoryFilter">
                        <option value="">All Categories</option>
                        <option value="Onboarding">Onboarding</option>
                        <option value="HR Policies">HR Policies</option>
                        <option value="Performance">Performance</option>
                        <option value="Exit">Exit</option>
                        <option value="General">General</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-outline-secondary btn-sm w-100"
                            @onclick="ClearFilters">
                        Clear
                    </button>
                </div>
            </div>
        </div>
    </div>

    {{!-- ── Table ──}}
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            @if (isLoading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                </div>
            }
            else if (!FilteredDocs.Any())
            {
                <div class="text-center py-5 text-muted">
                    <div class="fs-1 mb-2">📭</div>
                    <p class="mb-0">No documents match your filter.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light text-muted small text-uppercase">
                            <tr>
                                <th class="ps-4">Employee</th>
                                <th>Document</th>
                                <th>Category</th>
                                <th>Status</th>
                                <th>Issued On</th>
                                <th>Acknowledged</th>
                                <th class="text-end pe-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var doc in FilteredDocs)
                            {
                                <tr class="@(doc.Status == "Revoked" ? "table-secondary text-muted" : "")">
                                    <td class="ps-4">
                                        <div class="fw-semibold">@(doc.Employee?.FirstName) @(doc.Employee?.LastName)</div>
                                        <div class="text-muted small">@doc.Employee?.EmployeeCode</div>
                                    </td>
                                    <td>
                                        <div class="fw-medium">@doc.DocumentName</div>
                                        <div class="text-muted small">Ref: @doc.DocumentNumber</div>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(doc.ContentSnapshot))
                                        {
                                            @* Category stored in ContentSnapshot JSON or Description *@
                                        }
                                        <span class="badge @GetCategoryBadge(doc.Description)">
                                            @(doc.Description?.Split('|').FirstOrDefault()?.Trim() ?? "General")
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge @GetIssuedStatusBadge(doc.Status) px-2 py-1">
                                            @GetIssuedStatusIcon(doc.Status) @doc.Status
                                        </span>
                                    </td>
                                    <td>
                                        <div class="small">@doc.GeneratedAt.ToString("dd MMM yyyy")</div>
                                        <div class="text-muted" style="font-size:0.73rem;">
                                            by @doc.GeneratedByRole
                                        </div>
                                    </td>
                                    <td>
                                        @if (doc.AcknowledgedAt.HasValue)
                                        {
                                            <div class="text-success small fw-semibold">
                                                ✓ @doc.AcknowledgedAt.Value.ToString("dd MMM yyyy")
                                            </div>
                                            @if (!string.IsNullOrEmpty(doc.AcknowledgmentRemarks))
                                            {
                                                <div class="text-muted" style="font-size:0.72rem;" title="@doc.AcknowledgmentRemarks">
                                                    "@(doc.AcknowledgmentRemarks.Length > 40
                                                                                        ? doc.AcknowledgmentRemarks[..40] + "…"
                                                                                        : doc.AcknowledgmentRemarks)"
                                </div>
                                                                }
                                        }
                                        else if (doc.Status != "Revoked")
                                        {
                                            <span class="text-warning small">⏳ Awaiting</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">—</span>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group btn-group-sm">
                                            <a href="@doc.FilePath" target="_blank"
                                               class="btn btn-outline-primary" title="View file">
                                                👁️ View
                                            </a>
                                            <button class="btn btn-outline-secondary"
                                                    @onclick="() => ViewHistory(doc.DocumentId)"
                                                    title="Audit history">
                                                🕑
                                            </button>
                                            @if (doc.Status != "Revoked")
                                            {
                                                <button class="btn btn-outline-danger"
                                                        @onclick="() => OpenRevokeModal(doc)"
                                                        title="Revoke document">
                                                    🚫
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

{{!-- ── Revoke Modal ──}}
<div class="modal fade" id="revokeModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">🚫 Revoke Document</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                @if (docToRevoke != null)
                {
                    <div class="alert alert-warning">
                        <strong>What is Revoke?</strong><br />
                        Revoking marks a document as <strong>void/cancelled</strong>. The employee can no longer
                        acknowledge it, and it will be clearly marked as revoked in their portal. Use this when a
                        resignation is cancelled, a document was issued by mistake, or the terms have changed.
                    </div>
                    <div class="mb-3">
                        <strong>Document:</strong> @docToRevoke.DocumentName<br />
                        <strong>Employee:</strong> @docToRevoke.Employee?.FirstName @docToRevoke.Employee?.LastName
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold text-danger">Reason for Revocation <span class="text-danger">*</span></label>
                        <textarea class="form-control" @bind="revokeReason" rows="3"
                                  placeholder="e.g., Resignation cancelled by employee, document issued in error…"></textarea>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-danger" @onclick="ConfirmRevoke" disabled="@isProcessing">
                    @(isProcessing ? "Processing..." : "🚫 Revoke")
                </button>
            </div>
        </div>
    </div>
</div>

{{!-- ── History Modal ──}}
<div class="modal fade" id="historyModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">🕑 Document Audit History</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                @if (docHistory.Any())
                {
                    <div class="timeline">
                        @foreach (var h in docHistory)
                        {
                            <div class="d-flex gap-3 mb-3">
                                <div class="text-muted small text-nowrap" style="min-width:120px;">
                                    @h.PerformedAt.ToString("dd MMM yyyy HH:mm")
                                </div>
                                <div>
                                    <span class="badge @GetActionBadge(h.Action)">@h.Action</span>
                                    <span class="ms-2 small text-muted">by @h.PerformedByRole</span>
                                    @if (!string.IsNullOrEmpty(h.Remarks))
                                    {
                                        <div class="text-muted small mt-1">@h.Remarks</div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted text-center py-3">No history available.</p>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@code {
    private List<OrgGeneratedDocument> allDocs = new();
    private List<OrgDocumentHistory> docHistory = new();
    private OrgGeneratedDocument? docToRevoke;
    private string revokeReason = "";
    private string searchText = "";
    private string statusFilter = "";
    private string categoryFilter = "";
    private bool isLoading = true;
    private bool isProcessing = false;
    private ApplicationUser? _currentUser;
    private string _currentUserRole = "HR";
    private bool isOrgAdmin = false;

    private IEnumerable<OrgGeneratedDocument> FilteredDocs =>
        allDocs.Where(d =>
            (string.IsNullOrWhiteSpace(searchText) ||
                ($"{d.Employee?.FirstName} {d.Employee?.LastName}".Contains(searchText, StringComparison.OrdinalIgnoreCase)) ||
                d.DocumentName.Contains(searchText, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrWhiteSpace(statusFilter) || d.Status == statusFilter) &&
            (string.IsNullOrWhiteSpace(categoryFilter) ||
                (d.Description?.Contains(categoryFilter, StringComparison.OrdinalIgnoreCase) ?? false)));

    protected override async Task OnInitializedAsync()
    {
        _currentUser = await CurrentUserService.GetUserAsync();
        if (_currentUser?.OrganizationId == null) { Nav.NavigateTo("/login"); return; }
        isOrgAdmin = await CurrentUserService.IsInRoleAsync("OrgAdmin");
        _currentUserRole = isOrgAdmin ? "OrgAdmin" : "HR";
        await LoadDocs();
    }

    private async Task LoadDocs()
    {
        isLoading = true;
        try
        {
            allDocs = await DocumentService.GetOrganizationDocumentsAsync(
                _currentUser!.OrganizationId!.Value,
                _currentUser.Id,
                _currentUserRole);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading issued docs: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ViewHistory(Guid documentId)
    {
        docHistory = await DocumentService.GetDocumentHistoryAsync(documentId);
        await JS.InvokeVoidAsync("showModal", "historyModal");
    }

    private async Task OpenRevokeModal(OrgGeneratedDocument doc)
    {
        docToRevoke = doc;
        revokeReason = "";
        await JS.InvokeVoidAsync("showModal", "revokeModal");
    }

    private async Task ConfirmRevoke()
    {
        if (docToRevoke == null || string.IsNullOrWhiteSpace(revokeReason))
        {
            await JS.InvokeVoidAsync("alert", "Please enter a reason for revocation.");
            return;
        }
        isProcessing = true;
        try
        {
            await DocumentService.RevokeDocumentAsync(
                docToRevoke.DocumentId, _currentUser!.Id, _currentUserRole, revokeReason);
            await JS.InvokeVoidAsync("hideModal", "revokeModal");
            await LoadDocs();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Error: {ex.Message}");
        }
        finally
        {
            isProcessing = false;
        }
    }

    private void ClearFilters()
    {
        searchText = "";
        statusFilter = "";
        categoryFilter = "";
    }

    private static string GetIssuedStatusBadge(string status) => status switch
    {
        "Acknowledged" => "bg-success",
        "Issued" => "bg-warning text-dark",
        "Revoked" => "bg-danger",
        _ => "bg-secondary"
    };

    private static string GetIssuedStatusIcon(string status) => status switch
    {
        "Acknowledged" => "✓",
        "Issued" => "⏳",
        "Revoked" => "🚫",
        _ => "📄"
    };

    private static string GetCategoryBadge(string? desc)
    {
        if (desc == null) return "bg-secondary";
        if (desc.Contains("Onboarding")) return "bg-info text-dark";
        if (desc.Contains("Exit")) return "bg-danger";
        if (desc.Contains("Performance")) return "bg-warning text-dark";
        if (desc.Contains("HR Policies")) return "bg-primary";
        return "bg-secondary";
    }

    private static string GetActionBadge(string action) => action switch
    {
        "Generated" or "Uploaded" => "bg-primary",
        "Acknowledged" => "bg-success",
        "Revoked" => "bg-danger",
        "Viewed" => "bg-info text-dark",
        _ => "bg-secondary"
    };
}
