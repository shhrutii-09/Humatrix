@page "/orgadmin/assets/history/{AssetId:guid}"
@attribute [Authorize(Roles = "OrgAdmin")]

@using Humatrix_HRMS.DTOs.Asset
@using Humatrix_HRMS.Infrastructure.Services
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization

@inject AssetService AssetSvc
@inject CurrentUserService CurrentUser
@inject NavigationManager Nav

<PageTitle>Asset History</PageTitle>

<div class="container-fluid px-4 py-3">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-0">Asset Assignment History</h4>
            <small class="text-muted">
                Complete assignment timeline
            </small>
        </div>

        <button class="btn btn-outline-secondary btn-sm"
                @onclick="GoBack">
            <i class="bi bi-arrow-left me-1"></i>
            Back
        </button>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger">
            @_error
        </div>
    }
    else
    {
        <!-- Asset Summary -->
        @if (_asset != null)
        {
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">

                    <div class="row">

                        <div class="col-md-3">
                            <small class="text-muted d-block">
                                Asset Code
                            </small>

                            <code>@_asset.AssetCode</code>
                        </div>

                        <div class="col-md-3">
                            <small class="text-muted d-block">
                                Asset Name
                            </small>

                            <span class="fw-semibold">
                                @_asset.AssetName
                            </span>
                        </div>

                        <div class="col-md-2">
                            <small class="text-muted d-block">
                                Category
                            </small>

                            @_asset.Category
                        </div>

                        <div class="col-md-2">
                            <small class="text-muted d-block">
                                Status
                            </small>

                            <span class="badge bg-primary">
                                @_asset.Status
                            </span>
                        </div>

                        <div class="col-md-2">
                            <small class="text-muted d-block">
                                Condition
                            </small>

                            @_asset.Condition
                        </div>

                    </div>

                </div>
            </div>
        }

        <!-- History Table -->
        <div class="card border-0 shadow-sm">

            <div class="card-body p-0">

                @if (!_history.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-clock-history fs-1 d-block mb-2"></i>
                        No assignment history found.
                    </div>
                }
                else
                {
                    <div class="table-responsive">

                        <table class="table table-hover align-middle mb-0">

                            <thead class="table-light">
                                <tr>
                                    <th>Employee</th>
                                    <th>Assigned By</th>
                                    <th>Assigned At</th>
                                    <th>Returned At</th>
                                    <th>Return Condition</th>
                                    <th>Status</th>
                                    <th>Notes</th>
                                </tr>
                            </thead>

                            <tbody>

                                @foreach (var h in _history)
                                {
                                    <tr>

                                        <td>
                                            <div class="fw-semibold">
                                                @h.EmployeeName
                                            </div>

                                            <small class="text-muted">
                                                @h.EmployeeCode
                                            </small>
                                        </td>

                                        <td>
                                            @h.AssignedByName
                                        </td>

                                        <td>
                                            @h.AssignedAt.ToLocalTime()
                                            .ToString("dd MMM yyyy hh:mm tt")
                                        </td>

                                        <td>
                                            @if (h.ReturnedAt.HasValue)
                                            {
                                @h.ReturnedAt.Value.ToLocalTime().ToString("dd MMM yyyy hh:mm tt")
                                                                            }
                                            else
                                            {
                                                <span class="text-muted">
                                                    —
                                                </span>
                                            }
                                        </td>

                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(h.ReturnCondition))
                                            {
                                                @h.ReturnCondition
                                            }
                                            else
                                            {
                                                <span class="text-muted">
                                                    —
                                                </span>
                                            }
                                        </td>

                                        <td>
                                            @if (h.IsActive)
                                            {
                                                <span class="badge bg-success">
                                                    Active
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">
                                                    Returned
                                                </span>
                                            }
                                        </td>

                                        <td style="max-width:250px">
                                            @if (!string.IsNullOrWhiteSpace(h.AssignmentNotes))
                                            {
                                                @h.AssignmentNotes
                                            }
                                            else
                                            {
                                                <span class="text-muted">
                                                    —
                                                </span>
                                            }
                                        </td>

                                    </tr>
                                }

                            </tbody>

                        </table>

                    </div>
                }

            </div>

        </div>
    }

</div>

@code {

    [Parameter]
    public Guid AssetId { get; set; }

    private AssetDto? _asset;

    private List<AssetAssignmentHistoryDto> _history = new();

    private bool _loading = true;

    private string? _error;

    private Guid _orgId;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var user = await CurrentUser.GetUserAsync();

            _orgId = user?.OrganizationId ?? Guid.Empty;

            _asset = await AssetSvc.GetByIdAsync(
                AssetId,
                _orgId);

            _history = await AssetSvc.GetAssignmentHistoryAsync(
                AssetId,
                _orgId);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private void GoBack()
    {
        Nav.NavigateTo("/orgadmin/assets");
    }
}