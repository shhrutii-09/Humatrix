@page "/org/create-designation"
@rendermode InteractiveServer

@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize(Roles = "OrgAdmin")]

@inject DesignationService DesignationService
@inject DepartmentService DepartmentService
@inject NavigationManager Nav

<PageTitle>Create Designation | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom row-gap-3 flex-wrap">
        <div>
            <h2 class="fw-bold tracking-tight text-dark mb-1">Create New Designation</h2>
            <p class="text-muted small mb-0">Define a new professional role and map it to an organizational department.</p>
        </div>
        <button class="btn btn-interactive-back shadow-sm" @onclick="GoBack">
            BACK TO DESIGNATIONS
        </button>
    </div>

    <div class="card border-0 shadow-sm form-container-card mx-auto ms-0">
        <div class="card-body p-4">
            <EditForm Model="model" OnValidSubmit="HandleCreateDesignation">
                <DataAnnotationsValidator />

                <div class="row">
                    <div class="col-xl-8 col-lg-10 col-md-12">

                        <div class="mb-4">
                            <label class="form-label small fw-bold text-secondary tracking-wider mb-2">DESIGNATION NAME</label>
                            <InputText @bind-Value="model.Name"
                                       class="form-control premium-form-input"
                                       placeholder="e.g. Senior Software Engineer, HR Manager..." />
                            <ValidationMessage For="@(() => model.Name)" class="text-danger small mt-1 d-block fw-medium" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold text-secondary tracking-wider mb-2">ASSIGN DEPARTMENT</label>
                            <div class="dropdown-box-wrapper">
                                <select class="form-select premium-dropdown-select shadow-none" @bind="model.DepartmentId">
                                    <option value="@Guid.Empty" disabled selected>-- Select Aligned Department --</option>
                                    @if (departments != null)
                                    {
                                        @foreach (var dept in departments)
                                        {
                                            <option value="@dept.DepartmentId">@dept.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                            <ValidationMessage For="@(() => model.DepartmentId)" class="text-danger small mt-1 d-block fw-medium" />
                        </div>

                        @if (!string.IsNullOrEmpty(error))
                        {
                            <div class="alert alert-premium-danger d-flex align-items-center mb-4 border-0" role="alert">
                                <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
                                <div class="small fw-medium">@error</div>
                            </div>
                        }

                        <div class="d-flex gap-2 border-top pt-4 mt-2">
                            <button type="submit"
                                    class="btn btn-action-submit px-4 shadow-sm d-flex align-items-center gap-2"
                                    disabled="@isSubmitting">
                                @if (isSubmitting)
                                {
                                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                    <span>Processing Role...</span>
                                }
                                else
                                {
                                    <i class="bi bi-check-circle-fill"></i>
                                    <span>Create Designation</span>
                                }
                            </button>

                            <button type="button"
                                    class="btn btn-action-cancel px-4"
                                    @onclick="GoBack">
                                Cancel
                            </button>
                        </div>

                    </div>
                </div>
            </EditForm>
        </div>
    </div>
</div>

<style>
    /* Framework Structural Configuration Rules */
    .tracking-tight {
        letter-spacing: -0.025em;
    }

    .tracking-wider {
        letter-spacing: 0.05em;
        font-size: 11px !important;
    }

    .form-container-card {
        border-radius: 14px;
        background-color: #ffffff;
        max-width: 800px;
    }

    /* Premium Typography Inputs & Dropdowns styling */
    .premium-form-input, .premium-dropdown-select {
        font-size: 14px;
        padding: 10px 14px;
        border-radius: 10px;
        border: 1px solid #cbd5e1;
        background-color: #f8fafc !important;
        color: #1e293b;
        transition: all 0.2s ease;
    }

        .premium-form-input:focus, .premium-dropdown-select:focus {
            border-color: #5c4ac7 !important;
            background-color: #ffffff !important;
            box-shadow: 0 0 0 4px rgba(92, 74, 199, 0.12) !important;
        }

    .dropdown-box-wrapper {
        position: relative;
        display: flex;
        width: 100%;
    }

    .premium-dropdown-select {
        width: 100%;
        appearance: none;
        cursor: pointer;
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%23475569' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='m2 5 6 6 6-6'/%3e%3c/svg%3e") !important;
        background-repeat: no-repeat !important;
        background-position: right 14px center !important;
        background-size: 14px var(--bs-body-font-size) !important;
        padding-right: 40px !important;
    }

    .premium-form-input::placeholder {
        color: #94a3b8;
        font-size: 13.5px;
    }

    /* Interactive Navigation Header Controls */
    .btn-interactive-back {
        background: #ffffff !important;
        border: 1px solid #e5e7eb !important;
        color: #4b5563 !important;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
        transition: all 0.2s ease;
    }

        .btn-interactive-back:hover {
            background-color: #f8fafc !important;
            border-color: #5c4ac7 !important;
            color: #5c4ac7 !important;
            transform: translateY(-1px);
        }

    /* Action Form Processing Buttons */
    .btn-action-submit {
        background-color: #5c4ac7 !important;
        color: #ffffff !important;
        border: none !important;
        padding: 10px 20px;
        border-radius: 10px;
        font-size: 13.5px;
        font-weight: 600;
        transition: all 0.2s ease;
    }

        .btn-action-submit:hover:not(:disabled) {
            background-color: #4b3ba6 !important;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(92, 74, 199, 0.2) !important;
        }

        .btn-action-submit:disabled {
            opacity: 0.65;
            cursor: not-allowed;
        }

    .btn-action-cancel {
        background-color: #ffffff;
        color: #475569;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 10px 20px;
        font-size: 13.5px;
        font-weight: 500;
        transition: all 0.2s ease;
    }

        .btn-action-cancel:hover {
            background-color: #f1f5f9;
            color: #1e293b;
        }

    /* High-End System Alerts Override */
    .alert-premium-danger {
        background-color: #fef2f2;
        color: #991b1b;
        border-left: 4px solid #ef4444 !important;
        border-radius: 8px;
        padding: 12px 16px;
    }
</style>

@code {
    public CreateDesignationDto model { get; set; } = new();
    private List<DepartmentDto>? departments;

    private string? error;
    private bool isSubmitting;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            departments = await DepartmentService.GetAllAsync();
        }
        catch (Exception ex)
        {
            error = "Failed to load corporate departments. " + ex.Message;
        }
    }

    async Task HandleCreateDesignation()
    {
        error = null;

        if (string.IsNullOrWhiteSpace(model.Name))
        {
            error = "Designation title is required before executing creation protocols.";
            return;
        }

        if (model.DepartmentId == Guid.Empty)
        {
            error = "Please assign a valid corporate department to this role configuration.";
            return;
        }

        isSubmitting = true;

        try
        {
            await DesignationService.CreateAsync(model);
            Nav.NavigateTo("/org/designations");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    void GoBack() => Nav.NavigateTo("/org/designations");
}