@page "/org/add-employee"
@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization
@rendermode InteractiveServer
@attribute [Authorize(Roles = "OrgAdmin")]

@inject EmployeeService EmployeeService
@inject DepartmentService DeptService
@inject DesignationService DesignationService
@inject ShiftService ShiftService
@inject NavigationManager Nav

<PageTitle>Add Employee | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom row-gap-3 flex-wrap">
        <div>
            <h2 class="fw-bold tracking-tight text-dark mb-1">Add New Employee</h2>
            <p class="text-muted small mb-0">Define a new employee structure and trigger an activation email.</p>
        </div>
        <button class="btn btn-interactive-back shadow-sm" @onclick="GoBack">
            BACK TO EMPLOYEES
        </button>
    </div>

    <div class="card shadow-sm border-0 rounded-3 bg-white mb-4 custom-form-card">
        <div class="card-body p-4">

            @if (isPageLoading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-indigo"></div>
                    <div class="text-muted mt-2 small">Loading onboarding configurations...</div>
                </div>
            }
            else
            {
                <EditForm Model="model" OnValidSubmit="HandleSubmit" FormName="addEmployeeForm">
                    <DataAnnotationsValidator />

                    <div class="row g-4">
                        <div class="col-md-7 pe-md-4">
                            <h5 class="mb-4 text-secondary text-uppercase tracking-wider section-title">Basic Information</h5>

                            <div class="row">
                                <div class="col-md-6 mb-4">
                                    <label class="form-label small fw-bold text-secondary tracking-wider mb-2">FIRST NAME</label>
                                    <InputText @bind-Value="model.FirstName" class="form-control premium-form-input shadow-none" placeholder="e.g. John" disabled="@isSubmitting" />
                                    <ValidationMessage For="@(() => model.FirstName)" class="text-danger small mt-1" />
                                </div>

                                <div class="col-md-6 mb-4">
                                    <label class="form-label small fw-bold text-secondary tracking-wider mb-2">LAST NAME</label>
                                    <InputText @bind-Value="model.LastName" class="form-control premium-form-input shadow-none" placeholder="e.g. Doe" disabled="@isSubmitting" />
                                    <ValidationMessage For="@(() => model.LastName)" class="text-danger small mt-1" />
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label small fw-bold text-secondary tracking-wider mb-2">CORPORATE EMAIL ADDRESS</label>
                                <InputText @bind-Value="model.Email" type="email" class="form-control premium-form-input shadow-none" placeholder="employee@yopmail.com" disabled="@isSubmitting" />
                                <ValidationMessage For="@(() => model.Email)" class="text-danger small mt-1" />
                                <small class="text-muted d-block mt-1" style="font-size: 0.75rem;">*Employee will receive activation mail on Yopmail.</small>
                            </div>

                            <div class="mb-4">
                                <label class="form-label small fw-bold text-secondary tracking-wider mb-2">DATE OF BIRTH</label>
                                <InputDate @bind-Value="model.DateOfBirth" class="form-control premium-form-input shadow-none" disabled="@isSubmitting" />
                                <ValidationMessage For="@(() => model.DateOfBirth)" class="text-danger small mt-1" />
                            </div>
                        </div>

                        <div class="col-md-5 border-start ps-md-4">
                            <h5 class="mb-4 text-secondary text-uppercase tracking-wider section-title">Assignment</h5>

                            <div class="mb-4">
                                <label class="form-label small fw-bold text-secondary tracking-wider mb-2">DEPARTMENT</label>
                                <select class="form-select premium-form-input shadow-none"
                                        @onchange="OnDepartmentChanged"
                                        disabled="@isSubmitting">
                                    <option value="" disabled selected>Select Department</option>
                                    @foreach (var d in departments)
                                    {
                                        <option value="@d.DepartmentId">@d.Name</option>
                                    }
                                </select>
                                <ValidationMessage For="@(() => model.DepartmentId)" class="text-danger small mt-1" />
                            </div>

                            <div class="mb-4">
                                <label class="form-label small fw-bold text-secondary tracking-wider mb-2">DESIGNATION</label>
                                @if (isDesignationLoading)
                                {
                                    <div class="text-muted small py-2 d-flex align-items-center">
                                        <span class="spinner-border spinner-border-sm text-indigo me-2"></span>
                                        Retrieving roles...
                                    </div>
                                }
                                else
                                {
                                    <InputSelect @bind-Value="model.DesignationId"
                                                 class="form-select premium-form-input shadow-none"
                                                 disabled="@(isSubmitting || !model.DepartmentId.HasValue)">
                                        <option value="" disabled selected>Select Designation</option>
                                        @foreach (var d in designations)
                                        {
                                            <option value="@d.DesignationId">@d.Name</option>
                                        }
                                    </InputSelect>
                                }
                                <ValidationMessage For="@(() => model.DesignationId)" class="text-danger small mt-1" />
                            </div>

                            <div class="mb-4">
                                <label class="form-label small fw-bold text-secondary tracking-wider mb-2">WORK SHIFT</label>
                                <InputSelect @bind-Value="model.ShiftId"
                                             class="form-select premium-form-input shadow-none"
                                             disabled="@isSubmitting">
                                    <option value="" disabled selected>Select Shift</option>
                                    @foreach (var s in shifts)
                                    {
                                        <option value="@s.ShiftId">@s.Name</option>
                                    }
                                </InputSelect>
                                <ValidationMessage For="@(() => model.ShiftId)" class="text-danger small mt-1" />
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 pt-4 border-top d-flex gap-2">
                        <button type="submit"
                                class="btn btn-action-submit px-4 shadow-sm d-flex align-items-center gap-2"
                                disabled="@isSubmitting">
                            @if (isSubmitting)
                            {
                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                <span>Provisioning Employee...</span>
                            }
                            else
                            {
                                <i class="bi bi-check-circle-fill"></i>
                                <span>Create Employee</span>
                            }
                        </button>

                        <button type="button"
                                class="btn btn-action-cancel px-4"
                                @onclick="GoBack">
                            Cancel
                        </button>
                    </div>
                </EditForm>
            }

            @if (isCreatedSuccessfully)
            {
                <div class="alert alert-success mt-4 border-0 shadow-sm p-4" style="background-color: #e6ffed;">
                    <div class="d-flex align-items-start">
                        <i class="bi bi-check-circle-fill fs-3 text-success me-3"></i>
                        <div>
                            <h5 class="text-success fw-bold mb-2">Employee Account Created Successfully!</h5>
                            <p class="mb-0 text-muted small">Activation mail has been dispatched to the Yopmail inbox.</p>
                        </div>
                    </div>
                </div>
            }

            @if (!string.IsNullOrEmpty(error))
            {
                <div class="alert alert-premium-danger mt-4 shadow-sm border-0 d-flex align-items-center">
                    <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
                    <div class="small fw-medium">@error</div>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .tracking-tight {
        letter-spacing: -0.025em;
    }

    .tracking-wider {
        letter-spacing: 0.05em;
        font-size: 11px !important;
    }

    .section-title {
        color: #94a3b8 !important;
    }

    .premium-form-input {
        font-size: 14px;
        padding: 10px 14px;
        border-radius: 10px;
        border: 1px solid #cbd5e1;
        background-color: #f8fafc !important;
        transition: all 0.2s ease;
    }

        .premium-form-input:focus {
            border-color: #5c4ac7;
            background-color: #ffffff !important;
            box-shadow: 0 0 0 4px rgba(92, 74, 199, 0.12);
        }

    .btn-interactive-back {
        background: #ffffff !important;
        border: 1px solid #e5e7eb !important;
        color: #4b5563 !important;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
        transition: all 0.2s ease;
    }

        .btn-interactive-back:hover {
            background-color: #f8fafc !important;
            border-color: #5c4ac7 !important;
            color: #5c4ac7 !important;
            transform: translateY(-1px);
        }

    .btn-action-submit {
        background-color: #5c4ac7 !important;
        color: #ffffff !important;
        border: none !important;
        padding: 10px 20px;
        border-radius: 10px;
        font-size: 13.5px;
        font-weight: 600;
    }

    .btn-action-cancel {
        background-color: #ffffff;
        color: #475569;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 10px 20px;
        font-size: 13.5px;
    }

    .alert-premium-danger {
        background-color: #fef2f2;
        color: #991b1b;
        border-left: 4px solid #ef4444 !important;
        border-radius: 8px;
        padding: 12px 16px;
    }
</style>

@code {
    CreateEmployeeDto model = new();
    List<DepartmentDto> departments = new();
    List<DesignationDto> designations = new();
    private List<Shift> shifts = new();

    string? error;
    bool isSubmitting;
    bool isPageLoading = true;
    bool isDesignationLoading = false;
    bool isCreatedSuccessfully = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            departments = await DeptService.GetActiveAsync();
            shifts = await ShiftService.GetAllShiftsAsync();
        }
        catch
        {
            error = "Failed to load foundational server parameters.";
        }
        finally
        {
            isPageLoading = false;
        }
    }

    private async Task OnDepartmentChanged(ChangeEventArgs e)
    {
        isDesignationLoading = true;
        var selectedValue = e.Value?.ToString();

        if (Guid.TryParse(selectedValue, out var deptId))
        {
            model.DepartmentId = deptId;
            model.DesignationId = null;
            designations = await DesignationService.GetByDepartmentAsync(deptId);
        }
        else
        {
            model.DepartmentId = null;
            model.DesignationId = null;
            designations.Clear();
        }
        isDesignationLoading = false;
    }

    private async Task HandleSubmit()
    {
        try
        {
            error = null;
            isCreatedSuccessfully = false;
            isSubmitting = true;

            model.Role = "Employee";
            await EmployeeService.CreateEmployeeAsync(model);

            isCreatedSuccessfully = true;
            model = new CreateEmployeeDto();
            designations.Clear();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    void GoBack() => Nav.NavigateTo("/employees");
}