@page "/org/add-employee"
@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization
@rendermode InteractiveServer
@attribute [Authorize(Roles = "OrgAdmin")]

@inject EmployeeService EmployeeService
@inject DepartmentService DeptService
@inject DesignationService DesignationService
@inject ShiftService ShiftService
@inject NavigationManager Nav

<PageTitle>Add Employee | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1" style="font-size: 2rem;">Add New Employee</h2>
            <p class="text-muted small mb-0">Define a new employee structure and trigger an activation email.</p>
        </div>
        <button class="btn bg-white border text-secondary fw-bold px-4 py-2 text-uppercase shadow-sm text-back-btn"
                @onclick='() => Nav.NavigateTo("/employees")'>
            Back to Employees
        </button>
    </div>

    <div class="card shadow-sm border-0 rounded-3 bg-white mb-4 custom-form-card">
        <div class="card-body p-4.5">

            @if (isPageLoading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-indigo"></div>
                    <div class="text-muted mt-2 small">Loading onboarding configurations...</div>
                </div>
            }
            else
            {
                <EditForm Model="model" OnValidSubmit="HandleSubmit" FormName="addEmployeeForm">
                    <DataAnnotationsValidator />

                    <div class="row g-4">
                        <div class="col-md-7 pe-md-4">
                            <h5 class="mb-4 text-secondary text-uppercase tracking-wider section-title">Basic Information</h5>

                            <div class="row">
                                <div class="col-md-6 mb-4">
                                    <label class="form-label small fw-bold text-uppercase tracking-wider input-label">First Name</label>
                                    <InputText @bind-Value="model.FirstName"
                                               class="form-control custom-dept-input shadow-none"
                                               placeholder="e.g. John"
                                               disabled="@isSubmitting" />
                                    <ValidationMessage For="@(() => model.FirstName)" class="text-danger small mt-1" />
                                </div>

                                <div class="col-md-6 mb-4">
                                    <label class="form-label small fw-bold text-uppercase tracking-wider input-label">Last Name</label>
                                    <InputText @bind-Value="model.LastName"
                                               class="form-control custom-dept-input shadow-none"
                                               placeholder="e.g. Doe"
                                               disabled="@isSubmitting" />
                                    <ValidationMessage For="@(() => model.LastName)" class="text-danger small mt-1" />
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label small fw-bold text-uppercase tracking-wider input-label">Corporate Email Address</label>
                                <InputText @bind-Value="model.Email"
                                           type="email"
                                           class="form-control custom-dept-input shadow-none"
                                           placeholder="employee@yopmail.com"
                                           disabled="@isSubmitting" />
                                <ValidationMessage For="@(() => model.Email)" class="text-danger small mt-1" />
                                <small class="text-muted d-block mt-1" style="font-size: 0.75rem;">
                                    *Employee will receive activation mail on Yopmail.
                                </small>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold text-uppercase tracking-wider input-label">Date of Birth</label>
                            <InputDate @bind-Value="model.DateOfBirth"
                                       class="form-control custom-dept-input shadow-none"
                                       disabled="@isSubmitting" />
                            <ValidationMessage For="@(() => model.DateOfBirth)" class="text-danger small mt-1" />
                        </div>

                        <div class="col-md-5 border-start ps-md-4">
                            <h5 class="mb-4 text-secondary text-uppercase tracking-wider section-title">Assignment</h5>

                            <div class="mb-4">
                                <label class="form-label small fw-bold text-uppercase tracking-wider input-label">Department</label>
                                <select class="form-select custom-dept-input shadow-none"
                                        @onchange="OnDepartmentChanged"
                                        disabled="@isSubmitting">
                                    <option value="" disabled selected>Select Department</option>
                                    @foreach (var d in departments)
                                    {
                                        <option value="@d.DepartmentId">@d.Name</option>
                                    }
                                </select>
                                <ValidationMessage For="@(() => model.DepartmentId)" class="text-danger small mt-1" />
                            </div>

                            <div class="mb-4">
                                <label class="form-label small fw-bold text-uppercase tracking-wider input-label">Designation</label>

                                @if (isDesignationLoading)
                                {
                                    <div class="text-muted small py-2 d-flex align-items-center">
                                        <span class="spinner-border spinner-border-sm text-indigo me-2"></span>
                                        Retrieving roles...
                                    </div>
                                }
                                else
                                {
                                    <InputSelect @bind-Value="model.DesignationId"
                                                 class="form-select custom-dept-input shadow-none"
                                                 disabled="@(isSubmitting || !model.DepartmentId.HasValue)">
                                        <option value="" disabled selected>Select Designation</option>
                                        @foreach (var d in designations)
                                        {
                                            <option value="@d.DesignationId">@d.Name</option>
                                        }
                                    </InputSelect>
                                }

                                <ValidationMessage For="@(() => model.DesignationId)" class="text-danger small mt-1" />
                            </div>

                            <div class="mb-4">
                                <label class="form-label small fw-bold text-uppercase tracking-wider input-label">Work Shift</label>
                                <InputSelect @bind-Value="model.ShiftId"
                                             class="form-select custom-dept-input shadow-none"
                                             disabled="@isSubmitting">
                                    <option value="" disabled selected>Select Shift</option>
                                    @foreach (var s in shifts)
                                    {
                                        <option value="@s.ShiftId">@s.Name</option>
                                    }
                                </InputSelect>
                                <ValidationMessage For="@(() => model.ShiftId)" class="text-danger small mt-1" />
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 pt-4 border-top d-flex gap-2 justify-content-start">
                        <button type="submit"
                                class="btn text-white fw-bold px-4 py-2 text-uppercase btn-create-dept"
                                disabled="@isSubmitting">
                            @if (isSubmitting)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                <span>Provisioning Employee...</span>
                            }
                            else
                            {
                                <i class="bi bi-shield-check me-2"></i>
                        
                                <span>CREATE EMPLOYEE</span>
                            }
                        </button>

                        <button type="button"
                                class="btn btn-light border bg-white text-secondary fw-medium px-4 py-2"
                                @onclick='() => Nav.NavigateTo("/employees")'
                                disabled="@isSubmitting">
                            Cancel
                        </button>
                    </div>
                </EditForm>
            }

            @if (isCreatedSuccessfully)
            {
                <div class="alert alert-premium-success mt-4 border-0 shadow-sm p-4 animate__animated animate__fadeIn"
                     style="background-color: #e6ffed;">
                    <div class="d-flex align-items-start">
                        <div class="success-icon-badge me-3">
                            <i class="bi bi-check-circle-fill fs-3 text-success"></i>
                        </div>
                        <div>
                            <h5 class="text-success fw-bold mb-2">Employee Account Created Successfully!</h5>
                            <p class="mb-1 text-dark">Employee activation mail has been sent successfully.</p>
                            <p class="mb-0 text-muted small">Please check the provided Yopmail inbox and activate the employee account.</p>
                        </div>
                    </div>
                </div>
            }

            @if (!string.IsNullOrEmpty(error))
            {
                <div class="alert alert-premium-danger mt-4 shadow-sm border-0 d-flex align-items-center" style="background-color: #fbebeb; color: #dc3545;">
                    <i class="bi bi-exclamation-triangle-fill me-3 fs-4"></i>
                    <div>
                        <h6 class="mb-0 fw-bold">System Registration Blocked</h6>
                        <span class="small opacity-90">@error</span>
                    </div>
                </div>
            }

        </div>
    </div>
</div>

<style>
    .custom-form-card {
        border-radius: 12px !important;
    }

    .text-back-btn {
        font-size: 0.785rem !important;
        letter-spacing: 0.5px;
        border-radius: 8px !important;
        color: #5a6a85 !important;
    }

    .section-title {
        font-size: 0.76rem !important;
        font-weight: 700 !important;
        letter-spacing: 0.8px;
        color: #94a3b8 !important;
    }

    .input-label {
        font-size: 0.72rem !important;
        font-weight: 700 !important;
        letter-spacing: 0.6px;
        color: #64748b !important;
        margin-bottom: 0.5rem;
    }

    .custom-dept-input {
        background-color: #f8fafc !important;
        border: 1px solid #e2e8f0 !important;
        border-radius: 8px !important;
        padding: 0.7rem 1rem;
        font-size: 0.92rem;
        color: #334155;
    }

        .custom-dept-input:focus {
            background-color: #ffffff !important;
            border-color: #5c4ac7 !important;
            box-shadow: 0 0 0 4px rgba(92, 74, 199, 0.12) !important;
        }

    .btn-create-dept {
        background-color: #5c4ac7 !important;
        font-size: 0.785rem !important;
        letter-spacing: 0.5px;
        border-radius: 8px !important;
    }

        .btn-create-dept:hover {
            background-color: #4b3bb3 !important;
        }

    .alert-premium-success {
        border: 1px solid rgba(22, 163, 74, 0.15) !important;
        border-radius: 12px;
    }

    .success-icon-badge {
        color: #16a34a;
        background: rgba(22, 163, 74, 0.1);
        width: 42px;
        height: 42px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .text-indigo {
        color: #5c4ac7 !important;
    }
</style>

@code {
    CreateEmployeeDto model = new();
    List<DepartmentDto> departments = new();
    List<DesignationDto> designations = new();
    private List<Shift> shifts = new();

    string? error;
    bool isSubmitting;
    bool isPageLoading = true;
    bool isDesignationLoading = false;
    bool isCreatedSuccessfully = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            departments = await DeptService.GetActiveAsync();
            shifts = await ShiftService.GetAllShiftsAsync();
        }
        catch
        {
            error = "Failed to load foundational server parameters.";
        }
        finally
        {
            isPageLoading = false;
        }
    }

    private async Task OnDepartmentChanged(ChangeEventArgs e)
    {
        isDesignationLoading = true;
        var selectedValue = e.Value?.ToString();

        if (Guid.TryParse(selectedValue, out var deptId))
        {
            model.DepartmentId = deptId;
            model.DesignationId = null;
            designations = await DesignationService.GetByDepartmentAsync(deptId);
        }
        else
        {
            model.DepartmentId = null;
            model.DesignationId = null;
            designations.Clear();
        }

        isDesignationLoading = false;
    }

    private async Task HandleSubmit()
    {
        try
        {
            error = null;
            isCreatedSuccessfully = false;
            isSubmitting = true;

            model.Role = "Employee";

            // This triggers the email sending internally inside EmployeeService, just like HR onboarding
            await EmployeeService.CreateEmployeeAsync(model);

            isCreatedSuccessfully = true;
            model = new CreateEmployeeDto();
            designations.Clear();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }
}