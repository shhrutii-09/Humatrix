@page "/org/add-employee"
@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization
@rendermode InteractiveServer
@attribute [Authorize(Roles = "OrgAdmin")]

@inject EmployeeService EmployeeService
@inject DepartmentService DeptService
@inject DesignationService DesignationService
@inject ShiftService ShiftService
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Add Employee | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-normal">Add New Employee</h2>
        <button class="btn btn-primary shadow-sm"
                style="background-color: #5c4ac7; border: none;"
                @onclick='() => Nav.NavigateTo("/org/dashboard")'>
            BACK TO DASHBOARD
        </button>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">

            @if (isPageLoading)
            {
                <!-- 🔥 PAGE LOADING -->
                <div class="text-center py-5">
                    <div class="spinner-border text-primary"></div>
                    <div class="text-muted mt-2">Loading form...</div>
                </div>
            }
            else
            {
                <EditForm Model="model" OnValidSubmit="HandleSubmit" FormName="addEmployeeForm">
                    <DataAnnotationsValidator />

                    <div class="row g-4">
                        <!-- LEFT -->
                        <div class="col-md-7">
                            <h5 class="mb-3 text-muted border-bottom pb-2">Basic Information</h5>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label small fw-bold">First Name</label>
                                    <InputText @bind-Value="model.FirstName"
                                               class="form-control"
                                               placeholder="Enter first name"
                                               disabled="@isSubmitting" />
                                    <ValidationMessage For="@(() => model.FirstName)" class="text-danger small" />
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label class="form-label small fw-bold">Last Name</label>
                                    <InputText @bind-Value="model.LastName"
                                               class="form-control"
                                               placeholder="Enter last name"
                                               disabled="@isSubmitting" />
                                    <ValidationMessage For="@(() => model.LastName)" class="text-danger small" />
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label small fw-bold">Email Address</label>
                                <InputText @bind-Value="model.Email"
                                           type="email"
                                           class="form-control"
                                           placeholder="employee@company.com"
                                           disabled="@isSubmitting" />
                                <ValidationMessage For="@(() => model.Email)" class="text-danger small" />
                            </div>
                        </div>

                        <!-- RIGHT -->
                        <div class="col-md-5 border-start ps-4">
                            <h5 class="mb-3 text-muted border-bottom pb-2">Assignment</h5>

                            <!-- Department -->
                            <div class="mb-3">
                                <label class="form-label small fw-bold">Department</label>
                                <select class="form-select"
                                        @onchange="OnDepartmentChanged"
                                        disabled="@isSubmitting">
                                    <option value="" disabled selected>Select Department</option>
                                    @foreach (var d in departments)
                                    {
                                        <option value="@d.DepartmentId">@d.Name</option>
                                    }
                                </select>
                                <ValidationMessage For="@(() => model.DepartmentId)" class="text-danger small" />
                            </div>

                            <!-- Designation -->
                            <div class="mb-3">
                                <label class="form-label small fw-bold">Designation</label>

                                @if (isDesignationLoading)
                                {
                                    <div class="text-muted small">
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                        Loading designations...
                                    </div>
                                }
                                else
                                {
                                    <InputSelect @bind-Value="model.DesignationId"
                                                 class="form-select"
                                                 disabled="@isSubmitting">
                                        <option value="" disabled selected>Select Designation</option>
                                        @foreach (var d in designations)
                                        {
                                            <option value="@d.DesignationId">@d.Name</option>
                                        }
                                    </InputSelect>
                                }

                                <ValidationMessage For="@(() => model.DesignationId)" class="text-danger small" />
                            </div>

                            <!-- Shift -->
                            <div class="mb-3">
                                <label class="form-label small fw-bold">Work Shift</label>
                                <InputSelect @bind-Value="model.ShiftId"
                                             class="form-select"
                                             disabled="@isSubmitting">
                                    <option value="" disabled selected>Select Shift</option>
                                    @foreach (var s in shifts)
                                    {
                                        <option value="@s.ShiftId">@s.Name</option>
                                    }
                                </InputSelect>
                                <ValidationMessage For="@(() => model.ShiftId)" class="text-danger small" />
                            </div>
                        </div>
                    </div>

                    <!-- SUBMIT -->
                    <div class="mt-4 border-top pt-3 text-end">
                        <button type="submit"
                                class="btn btn-success px-5"
                                style="background-color: #28a745; border: none;"
                                disabled="@isSubmitting">

                            @if (isSubmitting)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                <span>PROCESSING...</span>
                            }
                            else
                            {
                                <span>GENERATE INVITE</span>
                            }
                        </button>
                    </div>
                </EditForm>
            }

            <!-- ✅ KEEPING YOUR ORIGINAL SUCCESS BLOCK EXACTLY -->
            @if (!string.IsNullOrEmpty(link))
            {
                <div class="alert alert-success mt-4 border-0 shadow-sm d-flex align-items-center p-3" style="background-color: #e6ffed;">
                    <div class="d-flex w-100 justify-content-between align-items-center">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-check-circle-fill fs-4 text-success me-3"></i>
                            <b class="text-success" style="font-size: 1.1rem;">Employee created successfully!</b>
                        </div>

                        <div class="d-flex align-items-center">
                            @if (showCopiedFeedback)
                            {
                                <span class="badge bg-success me-2 animate__animated animate__fadeIn">Copied!</span>
                            }

                            <button class="btn btn-link text-success border-0 fs-3 p-0"
                                    title="Copy Invite Link"
                                    @onclick="CopyLinkToClipboard">
                                <i class="bi bi-files"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }

            <!-- ERROR -->
            @if (!string.IsNullOrEmpty(error))
            {
                <div class="alert alert-danger alert-dismissible fade show mt-3 border-0 shadow-sm">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @error
                    <button type="button" class="btn-close" @onclick="() => error = null"></button>
                </div>
            }

        </div>
    </div>
</div>

<style>
    .form-control:focus, .form-select:focus {
        border-color: #5c4ac7;
        box-shadow: 0 0 0 0.2rem rgba(92, 74, 199, 0.25);
    }

    .form-label {
        color: #6c757d;
    }
</style>

@code {
    CreateEmployeeDto model = new();
    List<DepartmentDto> departments = new();
    List<DesignationDto> designations = new();
    private List<Shift> shifts = new();

    string? link;
    string? error;

    bool isSubmitting;
    bool isPageLoading = true;
    bool isDesignationLoading = false;

    private bool showCopiedFeedback = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            departments = await DeptService.GetActiveAsync();
            shifts = await ShiftService.GetAllShiftsAsync();
        }
        catch
        {
            error = "Failed to load data";
        }
        finally
        {
            isPageLoading = false;
        }
    }

    private async Task OnDepartmentChanged(ChangeEventArgs e)
    {
        isDesignationLoading = true;

        var selectedValue = e.Value?.ToString();

        if (Guid.TryParse(selectedValue, out var deptId))
        {
            model.DepartmentId = deptId;
            model.DesignationId = null;

            designations = await DesignationService.GetByDepartmentAsync(deptId);
        }
        else
        {
            model.DepartmentId = null;
            model.DesignationId = null;
            designations.Clear();
        }

        isDesignationLoading = false;
    }

    private async Task HandleSubmit()
    {
        try
        {
            error = null;
            link = null;
            isSubmitting = true;

            model.Role = "Employee";
            link = await EmployeeService.CreateEmployeeAsync(model);

            model = new CreateEmployeeDto();
            designations.Clear();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task CopyLinkToClipboard()
    {
        if (!string.IsNullOrEmpty(link))
        {
            await JS.InvokeVoidAsync("clipboardCopy.copyText", link);
            showCopiedFeedback = true;
            StateHasChanged();

            await Task.Delay(2000);

            showCopiedFeedback = false;
            StateHasChanged();
        }
    }
}