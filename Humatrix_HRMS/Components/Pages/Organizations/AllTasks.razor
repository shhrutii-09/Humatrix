@page "/admin/tasks"
@rendermode InteractiveServer

@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize(Roles = "HR,OrgAdmin")]

@inject TaskService TaskService
@inject NavigationManager Nav

<PageTitle>All Tasks</PageTitle>

<div class="container mt-4">

    <div class="d-flex justify-content-between mb-4">
        <h3>All Tasks</h3>

        <button class="btn btn-primary"
                @onclick="@(() => Nav.NavigateTo("/admin/tasks/assign"))">
            + Assign Task
        </button>
    </div>

    @if (tasks == null)
    {
        <p>Loading...</p>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover">

                    <thead class="table-light">
                        <tr>
                            <th>Title</th>
                            <th>Employee</th>
                            <th>Priority</th>
                            <th>Status</th>
                            <th>Progress</th>
                            <th>Due</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var t in tasks)
                        {
                            <tr>
                                <td>@t.Title</td>
                                <td>@t.AssignedToName</td>
                                <td>@t.Priority</td>

                                <td>
                                    <span class="badge @GetStatusClass(t.Status)">
                                        @t.Status
                                    </span>
                                </td>

                                <td>@t.Progress%</td>

                                <td>
                                    @(t.DueDate?.ToString("dd MMM yyyy") ?? "-")
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>
        </div>
    }

</div>

@code {

    private List<TaskDto> tasks = new();

    protected override async Task OnInitializedAsync()
    {
        tasks = await TaskService.GetAllTasksAsync();
    }

    private string GetStatusClass(string status) => status switch
    {
        "Completed" => "bg-success",
        "In Progress" => "bg-warning text-dark",
        _ => "bg-secondary"
    };
}