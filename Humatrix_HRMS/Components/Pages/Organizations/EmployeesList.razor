@page "/employees"
@rendermode InteractiveServer

@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization

@attribute [Authorize(Roles = "OrgAdmin,HR")]

@inject EmployeeService EmployeeService
@inject DepartmentService DeptService
@inject DesignationService DesignationService
@inject AuthenticationStateProvider AuthStateProvider

<h3>Employee Management</h3>

<div class="card p-3 mb-3">
    <div class="row">
        <div class="col-md-4">
            <input class="form-control"
                   placeholder="Search by name/email"
                   @bind="search"
                   @bind:event="oninput" />
        </div>

        @* Filter Dropdown: Only visible to OrgAdmin *@
        @if (UserIsOrgAdmin)
        {
            <div class="col-md-4">
                <select class="form-control" @onchange="OnDepartmentFilterChanged">
                    <option value="">All Departments</option>
                    @foreach (var d in departments)
                    {
                        <option value="@d.DepartmentId">@d.Name</option>
                    }
                </select>
            </div>
        }
    </div>
</div>

<table class="table table-hover table-bordered">
    <thead class="table-light">
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Role</th>
            <th>Department</th>
            <th>Designation</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (employees == null || !employees.Any())
        {
            <tr><td colspan="7" class="text-center">No employees found.</td></tr>
        }
        else
        {
            @foreach (var e in employees)
            {
                <tr>
                    <td>@e.Name</td>
                    <td>@e.Email</td>
                    <td><span class="badge bg-info text-dark">@e.Role</span></td>
                    <td>@e.Department</td>
                    <td>@e.Designation</td>
                    <td>
                        <span class="badge bg-@(e.IsActive ? "success" : "danger")">
                            @(e.IsActive ? "Active" : "Inactive")
                        </span>
                    </td>
                    <td>
                        <button class="btn btn-sm btn-warning" @onclick="() => OpenEditModal(e)">Edit</button>
                        <button class="btn btn-sm @(e.IsActive ? "btn-danger" : "btn-success")"
                                @onclick="() => ToggleStatus(e)">
                            @(e.IsActive ? "Deactivate" : "Activate")
                        </button>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

@if (isEditOpen)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Employee: @editingEmail</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="editModel" OnValidSubmit="SaveEdit">
                        <DataAnnotationsValidator />

                        <label>First Name</label>
                        <InputText @bind-Value="editModel.FirstName" class="form-control mb-2" />

                        <label>Last Name</label>
                        <InputText @bind-Value="editModel.LastName" class="form-control mb-2" />

                        <label>Department</label>
                        @if (UserIsOrgAdmin)
                        {
                            <InputSelect ValueExpression="@(() => editModel.DepartmentId)"
                                         Value="@editModel.DepartmentId"
                                         ValueChanged="@((Guid? id) => OnEditDepartmentChanged(id))"
                                         class="form-control mb-2">
                                <option value="">Select Department</option>
                                @foreach (var d in departments)
                                {
                                    <option value="@d.DepartmentId">@d.Name</option>
                                }
                            </InputSelect>
                        }
                        else
                        {
                            @* HR sees a read-only field with their own department name *@
                            <input type="text" class="form-control mb-2" value="@HRDepartmentName" disabled />
                        }

                        <label>Designation</label>
                        <InputSelect @bind-Value="editModel.DesignationId" class="form-control mb-2">
                            <option value="">Select Designation</option>
                            @foreach (var d in editDesignations)
                            {
                                <option value="@d.DesignationId">@d.Name</option>
                            }
                        </InputSelect>

                        <div class="mt-3">
                            <button type="submit" class="btn btn-primary">Save Changes</button>
                            <button type="button" class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@code {

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    List<EmployeeListDto> employees = new();
    List<DepartmentDto> departments = new();
    List<DesignationDto> editDesignations = new();

    EditEmployeeDto editModel = new();
    bool isEditOpen = false;
    string? editingEmail;

    // Role handling
    bool UserIsOrgAdmin = false;
    string HRDepartmentName = "";

    private string? _search;
    private string? search
    {
        get => _search;
        set
        {
            if (_search != value)
            {
                _search = value;
                _ = LoadEmployees();
            }
        }
    }

    Guid? filterDepartmentId;

    protected override async Task OnInitializedAsync()
    {
        departments = await DeptService.GetAllAsync();

        if (AuthState != null)
        {
            var authState = await AuthState;
            var user = authState.User;
            UserIsOrgAdmin = user.IsInRole("OrgAdmin");

            if (!UserIsOrgAdmin)
            {
                var hrEmail = user.Identity?.Name;
                // Optimization: Get only the specific user instead of the whole list if possible
                var hrData = await EmployeeService.GetEmployeesForListAsync();
                var hrProfile = hrData.FirstOrDefault(x => x.Email == hrEmail);
                HRDepartmentName = hrProfile?.Department ?? "Department Restricted";
            }
        }

        await LoadEmployees();
    }


    private async Task LoadEmployees()
    {
        employees = await EmployeeService.GetEmployeesForListAsync(_search, filterDepartmentId);
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnDepartmentFilterChanged(ChangeEventArgs e)
    {
        filterDepartmentId = Guid.TryParse(e.Value?.ToString(), out var id) ? id : null;
        await LoadEmployees();
    }

    private async Task OpenEditModal(EmployeeListDto e)
    {
        editingEmail = e.Email;
        editModel = new EditEmployeeDto
        {
            FirstName = e.FirstName,
            LastName = e.LastName,
            DepartmentId = e.DepartmentId,
            DesignationId = e.DesignationId,
            Role = e.Role
        };

        if (e.DepartmentId.HasValue)
        {
            editDesignations = await DesignationService.GetByDepartmentAsync(e.DepartmentId.Value);
        }

        isEditOpen = true;
    }

    private async Task OnEditDepartmentChanged(Guid? id)
    {
        editModel.DepartmentId = id;
        editModel.DesignationId = null;

        editDesignations = new(); // ✅ clear first


        if (id.HasValue)
            editDesignations = await DesignationService.GetByDepartmentAsync(id.Value);
        else
            editDesignations = new();
    }

    private async Task SaveEdit()
    {
        try
        {
            await EmployeeService.UpdateEmployeeAsync(editingEmail!, editModel);
            isEditOpen = false;
            await LoadEmployees();
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
    }

    private async Task ToggleStatus(EmployeeListDto e)
    {
        await EmployeeService.ToggleUserStatusAsync(e.Email, !e.IsActive);
        await LoadEmployees();
    }

    void CloseModal() => isEditOpen = false;
}