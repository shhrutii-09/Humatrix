@page "/employees"
@rendermode InteractiveServer

@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization

@attribute [Authorize(Roles = "OrgAdmin,HR")]

@inject EmployeeService EmployeeService
@inject CurrentUserService CurrentUserService
@inject DepartmentService DeptService
@inject DesignationService DesignationService
@inject NavigationManager Nav
@inject ShiftService ShiftService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Employees | Humatrix HRMS</PageTitle>

@* Fixed Premium Toast Notification Display Panel *@
<div class="position-fixed top-0 end-0 p-3" style="z-index: 1080;">
    @if (!string.IsNullOrEmpty(message))
    {
        <div class="toast show align-items-center border-0 shadow-lg mb-2" role="alert" style="background-color: #f0fdf4; color: #166534; border-left: 4px solid #10b981 !important; border-radius: 10px;">
            <div class="d-flex p-3">
                <div class="toast-body d-flex align-items-center p-0">
                    <i class="bi bi-check-circle-fill me-2 fs-5" style="color: #10b981;"></i>
                    <span class="small fw-medium">@message</span>
                </div>
                <button type="button" class="btn-close m-auto me-0 shadow-none" @onclick="() => message = null"></button>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(error))
    {
        <div class="toast show align-items-center border-0 shadow-lg mb-2" role="alert" style="background-color: #fef2f2; color: #991b1b; border-left: 4px solid #ef4444 !important; border-radius: 10px;">
            <div class="d-flex p-3">
                <div class="toast-body d-flex align-items-center p-0">
                    <i class="bi bi-exclamation-triangle-fill me-2 fs-5" style="color: #ef4444;"></i>
                    <span class="small fw-medium"><strong>Error:</strong> @error</span>
                </div>
                <button type="button" class="btn-close m-auto me-0 shadow-none" @onclick="() => error = null"></button>
            </div>
        </div>
    }
</div>

<div class="container-fluid px-4 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1" style="font-size: 2rem;">Employee Directory</h2>
            <p class="text-muted small mb-0">Manage, filter, and review team rosters and active directories.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn text-white fw-bold px-4 py-2 text-uppercase btn-add-dept" @onclick="NavigateToAddEmployee">
                <i class="bi bi-plus-lg me-2"></i>Add Employee
            </button>
            <button class="btn bg-white border text-secondary fw-bold px-4 py-2 text-uppercase shadow-sm text-dashboard" @onclick="NavigateToDashboard">
                <i class="bi bi-speedometer2 me-2"></i>Dashboard
            </button>
        </div>
    </div>

    @* Statistics Cards *@
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card p-3 shadow-sm border-0 border-start border-4 border-primary">
                <h6 class="text-muted text-uppercase small mb-1">Total Workers</h6>
                <h3 class="fw-bold mb-0">@stats.TotalWorkers</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card p-3 shadow-sm border-0 border-start border-4 border-indigo">
                <h6 class="text-muted text-uppercase small mb-1">Total Employees</h6>
                <h3 class="fw-bold mb-0 text-indigo">@stats.TotalEmployees</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card p-3 shadow-sm border-0 border-start border-4 border-success">
                <h6 class="text-muted text-uppercase small mb-1">Total HRs</h6>
                <h3 class="fw-bold mb-0 text-success">@stats.TotalHrs</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card p-3 shadow-sm border-0 border-start border-4 border-danger">
                <h6 class="text-muted text-uppercase small mb-1">Total Inactive</h6>
                <h3 class="fw-bold mb-0 text-danger">@stats.TotalInactive</h3>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="@(UserIsOrgAdmin ? "col-md-4" : "col-md-6")">
            <div class="position-relative">
                <span class="position-absolute top-50 start-0 translate-middle-y ps-3 text-muted">
                    <i class="bi bi-search"></i>
                </span>
                <input class="form-control custom-search-input shadow-none ps-5"
                       placeholder="Search by name or email..."
                       value="@search"
                       @oninput="OnSearchInput" />
            </div>
        </div>

        @if (UserIsOrgAdmin)
        {
            <div class="col-md-4">
                <select class="form-select custom-search-input shadow-none px-3" @onchange="OnDepartmentFilterChanged" value="@filterDepartmentId">
                    <option value="">All Departments</option>
                    @foreach (var d in departments.Where(x => x.IsActive))
                    {
                        <option value="@d.DepartmentId">@d.Name</option>
                    }
                </select>
            </div>
        }

        <div class="@(UserIsOrgAdmin ? "col-md-4" : "col-md-6")">
            <select class="form-select custom-search-input shadow-none px-3" @onchange="OnRoleFilterChanged" value="@filterRole">
                <option value="">All Roles</option>
                <option value="HR">HR</option>
                <option value="Employee">Employee</option>
            </select>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-3 overflow-hidden bg-white mb-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 custom-dept-table">
                <thead class="bg-light border-bottom text-secondary">
                    <tr>
                        <th class="ps-4 py-3 text-uppercase tracking-wider">Employee</th>
                        <th class="py-3 text-uppercase tracking-wider">Role & Department</th>
                        <th class="py-3 text-uppercase tracking-wider">Designation</th>
                        <th class="py-3 text-uppercase tracking-wider text-center">Shift</th>
                        <th class="py-3 text-uppercase tracking-wider">Status</th>
                        <th class="py-3 text-uppercase tracking-wider text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (isLoading)
                    {
                        <tr><td colspan="6" class="text-center py-5"><div class="spinner-border text-indigo" role="status"></div></td></tr>
                    }
                    else if (employees == null || !employees.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5">
                                <div class="py-4">
                                    <i class="bi bi-person-x text-muted display-4 d-block mb-3"></i>
                                    <h5 class="text-dark fw-semibold mb-1">No matches found</h5>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var e in employees)
                        {
                            <tr>
                                <td class="ps-4 py-3">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-circle me-3 bg-indigo-subtle text-indigo d-flex align-items-center justify-content-center fw-bold shadow-2xs">
                                            @(!string.IsNullOrEmpty(e.Name) ? e.Name[0].ToString().ToUpper() : "?")
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark mb-0">@e.Name</div>
                                            <div class="small text-muted" style="font-size: 0.85rem;">@e.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="py-3">
                                    <span class="badge bg-soft-info text-info rounded-pill px-2.5 py-1 mb-1 fw-medium" style="font-size: 0.75rem;">@e.Role</span>
                                    <div class="small text-dark fw-medium">@e.Department</div>
                                </td>
                                <td class="py-3"><span class="text-secondary fw-medium">@e.Designation</span></td>
                                <td class="py-3 text-center"><span class="badge bg-light text-secondary border rounded-2 px-2.5 py-1.5 font-monospace fw-normal">@e.ShiftName</span></td>
                                <td class="py-3">
                                    <div class="form-check form-switch d-flex align-items-center gap-2 mb-0">
                                        <input class="form-check-input shadow-none" type="checkbox" checked="@e.IsActive" @onchange="() => ToggleStatus(e)">
                                        <span class="badge @(e.IsActive ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger") px-2 py-1 rounded">
                                            @(e.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </div>
                                </td>
                                <td class="py-3 text-end pe-4">
                                    <button class="btn btn-sm btn-action text-info me-1" title="View" @onclick='() => Nav.NavigateTo($"/employee/details/{e.EmployeeId}")'><i class="bi bi-eye-fill"></i></button>
                                    <button class="btn btn-sm btn-action text-secondary border bg-white rounded shadow-2xs" title="Edit" @onclick="() => OpenEditModal(e)"><i class="bi bi-pencil-square"></i></button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer bg-white border-top py-3 px-4 d-flex justify-content-end">
            <div class="custom-dept-pagination border rounded d-flex align-items-center bg-light-subtle">
                <button class="btn btn-link text-muted p-2 border-end shadow-none rounded-0 @(currentPage == 1 ? "disabled opacity-50" : "")" @onclick="() => ChangePage(currentPage - 1)"><i class="bi bi-chevron-left"></i></button>
                <span class="px-3 text-secondary small fw-medium">Page <b>@currentPage</b>/<b>@(totalPages == 0 ? 1 : totalPages)</b></span>
                <button class="btn btn-link text-muted p-2 border-start shadow-none rounded-0 @(currentPage >= totalPages || totalPages == 0 ? "disabled opacity-50" : "")" @onclick="() => ChangePage(currentPage + 1)"><i class="bi bi-chevron-right"></i></button>
            </div>
        </div>
    </div>
</div>

@if (isEditOpen)
{
    <div class="modal fade show d-block" style="background: rgba(15, 23, 42, 0.45); backdrop-filter: blur(4px);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-3">
                <div class="modal-header border-bottom border-light px-4 pt-4 pb-3">
                    <h5 class="modal-title fw-bold text-dark">Modify Employee Roster</h5>
                    <button type="button" class="btn-close shadow-none" @onclick="CloseModal"></button>
                </div>
                <EditForm Model="editModel" OnValidSubmit="SaveEdit">
                    <DataAnnotationsValidator />
                    <div class="modal-body p-4">
                        <ValidationSummary class="text-danger small mb-3" />
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label small fw-semibold text-secondary">First Name</label>
                                <InputText @bind-Value="editModel.FirstName" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-semibold text-secondary">Last Name</label>
                                <InputText @bind-Value="editModel.LastName" class="form-control" />
                            </div>
                            <div class="col-12">
                                <label class="form-label small fw-semibold text-secondary">Department</label>
                                @if (UserIsOrgAdmin)
                                {
                                    <InputSelect ValueExpression="@(() => editModel.DepartmentId)" Value="@editModel.DepartmentId" ValueChanged="@((Guid? id) => OnEditDepartmentChanged(id))" class="form-select">
                                        <option value="">Select Department</option>
                                        @foreach (var d in departments.Where(x => x.IsActive))
                                        {
                                            <option value="@d.DepartmentId">@d.Name</option>
                                        }
                                    </InputSelect>
                                }
                                else
                                {
                                    <input type="text" class="form-control" value="@HRDepartmentName" disabled />
                                }
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-semibold text-secondary">Designation</label>
                                <InputSelect @bind-Value="editModel.DesignationId" class="form-select">
                                    <option value="">Select Designation</option>
                                    @foreach (var d in editDesignations)
                                    {
                                        <option value="@d.DesignationId">@d.Name</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-semibold text-secondary">Shift</label>
                                <InputSelect @bind-Value="editModel.ShiftId" class="form-select">
                                    <option value="">Select Shift</option>
                                    @foreach (var s in shifts)
                                    {
                                        <option value="@s.ShiftId">@s.Name</option>
                                    }
                                </InputSelect>
                            </div>
                            @* --- NEW: Role Change Field --- *@
                            <div class="col-12">
                                <label class="form-label small fw-semibold text-secondary">System Role</label>
                                <InputSelect @bind-Value="editModel.Role" class="form-select">
                                    <option value="Employee">Employee</option>
                                    <option value="HR">HR</option>
                                </InputSelect>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer bg-light border-top border-light px-4 py-3">
                        <button type="button" class="btn btn-light border" @onclick="CloseModal">Discard</button>
                        <button type="submit" class="btn btn-indigo">Commit Updates</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

<style>
    .btn-add-dept {
        background-color: #5c4ac7 !important;
        font-size: 0.785rem !important;
        border-radius: 8px !important;
    }

    .custom-search-input {
        border: 1px solid #dfe5ef !important;
        border-radius: 10px !important;
        padding: 0.65rem;
    }

    .avatar-circle {
        width: 38px;
        height: 38px;
        border-radius: 50%;
    }

    .btn-action {
        background-color: #ffffff;
        border: 1px solid #e2e8f0;
        padding: 0.35rem 0.5rem;
        border-radius: 6px;
    }

    .btn-indigo {
        background-color: #5c4ac7;
        color: white;
    }
</style>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }
    List<EmployeeListDto> employees = new();
    List<DepartmentDto> departments = new();
    List<DesignationDto> editDesignations = new();
    List<Shift> shifts = new();
    EditEmployeeDto editModel = new();

    EmployeeStatsDto stats = new();

    bool isEditOpen = false;
    bool isLoading = false;
    string? editingEmail, message, error, HRDepartmentName, search = "", filterRole = "";
    bool UserIsOrgAdmin = false;
    Guid? filterDepartmentId;
    int currentPage = 1, pageSize = 10, totalEmployees = 0;
    int totalPages => (int)Math.Ceiling((double)totalEmployees / pageSize);

    protected override async Task OnInitializedAsync()
    {
        departments = await DeptService.GetAllAsync();
        shifts = await ShiftService.GetAllShiftsAsync();
        if (AuthState != null)
        {
            var authState = await AuthState;
            UserIsOrgAdmin = authState.User.IsInRole("OrgAdmin");
            if (!UserIsOrgAdmin)
            {
                var currentUser = await CurrentUserService.GetUserAsync();
                filterDepartmentId = currentUser?.DepartmentId;
                HRDepartmentName = departments.FirstOrDefault(d => d.DepartmentId == filterDepartmentId)?.Name ?? "Restricted";
            }
        }
        await LoadEmployees();
    }

    private async Task LoadEmployees()
    {
        isLoading = true;
        var currentUser = await CurrentUserService.GetUserAsync();

        var result = await EmployeeService.GetEmployeesForListAsync(search, filterDepartmentId, filterRole, currentPage, pageSize);
        totalEmployees = result.TotalCount;
        employees = result.Items ?? new List<EmployeeListDto>();

        if (currentUser?.OrganizationId != null)
        {
            stats = await EmployeeService.GetEmployeeStatsAsync(currentUser.OrganizationId.Value);
        }

        isLoading = false;
    }

    private async Task ToggleStatus(EmployeeListDto e)
    {
        e.IsActive = !e.IsActive;
        try
        {
            await EmployeeService.ToggleUserStatusAsync(e.Email, e.IsActive);
            message = $"Status updated successfully.";
            await LoadEmployees();
        }
        catch
        {
            e.IsActive = !e.IsActive;
            error = "Failed to update status.";
        }
    }

    private async Task ChangePage(int newPage) { currentPage = newPage; await LoadEmployees(); }
    private async Task OnSearchInput(ChangeEventArgs e) { search = e.Value?.ToString(); currentPage = 1; await LoadEmployees(); }
    private async Task OnDepartmentFilterChanged(ChangeEventArgs e) { filterDepartmentId = Guid.TryParse(e.Value?.ToString(), out var id) ? id : null; currentPage = 1; await LoadEmployees(); }
    private async Task OnRoleFilterChanged(ChangeEventArgs e) { filterRole = e.Value?.ToString(); currentPage = 1; await LoadEmployees(); }

    private void NavigateToDashboard() => Nav.NavigateTo("/org/dashboard");
    private void NavigateToAddEmployee() => Nav.NavigateTo(UserIsOrgAdmin ? "/org/add-employee" : "/hr/add-employee");
    void CloseModal() => isEditOpen = false;

    private async Task OpenEditModal(EmployeeListDto e)
    {
        editingEmail = e.Email;
        // Map the role from the list item to the edit model
        editModel = new EditEmployeeDto
        {
            FirstName = e.FirstName,
            LastName = e.LastName,
            DepartmentId = e.DepartmentId,
            DesignationId = e.DesignationId,
            ShiftId = e.ShiftId,
            Role = e.Role
        };
        editDesignations = e.DepartmentId.HasValue ? await DesignationService.GetByDepartmentAsync(e.DepartmentId.Value) : new();
        isEditOpen = true;
    }

    private async Task OnEditDepartmentChanged(Guid? id)
    {
        editModel.DepartmentId = id;
        editModel.DesignationId = null;
        editDesignations = id.HasValue ? await DesignationService.GetByDepartmentAsync(id.Value) : new();
    }

    private async Task SaveEdit()
    {
        await EmployeeService.UpdateEmployeeAsync(editingEmail!, editModel);
        isEditOpen = false;
        message = "Changes saved.";
        await LoadEmployees();
    }
}