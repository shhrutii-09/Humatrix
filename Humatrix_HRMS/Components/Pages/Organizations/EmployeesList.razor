@page "/employees"
@rendermode InteractiveServer

@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization

@attribute [Authorize(Roles = "OrgAdmin,HR")]

@inject EmployeeService EmployeeService
@inject CurrentUserService CurrentUserService
@inject DepartmentService DeptService
@inject DesignationService DesignationService
@inject NavigationManager Nav
@inject ShiftService ShiftService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Employees | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-normal">Employee Directory</h2>
            <p class="text-muted small">Manage staff..</p>
        </div>
        @* <button class="btn btn-primary shadow-sm" style="background-color: #5c4ac7; border: none;" @onclick='() => { /* Navigate to Add Employee */ }'>
            <i class="bi bi-person-plus-fill me-2"></i> ADD NEW EMPLOYEE
        </button> *@
        <button class="btn btn-primary shadow-sm"
                style="background-color: #5c4ac7; border: none;"
                @onclick="NavigateToAddEmployee">
            <i class="bi bi-person-plus-fill me-2"></i> ADD NEW EMPLOYEE
        </button>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-3">
            <div class="row g-3 align-items-end">
                <div class="col-md-5">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 text-muted">
                            <i class="bi bi-search"></i>
                        </span>
                        <input class="form-control border-start-0"
                               placeholder="Search by name or email..."
                               @bind="search"
                               @bind:event="oninput" />
                    </div>
                </div>

                @if (UserIsOrgAdmin)
                {
                    <div class="col-md-4">
<select class="form-select" @onchange="OnDepartmentFilterChanged" value="@filterDepartmentId">                            <option value="">All Departments</option>
                            @foreach (var d in departments)
                            {
                                <option value="@d.DepartmentId">@d.Name</option>
                            }
                        </select>
                    </div>
                }

                <div class="col-md-3 text-end">
                    @* <button class="btn btn-outline-secondary w-100" @onclick="LoadEmployees">
                         FILTER
                    </button> *@
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 border-0 text-muted small">EMPLOYEE</th>
                        <th class="border-0 text-muted small">ROLE / DEPT</th>
                        <th class="border-0 text-muted small">DESIGNATION</th>
                        <th class="border-0 text-muted small text-center">SHIFT</th>
                        <th class="border-0 text-muted small">STATUS</th>
                        <th class="border-0 text-muted small text-end pe-4">ACTIONS</th>
                    </tr>
                </thead>
                <tbody>
                    @if (employees == null || !employees.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5">
                                <i class="bi bi-people text-muted display-4 d-block mb-3"></i>
                                <span class="text-muted">No employees found.</span>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var e in employees)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-sm me-3 bg-light text-primary d-flex align-items-center justify-content-center rounded-circle fw-bold" style="width: 40px; height: 40px; border: 1px solid #eee;">
                                            @e.Name[0]
                                        </div>
                                        <div>
                                            <div class="fw-bold mb-0">@e.Name</div>
                                            <div class="small text-muted">@e.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="badge bg-soft-info text-info mb-1">@e.Role</div>
                                    <div class="small text-muted">@e.Department</div>
                                </td>
                                <td><span class="text-dark">@e.Designation</span></td>
                                <td class="text-center">
                                    <span class=" bg-light text-dark fw-normal ">@e.ShiftName</span>
                                </td>
                                <td>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input shadow-none" type="checkbox" checked="@e.IsActive" @onchange="() => ToggleStatus(e)">
                                        <span class="small @(e.IsActive ? "text-success" : "text-danger")">
                                            @(e.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </div>
                                </td>
                                @* <td class="text-end pe-4">
                                    <button class="btn btn-sm btn-light border text-primary me-1" title="Edit Employee" @onclick="() => OpenEditModal(e)">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                </td> *@
                                <td class="text-end pe-4">
                                    @* Add this View Button *@
                                    @if (e.EmployeeId != Guid.Empty)
                                    {
                                        <button class="btn btn-sm btn-light border text-info me-1"
                                                @onclick='() => Nav.NavigateTo($"/employee/details/{e.EmployeeId}")'>
                                            <i class="bi bi-eye"></i>
                                        </button>
                                    }

                                    <button class="btn btn-sm btn-light border text-primary me-1" title="Edit Employee" @onclick="() => OpenEditModal(e)">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
<div class="card-footer bg-white border-0 py-3">
    <div class="d-flex justify-content-between align-items-center">
        <div class="small text-muted">
            @if (totalEmployees == 0)
            {
                <span>No entries found</span>
            }
            else
            {
                <span>
                    Showing @(((currentPage - 1) * pageSize) + 1)
                    to @(Math.Min(currentPage * pageSize, totalEmployees))
                    of @totalEmployees entries
                </span>
            }
        </div>
        <nav>
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <button class="page-link shadow-none" @onclick="() => ChangePage(currentPage - 1)">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                </li>

                @for (int i = 1; i <= totalPages; i++)
                {
                    var pageNum = i;
                    <li class="page-item @(currentPage == pageNum ? "active" : "")">
                        <button class="page-link shadow-none @(currentPage == pageNum ? "border-0" : "")"
                                style="@(currentPage == pageNum ? "background-color: #5c4ac7;" : "")"
                                @onclick="() => ChangePage(pageNum)">
                            @pageNum
                        </button>
                    </li>
                }

                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <button class="page-link shadow-none" @onclick="() => ChangePage(currentPage + 1)">
                        <i class="bi bi-chevron-right"></i>
                    </button>
                </li>
            </ul>
        </nav>
    </div>
</div>
@if (isEditOpen)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.4); backdrop-filter: blur(4px);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Edit Details</h5>
                    <button type="button" class="btn-close shadow-none" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body p-4">
                    <p class="text-muted small mb-4">Updating profile for <strong>@editingEmail</strong></p>

                    <EditForm Model="editModel" OnValidSubmit="SaveEdit">
                        <DataAnnotationsValidator />

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted">First Name</label>
                                <InputText @bind-Value="editModel.FirstName" class="form-control bg-light" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted">Last Name</label>
                                <InputText @bind-Value="editModel.LastName" class="form-control bg-light" />
                            </div>

                            <div class="col-12">
                                <label class="form-label small fw-bold text-muted">Department</label>
                                @if (UserIsOrgAdmin)
                                {
                                    <InputSelect ValueExpression="@(() => editModel.DepartmentId)"
                                                 Value="@editModel.DepartmentId"
                                                 ValueChanged="@((Guid? id) => OnEditDepartmentChanged(id))"
                                                 class="form-select bg-light">
                                        <option value="">Select Department</option>
                                        @foreach (var d in departments)
                                        {
                                            <option value="@d.DepartmentId">@d.Name</option>
                                        }
                                    </InputSelect>
                                }
                                else
                                {
                                    <input type="text" class="form-control bg-light" value="@HRDepartmentName" disabled />
                                }
                            </div>

                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted">Designation</label>
                                <InputSelect @bind-Value="editModel.DesignationId" class="form-select bg-light">
                                    <option value="">Select Designation</option>
                                    @foreach (var d in editDesignations)
                                    {
                                        <option value="@d.DesignationId">@d.Name</option>
                                    }
                                </InputSelect>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted">Shift</label>
                                <InputSelect @bind-Value="editModel.ShiftId" class="form-select bg-light">
                                    <option value="">Select Shift</option>
                                    @foreach (var s in shifts)
                                    {
                                        <option value="@s.ShiftId">@s.Name</option>
                                    }
                                </InputSelect>
                            </div>
                        </div>

                        <div class="mt-4 pt-3 border-top d-flex justify-content-end gap-2">
                            <button type="button" class="btn btn-light" @onclick="CloseModal">Cancel</button>
                            <button type="submit" class="btn btn-primary px-4" style="background-color: #5c4ac7; border: none;">Save Profile</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>

   
}

<style>
    .bg-soft-info {
        background-color: rgba(13, 202, 240, 0.15);
    }

    .form-switch .form-check-input {
        width: 2.5em;
        height: 1.25em;
        cursor: pointer;
    }

    .form-control:focus, .form-select:focus {
        border-color: #5c4ac7;
        box-shadow: 0 0 0 0.2rem rgba(92, 74, 199, 0.1);
    }

    .modal-content {
        border-radius: 12px;
    }
</style>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    List<EmployeeListDto> employees = new();
    List<DepartmentDto> departments = new();
    List<DesignationDto> editDesignations = new();
    List<Shift> shifts = new();

    EditEmployeeDto editModel = new();
    bool isEditOpen = false;
    string? editingEmail;

    bool UserIsOrgAdmin = false;
    string HRDepartmentName = "";


    int currentPage = 1;
    int pageSize = 10;
    int totalEmployees = 0;
    int totalPages => (int)Math.Ceiling((double)totalEmployees / pageSize);

    private async Task ChangePage(int newPage)
    {
        if (newPage >= 1 && newPage <= totalPages)
        {
            currentPage = newPage;
            await LoadEmployees();
        }
    }

    private string? _search;
    // private string? search
    // {
    //     get => _search;
    //     set
    //     {
    //         if (_search != value)
    //         {
    //             _search = value;
    //             _ = LoadEmployees();
    //         }
    //     }
    // }

    private string? search
    {
        get => _search;
        set
        {
            if (_search != value)
            {
                _search = value;
                currentPage = 1; // RESET TO PAGE 1
                _ = LoadEmployees();
            }
        }
    }

    Guid? filterDepartmentId;

    protected override async Task OnInitializedAsync()
    {
        departments = await DeptService.GetAllAsync();
        shifts = await ShiftService.GetAllShiftsAsync();

        if (AuthState != null)
        {
            var authState = await AuthState;
            var user = authState.User;
            UserIsOrgAdmin = user.IsInRole("OrgAdmin");

            if (!UserIsOrgAdmin)
            {
                // Retrieve the full profile of the logged-in HR user
                var currentUser = await CurrentUserService.GetUserAsync();
                if (currentUser != null)
                {
                    // Lock the filter to their department
                    filterDepartmentId = currentUser.DepartmentId;

                    // Get the name for the UI display
                    var dept = departments.FirstOrDefault(d => d.DepartmentId == filterDepartmentId);
                    HRDepartmentName = dept?.Name ?? "Restricted";
                }
            }
        }

        await LoadEmployees();
    }

    // private async Task LoadEmployees()
    // {
    //     employees = await EmployeeService.GetEmployeesForListAsync(_search, filterDepartmentId);
    //     StateHasChanged();
    // }

    // private async Task LoadEmployees()
    // {
    //     var result = await EmployeeService.GetEmployeesForListAsync(_search, filterDepartmentId, currentPage, pageSize);
    //     employees = result.Items;
    //     totalEmployees = result.TotalCount;
    //     StateHasChanged();
    // }

    private async Task LoadEmployees()
    {
        var result = await EmployeeService.GetEmployeesForListAsync(_search, filterDepartmentId, currentPage, pageSize);

        totalEmployees = result.TotalCount;

        // ✅ Fix invalid page
        if (currentPage > totalPages && totalPages > 0)
        {
            currentPage = totalPages;
            result = await EmployeeService.GetEmployeesForListAsync(_search, filterDepartmentId, currentPage, pageSize);
        }

        employees = result.Items;
    }


   // private async Task OnDepartmentFilterChanged(ChangeEventArgs e)
   //  {
   //    //  Only allow changing the filter if they are an OrgAdmin
   //      if (UserIsOrgAdmin)
   //      {
   //          filterDepartmentId = Guid.TryParse(e.Value?.ToString(), out var id) ? id : null;
   //          await LoadEmployees();
   //      }
   //  }

    private async Task OnDepartmentFilterChanged(ChangeEventArgs e)
    {
        if (UserIsOrgAdmin)
        {
            filterDepartmentId = Guid.TryParse(e.Value?.ToString(), out var id) ? id : null;
            currentPage = 1; // RESET TO PAGE 1
            await LoadEmployees();
        }
    }

    private async Task OpenEditModal(EmployeeListDto e)
    {
        editingEmail = e.Email;
        editModel = new EditEmployeeDto
        {
            FirstName = e.FirstName,
            LastName = e.LastName,
            DepartmentId = e.DepartmentId,
            DesignationId = e.DesignationId,
            ShiftId = e.ShiftId,
            Role = e.Role
        };

        if (e.DepartmentId.HasValue)
        {
            editDesignations = await DesignationService.GetByDepartmentAsync(e.DepartmentId.Value);
        }

        isEditOpen = true;
    }

    private async Task OnEditDepartmentChanged(Guid? id)
    {
        editModel.DepartmentId = id;
        editModel.DesignationId = null;
        editDesignations = id.HasValue
            ? await DesignationService.GetByDepartmentAsync(id.Value)
            : new List<DesignationDto>();
    }

    private async Task SaveEdit()
    {
        try
        {
            await EmployeeService.UpdateEmployeeAsync(editingEmail!, editModel);
            isEditOpen = false;
            await LoadEmployees();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating: {ex.Message}");
        }
    }

    private async Task ToggleStatus(EmployeeListDto e)
    {
        await EmployeeService.ToggleUserStatusAsync(e.Email, !e.IsActive);
        await LoadEmployees();
    }

    void CloseModal() => isEditOpen = false;


    private void NavigateToAddEmployee()
    {
        if (UserIsOrgAdmin)
        {
            Nav.NavigateTo("/org/add-employee");
        }
        else
        {
            // If they aren't an OrgAdmin, they must be HR (based on your [Authorize] attribute)
            Nav.NavigateTo("/hr/add-employee");
        }
    }
}