@page "/employees"
@rendermode InteractiveServer

@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization

@attribute [Authorize(Roles = "OrgAdmin,HR")]

@inject EmployeeService EmployeeService
@inject CurrentUserService CurrentUserService
@inject DepartmentService DeptService
@inject DesignationService DesignationService
@inject NavigationManager Nav
@inject ShiftService ShiftService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Employees | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">
    
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3 mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">
                <i class="bi bi-people-fill text-indigo me-2"></i>Employee Directory
            </h2>
            <p class="text-muted small mb-0">Manage, filter, and review team rosters and active directories.</p>
        </div>
        <button class="btn btn-indigo shadow-sm px-4 py-2 fw-medium d-inline-flex align-items-center"
                @onclick="NavigateToAddEmployee">
            <i class="bi bi-person-plus-fill me-2 fs-5"></i> Add New Employee
        </button>
    </div>

    <div class="card shadow-sm border-0 mb-4 rounded-3">
        <div class="card-body p-3">
            <div class="row g-3 align-items-center">
                <div class="@(UserIsOrgAdmin ? "col-md-7" : "col-md-10")">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0 text-muted px-3">
                            <i class="bi bi-search"></i>
                        </span>
                        <input class="form-control bg-light border-start-0 ps-1"
                               placeholder="Search by name or email address..."
                               @bind="search"
                               @bind:event="oninput" />
                    </div>
                </div>

                @if (UserIsOrgAdmin)
                {
                    <div class="col-md-5">
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0 text-muted small fw-medium">Dept:</span>
                            <select class="form-select bg-light border-start-0" @onchange="OnDepartmentFilterChanged" value="@filterDepartmentId">
                                <option value="">All Departments</option>
                                @foreach (var d in departments)
                                {
                                    <option value="@d.DepartmentId">@d.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                }
                else if (!string.IsNullOrEmpty(HRDepartmentName))
                {
                    <div class="col-md-2 text-md-end">
                        <span class="badge bg-indigo-subtle text-indigo px-3 py-2 rounded-2 border border-indigo-subtle w-100 text-center">
                            <i class="bi bi-building me-1"></i> @HRDepartmentName
                        </span>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light border-bottom">
                    <tr>
                        <th class="ps-4 py-3 text-secondary text-uppercase tracking-wider fs-7">Employee</th>
                        <th class="py-3 text-secondary text-uppercase tracking-wider fs-7">Role & Department</th>
                        <th class="py-3 text-secondary text-uppercase tracking-wider fs-7">Designation</th>
                        <th class="py-3 text-secondary text-uppercase tracking-wider fs-7 text-center">Shift</th>
                        <th class="py-3 text-secondary text-uppercase tracking-wider fs-7">Status</th>
                        <th class="py-3 text-secondary text-uppercase tracking-wider fs-7 text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (employees == null || !employees.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5">
                                <div class="py-4">
                                    <i class="bi bi-person-x text-muted display-3 d-block mb-3"></i>
                                    <h5 class="text-dark fw-semibold mb-1">No matches found</h5>
                                    <p class="text-muted small">Try refining your keyword search or department criteria.</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var e in employees)
                        {
                            <tr>
                                <td class="ps-4 py-3">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-circle me-3 bg-indigo-subtle text-indigo d-flex align-items-center justify-content-center fw-bold shadow-2xs">
                                            @(!string.IsNullOrEmpty(e.Name) ? e.Name[0].ToString().ToUpper() : "?")
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark mb-0">@e.Name</div>
                                            <div class="small text-muted">@e.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="py-3">
                                    <span class="badge bg-soft-info text-info rounded-pill px-2.5 py-1 mb-1 fw-medium fs-8">@e.Role</span>
                                    <div class="small text-dark fw-medium">@e.Department</div>
                                    <div class="text-muted dynamic-creator-tag mt-0.5">
                                        Added by: <span class="fw-medium text-secondary">@e.CreatedByName</span> <span class="opacity-75">(@e.CreatedByRole)</span>
                                    </div>
                                </td>
                                <td class="py-3">
                                    <span class="text-secondary fw-medium">@e.Designation</span>
                                </td>
                                <td class="py-3 text-center">
                                    <span class="badge bg-light text-secondary border rounded-2 px-2.5 py-1.5 font-monospace fw-normal">@e.ShiftName</span>
                                </td>
                                <td class="py-3">
                                    <div class="form-check form-switch d-flex align-items-center gap-2 mb-0">
                                        <input class="form-check-input shadow-none" type="checkbox" checked="@e.IsActive" @onchange="() => ToggleStatus(e)">
                                        <span class="small fw-semibold @(e.IsActive ? "text-success" : "text-danger")">
                                            @(e.IsActive ? "Active" : "Suspended")
                                        </span>
                                    </div>
                                </td>
                                <td class="py-3 text-end pe-4">
                                    <div class="d-inline-flex gap-1">
                                        @if (e.EmployeeId != Guid.Empty)
                                        {
                                            <button class="btn btn-sm btn-action text-info" title="View Profile"
                                                    @onclick='() => Nav.NavigateTo($"/employee/details/{e.EmployeeId}")'>
                                                <i class="bi bi-eye-fill"></i>
                                            </button>
                                        }
                                        <button class="btn btn-sm btn-action text-indigo" title="Edit Properties" @onclick="() => OpenEditModal(e)">
                                            <i class="bi bi-pencil-square"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="card-footer bg-white border-top border-light py-3 px-4">
            <div class="d-flex flex-column flex-sm-row justify-content-between align-items-center gap-3">
                <div class="small text-muted fw-medium">
                    @if (totalEmployees == 0)
                    {
                        <span>No structural entries logged</span>
                    }
                    else
                    {
                        <span>
                            Showing <strong class="text-dark">@(((currentPage - 1) * pageSize) + 1)</strong>
                            to <strong class="text-dark">@(Math.Min(currentPage * pageSize, totalEmployees))</strong>
                            of <strong class="text-dark">@totalEmployees</strong> employees
                        </span>
                    }
                </div>
                
                @if (totalPages > 1)
                {
                    <nav aria-label="Directory Pagination">
                        <ul class="pagination pagination-sm mb-0 gap-1 border-0">
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <button class="page-link rounded shadow-none border border-light-subtle" @onclick="() => ChangePage(currentPage - 1)">
                                    <i class="bi bi-chevron-left"></i>
                                </button>
                            </li>

                            @for (int i = 1; i <= totalPages; i++)
                            {
                                var pageNum = i;
                                <li class="page-item @(currentPage == pageNum ? "active" : "")">
                                    <button class="page-link rounded shadow-none @(currentPage == pageNum ? "border-0 text-white" : "border border-light-subtle text-secondary")"
                                            style="@(currentPage == pageNum ? "background-color: #5c4ac7 !important;" : "")"
                                            @onclick="() => ChangePage(pageNum)">
                                        @pageNum
                                    </button>
                                </li>
                            }

                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <button class="page-link rounded shadow-none border border-light-subtle" @onclick="() => ChangePage(currentPage + 1)">
                                    <i class="bi bi-chevron-right"></i>
                                </button>
                            </li>
                        </ul>
                    </nav>
                }
            </div>
        </div>
    </div>
</div>

@if (isEditOpen)
{
    <div class="modal fade show d-block" style="background: rgba(15, 23, 42, 0.45); backdrop-filter: blur(4px);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-3">
                <div class="modal-header border-bottom border-light px-4 pt-4 pb-3">
                    <div>
                        <h5 class="modal-title fw-bold text-dark">Modify Employee Roster</h5>
                        <p class="text-muted small mb-0">Updating credentials linked to: <strong class="text-indigo">@editingEmail</strong></p>
                    </div>
                    <button type="button" class="btn-close shadow-none" @onclick="CloseModal"></button>
                </div>
                
                <EditForm Model="editModel" OnValidSubmit="SaveEdit">
                    <div class="modal-body p-4">
                        <DataAnnotationsValidator />

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label small fw-semibold text-secondary">First Name</label>
                                <InputText @bind-Value="editModel.FirstName" class="form-control bg-light border-light-subtle" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-semibold text-secondary">Last Name</label>
                                <InputText @bind-Value="editModel.LastName" class="form-control bg-light border-light-subtle" />
                            </div>

                            <div class="col-12">
                                <label class="form-label small fw-semibold text-secondary">Department Assignment</label>
                                @if (UserIsOrgAdmin)
                                {
                                    <InputSelect ValueExpression="@(() => editModel.DepartmentId)"
                                                 Value="@editModel.DepartmentId"
                                                 ValueChanged="@((Guid? id) => OnEditDepartmentChanged(id))"
                                                 class="form-select bg-light border-light-subtle">
                                        <option value="">Select Department</option>
                                        @foreach (var d in departments)
                                        {
                                            <option value="@d.DepartmentId">@d.Name</option>
                                        }
                                    </InputSelect>
                                }
                                else
                                {
                                    <input type="text" class="form-control bg-light border-light-subtle text-muted" value="@HRDepartmentName" disabled />
                                }
                            </div>

                            <div class="col-md-6">
                                <label class="form-label small fw-semibold text-secondary">Designation</label>
                                <InputSelect @bind-Value="editModel.DesignationId" class="form-select bg-light border-light-subtle">
                                    <option value="">Select Designation</option>
                                    @foreach (var d in editDesignations)
                                    {
                                        <option value="@d.DesignationId">@d.Name</option>
                                    }
                                </InputSelect>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label small fw-semibold text-secondary">Operational Shift</label>
                                <InputSelect @bind-Value="editModel.ShiftId" class="form-select bg-light border-light-subtle">
                                    <option value="">Select Shift</option>
                                    @foreach (var s in shifts)
                                    {
                                        <option value="@s.ShiftId">@s.Name</option>
                                    }
                                </InputSelect>
                            </div>
                        </div>
                    </div>
                    
                    <div class="modal-footer bg-light border-top border-light px-4 py-3">
                        <button type="button" class="btn btn-light border fw-medium px-3" @onclick="CloseModal">Discard Changes</button>
                        <button type="submit" class="btn btn-indigo px-4fw-medium">Commit Updates</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

<style>
    .text-indigo { color: #5c4ac7 !important; }
    .bg-indigo-subtle { background-color: rgba(92, 74, 199, 0.08) !important; }
    .border-indigo-subtle { border-color: rgba(92, 74, 199, 0.2) !important; }
    
    .btn-indigo { 
        background-color: #5c4ac7 !important; 
        color: #ffffff !important;
        border: none;
        transition: background-color 0.2s ease;
    }
    .btn-indigo:hover { background-color: #4b3bb3 !important; }

    .bg-soft-info { background-color: rgba(13, 202, 240, 0.1) !important; }
    
    .avatar-circle {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        font-size: 1.05rem;
        letter-spacing: -0.5px;
    }

    .btn-action {
        background-color: #f8f9fa;
        border: 1px solid #e9ecef;
        padding: 0.35rem 0.55rem;
        border-radius: 6px;
        transition: all 0.15s ease;
    }
    .btn-action:hover {
        background-color: #e9ecef;
        transform: translateY(-1px);
    }

    .form-control:focus, .form-select:focus {
        border-color: #5c4ac7 !important;
        box-shadow: 0 0 0 0.2rem rgba(92, 74, 199, 0.15) !important;
    }

    .form-switch .form-check-input {
        width: 2.3em;
        height: 1.15em;
        cursor: pointer;
        border-color: #dee2e6;
    }
    .form-switch .form-check-input:checked {
        background-color: #198754;
        border-color: #198754;
    }

    .fs-7 { font-size: 0.765rem !important; font-weight: 600; letter-spacing: 0.5px; }
    .fs-8 { font-size: 0.72rem !important; }
    .dynamic-creator-tag { font-size: 0.71rem !important; }
    .shadow-2xs { box-shadow: 0 1px 2px rgba(0,0,0,0.04); }
</style>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    List<EmployeeListDto> employees = new();
    List<DepartmentDto> departments = new();
    List<DesignationDto> editDesignations = new();
    List<Shift> shifts = new();

    EditEmployeeDto editModel = new();
    bool isEditOpen = false;
    string? editingEmail;

    bool UserIsOrgAdmin = false;
    string HRDepartmentName = "";

    int currentPage = 1;
    int pageSize = 10;
    int totalEmployees = 0;
    int totalPages => (int)Math.Ceiling((double)totalEmployees / pageSize);

    private async Task ChangePage(int newPage)
    {
        if (newPage >= 1 && newPage <= totalPages)
        {
            currentPage = newPage;
            await LoadEmployees();
        }
    }

    private string? _search;
    private string? search
    {
        get => _search;
        set
        {
            if (_search != value)
            {
                _search = value;
                currentPage = 1; 
                _ = LoadEmployees();
            }
        }
    }

    Guid? filterDepartmentId;

    protected override async Task OnInitializedAsync()
    {
        departments = await DeptService.GetAllAsync();
        shifts = await ShiftService.GetAllShiftsAsync();

        if (AuthState != null)
        {
            var authState = await AuthState;
            var user = authState.User;
            UserIsOrgAdmin = user.IsInRole("OrgAdmin");

            if (!UserIsOrgAdmin)
            {
                var currentUser = await CurrentUserService.GetUserAsync();
                if (currentUser != null)
                {
                    filterDepartmentId = currentUser.DepartmentId;
                    var dept = departments.FirstOrDefault(d => d.DepartmentId == filterDepartmentId);
                    HRDepartmentName = dept?.Name ?? "Restricted View";
                }
            }
        }

        await LoadEmployees();
    }

    private async Task LoadEmployees()
    {
        var result = await EmployeeService.GetEmployeesForListAsync(_search, filterDepartmentId, currentPage, pageSize);
        totalEmployees = result.TotalCount;

        if (currentPage > totalPages && totalPages > 0)
        {
            currentPage = totalPages;
            result = await EmployeeService.GetEmployeesForListAsync(_search, filterDepartmentId, currentPage, pageSize);
        }

        employees = result.Items;
    }

    private async Task OnDepartmentFilterChanged(ChangeEventArgs e)
    {
        if (UserIsOrgAdmin)
        {
            filterDepartmentId = Guid.TryParse(e.Value?.ToString(), out var id) ? id : null;
            currentPage = 1; 
            await LoadEmployees();
        }
    }

    private async Task OpenEditModal(EmployeeListDto e)
    {
        editingEmail = e.Email;
        editModel = new EditEmployeeDto
        {
            FirstName = e.FirstName,
            LastName = e.LastName,
            DepartmentId = e.DepartmentId,
            DesignationId = e.DesignationId,
            ShiftId = e.ShiftId,
            Role = e.Role
        };

        if (e.DepartmentId.HasValue)
        {
            editDesignations = await DesignationService.GetByDepartmentAsync(e.DepartmentId.Value);
        }

        isEditOpen = true;
    }

    private async Task OnEditDepartmentChanged(Guid? id)
    {
        editModel.DepartmentId = id;
        editModel.DesignationId = null;
        editDesignations = id.HasValue
            ? await DesignationService.GetByDepartmentAsync(id.Value)
            : new List<DesignationDto>();
    }

    private async Task SaveEdit()
    {
        try
        {
            await EmployeeService.UpdateEmployeeAsync(editingEmail!, editModel);
            isEditOpen = false;
            await LoadEmployees();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating structural model context: {ex.Message}");
        }
    }

    private async Task ToggleStatus(EmployeeListDto e)
    {
        await EmployeeService.ToggleUserStatusAsync(e.Email, !e.IsActive);
        await LoadEmployees();
    }

    void CloseModal() => isEditOpen = false;

    private void NavigateToAddEmployee()
    {
        if (UserIsOrgAdmin)
        {
            Nav.NavigateTo("/org/add-employee");
        }
        else
        {
            Nav.NavigateTo("/hr/add-employee");
        }
    }
}