@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    List<EmployeeListDto> employees = new();
    List<DepartmentDto> departments = new();
    List<DesignationDto> editDesignations = new();
    List<Shift> shifts = new();

    EditEmployeeDto editModel = new();
    bool isEditOpen = false;
    string? editingEmail;

    bool UserIsOrgAdmin = false;
    string HRDepartmentName = "";

    // Toast strings matching department style
    private string? message;
    private string? error;

    int currentPage = 1;
    int pageSize = 10;
    int totalEmployees = 0;
    int totalPages => (int)Math.Ceiling((double)totalEmployees / pageSize);

    private string search = "";
    Guid? filterDepartmentId;

    private async Task ChangePage(int newPage)
    {
        if (newPage >= 1 && newPage <= totalPages)
        {
            currentPage = newPage;
            await LoadEmployees();
        }
    }

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        search = e.Value?.ToString() ?? "";
        currentPage = 1;
        await LoadEmployees();
    }

    protected override async Task OnInitializedAsync()
    {
        departments = await DeptService.GetAllAsync();
        shifts = await ShiftService.GetAllShiftsAsync();

        if (AuthState != null)
        {
            var authState = await AuthState;
            var user = authState.User;
            UserIsOrgAdmin = user.IsInRole("OrgAdmin");

            if (!UserIsOrgAdmin)
            {
                var currentUser = await CurrentUserService.GetUserAsync();
                if (currentUser != null)
                {
                    filterDepartmentId = currentUser.DepartmentId;
                    var dept = departments.FirstOrDefault(d => d.DepartmentId == filterDepartmentId);
                    HRDepartmentName = dept?.Name ?? "Restricted View";
                }
            }
        }

        await LoadEmployees();
    }

    private async Task LoadEmployees()
    {
        var result = await EmployeeService.GetEmployeesForListAsync(search, filterDepartmentId, currentPage, pageSize);
        totalEmployees = result.TotalCount;

        if (currentPage > totalPages && totalPages > 0)
        {
            currentPage = totalPages;
            result = await EmployeeService.GetEmployeesForListAsync(search, filterDepartmentId, currentPage, pageSize);
        }

        if (result.Items != null)
        {
            // Use EmployeeId as the sorting fallback variable
            employees = result.Items
                .OrderByDescending(e => e.EmployeeId)
                .ToList();
        }
        else
        {
            employees = new List<EmployeeListDto>();
        }
    }
    private async Task OnDepartmentFilterChanged(ChangeEventArgs e)
    {
        if (UserIsOrgAdmin)
        {
            filterDepartmentId = Guid.TryParse(e.Value?.ToString(), out var id) ? id : null;
            currentPage = 1;
            await LoadEmployees();
        }
    }

    private async Task OpenEditModal(EmployeeListDto e)
    {
        editingEmail = e.Email;
        editModel = new EditEmployeeDto
        {
            FirstName = e.FirstName,
            LastName = e.LastName,
            DepartmentId = e.DepartmentId,
            DesignationId = e.DesignationId,
            ShiftId = e.ShiftId,
            Role = e.Role
        };

        if (e.DepartmentId.HasValue)
        {
            editDesignations = await DesignationService.GetByDepartmentAsync(e.DepartmentId.Value);
        }

        isEditOpen = true;
    }

    private async Task OnEditDepartmentChanged(Guid? id)
    {
        editModel.DepartmentId = id;
        editModel.DesignationId = null;
        editDesignations = id.HasValue
            ? await DesignationService.GetByDepartmentAsync(id.Value)
            : new List<DesignationDto>();
    }

    // Auto dismiss handler matching department layout logic
    private async void TriggerAutoDismiss(bool isSuccess)
    {
        await Task.Delay(4000);
        if (isSuccess)
        {
            message = null;
        }
        else
        {
            error = null;
        }
        StateHasChanged();
    }

    private async Task SaveEdit()
    {
        try
        {
            await EmployeeService.UpdateEmployeeAsync(editingEmail!, editModel);
            isEditOpen = false;

            message = $"Properties for {editModel.FirstName} {editModel.LastName} updated successfully.";
            error = null;

            await LoadEmployees();
            TriggerAutoDismiss(true);
        }
        catch (Exception ex)
        {
            error = $"Failed to update employee properties: {ex.Message}";
            message = null;
            TriggerAutoDismiss(false);
        }
    }

    private async Task ToggleStatus(EmployeeListDto e)
    {
        var nextStatus = !e.IsActive;
        e.IsActive = nextStatus; // optimistically reflect locally

        try
        {
            await EmployeeService.ToggleUserStatusAsync(e.Email, nextStatus);

            message = $"Employee '{e.Name}' state changed to {(nextStatus ? "Active" : "Inactive")} successfully.";
            error = null;

            await LoadEmployees();
            TriggerAutoDismiss(true);
        }
        catch (Exception ex)
        {
            e.IsActive = !nextStatus; // Revert fallback state change locally on errors
            error = $"Failed to change employee status: {ex.Message}";
            message = null;
            TriggerAutoDismiss(false);
        }
    }

    void CloseModal() => isEditOpen = false;

    private void NavigateToDashboard() => Nav.NavigateTo("/org/dashboard");

    private void NavigateToAddEmployee()
    {
        if (UserIsOrgAdmin)
        {
            Nav.NavigateTo("/org/add-employee");
        }
        else
        {
            Nav.NavigateTo("/hr/add-employee");
        }
    }
}