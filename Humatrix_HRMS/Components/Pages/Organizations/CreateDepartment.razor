@page "/org/create-department"
@rendermode InteractiveServer

@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize(Roles = "OrgAdmin")]

@inject DepartmentService DeptService
@inject NavigationManager Nav

<PageTitle>Create Department | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom row-gap-3 flex-wrap">
        <div>
            <h2 class="fw-bold tracking-tight text-dark mb-1">Create New Department</h2>
            <p class="text-muted small mb-0">Define a new structural organizational unit within the core corporate grid.</p>
        </div>
        <button class="btn btn-interactive-back shadow-sm" @onclick="GoBack">
            BACK TO DEPARTMENTS
        </button>
    </div>

    <div class="card border-0 shadow-sm form-container-card mx-auto ms-0">
        <div class="card-body p-4">
            <EditForm Model="model" OnValidSubmit="HandleCreateDepartment">
                <DataAnnotationsValidator />

                <div class="row">
                    <div class="col-xl-8 col-lg-10 col-md-12">

                        <div class="mb-4">
                            <label class="form-label small fw-bold text-secondary tracking-wider mb-2">DEPARTMENT NAME</label>
                            <InputText @bind-Value="model.Name"
                                       class="form-control premium-form-input"
                                       placeholder="e.g. Engineering, Global Marketing, Human Resources..." />
                            <ValidationMessage For="@(() => model.Name)" class="text-danger small mt-1 d-block fw-medium" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold text-secondary tracking-wider mb-2">DESCRIPTION</label>
                            <InputTextArea @bind-Value="model.Description"
                                           class="form-control premium-form-input"
                                           rows="4"
                                           placeholder="Briefly describe the operational duties and core responsibilities of this business unit..." />
                            <ValidationMessage For="@(() => model.Description)" class="text-danger small mt-1 d-block fw-medium" />
                        </div>

                        @if (!string.IsNullOrEmpty(error))
                        {
                            <div class="alert alert-premium-danger d-flex align-items-center mb-4 border-0" role="alert">
                                <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
                                <div class="small fw-medium">@error</div>
                            </div>
                        }

                        <div class="d-flex gap-2 border-top pt-4 mt-2">
                            <button type="submit"
                                    class="btn btn-action-submit px-4 shadow-sm d-flex align-items-center gap-2"
                                    disabled="@isSubmitting">
                                @if (isSubmitting)
                                {
                                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                    <span>Processing Unit...</span>
                                }
                                else
                                {
                                    <i class="bi bi-check-circle-fill"></i>
                                    <span>Create Department</span>
                                }
                            </button>

                            <button type="button"
                                    class="btn btn-action-cancel px-4"
                                    @onclick="GoBack">
                                Cancel
                            </button>
                        </div>

                    </div>
                </div>
            </EditForm>
        </div>
    </div>
</div>

<style>
    /* Framework Structural Configuration Rules */
    .tracking-tight {
        letter-spacing: -0.025em;
    }

    .tracking-wider {
        letter-spacing: 0.05em;
        font-size: 11px !important;
    }

    .form-container-card {
        border-radius: 14px;
        background-color: #ffffff;
        max-width: 800px;
    }

    /* Premium Typography Inputs styling */
    .premium-form-input {
        font-size: 14px;
        padding: 10px 14px;
        border-radius: 10px;
        border: 1px solid #cbd5e1;
        background-color: #f8fafc !important;
        color: #1e293b;
        transition: all 0.2s ease;
    }

        .premium-form-input:focus {
            border-color: #5c4ac7;
            background-color: #ffffff !important;
            box-shadow: 0 0 0 4px rgba(92, 74, 199, 0.12);
        }

        .premium-form-input::placeholder {
            color: #94a3b8;
            font-size: 13.5px;
        }

    /* Interactive Navigation Header Controls */
    .btn-interactive-back {
        background: #ffffff !important;
        border: 1px solid #e5e7eb !important;
        color: #4b5563 !important;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
        transition: all 0.2s ease;
    }

        .btn-interactive-back:hover {
            background-color: #f8fafc !important;
            border-color: #5c4ac7 !important;
            color: #5c4ac7 !important;
            transform: translateY(-1px);
        }

    /* Action Form Processing Buttons */
    .btn-action-submit {
        background-color: #5c4ac7 !important;
        color: #ffffff !important;
        border: none !important;
        padding: 10px 20px;
        border-radius: 10px;
        font-size: 13.5px;
        font-weight: 600;
        transition: all 0.2s ease;
    }

        .btn-action-submit:hover:not(:disabled) {
            background-color: #4b3ba6 !important;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(92, 74, 199, 0.2) !important;
        }

        .btn-action-submit:disabled {
            opacity: 0.65;
            cursor: not-allowed;
        }

    .btn-action-cancel {
        background-color: #ffffff;
        color: #475569;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 10px 20px;
        font-size: 13.5px;
        font-weight: 500;
        transition: all 0.2s ease;
    }

        .btn-action-cancel:hover {
            background-color: #f1f5f9;
            color: #1e293b;
        }

    /* High-End System Alerts Override */
    .alert-premium-danger {
        background-color: #fef2f2;
        color: #991b1b;
        border-left: 4px solid #ef4444 !important;
        border-radius: 8px;
        padding: 12px 16px;
    }
</style>

@code {
    public CreateDepartmentDto model { get; set; } = new();

    private string? error;
    private bool isSubmitting;

    async Task HandleCreateDepartment()
    {
        error = null;

        if (string.IsNullOrWhiteSpace(model.Name))
        {
            error = "Department name is required before executing creation protocols.";
            return;
        }

        isSubmitting = true;

        try
        {
            await DeptService.CreateAsync(model);
            Nav.NavigateTo("/org/departments");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    void GoBack() => Nav.NavigateTo("/org/departments");
}