@page "/orgadmin/asset-requests"
@attribute [Authorize(Roles = "OrgAdmin")]
@rendermode InteractiveServer

@using Humatrix_HRMS.Data
@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Infrastructure.Constants
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject CurrentUserService CurrentUser

<PageTitle>Asset Requests</PageTitle>

<div class="container-fluid px-4 py-3">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-0">Asset Requests</h4>
            <small class="text-muted">
                Review procurement requests submitted by HR
            </small>
        </div>
    </div>

    <!-- Alerts -->
    @if (!string.IsNullOrWhiteSpace(_successMsg))
    {
        <div class="alert alert-success alert-dismissible fade show">
            @_successMsg
            <button class="btn-close" @onclick="() => _successMsg = null"></button>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(_errorMsg))
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @_errorMsg
            <button class="btn-close" @onclick="() => _errorMsg = null"></button>
        </div>
    }

    <!-- Table -->
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">

            @if (_loading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary"></div>
                </div>
            }
            else if (!_requests.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                    No asset requests found.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">

                        <thead class="table-light">
                            <tr>
                                <th>Requested By</th>
                                <th>Department</th>
                                <th>Category</th>
                                <th>Quantity</th>
                                <th>Reason</th>
                                <th>Status</th>
                                <th>Date</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>

                        <tbody>

                            @foreach (var r in _requests)
                            {
                                <tr>

                                    <td>
                                        <div class="fw-semibold">
                                            @r.Employee?.FirstName @r.Employee?.LastName
                                        </div>

                                        <small class="text-muted">
                                            @r.Employee?.EmployeeCode
                                        </small>
                                    </td>

                                    <td>
                                        @r.Employee?.Department?.Name
                                    </td>

                                    <td>
                                        <span class="badge bg-light text-dark border">
                                            @r.RequestedCategory
                                        </span>
                                    </td>

                                    <td>
                                        @r.Quantity
                                    </td>

                                    <td style="max-width:250px;">
                                        <small>
                                            @r.Reason
                                        </small>
                                    </td>

                                    <td>
                                        @RenderStatusBadge(r.Status)
                                    </td>

                                    <td>
                                        <small>
                                            @r.CreatedAt.ToString("dd MMM yyyy")
                                        </small>
                                    </td>

                                    <td class="text-end">

                                        @if (r.Status == AssetRequestStatuses.Pending)
                                        {
                                            <div class="btn-group btn-group-sm">

                                                <button class="btn btn-success"
                                                        @onclick="() => ApproveRequest(r)">
                                                    <i class="bi bi-check-lg"></i>
                                                </button>

                                                <button class="btn btn-danger"
                                                        @onclick="() => RejectRequest(r)">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>

                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">
                                                No actions
                                            </span>
                                        }

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>
                </div>
            }

        </div>
    </div>
</div>

@code {

    private List<AssetRequest> _requests = new();

    private bool _loading = true;

    private string? _successMsg;
    private string? _errorMsg;

    private Guid _orgId;

    protected override async Task OnInitializedAsync()
    {
        var currentUser = await CurrentUser.GetUserAsync();

        _orgId = currentUser?.OrganizationId ?? Guid.Empty;

        await LoadRequests();
    }

    private async Task LoadRequests()
    {
        _loading = true;

        try
        {
            using var db = await DbFactory.CreateDbContextAsync();

            _requests = await db.AssetRequests

                .Include(x => x.Employee)
                .ThenInclude(e => e.Department)

                .Where(x => x.OrganizationId == _orgId)

                .OrderByDescending(x => x.CreatedAt)

                .ToListAsync();
        }
        catch (Exception ex)
        {
            _errorMsg = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ApproveRequest(AssetRequest request)
    {
        try
        {
            using var db = await DbFactory.CreateDbContextAsync();

            var entity = await db.AssetRequests
                .FirstOrDefaultAsync(x => x.AssetRequestId == request.AssetRequestId);

            if (entity == null)
                return;

            entity.Status = AssetRequestStatuses.Approved;

            entity.ProcessedAt = DateTime.UtcNow;

            await db.SaveChangesAsync();

            _successMsg = "Request approved successfully.";

            await LoadRequests();
        }
        catch (Exception ex)
        {
            _errorMsg = ex.Message;
        }
    }

    private async Task RejectRequest(AssetRequest request)
    {
        try
        {
            using var db = await DbFactory.CreateDbContextAsync();

            var entity = await db.AssetRequests
                .FirstOrDefaultAsync(x => x.AssetRequestId == request.AssetRequestId);

            if (entity == null)
                return;

            entity.Status = AssetRequestStatuses.Rejected;

            entity.ProcessedAt = DateTime.UtcNow;

            await db.SaveChangesAsync();

            _successMsg = "Request rejected successfully.";

            await LoadRequests();
        }
        catch (Exception ex)
        {
            _errorMsg = ex.Message;
        }
    }

    private MarkupString RenderStatusBadge(string status)
    {
        return new(status switch
        {
            "Pending" =>
                "<span class='badge bg-warning text-dark'>Pending</span>",

            "Approved" =>
                "<span class='badge bg-success'>Approved</span>",

            "Rejected" =>
                "<span class='badge bg-danger'>Rejected</span>",

            _ =>
                $"<span class='badge bg-secondary'>{status}</span>"
        });
    }
}