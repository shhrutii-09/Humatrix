<!-- PASSWORD MODAL -->
@if (showPasswordModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">

                <div class="modal-header bg-light">
                    <h5 class="modal-title">Change Password</h5>
                    <button class="btn-close" @onclick="ClosePasswordModal"></button>
                </div>

                <div class="modal-body">
                    @if (hasPassword)
                    {
                        <input type="password" class="form-control mb-2"
                               placeholder="Current Password"
                               @bind="currentPwd" />
                    }

                    <input type="password" class="form-control mb-2"
                           placeholder="New Password"
                           @bind="newPwd" />

                    <input type="password" class="form-control"
                           placeholder="Confirm Password"
                           @bind="confirmPwd" />
                </div>

                <div class="modal-footer">
                    <button class="btn btn-light" @onclick="ClosePasswordModal">Cancel</button>
                    <button class="btn btn-primary"
                            style="background-color:#5c4ac7"
                            @onclick="ChangePassword">
                        Update
                    </button>
                </div>

            </div>
        </div>
    </div>
}

<style>
    .uppercase-tracking {
        text-transform: uppercase;
        letter-spacing: 1px;
        font-size: 0.75rem;
    }

    .btn-white {
        background: white;
    }

    .form-control:focus {
        border-color: #5c4ac7;
        box-shadow: 0 0 0 0.2rem rgba(92, 74, 199, 0.25);
    }
</style>

@code {

    private Organization orgModel = new();
    private string? adminEmail;

    private int employeeCount;
    private int hrCount;
    private int deptCount;

    private bool isLoading = true;
    private bool isSaving = false;

    private bool showPasswordModal = false;

    private string newAdminEmail = "";

    private string currentPwd = "";
    private string newPwd = "";
    private string confirmPwd = "";

    private bool hasPassword;

    private string? statusMessage;
    private string? errorMessage;
    private OfficeLocationDto locationModel = new();
    private bool isDetectingLocation = false;
    private ApplicationUser? currentUser;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = await UserManager.GetUserAsync(authState.User);

            if (user == null || user.OrganizationId == null)
            {
                errorMessage = "Invalid user or organization.";
                return;
            }

            currentUser = user;

            using var db = DbFactory.CreateDbContext();

            var orgId = user.OrganizationId.Value;

            orgModel = await db.Organizations
                .FirstAsync(x => x.OrganizationId == orgId);

            adminEmail = await OrgService.GetOrganizationAdminEmailAsync(orgId);

            var stats = await OrgService.GetOrganizationDetailsAsync(orgId);

            employeeCount = stats.EmployeeCount;
            hrCount = stats.HRCount;
            deptCount = stats.DepartmentCount;

            hasPassword = await UserManager.HasPasswordAsync(user);

            var location = await LocationService.GetAsync();

            if (location != null)
            {
                locationModel = new OfficeLocationDto
                {
                    Id = location.Id,
                    Name = location.Name,
                    Latitude = location.Latitude,
                    Longitude = location.Longitude,
                    RadiusInMeters = location.RadiusInMeters
                };
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }

        isLoading = false;
    }

    private async Task UpdateOrganization()
    {
        try
        {
            isSaving = true;
            await OrgService.UpdateOrganizationAsync(orgModel);

            statusMessage = "Organization updated successfully!";
            errorMessage = null;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DetectLocation()
    {
        try
        {
            isDetectingLocation = true;

            var loc = await JS.InvokeAsync<LocationResult>("getLocation");

            locationModel.Latitude = loc.Latitude;
            locationModel.Longitude = loc.Longitude;
        }
        catch (Exception ex)
        {
            errorMessage = "Location error: " + ex.Message;
        }
        finally
        {
            isDetectingLocation = false;
        }
    }
    
  

    private void ShowPasswordModal() => showPasswordModal = true;
    private void ClosePasswordModal() => showPasswordModal = false;

    private async Task ChangePassword()
    {
        if (newPwd != confirmPwd)
        {
            errorMessage = "Passwords do not match.";
            return;
        }

        try
        {
            IdentityResult result;

            if (hasPassword)
                result = await UserManager.ChangePasswordAsync(currentUser!, currentPwd, newPwd);
            else
                result = await UserManager.AddPasswordAsync(currentUser!, newPwd);

            if (result.Succeeded)
            {
                statusMessage = "Password updated successfully!";
                showPasswordModal = false;

                currentPwd = newPwd = confirmPwd = "";
            }
            else
            {
                errorMessage = string.Join(", ", result.Errors.Select(e => e.Description));
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }
}