@page "/org/profile"
@rendermode InteractiveServer

@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Data
@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Authorization
@using static Humatrix_HRMS.Components.Pages.Employee.Attendence

@attribute [Authorize(Roles = "OrgAdmin")]
@inject OfficeLocationService LocationService
@inject IJSRuntime JS

@inject OrganizationService OrgService
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav

<PageTitle>My Profile | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-normal">Organization Profile</h2>
        <button class="btn btn-white border shadow-sm"
                @onclick='() => Nav.NavigateTo("/org/dashboard")'>
            BACK TO DASHBOARD
        </button>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
            <p class="text-muted mt-2">Loading profile...</p>
        </div>
    }
    else
    {
        <div class="row g-4">

            <!-- LEFT SIDE -->
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">

                        <EditForm Model="orgModel" OnValidSubmit="UpdateOrganization">
                            <DataAnnotationsValidator />

                            <h5 class="text-muted border-bottom pb-2 mb-3">
                                Organization Details
                            </h5>

                            <div class="mb-3">
                                <label class="small fw-bold">Organization Name</label>
                                <InputText class="form-control" @bind-Value="orgModel.Name" />
                            </div>

                            <div class="mb-3">
                                <label class="small fw-bold">Organization Email</label>
                                <InputText class="form-control" @bind-Value="orgModel.Email" disabled />
                            </div>

                            <div class="mb-3">
                                <label class="small fw-bold">Phone</label>
                                <InputText class="form-control" @bind-Value="orgModel.Phone" />
                            </div>

                            <div class="mb-3">
                                <label class="small fw-bold">Address</label>
                                <InputText class="form-control" @bind-Value="orgModel.Address" />
                            </div>
                            <hr class="my-4" />

                            <h5 class="text-muted border-bottom pb-2 mb-3">
                                Office Location
                            </h5>

                            <div class="row g-3">

                                <div class="col-md-6">
                                    <label class="small fw-bold">Office Name</label>
                                    <InputText class="form-control" @bind-Value="locationModel.Name" />
                                </div>

                                <div class="col-md-3">
                                    <label class="small fw-bold">Latitude</label>
                                    <InputNumber class="form-control" @bind-Value="locationModel.Latitude" />
                                </div>

                                <div class="col-md-3">
                                    <label class="small fw-bold">Longitude</label>
                                    <InputNumber class="form-control" @bind-Value="locationModel.Longitude" />
                                </div>

                                <div class="col-md-4">
                                    <label class="small fw-bold">Allowed Radius (meters)</label>
                                    <InputNumber class="form-control" @bind-Value="locationModel.RadiusInMeters" />
                                </div>

                                <div class="col-md-8 d-flex align-items-end">
                                    <button type="button"
                                            class="btn btn-outline-primary me-2"
                                            @onclick="DetectLocation"
                                            disabled="@isDetectingLocation">

                                        @if (isDetectingLocation)
                                        {
                                            <span class="spinner-border spinner-border-sm me-2"></span>
                                        }

                                        📍 Detect Location
                                    </button>
                                </div>

                            </div>

                            @if (locationModel.Latitude != 0 && locationModel.Longitude != 0)
                            {
                                <div class="mt-3">
                                    <p class="text-muted small">
                                        📍 Current Location: <strong>@locationModel.Latitude, @locationModel.Longitude</strong>
                                    </p>

                                    <a class="btn btn-outline-primary btn-sm"
                                       href="https://www.google.com/maps?q=@locationModel.Latitude,@locationModel.Longitude"
                                       target="_blank">
                                        🌍 View on Map
                                    </a>
                                </div>
                            }

                            <div class="mt-4 d-flex gap-2">
                                <button class="btn btn-success px-4" disabled="@isSaving">
                                    @(isSaving ? "Saving..." : "SAVE CHANGES")
                                </button>

                                <button type="button" class="btn btn-outline-primary"
                                        @onclick="ShowPasswordModal">
                                    CHANGE PASSWORD
                                </button>
                            </div>
                        </EditForm>

                    </div>
                </div>
            </div>

            <!-- RIGHT SIDE PANEL -->
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm text-center">
                    <div class="card-body p-4">

                        <!-- Avatar -->
                        <div class="avatar-lg bg-light rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center"
                             style="width: 100px; height: 100px; font-size: 2rem; color: #5c4ac7; border: 2px solid #5c4ac7;">
                            @(string.IsNullOrEmpty(adminEmail) ? "A" : adminEmail[0].ToString().ToUpper())
                        </div>

                        <h5 class="mb-1">@orgModel.Name</h5>
                        <p class="text-muted small">Organization Admin</p>

                        <hr />

                        <p class="small text-muted mb-1">ADMIN EMAIL</p>
                        <p class="fw-bold">@adminEmail</p>

                        @* <button class="btn btn-warning w-100 mt-3"
                                @onclick="ShowChangeAdmin">
                            CHANGE ADMIN
                        </button> *@

                    </div>
                </div>

                <!-- STATS -->
                <div class="card border-0 shadow-sm mt-4">
                    <div class="card-body p-4">

                        <h6 class="text-muted mb-3 uppercase-tracking">
                            ORGANIZATION OVERVIEW
                        </h6>

                        <p><strong>Employees:</strong> @employeeCount</p>
                        <p><strong>HRs:</strong> @hrCount</p>
                        <p><strong>Departments:</strong> @deptCount</p>

                    </div>
                </div>
            </div>

        </div>
    }

    <!-- STATUS -->
    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="alert alert-success mt-4">@statusMessage</div>
    }
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger mt-4">@errorMessage</div>
    }
</div>

