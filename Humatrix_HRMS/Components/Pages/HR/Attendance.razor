@page "/admin/attendance"
@rendermode InteractiveServer
@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "HR,OrgAdmin")]

@inject AttendanceService AttendanceService
@inject DepartmentService DeptService
@inject AuthenticationStateProvider AuthStateProvider

<h3 class="mb-3">Attendance Management</h3>

<div class="card p-4 shadow-sm mb-4">
    <div class="row g-3">
        <div class="col-md-3">
            <label class="form-label">Date</label>
            <InputDate @bind-Value="selectedDate" class="form-control" />
        </div>

        @if (isOrgAdmin)
        {
            <div class="col-md-3">
                <label class="form-label">Department</label>
                <select @bind="selectedDepartmentId" class="form-control">
                    <option value="">All Departments</option>
                    @foreach (var dept in departments)
                    {
                        <option value="@dept.DepartmentId">@dept.Name</option>
                    }
                </select>
            </div>
        }

        <div class="col-md-3">
            <label class="form-label">Role</label>
            <select @bind="selectedRole" class="form-control">
                <option value="">All Roles</option>
                <option value="Employee">Employee</option>
                <option value="HR">HR</option>
            </select>
        </div>

        <div class="col-md-2 d-flex align-items-end">
            <button class="btn btn-primary w-100" @onclick="LoadData">Filter</button>
        </div>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-bordered table-hover bg-white">
        <thead class="table-dark">
            <tr>
                <th>Employee</th>
                <th>Department</th>
                <th>Check In</th>
                <th>Check Out</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @if (attendanceList != null && attendanceList.Any())
            {
                @foreach (var item in attendanceList)
                {
                    <tr>
                        <td>
                            <strong>@item.EmployeeName</strong><br />
                            <small class="text-muted">@item.Email</small>
                        </td>
                        <td>@item.Department</td>
                        <td>@item.CheckIn?.ToLocalTime().ToString("hh:mm tt")</td>
                        <td>@item.CheckOut?.ToLocalTime().ToString("hh:mm tt")</td>
                        <td>
                            <span class="badge @GetStatusClass(item.Status)">@item.Status</span>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="5" class="text-center">No records found for this selection.</td></tr>
            }
        </tbody>
    </table>
</div>

@code {
    private List<AttendanceListDto> attendanceList = new();
    private List<DepartmentDto> departments = new();
    private DateTime? selectedDate = DateTime.Today;
    private Guid? selectedDepartmentId;
    private string? selectedRole;
    private bool isOrgAdmin;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        isOrgAdmin = authState.User.IsInRole("OrgAdmin");

        if (isOrgAdmin)
        {
            departments = await DeptService.GetAllAsync();
        }

        await LoadData();
    }

    private async Task LoadData()
    {
        attendanceList = await AttendanceService.GetAllAttendanceAsync(selectedDate, selectedDepartmentId, selectedRole);
    }

    private string GetStatusClass(string status) => status switch
    {
        "Present" => "bg-success",
        "Late" => "bg-warning text-dark",
        "Half Day" => "bg-orange",
        "Absent" => "bg-danger",
        _ => "bg-secondary"
    };
}