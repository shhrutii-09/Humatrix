@page "/admin/attendance"
@rendermode InteractiveServer

@using Humatrix_HRMS.Data
@using Microsoft.EntityFrameworkCore
@using Humatrix_HRMS.Helpers
@inject ApplicationDbContext DbContext
@inject CurrentUserService CurrentUserService
@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize(Roles = "HR,OrgAdmin")]

@inject AttendanceService AttendanceService
@inject DepartmentService DeptService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Attendance Management | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-normal">Attendance Management</h2>
        <button class="btn btn-outline-secondary shadow-sm" @onclick="LoadData">
            <i class="bi bi-arrow-clockwise"></i> REFRESH
        </button>
    </div>

    <!-- STATS -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm border-0 border-start border-primary border-4">
                <div class="card-body py-3">
                    <small class="text-muted fw-bold">TOTAL RECORDS</small>
                    <h3 class="mb-0">@attendanceList.Count</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0 border-start border-warning border-4">
                <div class="card-body py-3">
                    <small class="text-muted fw-bold">LATE ARRIVALS</small>
                    <h3 class="mb-0 text-warning">
                        @attendanceList.Count(x => x.Status != null && x.Status.Contains("Late"))
                    </h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0 border-start border-danger border-4">
                <div class="card-body py-3">
                    <small class="text-muted fw-bold">ABSENT</small>
                    <h3 class="mb-0 text-danger">
                        @attendanceList.Count(x => x.Status == "Absent")
                    </h3>
                </div>
            </div>
        </div>
    </div>

    <!-- FILTER -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4">
            <div class="row g-3 align-items-end">

                <div class="col-md-3">
                    <label class="form-label small fw-bold text-muted">Filter Date</label>
                    <InputDate @bind-Value="selectedDate" class="form-control" />
                </div>

                @if (isOrgAdmin)
                {
                    <div class="col-md-3">
                        <label class="form-label small fw-bold text-muted">Department</label>
                        <select @bind="selectedDepartmentId" class="form-select">
                            <option value="">All Departments</option>
                            @foreach (var dept in departments)
                            {
                                <option value="@dept.DepartmentId">@dept.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-bold text-muted">User Role</label>
                        <select @bind="selectedRole" class="form-select">
                            <option value="">All Roles</option>
                            <option value="Employee">Employee</option>
                            <option value="HR">HR</option>
                        </select>
                    </div>
                }

              

                <div class="col-md-3">
                    <button class="btn btn-primary w-100 shadow-sm"
                            style="background-color: #5c4ac7; border: none;"
                            @onclick="LoadData"
                            disabled="@isLoading">
                        @if (isLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        FILTER RECORDS
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- TABLE -->
    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            @if (isNonWorkingDay)
            {
                <div class="alert alert-info text-center p-5 my-4">
                    <i class="bi bi-calendar-event fs-1"></i>
                    <h4 class="mt-3">@dayStatusMessage</h4>
                    <p class="text-muted">Attendance records are not available for non-working days.</p>
                </div>
            }
            else
            {
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 text-muted small">EMPLOYEE</th>
                            <th class="text-muted small">DEPARTMENT</th>
                            <th class="text-muted small text-center">CHECK IN</th>
                            <th class="text-muted small text-center">CHECK OUT</th>
                            <th class="text-muted small">STATUS</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (isLoading)
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                    Loading attendance data...
                                </td>
                            </tr>
                        }
                        else if (attendanceList.Any())
                        {
                            @* @foreach (var item in attendanceList)
                            { *@
                            @foreach (var item in attendanceList.Skip((currentPage - 1) * pageSize).Take(pageSize))
                            {
                                <tr class="@(item.Status == "Absent" ? "table-danger" : "")">

                                    <!-- EMPLOYEE -->
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <div class="me-3 bg-light text-primary d-flex align-items-center justify-content-center rounded-circle fw-bold"
                                                 style="width:40px;height:40px;">
                                                @(string.IsNullOrWhiteSpace(item.EmployeeName)
                                                                                    ? "?"
                                                                                    : item.EmployeeName[0])
                                </div>
                                <div>
                                    <div class="fw-bold">@item.EmployeeName</div>
                                    <div class="small text-muted">@item.Email</div>
                                </div>
                            </div>
                        </td>

                                    <!-- DEPARTMENT -->
                                    <td>
                                        <span class="badge bg-light text-dark fw-normal">
                                            @item.Department
                                        </span>
                            @if (item.IsManual)
                                        {
                                            <span class="ms-1 text-primary" title="Manual Entry">
                                                <i class="bi bi-info-circle"></i>
                                            </span>
                                        }
                                    </td>

                                    <!-- CHECK IN -->
                                    @* <td class="text-center font-monospace">
                                        @TimeHelper.FormatOrgTime(item.CheckIn)
                                    </td>

                                    <td class="text-center font-monospace">
                                        @TimeHelper.FormatOrgTime(item.CheckOut)
                                    </td> *@

                                    <!-- CHECK IN -->
                                    <td class="text-center font-monospace">
                                        @FormatTime(item.CheckIn)
                                    </td>

                                    <td class="text-center font-monospace">
                                        @FormatTime(item.CheckOut)
                                    </td>
                                    <!-- STATUS -->
                                    <td>
                                        <span class="badge rounded-pill @GetStatusClass(item.Status)">
                                            @item.Status
                                        </span>
                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    No attendance records found.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                @if (attendanceList.Any() && !isNonWorkingDay && !isLoading)
                {
                    <div class="card-footer bg-white border-top-0 py-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="small text-muted">
                                Showing <b>@(((currentPage - 1) * pageSize) + 1)</b> to
                                <b>@(Math.Min(currentPage * pageSize, attendanceList.Count))</b>
                                of <b>@attendanceList.Count</b> records
                            </div>
                            <nav>
                                <ul class="pagination pagination-sm mb-0">
                                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                        <button class="page-link" @onclick="(() => ChangePage(currentPage - 1))">Previous</button>
                                    </li>

                                    @for (int i = 1; i <= TotalPages; i++)
                                    {
                                        var pageNumber = i;
                                        <li class="page-item @(currentPage == pageNumber ? "active" : "")">
                                            <button class="page-link" @onclick="(() => ChangePage(pageNumber))"
                                                    style="@(currentPage == pageNumber ? "background-color: #5c4ac7; border-color: #5c4ac7;" : "")">
                                                @pageNumber
                                            </button>
                                        </li>
                                    }

                                    <li class="page-item @(currentPage == TotalPages ? "disabled" : "")">
                                        <button class="page-link" @onclick="(() => ChangePage(currentPage + 1))">Next</button>
                                    </li>
                                </ul>
                            </nav>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

@code {

    private List<AttendanceListDto> attendanceList = new();
    private List<DepartmentDto> departments = new();

    // FIX: Initialize to org-local date, not DateTime.Today (server date).
    // Set properly in OnInitializedAsync after org timezone is loaded.
    private DateTime selectedDate;
    private Guid? selectedDepartmentId;
    private string? selectedRole;

    private bool isOrgAdmin;
    private bool isLoading;

    private int currentPage = 1;
    private int pageSize = 10; // Change this to 25 or 50 if preferred
    private int TotalPages => (int)Math.Ceiling((decimal)attendanceList.Count / pageSize);

    private void ChangePage(int newPage)
    {
        currentPage = newPage;
        StateHasChanged();
    }

    // FIX: Store org timezone — used for all time display conversions.
    private TimeZoneInfo orgTimeZone = TimeZoneInfo.Utc;
    private string orgTimeZoneId = "UTC";

    private async Task LoadOrgTimezone()
    {
        var user = await CurrentUserService.GetUserAsync();
        if (user?.OrganizationId == null) return;

        var tzId = await DbContext.Organizations
            .AsNoTracking()
            .Where(o => o.OrganizationId == user.OrganizationId)
            .Select(o => o.TimeZoneId)
            .FirstOrDefaultAsync();

        if (!string.IsNullOrWhiteSpace(tzId))
        {
            orgTimeZoneId = tzId;
            orgTimeZone = TimeHelper.GetOrgTimeZone(tzId);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        isOrgAdmin = authState.User.IsInRole("OrgAdmin");

        // FIX: Load org timezone FIRST so selectedDate uses org-local today.
        await LoadOrgTimezone();

        // FIX: Use org-local today, not server DateTime.Today
        selectedDate = TimeHelper.GetOrgDate(orgTimeZone);

        if (isOrgAdmin)
            departments = await DeptService.GetAllAsync();

        await LoadData();
    }

    private bool isNonWorkingDay;
    private string dayStatusMessage = "";

    private async Task LoadData()
    {
        // isLoading = true;
        // isNonWorkingDay = false;
        // StateHasChanged();
        isLoading = true;
        isNonWorkingDay = false;
        currentPage = 1; // Reset to first page on new search
        StateHasChanged();
        try
        {
            attendanceList = await AttendanceService.GetAttendanceForDateAsync(
                selectedDate,
                selectedDepartmentId == Guid.Empty ? null : selectedDepartmentId,
                selectedRole);

            if (attendanceList.Any())
            {
                var firstStatus = attendanceList.First().Status ?? "";
                if (firstStatus.Contains("Holiday") || firstStatus.Contains("Weekend"))
                {
                    isNonWorkingDay = true;
                    dayStatusMessage = firstStatus;
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[AttendancePage] {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private string FormatTime(DateTime? utcTime)
    {
        if (utcTime == null)
            return "--";

        return utcTime.Value.ToLocalTime().ToString("hh:mm tt");
    }
    private string GetStatusClass(string? status)
    {
        if (string.IsNullOrEmpty(status)) return "bg-secondary";
        if (status.Contains("Holiday")) return "bg-info text-dark";
        if (status.Contains("Weekend")) return "bg-light text-muted border";
        return status switch
        {
            "Present" => "bg-success",
            "Late" => "bg-warning text-dark",
            "Absent" => "bg-danger",
            "On Leave" => "bg-primary",
            "Work From Home" => "bg-dark",
            "Not Started" => "bg-light text-dark border",
            _ => "bg-secondary"
        };
    }
}