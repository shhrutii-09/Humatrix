@code {
    [Parameter] public string? UserEmail { get; set; }

    private EmployeeListDto? model;
    private EditEmployeeDto editModel = new();
    private bool IsSelf => string.IsNullOrEmpty(UserEmail);
    private bool isSaving = false;
    private bool showPasswordModal = false;

    private string? statusMessage;
    private string? errorMessage;

    private string currentPwd = "";
    private string newPwd = "";
    private string confirmPwd = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }
// In /hr/profile @code section, update the LoadData method:
private async Task LoadData()
{
    try
    {
        string? emailToFetch = IsSelf ? (await CurrentUserService.GetUserAsync())?.Email : UserEmail;

        if (!string.IsNullOrEmpty(emailToFetch))
        {
            model = await EmployeeService.GetEmployeeByEmailAsync(emailToFetch);

            if (model != null)
            {
                editModel = new EditEmployeeDto
                {
                    FirstName = model.FirstName,
                    LastName = model.LastName,
                    DepartmentId = model.DepartmentId,
                    DesignationId = model.DesignationId,
                    ShiftId = model.ShiftId,
                    Role = model.Role,
                    DateOfBirth = model.DateOfBirth  // ✅ ADD THIS LINE
                };
            }
            else { errorMessage = "Profile not found."; }
        }
    }
    catch (Exception ex) { errorMessage = "Error loading profile: " + ex.Message; }

    StateHasChanged();
}

    private async Task HandleUpdate()
    {
        statusMessage = errorMessage = null;
        try
        {
            isSaving = true;
            await EmployeeService.UpdateEmployeeAsync(model!.Email, editModel);
            statusMessage = "Profile updated successfully!";
        }
        catch (Exception ex) { errorMessage = ex.Message; }
        finally { isSaving = false; }
    }

    private async Task HandlePasswordReset()
    {
        if (newPwd != confirmPwd) { errorMessage = "Passwords do not match."; return; }
        statusMessage = errorMessage = null;

        try
        {
            isSaving = true;
            var user = await UserManager.FindByEmailAsync(model!.Email);
            var result = await UserManager.ChangePasswordAsync(user!, currentPwd, newPwd);

            if (result.Succeeded)
            {
                statusMessage = "Password changed successfully!";
                showPasswordModal = false;
                currentPwd = newPwd = confirmPwd = "";
            }
            else { errorMessage = string.Join(", ", result.Errors.Select(e => e.Description)); }
        }
        catch (Exception ex) { errorMessage = ex.Message; }
        finally { isSaving = false; }
    }
}