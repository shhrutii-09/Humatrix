@page "/hr/profile"
@page "/hr/profile/{UserEmail}"
@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Data
@using Humatrix_HRMS.Services
@using Humatrix_HRMS.Models
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity

@attribute [Authorize(Roles = "HR")]
@inject EmployeeService EmployeeService
@inject CurrentUserService CurrentUserService
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Profile | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-normal">@(IsSelf ? "My Profile" : "Employee Profile")</h2>
        <button class="btn btn-primary shadow-sm" style="background-color: #5c4ac7; border: none;" @onclick='() => Nav.NavigateTo("/hr/dashboard")'>
            BACK TO DASHBOARD
        </button>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            @if (model == null && string.IsNullOrEmpty(errorMessage))
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2 text-muted">Fetching details...</p>
                </div>
            }
            else if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }
            else
            {
                <EditForm Model="editModel" OnValidSubmit="HandleUpdate">
                    <DataAnnotationsValidator />

                    <div class="row g-4">
                        <div class="col-md-8">
                            <h5 class="mb-3 text-muted border-bottom pb-2">Personal Information</h5>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label small fw-bold">First Name</label>
                                    <InputText @bind-Value="editModel.FirstName" class="form-control" disabled="@(!IsSelf)" />
                                    <ValidationMessage For="@(() => editModel.FirstName)" class="text-danger small" />
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label small fw-bold">Last Name</label>
                                    <InputText @bind-Value="editModel.LastName" class="form-control" disabled="@(!IsSelf)" />
                                    <ValidationMessage For="@(() => editModel.LastName)" class="text-danger small" />
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label small fw-bold">Email Address</label>
                                <input type="text" class="form-control bg-light" value="@model.Email" disabled />
                            </div>

                            <h5 class="mt-4 mb-3 text-muted border-bottom pb-2">Employment Details</h5>
                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label class="form-label small fw-bold">Department</label>
                                    <input type="text" class="form-control bg-light" value="@model.Department" disabled />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label small fw-bold">Designation</label>
                                    <input type="text" class="form-control bg-light" value="@model.Designation" disabled />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label small fw-bold">Work Shift</label>
                                    <input type="text" class="form-control bg-light" value="@model.ShiftName" disabled />
                                </div>
                            </div>

                            @if (IsSelf)
                            {
                                <div class="mt-4 d-flex gap-2">
                                    <button type="submit" class="btn btn-success px-4" disabled="@isSaving">
                                        @(isSaving ? "Saving..." : "SAVE CHANGES")
                                    </button>
                                    <button type="button" class="btn btn-outline-primary" @onclick="() => showPasswordModal = true">
                                        CHANGE PASSWORD
                                    </button>
                                </div>
                            }
                        </div>

                        <div class="col-md-4 border-start ps-4">
                            <div class="text-center">
                                <div class="avatar-lg bg-light rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center" style="width: 100px; height: 100px; font-size: 2rem; color: #5c4ac7; border: 2px solid #5c4ac7;">
                                    @model.FirstName[0]@model.LastName[0]
                                </div>
                                <h4 class="mb-0">@model.Name</h4>
                                <p class="text-muted">@model.Role</p>

                                <div class="mt-3">
                                    @if (model.IsActive)
                                    {
                                        <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill">ACTIVE ACCOUNT</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger px-3 py-2 rounded-pill">INACTIVE</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </EditForm>
            }

            @if (!string.IsNullOrEmpty(statusMessage))
            {
                <div class="alert alert-success mt-4 border-0 shadow-sm">@statusMessage</div>
            }
        </div>
    </div>
</div>

@* --- Reset Password Modal --- *@
@if (showPasswordModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-light">
                    <h5 class="modal-title fw-bold">Change Password</h5>
                    <button type="button" class="btn-close" @onclick="() => showPasswordModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="small fw-bold">Current Password</label>
                        <input type="password" class="form-control" @bind="currentPwd" />
                    </div>
                    <div class="mb-3">
                        <label class="small fw-bold">New Password</label>
                        <input type="password" class="form-control" @bind="newPwd" />
                    </div>
                    <div class="mb-3">
                        <label class="small fw-bold">Confirm New Password</label>
                        <input type="password" class="form-control" @bind="confirmPwd" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-light" @onclick="() => showPasswordModal = false">Cancel</button>
                    <button class="btn btn-primary" style="background-color: #5c4ac7;" @onclick="HandlePasswordReset" disabled="@isSaving">
                        UPDATE PASSWORD
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .bg-success-subtle {
        background-color: #d1e7dd;
    }

    .bg-danger-subtle {
        background-color: #f8d7da;
    }

    .form-control:focus {
        border-color: #5c4ac7;
        box-shadow: 0 0 0 0.2rem rgba(92, 74, 199, 0.25);
    }
</style>

@code {
    [Parameter] public string? UserEmail { get; set; }

    private EmployeeListDto? model;
    private EditEmployeeDto editModel = new();
    private bool IsSelf => string.IsNullOrEmpty(UserEmail);
    private bool isSaving = false;
    private bool showPasswordModal = false;

    private string? statusMessage;
    private string? errorMessage;

    private string currentPwd = "";
    private string newPwd = "";
    private string confirmPwd = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            string? emailToFetch = IsSelf ? (await CurrentUserService.GetUserAsync())?.Email : UserEmail;

            if (!string.IsNullOrEmpty(emailToFetch))
            {
                // Note: Make sure you added 'GetEmployeeByEmailAsync' to your EmployeeService as discussed earlier
                model = await EmployeeService.GetEmployeeByEmailAsync(emailToFetch);

                if (model != null)
                {
                    editModel = new EditEmployeeDto
                    {
                        FirstName = model.FirstName,
                        LastName = model.LastName,
                        DepartmentId = model.DepartmentId,
                        DesignationId = model.DesignationId,
                        ShiftId = model.ShiftId,
                        Role = model.Role
                    };
                }
                else { errorMessage = "Profile not found."; }
            }
        }
        catch (Exception ex) { errorMessage = "Error loading profile: " + ex.Message; }

        StateHasChanged();
    }

    private async Task HandleUpdate()
    {
        statusMessage = errorMessage = null;
        try
        {
            isSaving = true;
            await EmployeeService.UpdateEmployeeAsync(model!.Email, editModel);
            statusMessage = "Profile updated successfully!";
        }
        catch (Exception ex) { errorMessage = ex.Message; }
        finally { isSaving = false; }
    }

    private async Task HandlePasswordReset()
    {
        if (newPwd != confirmPwd) { errorMessage = "Passwords do not match."; return; }
        statusMessage = errorMessage = null;

        try
        {
            isSaving = true;
            var user = await UserManager.FindByEmailAsync(model!.Email);
            var result = await UserManager.ChangePasswordAsync(user!, currentPwd, newPwd);

            if (result.Succeeded)
            {
                statusMessage = "Password changed successfully!";
                showPasswordModal = false;
                currentPwd = newPwd = confirmPwd = "";
            }
            else { errorMessage = string.Join(", ", result.Errors.Select(e => e.Description)); }
        }
        catch (Exception ex) { errorMessage = ex.Message; }
        finally { isSaving = false; }
    }
}