@page "/hr/profile"
@page "/hr/profile/{UserEmail}"
@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Data
@using Humatrix_HRMS.Services
@using Humatrix_HRMS.Models
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity

@attribute [Authorize(Roles = "HR")]
@inject EmployeeService EmployeeService
@inject CurrentUserService CurrentUserService
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Profile | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">
    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-normal">@(IsSelf ? "My Profile" : "Employee Profile")</h2>
        </div>
        <!-- Unified interactive back button -->
        <button class="btn btn-interactive-back shadow-sm" @onclick='() => Nav.NavigateTo("/hr/dashboard")'>
            <i class="bi bi-arrow-left me-1"></i> BACK TO DASHBOARD
        </button>
    </div>

    <!-- Main Content Grid -->
    <div class="row g-4">
        @if (model == null && string.IsNullOrEmpty(errorMessage))
        {
            <div class="col-12">
                <div class="card shadow-sm border-0 py-5">
                    <div class="text-center">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p class="mt-2 text-muted mb-0">Fetching profile details...</p>
                    </div>
                </div>
            </div>
        }
        else if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="col-12">
                <div class="alert alert-danger shadow-sm border-0 d-flex align-items-center">
                    <i class="bi bi-exclamation-triangle-fill fs-5 me-2"></i>
                    <div>@errorMessage</div>
                </div>
            </div>
        }
        else
        {
            <!-- Left Side: Profile Information Form Card -->
            <div class="col-lg-8 col-md-7 order-2 order-md-1">
                <div class="card shadow-sm border-0 p-4 h-100">
                    <EditForm Model="editModel" OnValidSubmit="HandleUpdate">
                        <DataAnnotationsValidator />

                        <!-- Section: Personal Info -->
                        <div class="d-flex align-items-center mb-3 pb-2 border-bottom">
                            <i class="bi bi-person-workspace text-muted me-2 fs-5"></i>
                            <h5 class="mb-0 text-secondary fw-semibold">Personal Information</h5>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label small fw-bold text-muted">First Name</label>
                                <InputText @bind-Value="editModel.FirstName" class="form-control shadow-sm" disabled="@(!IsSelf)" />
                                <ValidationMessage For="@(() => editModel.FirstName)" class="text-danger small mt-1" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label small fw-bold text-muted">Last Name</label>
                                <InputText @bind-Value="editModel.LastName" class="form-control shadow-sm" disabled="@(!IsSelf)" />
                                <ValidationMessage For="@(() => editModel.LastName)" class="text-danger small mt-1" />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold text-muted">Email Address</label>
                            <div class="input-group shadow-sm">
                                <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-envelope-fill"></i></span>
                                <input type="text" class="form-control bg-light border-start-0 text-muted" value="@model.Email" disabled />
                            </div>
                        </div>

                        <!-- In /hr/profile - Add this after the Email field (around line 118-125) -->
<div class="mb-4">
    <label class="form-label small fw-bold text-muted">Date of Birth</label>
    <InputDate @bind-Value="editModel.DateOfBirth" class="form-control shadow-sm" disabled="@(!IsSelf)" />
    <ValidationMessage For="@(() => editModel.DateOfBirth)" class="text-danger small mt-1" />
    <small class="text-muted d-block mt-1" style="font-size: 0.72rem;">*Used for birthday wishes and age calculation</small>
</div>

                        <!-- Section: Employment Details -->
                        <div class="d-flex align-items-center mb-3 pb-2 border-bottom mt-2">
                            <i class="bi bi-briefcase-fill text-muted me-2 fs-5"></i>
                            <h5 class="mb-0 text-secondary fw-semibold">Employment Details</h5>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label small fw-bold text-muted">Department</label>
                                <input type="text" class="form-control bg-light shadow-sm text-muted" value="@model.Department" disabled />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label small fw-bold text-muted">Designation</label>
                                <input type="text" class="form-control bg-light shadow-sm text-muted" value="@model.Designation" disabled />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label small fw-bold text-muted">Work Shift</label>
                                <input type="text" class="form-control bg-light shadow-sm text-muted" value="@model.ShiftName" disabled />
                            </div>
                        </div>

                        <!-- Actions Bar -->
                        @if (IsSelf)
                        {
                            <div class="mt-4 pt-3 border-top d-flex gap-2 flex-wrap">
                                <button type="submit" class="btn btn-action-save px-4 shadow-sm" disabled="@isSaving">
                                    @if (isSaving)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                        <span>Saving...</span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-check-circle me-1"></i> <span>SAVE CHANGES</span>
                                    }
                                </button>
                                <button type="button" class="btn btn-action-password px-3 shadow-sm" @onclick="() => showPasswordModal = true">
                                    <i class="bi bi-shield-lock me-1"></i> CHANGE PASSWORD
                                </button>
                            </div>
                        }
                    </EditForm>

                    @if (!string.IsNullOrEmpty(statusMessage))
                    {
                        <div class="alert alert-success mt-4 border-0 shadow-sm d-flex align-items-center">
                            <i class="bi bi-check-circle-fill fs-5 me-2"></i>
                            <div>@statusMessage</div>
                        </div>
                    }
                </div>
            </div>

            <!-- Right Side: Beautiful Profile Display Badge Card -->
            <div class="col-lg-4 col-md-5 order-1 order-md-2">
                <div class="card shadow-sm border-0 p-4 text-center justify-content-center h-100 bg-white">
                    <div class="position-relative d-inline-block mx-auto mb-3">
                        <div class="avatar-container shadow">
                            @model.FirstName[0]@model.LastName[0]
                        </div>
                    </div>
                    
                    <h3 class="fw-normal text-dark mb-1">@model.Name</h3>
                    <p class="text-muted small text-uppercase tracking-wider mb-3">@model.Role</p>

                    <div class="mt-2">
                        <span class="status-badge-compact @(model.IsActive ? "active-badge" : "inactive-badge")">
                            <i class="bi @(model.IsActive ? "bi-check-circle-fill" : "bi-x-circle-fill") me-1"></i>
                            @(model.IsActive ? "Active Account" : "Inactive Profile")
                        </span>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@* --- Reset Password Modal --- *@
@if (showPasswordModal)
{
    <div class="modal fade show d-block" style="background: rgba(15, 23, 42, 0.45); backdrop-filter: blur(4px);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
                <div class="modal-header bg-light border-bottom-0 pt-4 px-4">
                    <h5 class="modal-title fw-semibold text-dark d-flex align-items-center">
                        <i class="bi bi-shield-lock-fill text-secondary me-2"></i> Change Password
                    </h5>
                    <button type="button" class="btn-close" @onclick="() => showPasswordModal = false"></button>
                </div>
                <div class="modal-body px-4 pb-4">
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Current Password</label>
                        <input type="password" class="form-control shadow-sm" @bind="currentPwd" placeholder="••••••••" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">New Password</label>
                        <input type="password" class="form-control shadow-sm" @bind="newPwd" placeholder="••••••••" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Confirm New Password</label>
                        <input type="password" class="form-control shadow-sm" @bind="confirmPwd" placeholder="••••••••" />
                    </div>
                </div>
                <div class="modal-footer bg-light border-top-0 pt-2 pb-3 px-4 d-flex gap-2">
                    <button class="btn btn-light shadow-sm px-3 border" style="border-radius: 8px;" @onclick="() => showPasswordModal = false">Cancel</button>
                    <button class="btn btn-action-save shadow-sm px-3" @onclick="HandlePasswordReset" disabled="@isSaving">
                        UPDATE PASSWORD
                    </button>
                </div>
            </div>
        </div>
    </div>
}

