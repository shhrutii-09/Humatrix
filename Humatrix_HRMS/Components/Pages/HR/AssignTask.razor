@page "/hr/assign-task"
@rendermode InteractiveServer

@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Data
@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Identity

@attribute [Authorize(Roles = "HR,OrgAdmin")]

@inject TaskService TaskService
@inject CurrentUserService CurrentUser
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav

<PageTitle>Assign Task</PageTitle>

<div class="container mt-4">

    <h3>Assign Task</h3>

    @if (!string.IsNullOrEmpty(error))
    {
        <div class="alert alert-danger">@error</div>
    }

    <EditForm Model="model" OnValidSubmit="AssignTaskAsync">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <!-- Employee Dropdown -->
        <div class="mb-3">
            <label>Assign To</label>
            <InputSelect class="form-control" @bind-Value="model.AssignedTo">
                <option value="">-- Select Employee --</option>
                @foreach (var emp in employees)
                {
                    <option value="@emp.EmployeeId">
                        @emp.FirstName @emp.LastName
                    </option>
                }
            </InputSelect>
            <ValidationMessage For="@(() => model.AssignedTo)" />
        </div>

        <!-- Title -->
        <div class="mb-3">
            <label>Title</label>
            <InputText class="form-control" @bind-Value="model.Title" />
            <ValidationMessage For="@(() => model.Title)" />
        </div>

        <!-- Description -->
        <div class="mb-3">
            <label>Description</label>
            <InputTextArea class="form-control" @bind-Value="model.Description" />
            <ValidationMessage For="@(() => model.Description)" />
        </div>

        <!-- Priority -->
        <div class="mb-3">
            <label>Priority</label>
            <InputSelect class="form-control" @bind-Value="model.Priority">
                <option value="">-- Select Priority --</option>
                <option>Low</option>
                <option>Medium</option>
                <option>High</option>
            </InputSelect>
            <ValidationMessage For="@(() => model.Priority)" />
        </div>

        <!-- Due Date -->
        <div class="mb-3">
            <label>Due Date</label>
            <InputDate class="form-control"
                       @bind-Value="model.DueDate"
                       min="@DateTime.Today.ToString("yyyy-MM-dd")" />
            <ValidationMessage For="@(() => model.DueDate)" />
        </div>

        <button class="btn btn-primary">Assign Task</button>
    </EditForm>

</div>

@code {
    private CreateTaskDto model = new();
    private List<Employee> employees = new();
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        using var db = DbFactory.CreateDbContext();

        // Current User सेशन गेट करें
        var sessionUser = await CurrentUser.GetUserAsync();
        if (sessionUser == null) return;

        // 1. 🔥 FIX: सीधे DB से फ्रेश User रिकॉर्ड लाएं ताकि OrganizationId मिस न हो
        var dbUser = await db.Users.FirstOrDefaultAsync(u => u.Id == sessionUser.Id);
        if (dbUser == null) return;

        var organizationId = dbUser.OrganizationId;

        // 2. 🔥 FIX: सीधे DB से Roles चेक करें (Blazor lifecycle क्लैश से बचने के लिए)
        var userRoles = await (from ur in db.UserRoles
                               join r in db.Roles on ur.RoleId equals r.Id
                               where ur.UserId == dbUser.Id
                               select r.Name.ToLower()).ToListAsync();

        bool isOrgAdmin = userRoles.Contains("orgadmin");
        bool isHr = userRoles.Contains("hr");

        // 🏢 CASE 1: अगर Organization Admin लॉगिन है -> केवल "HR" Role वाले Employees दिखाएं
        if (isOrgAdmin)
        {
            // Identity Roles टेबल से सभी HR यूज़र्स की IDs निकालें
            var hrUserIds = await (from ur in db.UserRoles
                                   join r in db.Roles on ur.RoleId equals r.Id
                                   where r.Name.ToLower() == "hr"
                                   select ur.UserId).ToListAsync();

            employees = await db.Employees
                .Include(e => e.Designation)
                .Where(e =>
                    e.OrganizationId == organizationId &&
                    e.Status == "Active" &&
                    e.UserId != dbUser.Id &&
                    // या तो उसका Identity Role 'HR' हो या Designation 'HR' हो
                    (hrUserIds.Contains(e.UserId) || (e.Designation != null && e.Designation.Name.ToLower().Contains("hr")))
                )
                .ToListAsync();
        }
        // 👥 CASE 2: अगर HR लॉगिन है -> केवल अपने Department के Regular Employees दिखाएं
        else if (isHr)
        {
            var currentEmployee = await db.Employees
                .FirstOrDefaultAsync(e => e.UserId == dbUser.Id);

            if (currentEmployee != null)
            {
                // HR और OrgAdmin यूज़र्स को फ़िल्टर आउट करने के लिए उनकी IDs निकालें
                var excludedUserIds = await (from ur in db.UserRoles
                                             join r in db.Roles on ur.RoleId equals r.Id
                                             where r.Name.ToLower() == "hr" || r.Name.ToLower() == "orgadmin"
                                             select ur.UserId).ToListAsync();

                employees = await db.Employees
                    .Include(e => e.Designation)
                    .Where(e =>
                        e.OrganizationId == organizationId &&
                        e.DepartmentId == currentEmployee.DepartmentId &&
                        e.Status == "Active" &&
                        e.UserId != dbUser.Id &&
                        !excludedUserIds.Contains(e.UserId)
                    )
                    .ToListAsync();
            }
        }
    }

    private async Task AssignTaskAsync()
    {
        error = null;

        if (model.DueDate.HasValue && model.DueDate.Value.Date < DateTime.Today)
        {
            error = "Cannot assign past date";
            return;
        }

        try
        {
            await TaskService.AssignTaskAsync(model);
            Nav.NavigateTo("/hr/tasks");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }
}