@page "/hr/wfh"
@rendermode InteractiveServer

@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Humatrix_HRMS.Data
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore

@attribute [Authorize(Roles = "HR,OrgAdmin")]

@inject WorkFromHomeService WfhService
@inject NavigationManager Nav
@inject CurrentUserService CurrentUser
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>WFH Approvals | Humatrix HRMS</PageTitle>

<div class="position-fixed top-0 end-0 p-3" style="z-index: 1080;">
    @if (!string.IsNullOrEmpty(message))
    {
        <div class="toast show align-items-center border-0 shadow-lg mb-2" role="alert" style="background-color: #f0fdf4; color: #166534; border-left: 4px solid #10b981 !important; border-radius: 10px;">
            <div class="d-flex p-3">
                <div class="toast-body d-flex align-items-center p-0">
                    <i class="bi bi-check-circle-fill me-2 fs-5" style="color: #10b981;"></i>
                    <span class="small fw-medium">@message</span>
                </div>
                <button type="button" class="btn-close m-auto me-0 shadow-none" @onclick="() => message = null"></button>
            </div>
        </div>
    }
</div>

<div class="container-fluid px-4 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom row-gap-3 flex-wrap">
        <div>
            <h2 class="fw-bold tracking-tight text-dark mb-1">
                WFH Approvals
            </h2>
            <p class="text-muted small mb-0">Manage and process employee Work From Home requests.</p>
        </div>
        <button class="btn btn-interactive-back shadow-sm d-flex align-items-center gap-2" @onclick='() => Nav.NavigateTo(dashboardPath)'>
            <i class="bi bi-speedometer2"></i>
            DASHBOARD
        </button>
    </div>

    <div class="card border-0 shadow-sm p-3 mb-4 bg-light-gradient">
        <select class="form-select custom-select" @onchange="HandleFilterChange">
            <option value="">All Statuses</option>
            <option value="Pending">Pending</option>
            <option value="Approved">Approved</option>
            <option value="Rejected">Rejected</option>
        </select>
    </div>

    <div class="card border-0 shadow-sm overflow-hidden mb-5">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 custom-table">
                <thead>
                    <tr>
                        <th class="ps-4">Employee</th>
                        <th>Date</th>
                        <th>Reason</th>
                        <th>Applied On</th>
                        <th>Status</th>
                        <th class="pe-4 text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (loading)
                    {
                        <tr><td colspan="6" class="text-center py-5"><div class="spinner-border text-primary"></div></td></tr>
                    }
                    else if (!list.Any())
                    {
                        <tr><td colspan="6" class="text-center py-5 text-muted">No requests found.</td></tr>
                    }
                    else
                    {
                        @foreach (var r in list)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-dark">@r.Employee?.FirstName @r.Employee?.LastName</div>
                                    <div class="small text-muted">@r.Employee?.Department?.Name</div>
                                </td>
                                <td>@r.Date.ToString("dd MMM yyyy")</td>
                                <td class="text-muted" style="max-width: 250px;">@r.Reason</td>
                                <td>@r.AppliedAt.ToString("dd MMM yyyy")</td>
                                <td>
                                    <span class="badge rounded-pill status-badge @GetStatusClass(r.Status)">
                                        <i class="bi bi-circle-fill me-1 small-dot"></i>@r.Status
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    @if (r.Status == "Pending")
                                    {
                                        <div class="d-flex justify-content-end gap-2">
                                            <button class="btn btn-sm btn-success rounded-pill px-3" @onclick="() => Approve(r.Id)">Approve</button>
                                            <button class="btn btn-sm btn-outline-danger rounded-pill px-3" @onclick="() => OpenRejectModal(r)">Reject</button>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (showRejectModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header"><h5 class="modal-title">Reject Request</h5></div>
                <div class="modal-body">
                    <textarea class="form-control" placeholder="Reason for rejection..." @bind="rejectReason"></textarea>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => showRejectModal = false">Cancel</button>
                    <button class="btn btn-danger" @onclick="ConfirmReject">Reject</button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .text-premium {
        color: #5c4ac7 !important;
    }

    .tracking-tight {
        letter-spacing: -0.025em;
    }

    .bg-light-gradient {
        background: #f8f9fa;
        border: 1px solid #e9ecef;
        border-radius: 12px;
    }

    .btn-interactive-back {
        background: #ffffff !important;
        border: 1px solid #e5e7eb !important;
        color: #4b5563 !important;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
        transition: all 0.2s ease;
    }

        .btn-interactive-back:hover {
            background-color: #f8fafc !important;
            border-color: #5c4ac7 !important;
            color: #5c4ac7 !important;
            transform: translateY(-1px);
        }

    .custom-table th {
        color: #4a5568;
        text-transform: uppercase;
        font-size: 0.75rem;
        padding: 16px 12px;
    }

    .status-badge {
        font-size: 0.75rem;
        padding: 6px 12px;
    }

    .bg-success-soft {
        background-color: rgba(25, 135, 84, 0.1);
        color: #198754;
    }

    .bg-warning-soft {
        background-color: rgba(255, 193, 7, 0.15);
        color: #ffc107;
    }

    .bg-danger-soft {
        background-color: rgba(220, 53, 69, 0.1);
        color: #dc3545;
    }
</style>

@code {
    private List<WorkFromHomeRequest> list = new();
    private string dashboardPath = "/";
    private string? message, rejectReason, selectedStatus;
    private bool loading, showRejectModal;
    private WorkFromHomeRequest? selectedRequest;

    protected override async Task OnInitializedAsync()
    {
        using var db = DbFactory.CreateDbContext();
        var sessionUser = await CurrentUser.GetUserAsync();

        if (sessionUser != null)
        {
            var userRoles = await (from ur in db.UserRoles
                                   join r in db.Roles on ur.RoleId equals r.Id
                                   where ur.UserId == sessionUser.Id
                                   select r.Name.ToLower()).ToListAsync();

            // Set dashboard navigation path based on role
            bool isOrgAdmin = userRoles.Contains("orgadmin");
            dashboardPath = isOrgAdmin ? "/org/dashboard" : "/hr/dashboard";
        }

        await LoadData();
    }

    private async Task LoadData()
    {
        loading = true;
        // WfhService.GetAllAsync now handles the visibility logic for both HR and OrgAdmin
        list = await WfhService.GetAllAsync(selectedStatus);
        loading = false;
    }

    private async Task HandleFilterChange(ChangeEventArgs e)
    {
        selectedStatus = e.Value?.ToString();
        await LoadData();
    }

    private async Task Approve(Guid id)
    {
        await WfhService.UpdateStatusAsync(id, "Approved");
        message = "WFH request approved successfully.";
        await LoadData();
        await Task.Delay(3000); message = null;
    }

    private void OpenRejectModal(WorkFromHomeRequest r)
    {
        selectedRequest = r;
        rejectReason = string.Empty;
        showRejectModal = true;
    }

    private async Task ConfirmReject()
    {
        if (selectedRequest != null)
        {
            await WfhService.UpdateStatusAsync(selectedRequest.Id, "Rejected", rejectReason);
            message = "WFH request rejected.";
            showRejectModal = false;
            await LoadData();
            await Task.Delay(3000); message = null;
        }
    }

    private string GetStatusClass(string s) => s switch
    {
        "Approved" => "bg-success-soft",
        "Rejected" => "bg-danger-soft",
        _ => "bg-warning-soft"
    };
}