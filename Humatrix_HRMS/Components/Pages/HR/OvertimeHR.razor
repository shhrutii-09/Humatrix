@page "/hr/overtime"
@rendermode InteractiveServer
@using Humatrix_HRMS.Data
@using Humatrix_HRMS.Helpers
@using Humatrix_HRMS.Models
@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject CurrentUserService CurrentUserService
@inject ApplicationDbContext DbContext
@using Microsoft.EntityFrameworkCore
@attribute [Authorize(Roles = "HR,OrgAdmin")]
@inject OvertimeService OvertimeService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Overtime Approvals | HR</PageTitle>

<div class="container-fluid px-4 mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-0">Overtime Approvals</h4>
            <small class="text-muted">Review employee overtime requests</small>
        </div>
        <button class="btn btn-outline-secondary shadow-sm" @onclick="LoadData">
            <i class="bi bi-arrow-clockwise"></i> Refresh
        </button>
    </div>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert @(isError ? "alert-danger" : "alert-success") alert-dismissible fade show shadow-sm">
            @message
            <button class="btn-close" @onclick="() => message = null"></button>
        </div>
    }

    @if (loading)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-primary"></div>
            <p class="text-muted mt-2 small">Loading requests...</p>
        </div>
    }
    else if (!requests.Any())
    {
        <div class="alert alert-info shadow-sm border-0">
            <i class="bi bi-info-circle me-2"></i>No overtime requests found.
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center py-3">
                <span class="text-muted small fw-bold">@requests.Count REQUEST(S)</span>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">EMPLOYEE</th>
                            <th>DATE</th>
                            <th>DEPT</th>
                            <th>REQ. HOURS</th>
                            <th>ACTUAL OUT</th>
                            <th>REASON</th>
                            <th>STATUS</th>
                            <th class="text-end pe-4">ACTION</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in requests
                                            .OrderBy(x => x.Status != "Pending")
                                            .ThenByDescending(x => x.AppliedAt))
{
                            <tr>
                                <td class="ps-4">
                                    <strong>@r.Employee.FirstName @r.Employee.LastName</strong>
                                </td>
                                <td>@r.Date.ToString("dd MMM yyyy")</td>
                                <td>
                                    <span class="text-muted small">
                                        @(r.Employee.Department?.Name ?? "—")
                                    </span>
                                </td>
                                <td>
                                    <span class="badge bg-warning text-dark">
                                        @r.RequestedHours.ToString("0.##") hrs
                                    </span>
                                </td>
                                <td class="font-monospace small">
                                    @* @r.ActualCheckOut?.ToLocalTime().ToString("hh:mm tt") *@
                                    @FormatTime(r.ActualCheckOut)

                                </td>
                               <td class="text-muted small text-truncate"
                                    style="max-width:180px;"
                                    title="@r.Reason">
                                    @r.Reason
                                </td>

                                <td>
                                    <span class="badge @GetStatusClass(r.Status)">
                                        @r.Status
                                    </span>
                                </td>

                                <td class="text-end pe-4">

                                    @if (r.Status == "Pending")
                                    {
                                        <button class="btn btn-sm btn-success me-1"
                                                disabled="@actionLoading"
                                                @onclick="() => Review(r.OvertimeRequestId, true)">
                                            <i class="bi bi-check-circle me-1"></i>Approve
                                        </button>

                                        <button class="btn btn-sm btn-outline-danger"
                                                disabled="@actionLoading"
                                                @onclick="() => Review(r.OvertimeRequestId, false)">
                                            <i class="bi bi-x-circle me-1"></i>Reject
                                        </button>
                                    }

                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    // private List<OvertimeRequest> requests = new();
    // private bool loading = true;
    // private bool actionLoading = false;
    // private string? message;
    // private bool isError;

    // OrgAdmin sees all departments; HR sees only their own department
    // private bool isOrgAdmin = false;

    // protected override async Task OnInitializedAsync()
    // {
    //     var authState = await AuthStateProvider.GetAuthenticationStateAsync();
    //     isOrgAdmin = authState.User.IsInRole("OrgAdmin");
    //     await LoadData();
    // }
    private List<OvertimeRequest> requests = new();
    private bool loading = true;
    private bool actionLoading = false;
    private string? message;
    private bool isError;
    private bool isOrgAdmin = false;

    // FIX: Org timezone for correct time display
    private TimeZoneInfo orgTimeZone = TimeZoneInfo.Utc;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        isOrgAdmin = authState.User.IsInRole("OrgAdmin");
        await LoadOrgTimezone();
        await LoadData();
    }

    private async Task LoadOrgTimezone()
    {
        try
        {
            var user = await CurrentUserService.GetUserAsync();
            if (user?.OrganizationId == null) return;
            var tzId = await DbContext.Organizations
                .AsNoTracking()
                .Where(o => o.OrganizationId == user.OrganizationId)
                .Select(o => o.TimeZoneId)
                .FirstOrDefaultAsync();
            if (!string.IsNullOrWhiteSpace(tzId))
                orgTimeZone = TimeHelper.GetOrgTimeZone(tzId);
        }
        catch { orgTimeZone = TimeZoneInfo.Utc; }
    }

    // FIX: Replace all .ToLocalTime() with this method
    private string FormatTime(DateTime? utcTime)
        => TimeHelper.FormatOrgTime(utcTime, orgTimeZone);
    private async Task LoadData()
    {
        loading = true;
        try
        {
            requests = await OvertimeService.GetAllAsync(allDepartments: isOrgAdmin);
        }
        catch (Exception ex)
        {
            isError = true;
            message = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }

    private async Task Review(Guid id, bool approve)
    {
        try
        {
            actionLoading = true;
            isError = false;
            message = null;

            await OvertimeService.ReviewAsync(new ReviewOvertimeDto
            {
                OvertimeRequestId = id,
                Approve = approve
            });

            message = approve ? "Overtime approved successfully." : "Overtime request rejected.";
            await LoadData();
        }
        catch (Exception ex)
        {
            isError = true;
            message = ex.Message;
        }
        finally
        {
            actionLoading = false;
        }
    }

    private static string GetStatusClass(string? status) => status switch
    {
        "Approved" => "bg-success",
        "Rejected" => "bg-danger",
        "Cancelled" => "bg-secondary",
        _ => "bg-warning text-dark"
    };
}
