@page "/hr/overtime"
@rendermode InteractiveServer
@using Humatrix_HRMS.Data
@using Humatrix_HRMS.Helpers
@using Humatrix_HRMS.Models
@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject CurrentUserService CurrentUserService
@inject ApplicationDbContext DbContext
@using Microsoft.EntityFrameworkCore
@attribute [Authorize(Roles = "HR,OrgAdmin")]
@inject OvertimeService OvertimeService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<PageTitle>Overtime Approvals | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">

    <!-- HEADER with Dashboard Button -->
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom row-gap-3 flex-wrap">
        <div>
            <h2 class="fw-bold tracking-tight text-dark mb-1">Overtime Approvals</h2>
            <p class="text-muted small mb-0">Review employee overtime requests</p>
        </div>
        <div class="d-flex align-items-center gap-2">
            @* <button class="btn btn-refresh-custom shadow-sm d-flex align-items-center gap-2" @onclick="LoadData" disabled="@loading">
                <i class="bi bi-arrow-clockwise"></i>REFRESH
            </button> *@
            <button class="btn btn-interactive-back shadow-sm" @onclick='() => Nav.NavigateTo(dashboardPath)'>
                <i class="bi bi-speedometer2"></i>
                DASHBOARD
            </button>
        </div>
    </div>

    <!-- ALERT BANNER -->
    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert @(isError ? "alert-danger" : "alert-success") alert-dismissible fade show shadow-sm border-0" role="alert">
            <i class="bi bi-@(isError ? "exclamation-triangle-fill" : "check-circle-fill") me-2"></i>
            @message
            <button type="button" class="btn-close" @onclick="() => message = null"></button>
        </div>
    }

    @if (loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="text-muted small mt-2">Loading requests...</p>
        </div>
    }
    else if (!requests.Any())
    {
        <div class="card border-0 shadow-sm panel-container-card">
            <div class="text-center py-5 text-muted">
                <i class="bi bi-inbox fs-1 d-block mb-2 opacity-25"></i>
                <p>No overtime requests found.</p>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm panel-container-card">
            <div class="card-header bg-white border-bottom py-3 px-4 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-semibold">Overtime Requests</h5>
                <span class="badge bg-secondary text-white">@requests.Count request(s)</span>
            </div>
            <div class="table-responsive">
                <table class="table align-middle table-hover mb-0">
                    <thead class="bg-light border-bottom">
                        <tr>
                            <th class="ps-4 text-secondary small fw-bold tracking-wider py-3">EMPLOYEE</th>
                            <th class="text-secondary small fw-bold tracking-wider py-3">DATE</th>
                            <th class="text-secondary small fw-bold tracking-wider py-3">DEPT</th>
                            <th class="text-secondary small fw-bold tracking-wider py-3">REQ. HOURS</th>
                            <th class="text-secondary small fw-bold tracking-wider py-3">ACTUAL OUT</th>
                            <th class="text-secondary small fw-bold tracking-wider py-3">REASON</th>
                            <th class="text-secondary small fw-bold tracking-wider py-3">STATUS</th>
                            <th class="text-secondary small fw-bold tracking-wider py-3 pe-4 text-end">ACTION</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in requests
                                            .OrderBy(x => x.Status != "Pending")
                                            .ThenByDescending(x => x.AppliedAt))
                        {
                            <tr class="table-row-interactive">
                                <td class="ps-4">
                                    <div class="fw-bold text-dark">@r.Employee.FirstName @r.Employee.LastName</div>
                                    @* <div class="small text-muted">@r.Employee.Email</div> *@
                                </td>
                                <td class="fw-semibold">@r.Date.ToString("dd MMM yyyy")</td>
                                <td>
                                    <span class="badge bg-light text-dark fw-normal">
                                        @(r.Employee.Department?.Name ?? "—")
                                    </span>
                                </td>
                                <td>
                                    <span class="badge bg-warning text-dark px-3 py-1">
                                        @r.RequestedHours.ToString("0.##") hrs
                                    </span>
                                </td>
                                <td class="font-monospace small fw-semibold">
                                    @FormatTime(r.ActualCheckOut)
                                </td>
                                <td class="text-muted small" style="max-width:200px;" title="@r.Reason">
                                    @TruncateText(r.Reason, 40)
                                </td>
                                <td>
                                    <span class="badge @GetStatusClass(r.Status) px-3 py-1">
                                        @r.Status
                                    </span>
                                </td>
                                <td class="pe-4 text-end">
                                    @if (r.Status == "Pending")
                                    {
                                        <button class="btn btn-sm btn-success me-1 px-3"
                                                disabled="@actionLoading"
                                                @onclick="() => Review(r.OvertimeRequestId, true)">
                                            <i class="bi bi-check-circle me-1"></i>Approve
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger px-3"
                                                disabled="@actionLoading"
                                                @onclick="() => Review(r.OvertimeRequestId, false)">
                                            <i class="bi bi-x-circle me-1"></i>Reject
                                        </button>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<style>
    .tracking-tight {
        letter-spacing: -0.025em;
    }

    .tracking-wider {
        letter-spacing: 0.04em;
        font-size: 11px;
    }

    .panel-container-card {
        border-radius: 14px;
        background-color: #ffffff;
        overflow: hidden;
    }

    .btn-interactive-back {
        background: #ffffff !important;
        border: 1px solid #e5e7eb !important;
        color: #4b5563 !important;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
        transition: all 0.2s ease;
    }

        .btn-interactive-back:hover {
            border-color: #5c4ac7 !important;
            color: #5c4ac7 !important;
            transform: translateY(-1px);
        }

    .btn-refresh-custom {
        background: #ffffff !important;
        border: 1px solid #e5e7eb !important;
        color: #4b5563 !important;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
        transition: all 0.2s ease;
    }

        .btn-refresh-custom:hover {
            border-color: #5c4ac7 !important;
            color: #5c4ac7 !important;
            transform: translateY(-1px);
        }

    .table thead th {
        background-color: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
    }

    .table-row-interactive:hover {
        background-color: #f8fafc;
    }

    .btn-success {
        background-color: #10b981 !important;
        border-color: #10b981 !important;
    }

        .btn-success:hover {
            background-color: #059669 !important;
            border-color: #059669 !important;
        }
</style>

@code {
    private List<OvertimeRequest> requests = new();
    private bool loading = true;
    private bool actionLoading = false;
    private string? message;
    private bool isError;
    private bool isOrgAdmin = false;
    private string dashboardPath = "/hr/dashboard";

    private TimeZoneInfo orgTimeZone = TimeZoneInfo.Utc;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        isOrgAdmin = authState.User.IsInRole("OrgAdmin");

        // Set dashboard path based on role
        var currentUser = await CurrentUserService.GetUserAsync();
        if (currentUser != null)
        {
            var isHR = await CurrentUserService.IsInRoleAsync("HR");
            dashboardPath = isHR ? "/hr/dashboard" : "/org/dashboard";
        }

        await LoadOrgTimezone();
        await LoadData();
    }

    private async Task LoadOrgTimezone()
    {
        try
        {
            var user = await CurrentUserService.GetUserAsync();
            if (user?.OrganizationId == null) return;
            var tzId = await DbContext.Organizations
                .AsNoTracking()
                .Where(o => o.OrganizationId == user.OrganizationId)
                .Select(o => o.TimeZoneId)
                .FirstOrDefaultAsync();
            if (!string.IsNullOrWhiteSpace(tzId))
                orgTimeZone = TimeHelper.GetOrgTimeZone(tzId);
        }
        catch { orgTimeZone = TimeZoneInfo.Utc; }
    }

    private string FormatTime(DateTime? utcTime)
        => TimeHelper.FormatOrgTime(utcTime, orgTimeZone);

    private async Task LoadData()
    {
        loading = true;
        try
        {
            requests = await OvertimeService.GetAllAsync(allDepartments: isOrgAdmin);
        }
        catch (Exception ex)
        {
            isError = true;
            message = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }

    private async Task Review(Guid id, bool approve)
    {
        try
        {
            actionLoading = true;
            isError = false;
            message = null;

            await OvertimeService.ReviewAsync(new ReviewOvertimeDto
            {
                OvertimeRequestId = id,
                Approve = approve
            });

            message = approve ? "Overtime approved successfully." : "Overtime request rejected.";
            await LoadData();
        }
        catch (Exception ex)
        {
            isError = true;
            message = ex.Message;
        }
        finally
        {
            actionLoading = false;
        }
    }

    private static string GetStatusClass(string? status) => status switch
    {
        "Approved" => "bg-success text-white",
        "Rejected" => "bg-danger text-white",
        "Cancelled" => "bg-secondary text-white",
        _ => "bg-warning text-dark"
    };

    private static string TruncateText(string? text, int max) =>
        string.IsNullOrEmpty(text) ? "—" :
        text.Length <= max ? text : text[..max] + "…";
}