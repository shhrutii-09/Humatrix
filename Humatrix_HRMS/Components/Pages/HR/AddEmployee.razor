@page "/hr/add-employee"
@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Data
@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@rendermode InteractiveServer
@attribute [Authorize(Roles = "HR")]

@inject EmployeeService EmployeeService
@inject DesignationService DesignationService
@inject DepartmentService DeptService
@inject ShiftService ShiftService
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Add Employee | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1" style="font-size: 2rem;">Add New Employee</h2>
            <p class="text-muted small mb-0">Onboard a new team member to your department.</p>
        </div>
        <button class="btn bg-white border text-secondary fw-bold px-4 py-2 text-uppercase shadow-sm text-back-btn"
                @onclick='() => Nav.NavigateTo("/hr/dashboard")'>
            Back to Dashboard
        </button>
    </div>

    <div class="card shadow-sm border-0 rounded-3 bg-white mb-4 custom-form-card">
        <div class="card-body p-4">
            <EditForm Model="model" OnValidSubmit="HandleSubmit" FormName="hrAddEmployeeForm">
                <DataAnnotationsValidator />

                <div class="row g-4">
                    <div class="col-md-7 pe-md-4">
                        <h5 class="mb-4 text-secondary text-uppercase tracking-wider section-title">Basic Information</h5>
                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label class="form-label small fw-bold text-uppercase tracking-wider input-label">First Name</label>
                                <InputText @bind-Value="model.FirstName" class="form-control custom-dept-input shadow-none" placeholder="e.g. John" disabled="@isSubmitting" />
                                <ValidationMessage For="@(() => model.FirstName)" class="text-danger small mt-1" />
                            </div>
                            <div class="col-md-6 mb-4">
                                <label class="form-label small fw-bold text-uppercase tracking-wider input-label">Last Name</label>
                                <InputText @bind-Value="model.LastName" class="form-control custom-dept-input shadow-none" placeholder="e.g. Doe" disabled="@isSubmitting" />
                                <ValidationMessage For="@(() => model.LastName)" class="text-danger small mt-1" />
                            </div>
                        </div>
                        <div class="mb-4">
                            <label class="form-label small fw-bold text-uppercase tracking-wider input-label">Email Address</label>
                            <InputText @bind-Value="model.Email" type="email" class="form-control custom-dept-input shadow-none" placeholder="employee@company.com" disabled="@isSubmitting" />
                            <ValidationMessage For="@(() => model.Email)" class="text-danger small mt-1" />
                        </div>
                    </div>

                    <div class="col-md-5 border-start ps-md-4">
                        <h5 class="mb-4 text-secondary text-uppercase tracking-wider section-title">Assignment</h5>
                        <div class="mb-4">
                            <label class="form-label small fw-bold text-uppercase tracking-wider input-label">Department</label>
                            <input class="form-control custom-dept-input bg-light shadow-none" value="@departmentName" readonly />
                        </div>
                        <div class="mb-4">
                            <label class="form-label small fw-bold text-uppercase tracking-wider input-label">Designation</label>
                            <InputSelect @bind-Value="model.DesignationId" class="form-select custom-dept-input shadow-none" disabled="@isSubmitting">
                                <option value="" disabled selected>Select Designation</option>
                                @foreach (var d in designations)
                                {
                                    <option value="@d.DesignationId">@d.Name</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => model.DesignationId)" class="text-danger small mt-1" />
                        </div>
                        <div class="mb-4">
                            <label class="form-label small fw-bold text-uppercase tracking-wider input-label">Work Shift</label>
                            <InputSelect @bind-Value="model.ShiftId" class="form-select custom-dept-input shadow-none" disabled="@isSubmitting">
                                <option value="" disabled selected>Select Shift</option>
                                @foreach (var s in shifts)
                                {
                                    <option value="@s.ShiftId">@s.Name</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => model.ShiftId)" class="text-danger small mt-1" />
                        </div>
                    </div>
                </div>

                <div class="mt-4 pt-4 border-top d-flex gap-2">
                    <button type="submit" class="btn text-white fw-bold px-4 py-2 text-uppercase btn-create-dept" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            <span>Processing...</span>
 }
                        else
                        {
                            <i class="bi bi-person-plus me-2"></i>
                            <span>ADD EMPLOYEE</span>
 }
                    </button>
                </div>
            </EditForm>

            @if (!string.IsNullOrEmpty(link))
            {
                <div class="alert alert-success mt-4 border-0 shadow-sm p-3">
                    <strong>Success!</strong> Employee created. <button class="btn btn-sm btn-link" @onclick="CopyLinkToClipboard">Copy Link</button>
                </div>
            }

            @if (!string.IsNullOrEmpty(error))
            {
                <div class="alert alert-danger mt-4">@error</div>
            }
        </div>
    </div>
</div>

<style>
    .custom-form-card {
        border-radius: 12px !important;
    }

    .text-back-btn {
        font-size: 0.785rem !important;
        border-radius: 8px !important;
        color: #5a6a85 !important;
    }

    .section-title {
        font-size: 0.76rem !important;
        font-weight: 700 !important;
        color: #94a3b8 !important;
    }

    .input-label {
        font-size: 0.72rem !important;
        font-weight: 700 !important;
        color: #64748b !important;
    }

    .custom-dept-input {
        background-color: #f8fafc !important;
        border: 1px solid #e2e8f0 !important;
        border-radius: 8px !important;
    }

    .btn-create-dept {
        background-color: #5c4ac7 !important;
        border-radius: 8px !important;
    }
</style>

@code {
    CreateEmployeeDto model = new();
    List<DesignationDto> designations = new();
    List<Shift> shifts = new();
    string? departmentName;
    string? link;
    string? error;
    bool isSubmitting;
    bool showCopiedFeedback;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var auth = await AuthState.GetAuthenticationStateAsync();
            var user = await UserManager.GetUserAsync(auth.User);
            if (user?.DepartmentId != null)
            {
                model.DepartmentId = user.DepartmentId;
                var dept = await DeptService.GetByIdAsync(user.DepartmentId.Value);
                departmentName = dept?.Name;
                designations = await DesignationService.GetByDepartmentAsync(user.DepartmentId.Value);
                shifts = await ShiftService.GetAllShiftsAsync();
            }
        }
        catch (Exception ex) { error = ex.Message; }
    }

    private async Task HandleSubmit()
    {
        if (isSubmitting) return;
        isSubmitting = true;
        try
        {
            model.Role = "Employee";
            link = await EmployeeService.CreateEmployeeAsync(model);
            model = new CreateEmployeeDto { DepartmentId = model.DepartmentId, Role = "Employee" };
        }
        catch (Exception ex) { error = ex.Message; }
        finally { isSubmitting = false; }
    }

    private async Task CopyLinkToClipboard()
    {
        if (!string.IsNullOrEmpty(link))
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", link);
            showCopiedFeedback = true;
            await Task.Delay(2000);
            showCopiedFeedback = false;
        }
    }
}