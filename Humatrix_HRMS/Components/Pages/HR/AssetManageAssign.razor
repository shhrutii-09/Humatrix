@code {
    // ── Tab enum ──────────────────────────────────────────────────────────────
    private enum Tab { Inventory, Requests, Procurement }
    private Tab activeTab = Tab.Inventory;

    // ── Context ───────────────────────────────────────────────────────────────
    private Guid orgId;
    private Guid hrDeptId;
    private Guid hrEmpId;
    private string hrUserId = "";
    private string departmentName = "";
    private bool pageLoading = true;

    // ── KPI ───────────────────────────────────────────────────────────────────
    private int kpiTotal, kpiAvailable, kpiAssigned, kpiRepair, kpiPendingRequests;

    // ── Inventory ─────────────────────────────────────────────────────────────
    private List<AssetListDto> invAll = new();
    private List<AssetListDto> invFiltered = new();
    private AssetFilterDto invFilter = new() { PageSize = 20 };
    private List<string> invCategories = new();
    private string invSearch = "";
    private int invTotalCount, invTotalPages;
    private bool invLoading = false;

    // ── Requests ──────────────────────────────────────────────────────────────
    private List<AssetRequestDto> reqAll = new();
    private List<AssetRequestDto> reqFiltered = new();
    private string reqStatusFilter = "";
    private string reqTypeFilter = "";
    private bool reqLoading = false;

    // ── Procurement ───────────────────────────────────────────────────────────
    private List<ProcurementRequestDto> procurements = new();
    private bool procLoading = false;

    // ── Modal state ───────────────────────────────────────────────────────────
    private bool showAssignModal, showReturnModal, showRequestModal, showProcurementModal;
    private AssetListDto? modalAsset;
    private string requestType = "";
    private string assignEmpId = "";
    private string assignNotes = "";
    private string returnNotes = "";
    private string requestReason = "";
    private bool submitting = false;
    private string modalError = "";
    private bool empLoading = false;
    private List<EmployeeDropdownDto> assignableEmps = new();
    private CreateProcurementRequestDto procDto = new();

    // ── Toast ─────────────────────────────────────────────────────────────────
    private string toastMsg = "", toastCss = "", toastIcon = "";

    // ─────────────────────────────────────────────────────────────────────────
    // INIT
    // ─────────────────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        var ctx = await CurrentUserService.GetOrgDashboardContextAsync();
        orgId = ctx.OrganizationId;
        hrUserId = ctx.UserId;

        var emp = await EmployeeService.GetEmployeeByUserIdAsync(hrUserId);
        if (emp == null)
        {
            Toast("Could not load your employee profile. Please contact admin.", false);
            pageLoading = false;
            return;
        }

        hrEmpId = emp.EmployeeId;
        // hrDeptId = emp.DepartmentId ?? Guid.Empty;
        hrDeptId = emp.DepartmentId;

        // Load department name
        if (hrDeptId != Guid.Empty)
        {
            // Quick lookup via EF through GetAssetForHR would be overkill;
            // re-use the department name from employee navigation if available.
            // The Employee entity doesn't expose DepartmentName directly,
            // so we rely on the EmployeeListDto which has it.
            var allEmps = await EmployeeService.GetEmployeesByOrganizationIdAsync(orgId);
            var myRecord = allEmps.FirstOrDefault(e => e.EmployeeId == hrEmpId);
            departmentName = myRecord?.Department ?? "Your Department";
        }

        await LoadInventoryAsync();
        pageLoading = false;
    }

    // ─────────────────────────────────────────────────────────────────────────
    // TAB SWITCHING
    // ─────────────────────────────────────────────────────────────────────────
    private async Task SetTab(Tab t)
    {
        activeTab = t;
        switch (t)
        {
            case Tab.Requests when !reqAll.Any(): await LoadRequestsAsync(); break;
            case Tab.Procurement when !procurements.Any(): await LoadProcurementAsync(); break;
        }
    }

    private async Task RefreshAllAsync()
    {
        invAll.Clear(); reqAll.Clear(); procurements.Clear();
        await LoadInventoryAsync();
        if (activeTab == Tab.Requests) await LoadRequestsAsync();
        if (activeTab == Tab.Procurement) await LoadProcurementAsync();
    }

    // ─────────────────────────────────────────────────────────────────────────
    // INVENTORY
    // ─────────────────────────────────────────────────────────────────────────
    private async Task LoadInventoryAsync()
    {
        if (hrDeptId == Guid.Empty) return;
        invLoading = true;
        StateHasChanged();

        try
        {
            var result = await AssetService.GetAssetsForHRAsync(orgId, hrDeptId, invFilter);
            invAll = result.Items;
            invTotalCount = result.TotalCount;
            invTotalPages = result.TotalPages;

            // Recompute KPIs from full un-paged set
            var allFilter = new AssetFilterDto { PageSize = 10000 };
            var allResult = await AssetService.GetAssetsForHRAsync(orgId, hrDeptId, allFilter);

            kpiTotal = allResult.TotalCount;
            kpiAvailable = allResult.Items.Count(a => a.Status == AssetStatus.Available);
            kpiAssigned = allResult.Items.Count(a => a.Status == AssetStatus.Assigned);
            kpiRepair = allResult.Items.Count(a => a.Status == AssetStatus.InRepair);

            invCategories = allResult.Items
                .Select(a => a.Category).Distinct().OrderBy(c => c).ToList();

            ApplyInvSearch();
        }
        catch (Exception ex)
        {
            Toast($"Error loading assets: {ex.Message}", false);
        }
        finally { invLoading = false; }
    }

    private void ApplyInvSearch()
    {
        invFiltered = string.IsNullOrWhiteSpace(invSearch)
            ? invAll.ToList()
            : invAll.Where(a =>
                a.Name.Contains(invSearch, StringComparison.OrdinalIgnoreCase) ||
                a.AssetCode.Contains(invSearch, StringComparison.OrdinalIgnoreCase) ||
                (a.CurrentEmployeeName?.Contains(invSearch, StringComparison.OrdinalIgnoreCase) ?? false))
              .ToList();
    }

    private async Task ClearInvFilters()
    {
        invFilter = new AssetFilterDto { PageSize = 20 };
        invSearch = "";
        await LoadInventoryAsync();
    }

    private async Task InvGoPage(int p) { invFilter.Page = p; await LoadInventoryAsync(); }
    private async Task InvPrev() { if (invFilter.Page > 1) { invFilter.Page--; await LoadInventoryAsync(); } }
    private async Task InvNext() { if (invFilter.Page < invTotalPages) { invFilter.Page++; await LoadInventoryAsync(); } }

    // ─────────────────────────────────────────────────────────────────────────
    // REQUESTS
    // ─────────────────────────────────────────────────────────────────────────
    private async Task LoadRequestsAsync()
    {
        if (hrDeptId == Guid.Empty) return;
        reqLoading = true;
        StateHasChanged();
        try
        {
            reqAll = await AssetService.GetAssetRequestsByDepartmentAsync(
                orgId, hrDeptId, string.IsNullOrEmpty(reqStatusFilter) ? null : reqStatusFilter);

            kpiPendingRequests = reqAll.Count(r => r.Status == AssetRequestStatus.Pending);
            ApplyReqFilters();
        }
        catch (Exception ex) { Toast($"Error loading requests: {ex.Message}", false); }
        finally { reqLoading = false; }
    }

    private void ApplyReqFilters()
    {
        reqFiltered = reqAll
            .Where(r =>
                (string.IsNullOrEmpty(reqTypeFilter) || r.RequestType == reqTypeFilter) &&
                (string.IsNullOrEmpty(reqStatusFilter) || r.Status == reqStatusFilter))
            .ToList();
    }

    // ─────────────────────────────────────────────────────────────────────────
    // PROCUREMENT
    // ─────────────────────────────────────────────────────────────────────────
    private async Task LoadProcurementAsync()
    {
        if (hrDeptId == Guid.Empty) return;
        procLoading = true;
        StateHasChanged();
        try
        {
            procurements = await AssetService.GetProcurementRequestsAsync(orgId, null, hrDeptId);
        }
        catch (Exception ex) { Toast($"Error loading procurement: {ex.Message}", false); }
        finally { procLoading = false; }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // ASSIGN MODAL
    // ─────────────────────────────────────────────────────────────────────────
    private async Task OpenAssignModal(AssetListDto asset)
    {
        modalAsset = asset;
        assignEmpId = "";
        assignNotes = "";
        modalError = "";
        showAssignModal = true;

        empLoading = true;
        StateHasChanged();
        try
        {
            // Uses the new HR-specific method: excludes HR + OrgAdmin roles
            assignableEmps = await AssetService.GetAssignableEmployeesForHRAsync(
                orgId, asset.AssetId, UserManager);
        }
        catch (Exception ex) { assignableEmps = new(); modalError = ex.Message; }
        finally { empLoading = false; }
    }

    private async Task SubmitAssignAsync()
    {
        if (!Guid.TryParse(assignEmpId, out var empId))
        {
            modalError = "Please select an employee.";
            return;
        }
        submitting = true; modalError = "";
        try
        {
            await AssetService.AssignAssetAsync(orgId,
                new AssignAssetDto
                {
                    AssetId = modalAsset!.AssetId,
                    EmployeeId = empId,
                    Notes = assignNotes
                },
                hrUserId, "HR");
            var assetName = modalAsset!.Name;

            CloseAll();
            await LoadInventoryAsync();

            Toast($"{assetName} returned successfully.", true);
        }
        catch (Exception ex) { modalError = ex.Message; }
        finally { submitting = false; }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // RETURN MODAL
    // ─────────────────────────────────────────────────────────────────────────
    private void OpenReturnModal(AssetListDto asset)
    {
        modalAsset = asset;
        returnNotes = "";
        modalError = "";
        showReturnModal = true;
    }

    private async Task SubmitReturnAsync()
    {
        submitting = true;
        modalError = "";

        try
        {
            var assetName = modalAsset!.Name;

            await AssetService.ReturnAssetAsync(
                orgId,
                new ReturnAssetDto
                {
                    AssetId = modalAsset.AssetId,
                    Notes = returnNotes
                },
                hrUserId,
                "HR");

            CloseAll();

            await LoadInventoryAsync();

            Toast($"{assetName} returned successfully.", true);
        }
        catch (Exception ex)
        {
            modalError = ex.Message;
        }
        finally
        {
            submitting = false;
        }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // REQUEST MODAL  (Repair / Replacement / Return)
    // ─────────────────────────────────────────────────────────────────────────
    private void OpenRequestModal(AssetListDto asset, string type)
    {
        modalAsset = asset;
        requestType = type;
        requestReason = "";
        modalError = "";
        showRequestModal = true;
    }

    private async Task SubmitRequestAsync()
    {
        submitting = true; modalError = "";
        try
        {
            // HR raises on behalf of the department — uses the new HR-aware method
            await AssetService.CreateAssetRequestByHRAsync(
                orgId, hrDeptId, hrEmpId,
                new CreateAssetRequestDto
                {
                    AssetId = modalAsset!.AssetId,
                    RequestType = requestType,
                    Reason = requestReason
                });

            var assetName = modalAsset!.Name;

            CloseAll();
            await LoadInventoryAsync();
            reqAll.Clear();

            kpiPendingRequests++;

            Toast($"{requestType} request submitted for {assetName}. OrgAdmin will review.", true);
        }
        catch (Exception ex) { modalError = ex.Message; }
        finally { submitting = false; }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // PROCUREMENT MODAL
    // ─────────────────────────────────────────────────────────────────────────
    private void OpenProcurementModal()
    {
        procDto = new CreateProcurementRequestDto();
        modalError = "";
        showProcurementModal = true;
        activeTab = Tab.Procurement;
    }

    private async Task SubmitProcurementAsync()
    {
        submitting = true; modalError = "";
        try
        {
            await AssetService.CreateProcurementRequestAsync(
                orgId, hrDeptId, hrEmpId, procDto, hrUserId);

            CloseAll();
            procurements.Clear();
            await LoadProcurementAsync();
            Toast("Procurement request submitted. OrgAdmin will review.", true);
        }
        catch (Exception ex) { modalError = ex.Message; }
        finally { submitting = false; }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // HELPERS
    // ─────────────────────────────────────────────────────────────────────────
    private void CloseAll()
    {
        showAssignModal = showReturnModal = showRequestModal = showProcurementModal = false;
        modalAsset = null;
        modalError = "";
    }

    private async void Toast(string msg, bool success)
    {
        toastMsg = msg;
        toastCss = success ? "hr-toast hr-toast-ok" : "hr-toast hr-toast-err";
        toastIcon = success ? "bi bi-check-circle-fill" : "bi bi-exclamation-circle-fill";
        StateHasChanged();
        await Task.Delay(4000);
        toastMsg = "";
        StateHasChanged();
    }

    // Status badge helpers
    private static string StatusClass(string s) => s switch
    {
        AssetStatus.Available => "hr-status hr-s-available",
        AssetStatus.Assigned => "hr-status hr-s-assigned",
        AssetStatus.InRepair => "hr-status hr-s-inrepair",
        AssetStatus.Retired => "hr-status hr-s-retired",
        AssetStatus.Lost => "hr-status hr-s-lost",
        _ => "hr-status"
    };
    private static string StatusLabel(string s) =>
        s == AssetStatus.InRepair ? "In Repair" : s;

    private static string ReqTypeClass(string t) => t switch
    {
        AssetRequestType.Repair => "hr-rt-repair",
        AssetRequestType.Replacement => "hr-rt-replacement",
        AssetRequestType.Return => "hr-rt-return",
        _ => "hr-rt-repair"
    };
    private static string ReqTypeIcon(string t) => t switch
    {
        AssetRequestType.Repair => "🔧",
        AssetRequestType.Replacement => "🔄",
        AssetRequestType.Return => "↩️",
        _ => ""
    };
    private static string ReqStatusClass(string s) => s switch
    {
        AssetRequestStatus.Pending => "hr-rs-pending",
        AssetRequestStatus.Approved => "hr-rs-approved",
        AssetRequestStatus.Rejected => "hr-rs-rejected",
        AssetRequestStatus.Completed => "hr-rs-completed",
        AssetRequestStatus.Cancelled => "hr-rs-cancelled",
        _ => "hr-rs-pending"
    };
    private static string RoleClass(string r) =>
        r == AssetRequestorRole.HR ? "hr-role-hr" : "hr-role-employee";

    private static string ProcStatusClass(string s) => s switch
    {
        ProcurementStatus.Pending => "hr-ps-pending",
        ProcurementStatus.Approved => "hr-ps-approved",
        ProcurementStatus.Rejected => "hr-ps-rejected",
        ProcurementStatus.Fulfilled => "hr-ps-fulfilled",
        _ => "hr-ps-pending"
    };

    // Request modal helpers
    private string RequestModalIconClass() => requestType switch
    {
        AssetRequestType.Repair => "hr-modal-ico hr-ico-warning",
        AssetRequestType.Replacement => "hr-modal-ico hr-ico-primary",
        AssetRequestType.Return => "hr-modal-ico hr-ico-info",
        _ => "hr-modal-ico hr-ico-warning"
    };
    private string RequestModalIcon() => requestType switch
    {
        AssetRequestType.Repair => "bi bi-tools",
        AssetRequestType.Replacement => "bi bi-arrow-repeat",
        AssetRequestType.Return => "bi bi-arrow-return-left",
        _ => "bi bi-tools"
    };
    private string RequestChipIconColor() => requestType switch
    {
        AssetRequestType.Repair => "text-warning",
        AssetRequestType.Replacement => "text-primary",
        AssetRequestType.Return => "text-info",
        _ => ""
    };
    private string RequestSubmitBtnClass() => requestType switch
    {
        AssetRequestType.Repair => "hr-btn hr-btn-warning",
        AssetRequestType.Replacement => "hr-btn hr-btn-primary",
        AssetRequestType.Return => "hr-btn hr-btn-danger",
        _ => "hr-btn hr-btn-primary"
    };
    private string RequestReasonPlaceholder() => requestType switch
    {
        AssetRequestType.Repair => "Describe the issue — e.g. screen cracked, battery not charging…",
        AssetRequestType.Replacement => "Reason for replacement — e.g. asset is beyond repair, too old…",
        AssetRequestType.Return => "Reason for returning — e.g. employee resigned, no longer needed…",
        _ => "Reason…"
    };
}
