</style>

@code {

    private List<AssetListDto> assets = new();
    private List<AssetListDto> filteredAssets = new();

    private AssetFilterDto filter = new()
    {
        PageSize = 20
    };

    private bool loading = true;
    private string searchText = "";

    private int totalCount;
    private int availableCount;
    private int assignedCount;
    private int inRepairCount;
    private int totalPages;

    private List<string> categories = new();

    private bool showAssignModal;
    private bool showReturnModal;

    private AssetListDto? selectedAsset;

    private AssignAssetDto assignDto = new();

    private string assignEmployeeId = "";
    private string returnNotes = "";

    private bool submitting;
    private string errorMessage = "";

    private Guid orgId;
    private Guid? hrDepartmentId;

    private string userId = "";
    private string userRole = "HR";

    private List<EmployeeSelectItem> employees = new();

    protected override async Task OnInitializedAsync()
    {
        var ctx = await CurrentUserService.GetOrgDashboardContextAsync();

        orgId = ctx.OrganizationId;
        userId = ctx.UserId;

        var hrEmployee = await EmployeeService.GetEmployeeByUserIdAsync(userId);

        hrDepartmentId = hrEmployee?.DepartmentId;

        await LoadAsync();
        await LoadEmployeesAsync();
    }

    private async Task LoadAsync()
    {
        loading = true;

        StateHasChanged();

        var result = await AssetService.GetAssetsAsync(orgId, filter);

        assets = result.Items
            .Where(a => a.DepartmentId == hrDepartmentId)
            .ToList();

        filteredAssets = assets.ToList();

        totalCount = assets.Count;

        availableCount = assets.Count(a => a.Status == AssetStatus.Available);

        assignedCount = assets.Count(a => a.Status == AssetStatus.Assigned);

        inRepairCount = assets.Count(a => a.Status == AssetStatus.InRepair);

        totalPages = result.TotalPages;

        categories = assets
            .Select(a => a.Category)
            .Distinct()
            .OrderBy(c => c)
            .ToList();

        ApplySearch();

        loading = false;
    }

    private async Task LoadEmployeesAsync()
    {
        var result = await EmployeeService.GetEmployeesByOrganizationIdAsync(orgId);

        employees = result
            .Where(e => e.DepartmentId == hrDepartmentId)
            .Select(e => new EmployeeSelectItem
            {
                EmployeeId = e.EmployeeId,
                FirstName = e.FirstName,
                LastName = e.LastName,
                EmployeeCode = e.EmployeeCode
            })
            .ToList();
    }

    private void ApplySearch()
    {
        filteredAssets = string.IsNullOrWhiteSpace(searchText)

            ? assets.ToList()

            : assets.Where(a =>

                a.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase)

                || a.AssetCode.Contains(searchText, StringComparison.OrdinalIgnoreCase)

                || (a.CurrentEmployeeName?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false)

            ).ToList();
    }

    private async Task RefreshAsync()
    {
        await LoadAsync();
    }

    private async Task ClearFilters()
    {
        filter = new AssetFilterDto
        {
            PageSize = 20
        };

        searchText = "";

        await LoadAsync();
    }

    private async Task GoToPage(int p)
    {
        filter.Page = p;
        await LoadAsync();
    }

    private async Task PrevPage()
    {
        if (filter.Page > 1)
        {
            filter.Page--;
            await LoadAsync();
        }
    }

    private async Task NextPage()
    {
        if (filter.Page < totalPages)
        {
            filter.Page++;
            await LoadAsync();
        }
    }

    private void ViewAsset(Guid id)
    {
        Nav.NavigateTo($"/hr/assets/{id}");
    }

    private void OpenAssignModal(AssetListDto asset)
    {
        selectedAsset = asset;

        assignDto = new AssignAssetDto
        {
            AssetId = asset.AssetId
        };

        assignEmployeeId = "";

        errorMessage = "";

        showAssignModal = true;
    }

    private async Task SubmitAssignAsync()
    {
        if (!Guid.TryParse(assignEmployeeId, out var empId))
        {
            errorMessage = "Please select an employee.";
            return;
        }

        assignDto.EmployeeId = empId;

        submitting = true;

        errorMessage = "";

        try
        {
            await AssetService.AssignAssetAsync(
                orgId,
                assignDto,
                userId,
                userRole
            );

            CloseModals();

            await LoadAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            submitting = false;
        }
    }

    private void OpenReturnModal(AssetListDto asset)
    {
        selectedAsset = asset;

        returnNotes = "";

        errorMessage = "";

        showReturnModal = true;
    }

    private async Task SubmitReturnAsync()
    {
        submitting = true;

        errorMessage = "";

        try
        {
            await AssetService.ReturnAssetAsync(
                orgId,
                new ReturnAssetDto
                {
                    AssetId = selectedAsset!.AssetId,
                    Notes = returnNotes
                },
                userId,
                userRole
            );

            CloseModals();

            await LoadAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            submitting = false;
        }
    }

    private void CloseModals()
    {
        showAssignModal = false;
        showReturnModal = false;

        selectedAsset = null;

        errorMessage = "";
    }

    private RenderFragment GetStatusBadge(string status) => status switch
    {
        AssetStatus.Available => @<span class="badge bg-soft-success text-success">Available</span>,

        AssetStatus.Assigned => @<span class="badge bg-soft-info text-info">Assigned</span>,

        AssetStatus.InRepair => @<span class="badge bg-soft-warning text-warning">In Repair</span>,

        AssetStatus.Retired => @<span class="badge bg-soft-secondary text-secondary">Retired</span>,

        AssetStatus.Lost => @<span class="badge bg-danger">Lost</span>,

        _ => @<span class="badge bg-light text-dark">@status</span>
    };

    private class EmployeeSelectItem
    {
        public Guid EmployeeId { get; set; }

        public string FirstName { get; set; } = "";

        public string LastName { get; set; } = "";

        public string EmployeeCode { get; set; } = "";
    }

}