@page "/hr/assets"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "HR")]

@using Humatrix_HRMS.DTOs.Assets
@using Humatrix_HRMS.Data
@using Humatrix_HRMS.Services
@using Humatrix_HRMS.Services.Assets
@using Humatrix_HRMS.Infrastructure.Constants
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity

@inject AssetService AssetService
@inject EmployeeService EmployeeService
@inject CurrentUserService CurrentUserService
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Nav

<PageTitle>Department Assets | Humatrix HRMS</PageTitle>

<div class="hr-wrapper">

    <!-- ── Page Header ──────────────────────────────────────────────────────── -->
    <div class="hr-header">
        <div class="hr-header-left">
            <div class="hr-header-icon">
                <i class="bi bi-building-fill"></i>
            </div>
            <div>
                <h1 class="hr-title">Department Assets</h1>
                <p class="hr-subtitle">
                    @if (!string.IsNullOrEmpty(departmentName))
                    {
                        <span class="hr-dept-pill">
                            <i class="bi bi-building me-1"></i>@departmentName
                        </span>
                    }
                    <span class="text-muted ms-1">— manage, assign and track</span>
                </p>
            </div>
        </div>
        <div class="hr-header-actions">
            <button class="hr-btn hr-btn-ghost" @onclick="RefreshAllAsync" disabled="@(pageLoading)">
                <i class="bi bi-arrow-clockwise @(pageLoading ? "spin" : "")"></i>
                Refresh
            </button>
            <button class="hr-btn hr-btn-outline" @onclick="OpenProcurementModal">
                <i class="bi bi-clipboard-plus"></i>
                Request Assets
            </button>
        </div>
    </div>

    <!-- ── KPI Strip ────────────────────────────────────────────────────────── -->
    <div class="hr-kpi-row">
        <div class="hr-kpi hr-kpi-total">
            <div class="hr-kpi-icon"><i class="bi bi-layers-fill"></i></div>
            <div>
                <div class="hr-kpi-label">Total Assets</div>
                <div class="hr-kpi-val">@kpiTotal</div>
            </div>
        </div>
        <div class="hr-kpi hr-kpi-available">
            <div class="hr-kpi-icon"><i class="bi bi-check-circle-fill"></i></div>
            <div>
                <div class="hr-kpi-label">Available</div>
                <div class="hr-kpi-val">@kpiAvailable</div>
            </div>
        </div>
        <div class="hr-kpi hr-kpi-assigned">
            <div class="hr-kpi-icon"><i class="bi bi-person-check-fill"></i></div>
            <div>
                <div class="hr-kpi-label">Assigned</div>
                <div class="hr-kpi-val">@kpiAssigned</div>
            </div>
        </div>
        <div class="hr-kpi hr-kpi-repair">
            <div class="hr-kpi-icon"><i class="bi bi-tools"></i></div>
            <div>
                <div class="hr-kpi-label">In Repair</div>
                <div class="hr-kpi-val">@kpiRepair</div>
            </div>
        </div>
        <div class="hr-kpi hr-kpi-pending">
            <div class="hr-kpi-icon"><i class="bi bi-hourglass-split"></i></div>
            <div>
                <div class="hr-kpi-label">Pending Requests</div>
                <div class="hr-kpi-val">@kpiPendingRequests</div>
            </div>
        </div>
    </div>

    <!-- ── Tabs ─────────────────────────────────────────────────────────────── -->
    <div class="hr-tabs">
        <button class="hr-tab @(activeTab == Tab.Inventory ? "active" : "")"
                @onclick='() => SetTab(Tab.Inventory)'>
            <i class="bi bi-box-seam"></i>
            <span>Inventory</span>
            <span class="hr-tab-count">@kpiTotal</span>
        </button>
        <button class="hr-tab @(activeTab == Tab.Requests ? "active" : "")"
                @onclick='() => SetTab(Tab.Requests)'>
            <i class="bi bi-inbox-fill"></i>
            <span>Asset Requests</span>
            @if (kpiPendingRequests > 0)
            {
                <span class="hr-tab-badge">@kpiPendingRequests</span>
            }
        </button>
        <button class="hr-tab @(activeTab == Tab.Procurement ? "active" : "")"
                @onclick='() => SetTab(Tab.Procurement)'>
            <i class="bi bi-clipboard-check-fill"></i>
            <span>Procurement</span>
        </button>
    </div>

    <!-- ════════════════════════════════════════════════════════════════════════
         TAB — INVENTORY
    ════════════════════════════════════════════════════════════════════════════ -->
    @if (activeTab == Tab.Inventory)
    {
        <!-- Filter bar -->
        <div class="hr-filter-bar">
            <div class="hr-filter-group">
                <label class="hr-filter-label">Category</label>
                <select class="hr-sel" @bind="invFilter.Category" @bind:after="LoadInventoryAsync">
                    <option value="">All Categories</option>
                    @foreach (var c in invCategories)
                    {
                        <option value="@c">@c</option>
                    }
                </select>
            </div>
            <div class="hr-filter-group">
                <label class="hr-filter-label">Status</label>
                <select class="hr-sel" @bind="invFilter.Status" @bind:after="LoadInventoryAsync">
                    <option value="">All Statuses</option>
                    <option value="@AssetStatus.Available">Available</option>
                    <option value="@AssetStatus.Assigned">Assigned</option>
                    <option value="@AssetStatus.InRepair">In Repair</option>
                    <option value="@AssetStatus.Retired">Retired</option>
                </select>
            </div>
            <div class="hr-filter-group hr-filter-search">
                <label class="hr-filter-label">Search</label>
                <div class="hr-search-wrap">
                    <i class="bi bi-search hr-search-ico"></i>
                    <input class="hr-inp hr-inp-search"
                           placeholder="Name, code, assigned employee…"
                           @bind="invSearch"
                           @bind:event="oninput"
                           @bind:after="ApplyInvSearch" />
                    @if (!string.IsNullOrEmpty(invSearch))
                    {
                        <button class="hr-search-clear" @onclick='() => { invSearch = ""; ApplyInvSearch(); }'>
                            <i class="bi bi-x"></i>
                        </button>
                    }
                </div>
            </div>
            <div class="hr-filter-group" style="justify-content:flex-end; margin-left:auto;">
                <label class="hr-filter-label">&nbsp;</label>
                <button class="hr-btn hr-btn-ghost hr-btn-sm" @onclick="ClearInvFilters">
                    <i class="bi bi-x-circle"></i> Clear
                </button>
            </div>
        </div>

        <!-- Info note about scope -->
        <div class="hr-scope-note">
            <i class="bi bi-info-circle-fill me-2"></i>
            Showing assets assigned to <strong>@departmentName</strong> and organisation-wide assets.
            Assets of other departments are not visible here.
        </div>

        <!-- Table -->
        <div class="hr-card">
            @if (invLoading)
            {
                <div class="hr-state-center">
                    <div class="hr-spinner"></div>
                    <p class="hr-state-sub">Loading assets…</p>
                </div>
            }
            else if (!invFiltered.Any())
            {
                <div class="hr-state-center">
                    <i class="bi bi-box-seam hr-empty-icon"></i>
                    <p class="hr-state-title">No assets found</p>
                    <p class="hr-state-sub">
                        @if (string.IsNullOrEmpty(invSearch) && string.IsNullOrEmpty(invFilter.Status) && string.IsNullOrEmpty(invFilter.Category))
                        {
                            <text>Your department has no assets yet. Use <strong>Request Assets</strong> to raise a procurement.</text>
                        }
                        else
                        {
                            <text>No assets match your filters. Try clearing them.</text>
                        }
                    </p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="hr-table">
                        <thead>
                            <tr>
                                <th>Asset</th>
                                <th>Category</th>
                                <th>Code</th>
                                <th>Scope</th>
                                <th>Status</th>
                                <th>Assigned To</th>
                                <th>Added</th>
                                <th class="text-end pe-3">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var a in invFiltered)
                            {
                                <tr class="hr-row">
                                    <td>
                                        <div class="hr-asset-name">@a.Name</div>
                                    </td>
                                    <td><span class="hr-cat">@a.Category</span></td>
                                    <td><code class="hr-code">@a.AssetCode</code></td>
                                    <td>
                                        @if (a.DepartmentId == null)
                                        {
                                            <span class="hr-badge hr-badge-orgwide">Org-Wide</span>
                                        }
                                        else
                                        {
                                            <span class="hr-badge hr-badge-dept">
                                                <i class="bi bi-building me-1"></i>@departmentName
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        <span class="@StatusClass(a.Status)">@StatusLabel(a.Status)</span>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(a.CurrentEmployeeName))
                                        {
                                            <div class="hr-assignee">
                                                <div class="hr-avatar">@a.CurrentEmployeeName[0]</div>
                                                <span>@a.CurrentEmployeeName</span>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="hr-muted">—</span>
                                        }
                                    </td>
                                    <td class="hr-muted hr-sm">@a.CreatedAt.ToString("dd MMM yyyy")</td>
                                    <td class="text-end pe-3">
                                        <div class="hr-actions">
                                            @if (a.Status == AssetStatus.Available)
                                            {
                                                <button class="hr-act-btn hr-act-assign"
                                                        @onclick="() => OpenAssignModal(a)"
                                                        title="Assign to Employee">
                                                    <i class="bi bi-person-plus-fill"></i>
                                                </button>
                                            }
                                            @if (a.Status == AssetStatus.Assigned)
                                            {
                                                <button class="hr-act-btn hr-act-return"
                                                        @onclick="() => OpenReturnModal(a)"
                                                        title="Return Asset">
                                                    <i class="bi bi-arrow-return-left"></i>
                                                </button>
                                                <button class="hr-act-btn hr-act-repair"
                                                        @onclick="() => OpenRequestModal(a, AssetRequestType.Repair)"
                                                        title="Request Repair">
                                                    <i class="bi bi-tools"></i>
                                                </button>
                                                <button class="hr-act-btn hr-act-replace"
                                                        @onclick="() => OpenRequestModal(a, AssetRequestType.Replacement)"
                                                        title="Request Replacement">
                                                    <i class="bi bi-arrow-repeat"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (invTotalPages > 1)
                {
                    <div class="hr-pagination">
                        <span class="hr-muted hr-sm">
                            Showing @((invFilter.Page - 1) * invFilter.PageSize + 1)–@Math.Min(invFilter.Page * invFilter.PageSize, invTotalCount) of @invTotalCount
                        </span>
                        <div class="hr-pages">
                            <button class="hr-pg-btn" disabled="@(invFilter.Page <= 1)" @onclick="InvPrev">
                                <i class="bi bi-chevron-left"></i>
                            </button>
                            @for (int p = Math.Max(1, invFilter.Page - 2); p <= Math.Min(invTotalPages, invFilter.Page + 2); p++)
                            {
                                var pg = p;
                                <button class="hr-pg-btn @(invFilter.Page == pg ? "active" : "")" @onclick="() => InvGoPage(pg)">@pg</button>
                            }
                            <button class="hr-pg-btn" disabled="@(invFilter.Page >= invTotalPages)" @onclick="InvNext">
                                <i class="bi bi-chevron-right"></i>
                            </button>
                        </div>
                    </div>
                }
            }
        </div>
    }

    <!-- ════════════════════════════════════════════════════════════════════════
         TAB — ASSET REQUESTS
    ════════════════════════════════════════════════════════════════════════════ -->
    @if (activeTab == Tab.Requests)
    {
        <!-- Filter for requests -->
        <div class="hr-filter-bar">
            <div class="hr-filter-group">
                <label class="hr-filter-label">Status</label>
                <select class="hr-sel" @bind="reqStatusFilter" @bind:after="LoadRequestsAsync">
                    <option value="">All Statuses</option>
                    <option value="@AssetRequestStatus.Pending">Pending</option>
                    <option value="@AssetRequestStatus.Approved">Approved</option>
                    <option value="@AssetRequestStatus.Rejected">Rejected</option>
                    <option value="@AssetRequestStatus.Completed">Completed</option>
                </select>
            </div>
            <div class="hr-filter-group">
                <label class="hr-filter-label">Type</label>
                <select class="hr-sel" @bind="reqTypeFilter" @bind:after="ApplyReqFilters">
                    <option value="">All Types</option>
                    <option value="@AssetRequestType.Repair">Repair</option>
                    <option value="@AssetRequestType.Replacement">Replacement</option>
                    <option value="@AssetRequestType.Return">Return</option>
                </select>
            </div>
        </div>

        <div class="hr-scope-note">
            <i class="bi bi-info-circle-fill me-2"></i>
            Showing requests for assets in <strong>@departmentName</strong> and org-wide assets.
            All HRs in your department can see these requests.
        </div>

        <div class="hr-card">
            @if (reqLoading)
            {
                <div class="hr-state-center"><div class="hr-spinner"></div></div>
            }
            else if (!reqFiltered.Any())
            {
                <div class="hr-state-center">
                    <i class="bi bi-inbox hr-empty-icon"></i>
                    <p class="hr-state-title">No requests found</p>
                    <p class="hr-state-sub">Repair, replacement and return requests for your department will appear here.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="hr-table">
                        <thead>
                            <tr>
                                <th>Asset</th>
                                <th>Type</th>
                                <th>Raised By</th>
                                <th>Role</th>
                                <th>Reason</th>
                                <th>Status</th>
                                <th>Date</th>
                                <th>Reviewed By</th>
                                <th>Review Notes</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in reqFiltered)
                            {
                                <tr class="hr-row">
                                    <td>
                                        <div class="hr-asset-name">@r.AssetName</div>
                                        <code class="hr-code-sm">@r.AssetCode</code>
                                    </td>
                                    <td>
                                        <span class="@ReqTypeClass(r.RequestType)">
                                            @ReqTypeIcon(r.RequestType) @r.RequestType
                                        </span>
                                    </td>
                                    <td>
                                        <div class="hr-assignee">
                                            <div class="hr-avatar hr-avatar-sm">@r.RequestedByEmployeeName[0]</div>
                                            <span class="hr-sm">@r.RequestedByEmployeeName</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="@RoleClass(r.RequestorRole)">@r.RequestorRole</span>
                                    </td>
                                    <td class="hr-reason-cell" title="@r.Reason">@r.Reason</td>
                                    <td><span class="@ReqStatusClass(r.Status)">@r.Status</span></td>
                                    <td class="hr-muted hr-sm">@r.RequestedAt.ToString("dd MMM yyyy")</td>
                                    <td class="hr-muted hr-sm">@(r.ReviewedByEmployeeName ?? "—")</td>
                                    <td class="hr-muted hr-sm hr-reason-cell" title="@r.ReviewNotes">@(r.ReviewNotes ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    }

    <!-- ════════════════════════════════════════════════════════════════════════
         TAB — PROCUREMENT
    ════════════════════════════════════════════════════════════════════════════ -->
    @if (activeTab == Tab.Procurement)
    {
        <div class="hr-section-toolbar">
            <p class="hr-muted hr-sm">
                Procurement requests are visible to all HRs in <strong>@departmentName</strong>.
                OrgAdmin reviews and fulfils approved requests.
            </p>
            <button class="hr-btn hr-btn-primary hr-btn-sm" @onclick="OpenProcurementModal">
                <i class="bi bi-plus-lg"></i> New Request
            </button>
        </div>

        <div class="hr-card">
            @if (procLoading)
            {
                <div class="hr-state-center"><div class="hr-spinner"></div></div>
            }
            else if (!procurements.Any())
            {
                <div class="hr-state-center">
                    <i class="bi bi-clipboard hr-empty-icon"></i>
                    <p class="hr-state-title">No procurement requests yet</p>
                    <p class="hr-state-sub">Click <strong>New Request</strong> to ask OrgAdmin for new assets.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="hr-table">
                        <thead>
                            <tr>
                                <th>Category</th>
                                <th>Asset Name</th>
                                <th>Requested</th>
                                <th>Fulfilled</th>
                                <th>Requested By</th>
                                <th>Justification</th>
                                <th>Status</th>
                                <th>Date</th>
                                <th>Review Notes</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in procurements)
                            {
                                <tr class="hr-row">
                                    <td><span class="hr-cat">@p.AssetCategory</span></td>
                                    <td class="hr-sm">@(p.AssetName ?? "—")</td>
                                    <td class="fw-semibold">@p.QuantityRequested</td>
                                    <td>
                                        @if (p.QuantityFulfilled > 0)
                                        {
                                            <span class="hr-badge hr-badge-success">@p.QuantityFulfilled</span>
                                        }
                                        else
                                        {

                                            <span class="hr-muted">0</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="hr-assignee">
                                            @if (!string.IsNullOrEmpty(p.RequestedByEmployeeName))
                                            {
                                                <div class="hr-avatar hr-avatar-sm">@p.RequestedByEmployeeName[0]</div>
                                            }
                                            <span class="hr-sm">@p.RequestedByEmployeeName</span>
                                        </div>
                                    </td>
                                    <td class="hr-reason-cell hr-sm" title="@p.Justification">@p.Justification</td>
                                    <td><span class="@ProcStatusClass(p.Status)">@p.Status</span></td>
                                    <td class="hr-muted hr-sm">@p.RequestedAt.ToString("dd MMM yyyy")</td>
                                    <td class="hr-muted hr-sm hr-reason-cell" title="@p.ReviewNotes">@(p.ReviewNotes ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    }

</div>

<!-- ══════════════════════════════════════════════════════════════════════════════
     MODAL — ASSIGN ASSET
══════════════════════════════════════════════════════════════════════════════ -->
@if (showAssignModal && modalAsset != null)
{
    <div class="hr-overlay" @onclick="CloseAll"></div>
    <div class="hr-modal hr-modal-sm">
        <div class="hr-modal-hdr">
            <div class="hr-modal-title-wrap">
                <div class="hr-modal-ico hr-ico-success"><i class="bi bi-person-plus-fill"></i></div>
                <div>
                    <h5 class="hr-modal-title">Assign Asset</h5>
                    <p class="hr-modal-sub">Select an employee from your department</p>
                </div>
            </div>
            <button class="hr-close" @onclick="CloseAll"><i class="bi bi-x-lg"></i></button>
        </div>
        <div class="hr-modal-body">

            <!-- Asset chip -->
            <div class="hr-chip">
                <i class="bi bi-box-seam-fill hr-chip-ico"></i>
                <div class="hr-chip-info">
                    <span class="hr-chip-name">@modalAsset.Name</span>
                    <code class="hr-chip-code">@modalAsset.AssetCode</code>
                </div>
                @if (modalAsset.DepartmentId == null)
                {
                    <span class="hr-badge hr-badge-orgwide">Org-Wide</span>
                }
                else
                {
                    <span class="hr-badge hr-badge-dept">@departmentName</span>
                }
            </div>

            <div class="hr-info-box hr-info-blue">
                <i class="bi bi-shield-lock-fill"></i>
                <span>
                    Only <strong>Employee-role</strong> users in <strong>@departmentName</strong> are listed.
                    HR users and members of other departments cannot be assigned.
                </span>
            </div>

            <div class="hr-form-grp">
                <label class="hr-lbl">Assign To <span class="hr-req">*</span></label>
                @if (empLoading)
                {
                    <div class="hr-inline-load">
                        <span class="hr-spinner-sm"></span>
                        <span class="hr-muted hr-sm">Loading eligible employees…</span>
                    </div>
                }
                else if (!assignableEmps.Any())
                {
                    <div class="hr-alert hr-alert-warn">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        No eligible employees found in <strong>@departmentName</strong>.
                        All employees may already have assets, or no Employee-role users exist yet.
                    </div>
                }
                else
                {
                    <select class="hr-inp" @bind="assignEmpId">
                        <option value="">— Select Employee —</option>
                        @foreach (var e in assignableEmps)
                        {
                            <option value="@e.EmployeeId">@e.FullName</option>
                        }
                    </select>
                }
            </div>

            <div class="hr-form-grp">
                <label class="hr-lbl">Assignment Notes</label>
                <textarea class="hr-inp" rows="2" @bind="assignNotes"
                          placeholder="Optional — project name, reason for assignment…"></textarea>
            </div>

            @if (!string.IsNullOrEmpty(modalError))
            {
                <div class="hr-alert hr-alert-err"><i class="bi bi-exclamation-circle me-2"></i>@modalError</div>
            }

            <div class="hr-modal-footer">
                <button class="hr-btn hr-btn-ghost" @onclick="CloseAll">Cancel</button>
                <button class="hr-btn hr-btn-success"
                        @onclick="SubmitAssignAsync"
                        disabled="@(submitting || string.IsNullOrEmpty(assignEmpId) || !assignableEmps.Any())">
                    @if (submitting)
                    {
                        <span class="hr-spinner-sm me-1"></span>
                    }
                    Assign Asset
                </button>
            </div>
        </div>
    </div>
}

<!-- ══════════════════════════════════════════════════════════════════════════════
     MODAL — RETURN ASSET
══════════════════════════════════════════════════════════════════════════════ -->
@if (showReturnModal && modalAsset != null)
{
    <div class="hr-overlay" @onclick="CloseAll"></div>
    <div class="hr-modal hr-modal-sm">
        <div class="hr-modal-hdr">
            <div class="hr-modal-title-wrap">
                <div class="hr-modal-ico hr-ico-warning"><i class="bi bi-arrow-return-left"></i></div>
                <div>
                    <h5 class="hr-modal-title">Return Asset</h5>
                    <p class="hr-modal-sub">Mark this asset as returned from the employee</p>
                </div>
            </div>
            <button class="hr-close" @onclick="CloseAll"><i class="bi bi-x-lg"></i></button>
        </div>
        <div class="hr-modal-body">
            <div class="hr-chip">
                <i class="bi bi-box-seam-fill hr-chip-ico"></i>
                <div class="hr-chip-info">
                    <span class="hr-chip-name">@modalAsset.Name</span>
                    <span class="hr-chip-sub">
                        Currently held by <strong>@modalAsset.CurrentEmployeeName</strong>
                    </span>
                </div>
            </div>

            <div class="hr-form-grp">
                <label class="hr-lbl">Return Notes</label>
                <textarea class="hr-inp" rows="2" @bind="returnNotes"
                          placeholder="Condition on return, any remarks…"></textarea>
            </div>

            @if (!string.IsNullOrEmpty(modalError))
            {
                <div class="hr-alert hr-alert-err"><i class="bi bi-exclamation-circle me-2"></i>@modalError</div>
            }

            <div class="hr-modal-footer">
                <button class="hr-btn hr-btn-ghost" @onclick="CloseAll">Cancel</button>
                <button class="hr-btn hr-btn-warning" @onclick="SubmitReturnAsync" disabled="@submitting">
                    @if (submitting)
                    {
                        <span class="hr-spinner-sm me-1"></span>
                    }
                    Confirm Return
                </button>
            </div>
        </div>
    </div>
}

<!-- ══════════════════════════════════════════════════════════════════════════════
     MODAL — ASSET REQUEST (Repair / Replacement / Return)
══════════════════════════════════════════════════════════════════════════════ -->
@if (showRequestModal && modalAsset != null)
{
    <div class="hr-overlay" @onclick="CloseAll"></div>
    <div class="hr-modal hr-modal-sm">
        <div class="hr-modal-hdr">
            <div class="hr-modal-title-wrap">
                <div class="hr-modal-ico @RequestModalIconClass()">
                    <i class="@RequestModalIcon()"></i>
                </div>
                <div>
                    <h5 class="hr-modal-title">Request @requestType</h5>
                    <p class="hr-modal-sub">This request will be reviewed by OrgAdmin</p>
                </div>
            </div>
            <button class="hr-close" @onclick="CloseAll"><i class="bi bi-x-lg"></i></button>
        </div>
        <div class="hr-modal-body">
            <div class="hr-chip">
                <i class="@RequestModalIcon() hr-chip-ico @RequestChipIconColor()"></i>
                <div class="hr-chip-info">
                    <span class="hr-chip-name">@modalAsset.Name</span>
                    <span class="hr-chip-sub">
                        Assigned to <strong>@modalAsset.CurrentEmployeeName</strong>
                    </span>
                </div>
            </div>

            @if (requestType == AssetRequestType.Replacement)
            {
                <div class="hr-info-box hr-info-blue">
                    <i class="bi bi-info-circle-fill"></i>
                    <span>
                        On approval, OrgAdmin will select a replacement asset from
                        <strong>@departmentName</strong>'s available inventory.
                        The old asset will be returned automatically.
                    </span>
                </div>
            }
            @if (requestType == AssetRequestType.Repair)
            {
                <div class="hr-info-box hr-info-amber">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <span>
                        On approval, the asset will move to <strong>In Repair</strong> status.
                        When repair is complete, it will return to <strong>Assigned</strong>.
                    </span>
                </div>
            }

            <div class="hr-form-grp">
                <label class="hr-lbl">Reason <span class="hr-req">*</span></label>
                <textarea class="hr-inp" rows="3" @bind="requestReason"
                          placeholder="@RequestReasonPlaceholder()"></textarea>
            </div>

            @if (!string.IsNullOrEmpty(modalError))
            {
                <div class="hr-alert hr-alert-err"><i class="bi bi-exclamation-circle me-2"></i>@modalError</div>
            }

            <div class="hr-modal-footer">
                <button class="hr-btn hr-btn-ghost" @onclick="CloseAll">Cancel</button>
                <button class="hr-btn @RequestSubmitBtnClass()"
                        @onclick="SubmitRequestAsync"
                        disabled="@(submitting || string.IsNullOrWhiteSpace(requestReason))">
                    @if (submitting)
                    {
                        <span class="hr-spinner-sm me-1"></span>
                    }
                    Submit @requestType Request
                </button>
            </div>
        </div>
    </div>
}

<!-- ══════════════════════════════════════════════════════════════════════════════
     MODAL — PROCUREMENT REQUEST
══════════════════════════════════════════════════════════════════════════════ -->
@if (showProcurementModal)
{
    <div class="hr-overlay" @onclick="CloseAll"></div>
    <div class="hr-modal hr-modal-sm">
        <div class="hr-modal-hdr">
            <div class="hr-modal-title-wrap">
                <div class="hr-modal-ico hr-ico-primary"><i class="bi bi-clipboard-plus-fill"></i></div>
                <div>
                    <h5 class="hr-modal-title">Request New Assets</h5>
                    <p class="hr-modal-sub">OrgAdmin will review and create assets for your department</p>
                </div>
            </div>
            <button class="hr-close" @onclick="CloseAll"><i class="bi bi-x-lg"></i></button>
        </div>
        <div class="hr-modal-body">

            <div class="hr-info-box hr-info-blue mb-3">
                <i class="bi bi-info-circle-fill"></i>
                <span>
                    Request is raised on behalf of <strong>@departmentName</strong>.
                    All HRs in your department will see this request once submitted.
                </span>
            </div>

            <EditForm Model="procDto" OnValidSubmit="SubmitProcurementAsync">
                <DataAnnotationsValidator />

                <div class="hr-form-grp">
                    <label class="hr-lbl">Asset Category <span class="hr-req">*</span></label>
                    <InputText class="hr-inp" @bind-Value="procDto.AssetCategory"
                               placeholder="e.g. Laptop, Monitor, Headset" />
                    <ValidationMessage For="() => procDto.AssetCategory" class="hr-val-err" />
                </div>

                <div class="hr-form-grp">
                    <label class="hr-lbl">Preferred Asset Name <span class="hr-hint">(optional)</span></label>
                    <InputText class="hr-inp" @bind-Value="procDto.AssetName"
                               placeholder="e.g. Dell Latitude 5540, LG 27-inch Monitor" />
                </div>

                <div class="hr-form-grp">
                    <label class="hr-lbl">Quantity Required <span class="hr-req">*</span></label>
                    <InputNumber class="hr-inp" @bind-Value="procDto.QuantityRequested" min="1" max="1000" />
                    <ValidationMessage For="() => procDto.QuantityRequested" class="hr-val-err" />
                </div>

                <div class="hr-form-grp">
                    <label class="hr-lbl">Justification <span class="hr-req">*</span></label>
                    <InputTextArea class="hr-inp" @bind-Value="procDto.Justification" rows="3"
                                   placeholder="Why does your department need these assets? Include urgency, use case…" />
                    <ValidationMessage For="() => procDto.Justification" class="hr-val-err" />
                </div>

                @if (!string.IsNullOrEmpty(modalError))
                {
                    <div class="hr-alert hr-alert-err"><i class="bi bi-exclamation-circle me-2"></i>@modalError</div>
                }

                <div class="hr-modal-footer">
                    <button type="button" class="hr-btn hr-btn-ghost" @onclick="CloseAll">Cancel</button>
                    <button type="submit" class="hr-btn hr-btn-primary" disabled="@submitting">
                        @if (submitting)
                        {
                            <span class="hr-spinner-sm me-1"></span>
                        }
                        Submit Request
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

<!-- ── Toast ───────────────────────────────────────────────────────────────── -->
@if (!string.IsNullOrEmpty(toastMsg))
{
    <div class="hr-toast @toastCss">
        <i class="@toastIcon me-2"></i>@toastMsg
    </div>
}

<!-- ─────────────────────────────────────────────────────────────────────────
     STYLES
───────────────────────────────────────────────────────────────────────── -->
<style>
    :root {
        --c-primary: #4f46e5;
        --c-pdk: #4338ca;
        --c-success: #059669;
        --c-warning: #d97706;
        --c-danger: #dc2626;
        --c-info: #0891b2;
        --c-bg: #f8f9fc;
        --c-surface: #ffffff;
        --c-border: #e5e7eb;
        --c-text: #111827;
        --c-muted: #6b7280;
        --c-radius: 12px;
        --c-shadow: 0 1px 3px rgba(0,0,0,.08);
        --c-shadow-lg: 0 12px 40px rgba(0,0,0,.14);
    }

    /* Wrapper */
    .hr-wrapper {
        padding: 1.75rem 1.5rem;
        background: var(--c-bg);
        min-height: 100vh;
        max-width: 1500px;
    }

    /* Header */
    .hr-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
        gap: .75rem;
    }

    .hr-header-left {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .hr-header-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        background: linear-gradient(135deg,#667eea,#764ba2);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        flex-shrink: 0;
    }

    .hr-title {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--c-text);
        margin: 0;
        letter-spacing: -.02em;
    }

    .hr-subtitle {
        font-size: .825rem;
        color: var(--c-muted);
        margin: 0;
        display: flex;
        align-items: center;
        gap: .35rem;
        flex-wrap: wrap;
    }

    .hr-dept-pill {
        background: rgba(79,70,229,.1);
        color: var(--c-primary);
        font-weight: 600;
        padding: .15rem .55rem;
        border-radius: 20px;
        font-size: .78rem;
    }

    .hr-header-actions {
        display: flex;
        gap: .625rem;
    }

    /* KPI */
    .hr-kpi-row {
        display: grid;
        grid-template-columns: repeat(5,1fr);
        gap: .875rem;
        margin-bottom: 1.25rem;
    }

    @@media(max-width:1100px) {
        .hr-kpi-row {
            grid-template-columns: repeat(3,1fr);
        }
    }

    @@media(max-width:640px) {
        .hr-kpi-row {
            grid-template-columns: repeat(2,1fr);
        }
    }

    .hr-kpi {
        background: var(--c-surface);
        border: 1px solid var(--c-border);
        border-radius: var(--c-radius);
        padding: .875rem 1rem;
        display: flex;
        align-items: center;
        gap: .75rem;
        box-shadow: var(--c-shadow);
    }

    .hr-kpi-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        flex-shrink: 0;
    }

    .hr-kpi-label {
        font-size: .68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .8px;
        color: var(--c-muted);
    }

    .hr-kpi-val {
        font-size: 1.65rem;
        font-weight: 800;
        line-height: 1.1;
        color: var(--c-text);
    }

    .hr-kpi-total .hr-kpi-icon {
        background: rgba(79,70,229,.1);
        color: var(--c-primary);
    }

    .hr-kpi-available .hr-kpi-icon {
        background: rgba(5,150,105,.1);
        color: var(--c-success);
    }

    .hr-kpi-available .hr-kpi-val {
        color: var(--c-success);
    }

    .hr-kpi-assigned .hr-kpi-icon {
        background: rgba(8,145,178,.1);
        color: var(--c-info);
    }

    .hr-kpi-assigned .hr-kpi-val {
        color: var(--c-info);
    }

    .hr-kpi-repair .hr-kpi-icon {
        background: rgba(217,119,6,.1);
        color: var(--c-warning);
    }

    .hr-kpi-repair .hr-kpi-val {
        color: var(--c-warning);
    }

    .hr-kpi-pending .hr-kpi-icon {
        background: rgba(220,38,38,.1);
        color: var(--c-danger);
    }

    .hr-kpi-pending .hr-kpi-val {
        color: var(--c-danger);
    }

    /* Tabs */
    .hr-tabs {
        display: flex;
        gap: .25rem;
        background: var(--c-surface);
        border: 1px solid var(--c-border);
        border-radius: var(--c-radius);
        padding: .35rem;
        margin-bottom: 1rem;
    }

    .hr-tab {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .4rem;
        padding: .6rem .875rem;
        border-radius: 8px;
        border: none;
        background: transparent;
        font-size: .85rem;
        font-weight: 500;
        color: var(--c-muted);
        cursor: pointer;
        transition: all .15s;
    }

        .hr-tab:hover:not(.active) {
            background: #f3f4f6;
            color: var(--c-text);
        }

        .hr-tab.active {
            background: var(--c-primary);
            color: #fff;
            font-weight: 600;
        }

    .hr-tab-count {
        font-size: .68rem;
        font-weight: 700;
        padding: .1rem .4rem;
        border-radius: 20px;
        background: rgba(0,0,0,.1);
    }

    .hr-tab.active .hr-tab-count {
        background: rgba(255,255,255,.25);
    }

    .hr-tab-badge {
        font-size: .68rem;
        font-weight: 700;
        background: var(--c-danger);
        color: #fff;
        padding: .1rem .4rem;
        border-radius: 20px;
    }

    /* Filter bar */
    .hr-filter-bar {
        background: var(--c-surface);
        border: 1px solid var(--c-border);
        border-radius: var(--c-radius);
        padding: .875rem 1rem;
        margin-bottom: .75rem;
        display: flex;
        gap: .75rem;
        flex-wrap: wrap;
        align-items: flex-end;
    }

    .hr-filter-group {
        display: flex;
        flex-direction: column;
        gap: .3rem;
        min-width: 140px;
    }

    .hr-filter-search {
        flex: 1;
        min-width: 220px;
    }

    .hr-filter-label {
        font-size: .68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .7px;
        color: var(--c-muted);
    }

    .hr-sel, .hr-inp {
        height: 36px;
        padding: 0 .625rem;
        border: 1px solid var(--c-border);
        border-radius: 8px;
        font-size: .85rem;
        color: var(--c-text);
        background: var(--c-surface);
        width: 100%;
        outline: none;
        transition: border-color .15s;
    }

        .hr-sel:focus, .hr-inp:focus {
            border-color: var(--c-primary);
            box-shadow: 0 0 0 3px rgba(79,70,229,.1);
        }

    .hr-search-wrap {
        position: relative;
    }

    .hr-search-ico {
        position: absolute;
        left: .625rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--c-muted);
        font-size: .8rem;
        pointer-events: none;
    }

    .hr-inp-search {
        padding-left: 2rem;
    }

    .hr-search-clear {
        position: absolute;
        right: .5rem;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        color: var(--c-muted);
        cursor: pointer;
    }

    /* Scope note */
    .hr-scope-note {
        background: rgba(79,70,229,.05);
        border: 1px solid rgba(79,70,229,.15);
        color: #374151;
        border-radius: 8px;
        padding: .6rem 1rem;
        font-size: .8rem;
        margin-bottom: .75rem;
        display: flex;
        align-items: center;
    }

    /* Section toolbar */
    .hr-section-toolbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: .75rem;
    }

    /* Card / table */
    .hr-card {
        background: var(--c-surface);
        border: 1px solid var(--c-border);
        border-radius: var(--c-radius);
        box-shadow: var(--c-shadow);
        overflow: hidden;
    }

    .hr-table {
        width: 100%;
        border-collapse: collapse;
    }

        .hr-table thead tr {
            background: #f9fafb;
            border-bottom: 1px solid var(--c-border);
        }

        .hr-table th {
            font-size: .7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .8px;
            color: var(--c-muted);
            padding: .75rem 1rem;
            white-space: nowrap;
        }

        .hr-table td {
            padding: .75rem 1rem;
            font-size: .85rem;
            border-bottom: 1px solid #f3f4f6;
            vertical-align: middle;
        }

    .hr-row:hover td {
        background: #fafafa;
    }

    .hr-asset-name {
        font-weight: 600;
        color: var(--c-text);
    }

    .hr-code {
        font-family: 'JetBrains Mono',monospace;
        font-size: .78rem;
        background: #f3f4f6;
        color: var(--c-muted);
        padding: .1rem .35rem;
        border-radius: 4px;
    }

    .hr-code-sm {
        font-family: monospace;
        font-size: .72rem;
        color: var(--c-muted);
    }

    .hr-cat {
        background: #f3f4f6;
        color: #374151;
        font-size: .72rem;
        font-weight: 600;
        padding: .2rem .55rem;
        border-radius: 20px;
    }

    .hr-muted {
        color: var(--c-muted);
    }

    .hr-sm {
        font-size: .82rem;
    }

    .hr-reason-cell {
        max-width: 180px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    /* Status badges */
    .hr-status {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        font-size: .72rem;
        font-weight: 700;
        padding: .25rem .6rem;
        border-radius: 20px;
        white-space: nowrap;
    }

        .hr-status::before {
            content: '';
            width: 6px;
            height: 6px;
            border-radius: 50%;
            flex-shrink: 0;
        }

    .hr-s-available {
        background: rgba(5,150,105,.1);
        color: #065f46;
    }

        .hr-s-available::before {
            background: var(--c-success);
        }

    .hr-s-assigned {
        background: rgba(8,145,178,.1);
        color: #155e75;
    }

        .hr-s-assigned::before {
            background: var(--c-info);
        }

    .hr-s-inrepair {
        background: rgba(217,119,6,.1);
        color: #92400e;
    }

        .hr-s-inrepair::before {
            background: var(--c-warning);
        }

    .hr-s-retired {
        background: rgba(107,114,128,.1);
        color: #374151;
    }

        .hr-s-retired::before {
            background: var(--c-muted);
        }

    .hr-s-lost {
        background: rgba(220,38,38,.1);
        color: #991b1b;
    }

        .hr-s-lost::before {
            background: var(--c-danger);
        }

    /* Request type badges */
    .hr-rt-repair {
        background: rgba(217,119,6,.1);
        color: #92400e;
        font-size: .72rem;
        font-weight: 600;
        padding: .2rem .55rem;
        border-radius: 20px;
    }

    .hr-rt-replacement {
        background: rgba(79,70,229,.1);
        color: var(--c-primary);
        font-size: .72rem;
        font-weight: 600;
        padding: .2rem .55rem;
        border-radius: 20px;
    }

    .hr-rt-return {
        background: rgba(8,145,178,.1);
        color: #155e75;
        font-size: .72rem;
        font-weight: 600;
        padding: .2rem .55rem;
        border-radius: 20px;
    }

    /* Request status badges */
    .hr-rs-pending {
        background: rgba(217,119,6,.1);
        color: #92400e;
        font-size: .72rem;
        font-weight: 600;
        padding: .2rem .55rem;
        border-radius: 20px;
    }

    .hr-rs-approved {
        background: rgba(5,150,105,.1);
        color: #065f46;
        font-size: .72rem;
        font-weight: 600;
        padding: .2rem .55rem;
        border-radius: 20px;
    }

    .hr-rs-rejected {
        background: rgba(220,38,38,.1);
        color: #991b1b;
        font-size: .72rem;
        font-weight: 600;
        padding: .2rem .55rem;
        border-radius: 20px;
    }

    .hr-rs-completed {
        background: rgba(79,70,229,.1);
        color: var(--c-primary);
        font-size: .72rem;
        font-weight: 600;
        padding: .2rem .55rem;
        border-radius: 20px;
    }

    .hr-rs-cancelled {
        background: rgba(107,114,128,.1);
        color: #374151;
        font-size: .72rem;
        font-weight: 600;
        padding: .2rem .55rem;
        border-radius: 20px;
    }

    /* Procurement status */
    .hr-ps-pending {
        background: rgba(217,119,6,.1);
        color: #92400e;
        font-size: .72rem;
        font-weight: 600;
        padding: .2rem .55rem;
        border-radius: 20px;
    }

    .hr-ps-approved {
        background: rgba(5,150,105,.1);
        color: #065f46;
        font-size: .72rem;
        font-weight: 600;
        padding: .2rem .55rem;
        border-radius: 20px;
    }

    .hr-ps-rejected {
        background: rgba(220,38,38,.1);
        color: #991b1b;
        font-size: .72rem;
        font-weight: 600;
        padding: .2rem .55rem;
        border-radius: 20px;
    }

    .hr-ps-fulfilled {
        background: rgba(79,70,229,.1);
        color: var(--c-primary);
        font-size: .72rem;
        font-weight: 600;
        padding: .2rem .55rem;
        border-radius: 20px;
    }

    /* Role badges */
    .hr-role-hr {
        background: rgba(79,70,229,.1);
        color: var(--c-primary);
        font-size: .7rem;
        font-weight: 600;
        padding: .15rem .45rem;
        border-radius: 20px;
    }

    .hr-role-employee {
        background: #f3f4f6;
        color: #374151;
        font-size: .7rem;
        font-weight: 600;
        padding: .15rem .45rem;
        border-radius: 20px;
    }

    /* Generic badges */
    .hr-badge {
        display: inline-block;
        font-size: .7rem;
        font-weight: 600;
        padding: .15rem .5rem;
        border-radius: 20px;
    }

    .hr-badge-orgwide {
        background: #f3f4f6;
        color: #374151;
    }

    .hr-badge-dept {
        background: rgba(79,70,229,.1);
        color: var(--c-primary);
    }

    .hr-badge-success {
        background: rgba(5,150,105,.1);
        color: #065f46;
    }

    /* Assignee */
    .hr-assignee {
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    .hr-avatar {
        width: 26px;
        height: 26px;
        border-radius: 50%;
        background: var(--c-primary);
        color: #fff;
        font-size: .7rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        text-transform: uppercase;
    }

    .hr-avatar-sm {
        width: 22px;
        height: 22px;
        font-size: .65rem;
    }

    /* Action buttons */
    .hr-actions {
        display: flex;
        gap: .3rem;
        justify-content: flex-end;
    }

    .hr-act-btn {
        width: 30px;
        height: 30px;
        border-radius: 7px;
        border: 1px solid var(--c-border);
        background: var(--c-surface);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: .8rem;
        cursor: pointer;
        transition: all .15s;
        color: var(--c-muted);
    }

    .hr-act-assign:hover {
        color: var(--c-success);
        background: rgba(5,150,105,.06);
        border-color: var(--c-success);
    }

