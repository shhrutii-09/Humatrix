@page "/hr/assets"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "HR")]

@using Humatrix_HRMS.DTOs.Assets
@using Humatrix_HRMS.Services
@using Humatrix_HRMS.Services.Assets
@using Humatrix_HRMS.Infrastructure.Constants
@using Microsoft.AspNetCore.Authorization

@inject EmployeeService EmployeeService
@inject AssetService AssetService
@inject CurrentUserService CurrentUserService
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Department Assets | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 py-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-0">Department Assets</h2>
            <p class="text-muted mb-0">
                Manage and assign department assets.
            </p>
        </div>

        <button class="btn btn-outline-secondary btn-sm px-3"
                @onclick="RefreshAsync">
            <i class="bi bi-arrow-clockwise me-1"></i> Refresh
        </button>
    </div>

    <!-- Summary Cards -->
    <div class="row g-3 mb-4">

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm asset-stat-card">
                <div class="card-body p-3 d-flex align-items-center gap-3">
                    <div class="stat-icon bg-soft-primary">
                        <i class="bi bi-box-seam text-primary"></i>
                    </div>

                    <div>
                        <div class="stat-label">Total Assets</div>
                        <div class="stat-value">@totalCount</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm asset-stat-card">
                <div class="card-body p-3 d-flex align-items-center gap-3">
                    <div class="stat-icon bg-soft-success">
                        <i class="bi bi-check-circle text-success"></i>
                    </div>

                    <div>
                        <div class="stat-label">Available</div>
                        <div class="stat-value text-success">@availableCount</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm asset-stat-card">
                <div class="card-body p-3 d-flex align-items-center gap-3">
                    <div class="stat-icon bg-soft-info">
                        <i class="bi bi-person-check text-info"></i>
                    </div>

                    <div>
                        <div class="stat-label">Assigned</div>
                        <div class="stat-value text-info">@assignedCount</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm asset-stat-card">
                <div class="card-body p-3 d-flex align-items-center gap-3">
                    <div class="stat-icon bg-soft-warning">
                        <i class="bi bi-tools text-warning"></i>
                    </div>

                    <div>
                        <div class="stat-label">In Repair</div>
                        <div class="stat-value text-warning">@inRepairCount</div>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- Filters -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-3">

            <div class="row g-2 align-items-end">

                <div class="col-md-3">
                    <label class="form-label small fw-semibold text-muted">
                        CATEGORY
                    </label>

                    <select class="form-select form-select-sm"
                            @bind="filter.Category"
                            @bind:after="RefreshAsync">

                        <option value="">All Categories</option>

                        @foreach (var cat in categories)
                        {
                            <option value="@cat">@cat</option>
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label small fw-semibold text-muted">
                        STATUS
                    </label>

                    <select class="form-select form-select-sm"
                            @bind="filter.Status"
                            @bind:after="RefreshAsync">

                        <option value="">All Statuses</option>

                        <option value="@AssetStatus.Available">Available</option>
                        <option value="@AssetStatus.Assigned">Assigned</option>
                        <option value="@AssetStatus.InRepair">In Repair</option>
                        <option value="@AssetStatus.Retired">Retired</option>
                        <option value="@AssetStatus.Lost">Lost</option>

                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label small fw-semibold text-muted">
                        SEARCH
                    </label>

                    <input class="form-control form-control-sm"
                           placeholder="Name, code, serial..."
                           @bind="searchText"
                           @bind:event="oninput"
                           @bind:after="ApplySearch" />
                </div>

                <div class="col-md-2 text-end">
                    <button class="btn btn-link btn-sm text-muted p-0"
                            @onclick="ClearFilters">
                        <i class="bi bi-x-circle me-1"></i>Clear
                    </button>
                </div>

            </div>
        </div>
    </div>

    <!-- Table -->
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">

            @if (loading)
            {
                <div class="d-flex justify-content-center align-items-center py-5">
                    <div class="spinner-border text-primary"
                         style="width:2.5rem;height:2.5rem;">
                    </div>
                </div>
            }
            else if (filteredAssets == null || !filteredAssets.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-box-seam fs-1 mb-3 d-block opacity-25"></i>

                    <p class="mb-1 fw-semibold">
                        No assets found
                    </p>

                    <p class="small">
                        No assets available in your department.
                    </p>
                </div>
            }
            else
            {
                <div class="table-responsive">

                    <table class="table table-hover align-middle mb-0 asset-table">

                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Asset</th>
                                <th>Category</th>
                                <th>Code</th>
                                <th>Status</th>
                                <th>Assigned To</th>
                                <th>Added</th>
                                <th class="text-end pe-4">Actions</th>
                            </tr>
                        </thead>

                        <tbody>

                            @foreach (var asset in filteredAssets)
                            {
                                <tr>

                                    <td class="ps-4 fw-semibold">
                                        @asset.Name
                                    </td>

                                    <td>
                                        <span class="badge bg-soft-secondary text-secondary">
                                            @asset.Category
                                        </span>
                                    </td>

                                    <td class="font-monospace small text-muted">
                                        @asset.AssetCode
                                    </td>

                                    <td>
                                        @GetStatusBadge(asset.Status)
                                    </td>

                                    <td class="text-muted small">
                                        @(asset.CurrentEmployeeName ?? "—")
                                    </td>

                                    <td class="text-muted small">
                                        @asset.CreatedAt.ToString("dd MMM yyyy")
                                    </td>

                                    <td class="text-end pe-4">

                                        <div class="d-flex gap-1 justify-content-end">

                                            <button class="btn btn-xs btn-outline-primary"
                                                    @onclick="() => ViewAsset(asset.AssetId)"
                                                    title="View details">
                                                <i class="bi bi-eye"></i>
                                            </button>

                                            @if (asset.Status == AssetStatus.Available)
                                            {
                                                <button class="btn btn-xs btn-outline-success"
                                                        @onclick="() => OpenAssignModal(asset)"
                                                        title="Assign">
                                                    <i class="bi bi-person-plus"></i>
                                                </button>
                                            }

                                            @if (asset.Status == AssetStatus.Assigned)
                                            {
                                                <button class="btn btn-xs btn-outline-warning"
                                                        @onclick="() => OpenReturnModal(asset)"
                                                        title="Return">
                                                    <i class="bi bi-arrow-return-left"></i>
                                                </button>
                                            }

                                        </div>

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>

                <!-- Pagination -->
                @if (totalPages > 1)
                {
                    <div class="d-flex justify-content-between align-items-center px-4 py-3 border-top">

                        <span class="text-muted small">
                            Showing
                            @((filter.Page - 1) * filter.PageSize + 1)
                            –
                            @Math.Min(filter.Page * filter.PageSize, totalCount)
                            of
                            @totalCount assets
                        </span>

                        <div class="d-flex gap-1">

                            <button class="btn btn-xs btn-outline-secondary"
                                    disabled="@(filter.Page <= 1)"
                                    @onclick="PrevPage">
                                <i class="bi bi-chevron-left"></i>
                            </button>

                            @for (int p = 1; p <= totalPages; p++)
                            {
                                var pg = p;

                                <button class="btn btn-xs @(filter.Page == pg ? "btn-primary" : "btn-outline-secondary")"
                                        @onclick="() => GoToPage(pg)">
                                    @pg
                                </button>
                            }

                            <button class="btn btn-xs btn-outline-secondary"
                                    disabled="@(filter.Page >= totalPages)"
                                    @onclick="NextPage">
                                <i class="bi bi-chevron-right"></i>
                            </button>

                        </div>

                    </div>
                }
            }

        </div>
    </div>

</div>

<!-- ASSIGN MODAL -->
@if (showAssignModal && selectedAsset != null)
{
    <div class="modal-backdrop-custom" @onclick="CloseModals"></div>

    <div class="modal-panel modal-panel-sm">

        <div class="modal-panel-header">

            <h5 class="fw-bold mb-0">
                <i class="bi bi-person-plus me-2 text-success"></i>
                Assign Asset
            </h5>

            <button class="btn btn-link text-muted p-0"
                    @onclick="CloseModals">
                <i class="bi bi-x-lg"></i>
            </button>

        </div>

        <div class="modal-panel-body">

            <div class="asset-info-chip mb-4">

                <i class="bi bi-box-seam text-primary me-2"></i>

                <span class="fw-semibold">
                    @selectedAsset.Name
                </span>

                <span class="font-monospace text-muted ms-2 small">
                    @selectedAsset.AssetCode
                </span>

            </div>

            <EditForm Model="assignDto"
                      OnValidSubmit="SubmitAssignAsync">

                <DataAnnotationsValidator />

                <div class="mb-3">

                    <label class="form-label small fw-semibold">
                        Assign To
                        <span class="text-danger">*</span>
                    </label>

                    <select class="form-select"
                            @bind="assignEmployeeId">

                        <option value="">
                            — Select Employee —
                        </option>

                        @foreach (var emp in employees)
                        {
                            <option value="@emp.EmployeeId">
                                @emp.FirstName @emp.LastName (@emp.EmployeeCode)
                            </option>
                        }

                    </select>

                </div>

                <div class="mb-3">

                    <label class="form-label small fw-semibold">
                        Notes
                    </label>

                    <InputTextArea class="form-control"
                                   @bind-Value="assignDto.Notes"
                                   rows="2"
                                   placeholder="Optional assignment notes..." />

                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger py-2 small">
                        @errorMessage
                    </div>
                }

                <div class="d-flex justify-content-end gap-2 mt-3">

                    <button type="button"
                            class="btn btn-light"
                            @onclick="CloseModals">
                        Cancel
                    </button>

                    <button type="submit"
                            class="btn btn-success"
                            disabled="@submitting">

                        @if (submitting)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }

                        Assign

                    </button>

                </div>

            </EditForm>

        </div>
    </div>
}

<!-- RETURN MODAL -->
@if (showReturnModal && selectedAsset != null)
{
    <div class="modal-backdrop-custom" @onclick="CloseModals"></div>

    <div class="modal-panel modal-panel-sm">

        <div class="modal-panel-header">

            <h5 class="fw-bold mb-0">
                <i class="bi bi-arrow-return-left me-2 text-warning"></i>
                Return Asset
            </h5>

            <button class="btn btn-link text-muted p-0"
                    @onclick="CloseModals">
                <i class="bi bi-x-lg"></i>
            </button>

        </div>

        <div class="modal-panel-body">

            <div class="asset-info-chip mb-4">

                <i class="bi bi-box-seam text-primary me-2"></i>

                <span class="fw-semibold">
                    @selectedAsset.Name
                </span>

                <span class="text-muted ms-2 small">
                    currently assigned to
                    <strong>@selectedAsset.CurrentEmployeeName</strong>
                </span>

            </div>

            <div class="mb-3">

                <label class="form-label small fw-semibold">
                    Return Notes
                </label>

                <textarea class="form-control"
                          @bind="returnNotes"
                          rows="2"
                          placeholder="Optional notes...">
                    </textarea>

            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger py-2 small">
                    @errorMessage
                </div>
            }

            <div class="d-flex justify-content-end gap-2 mt-3">

                <button class="btn btn-light"
                        @onclick="CloseModals">
                    Cancel
                </button>

                <button class="btn btn-warning"
                        @onclick="SubmitReturnAsync"
                        disabled="@submitting">

                    @if (submitting)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }

                    Confirm Return

                </button>

            </div>

        </div>
    </div>
}

<style>

