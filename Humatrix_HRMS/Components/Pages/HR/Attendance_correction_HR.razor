@page "/hr/attendance-corrections"
@rendermode InteractiveServer

@using Humatrix_HRMS.Data
@using Humatrix_HRMS.DTOs.AttendanceCorrections
@using Humatrix_HRMS.Helpers
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore

@attribute [Authorize(Roles = "HR,OrgAdmin")]

@inject AttendanceCorrectionService CorrectionService
@inject CurrentUserService CurrentUserService
@inject ApplicationDbContext DbContext

<PageTitle>Attendance Corrections | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-normal">Attendance Correction Requests</h2>

        <button class="btn btn-outline-secondary shadow-sm"
                @onclick="LoadRequests">

            <i class="bi bi-arrow-clockwise"></i>
            REFRESH

        </button>
    </div>

    <!-- TABLE -->
    <div class="card shadow-sm border-0">

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 text-muted small">EMPLOYEE</th>
                        <th class="text-muted small">DATE</th>
                        <th class="text-muted small">TYPE</th>
                        <th class="text-muted small">REQUESTED IN</th>
                        <th class="text-muted small">REQUESTED OUT</th>
                        <th class="text-muted small">REASON</th>
                        <th class="text-muted small">STATUS</th>
                        <th class="text-muted small text-center">ACTION</th>
                    </tr>
                </thead>

                <tbody>

                    @if (isLoading)
                    {
                        <tr>
                            <td colspan="8"
                                class="text-center py-5 text-muted">

                                <span class="spinner-border spinner-border-sm me-2"></span>
                                Loading requests...

                            </td>
                        </tr>
                    }
                    else if (requests.Any())
                    {
                        @foreach (var item in requests)
                        {
                            <tr>

                                <!-- EMPLOYEE -->
                                <td class="ps-4">

                                    <div class="fw-semibold">
                                        @item.EmployeeName
                                    </div>

                                    <div class="small text-muted">
                                        @item.Email
                                    </div>

                                </td>

                                <!-- DATE -->
                                <td>
                                    @item.WorkDate.ToString("dd MMM yyyy")
                                </td>

                                <!-- TYPE -->
                                <td>
                                    @FormatType(item.RequestType)
                                </td>

                                <!-- IN -->
                                <td class="font-monospace">
                                    @FormatTime(item.RequestedCheckIn)
                                </td>

                                <!-- OUT -->
                                <td class="font-monospace">
                                    @FormatTime(item.RequestedCheckOut)
                                </td>

                                <!-- REASON -->
                                <td style="max-width:250px;">
                                    @item.Reason
                                </td>

                                <!-- STATUS -->
                                <td>
                                    <span class="badge rounded-pill @GetStatusClass(item.Status)">
                                        @item.Status
                                    </span>
                                </td>

                                <!-- ACTION -->
                                <td class="text-center">

                                    @if (item.Status == AttendanceCorrectionStatuses.Pending)
                                    {
                                        <div class="d-flex justify-content-center gap-2">

                                            <button class="btn btn-success btn-sm"
                                                    @onclick="() => Approve(item.AttendanceCorrectionRequestId)">

                                                APPROVE

                                            </button>

                                            <button class="btn btn-danger btn-sm"
                                                    @onclick="() => Reject(item.AttendanceCorrectionRequestId)">

                                                REJECT

                                            </button>

                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">
                                            Completed
                                        </span>
                                    }

                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8"
                                class="text-center py-5 text-muted">

                                No correction requests found.

                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>
    </div>
</div>

@code {

    private List<AttendanceCorrectionListDto> requests = new();

    private bool isLoading;

    private TimeZoneInfo orgTimeZone = TimeZoneInfo.Utc;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrgTimezone();
        await LoadRequests();
    }

    private async Task LoadOrgTimezone()
    {
        var user = await CurrentUserService.GetUserAsync();

        if (user?.OrganizationId == null)
        {
            orgTimeZone = TimeZoneInfo.Utc;
            return;
        }

        var org = await DbContext.Organizations
            .AsNoTracking()
            .FirstOrDefaultAsync(x =>
                x.OrganizationId == user.OrganizationId);

        try
        {
            orgTimeZone = TimeZoneInfo.FindSystemTimeZoneById(
                org?.TimeZoneId ?? "UTC");
        }
        catch
        {
            orgTimeZone = TimeZoneInfo.Utc;
        }
    }

    private async Task LoadRequests()
    {
        isLoading = true;

        try
        {
            requests = await CorrectionService.GetAllRequestsAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task Approve(Guid correctionId)
    {
        try
        {
            await CorrectionService.ApproveAsync(correctionId);

            await LoadRequests();
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
    }

    private async Task Reject(Guid correctionId)
    {
        try
        {
            await CorrectionService.RejectAsync(
                correctionId,
                "Rejected by HR");

            await LoadRequests();
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
    }

    private string FormatTime(DateTime? utcTime)
    {
        if (!utcTime.HasValue)
            return "--";

        var localTime = TimeZoneInfo.ConvertTimeFromUtc(
            DateTime.SpecifyKind(
                utcTime.Value,
                DateTimeKind.Utc),
            orgTimeZone);

        return localTime.ToString("dd MMM yyyy hh:mm tt");
    }

    private string FormatType(string type)
    {
        return type switch
        {
            AttendanceCorrectionTypes.MissingCheckIn => "Missing Check-In",
            AttendanceCorrectionTypes.MissingCheckOut => "Missing Check-Out",
            AttendanceCorrectionTypes.WrongCheckIn => "Wrong Check-In",
            AttendanceCorrectionTypes.WrongCheckOut => "Wrong Check-Out",
            AttendanceCorrectionTypes.FullCorrection => "Full Correction",
            _ => type
        };
    }

    private string GetStatusClass(string? status)
    {
        return status switch
        {
            AttendanceCorrectionStatuses.Pending
                => "bg-warning text-dark",

            AttendanceCorrectionStatuses.Approved
                => "bg-success",

            AttendanceCorrectionStatuses.Rejected
                => "bg-danger",

            _ => "bg-secondary"
        };
    }
}