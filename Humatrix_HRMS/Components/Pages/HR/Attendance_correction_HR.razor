@page "/hr/corrections"
@rendermode InteractiveServer
@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Helpers
@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Components.Authorization
@using Humatrix_HRMS.Data
@using System.Globalization
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@attribute [Authorize(Roles = "HR,OrgAdmin")]

@inject AttendanceCorrectionService CorrectionService
@inject DepartmentService DeptService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject CurrentUserService CurrentUserService

<PageTitle>Correction Desk | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-0">Attendance Correction Management Desk</h4>
            @if (isOrgAdmin)
            {
                <span class="badge bg-danger mt-1">OrgAdmin Privilege Mode</span>
                <small class="text-muted d-block mt-1">You can view all organizational requests, including those submitted by HR teams.</small>
            }
            else
            {
                <span class="badge bg-primary mt-1">Department HR Mode</span>
                <small class="text-muted d-block mt-1">Managing requests from standard employees within your assigned department branch.</small>
            }
        </div>

        @if (isHr)
        {
            <button class="btn btn-outline-primary shadow-sm" @onclick="() => showManualModal = true">
                <i class="bi bi-pencil-square me-2"></i>HR Manual Correction
            </button>
        }
    </div>

    @if (summary != null)
    {
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card shadow-sm border-0 border-start border-warning border-4">
                    <div class="card-body py-3">
                        <small class="text-muted fw-bold d-block">PENDING ACTION</small>
                        <h3 class="mb-0 fw-bold text-warning">@summary.TotalPending</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm border-0 border-start border-danger border-4">
                    <div class="card-body py-3">
                        <small class="text-muted fw-bold d-block">OVERDUE (2+ DAYS)</small>
                        <h3 class="mb-0 fw-bold text-danger">@summary.PendingOlderThan2Days</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm border-0 border-start border-success border-4">
                    <div class="card-body py-3">
                        <small class="text-muted fw-bold d-block">APPROVED (THIS WEEK)</small>
                        <h3 class="mb-0 fw-bold text-success">@summary.ApprovedThisWeek</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm border-0 border-start border-secondary border-4">
                    <div class="card-body py-3">
                        <small class="text-muted fw-bold d-block">REJECTED (THIS WEEK)</small>
                        <h3 class="mb-0 fw-bold">@summary.RejectedThisWeek</h3>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success alert-dismissible shadow-sm border-0">
            <i class="bi bi-check-circle-fill me-2"></i>@successMessage
            <button class="btn-close" @onclick="() => successMessage = null"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger alert-dismissible shadow-sm border-0">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@errorMessage
            <button class="btn-close" @onclick="() => errorMessage = null"></button>
        </div>
    }

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-3">
            <div class="row g-2 align-items-end">
                <div class="col-md-2">
                    <label class="form-label small text-muted mb-1">STATUS</label>
                    <select @bind="filter.Status" class="form-select form-select-sm">
                        <option value="">All Statuses</option>
                        <option value="@CorrectionStatuses.Pending">Pending</option>
                        <option value="@CorrectionStatuses.Approved">Approved</option>
                        <option value="@CorrectionStatuses.Rejected">Rejected</option>
                        <option value="@CorrectionStatuses.Cancelled">Cancelled</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small text-muted mb-1">CORRECTION TYPE</label>
                    <select @bind="filter.CorrectionType" class="form-select form-select-sm">
                        <option value="">All Types</option>
                        <option value="@CorrectionTypes.ForgotCheckIn">Forgot Check-In</option>
                        <option value="@CorrectionTypes.ForgotCheckOut">Forgot Check-Out</option>
                        <option value="@CorrectionTypes.WrongTime">Wrong Time</option>
                        <option value="@CorrectionTypes.AbsentButWorked">Absent but Worked</option>
                        <option value="@CorrectionTypes.OvertimeCorrection">OT Correction</option>
                        <option value="@CorrectionTypes.HrManualCorrection">HR Manual</option>
                    </select>
                </div>

                @if (isOrgAdmin)
                {
                    <div class="col-md-3">
                        <label class="form-label small text-muted mb-1">DEPARTMENT AREA</label>
                        <select @bind="selectedDepartmentId" class="form-select form-select-sm">
                            <option value="">All Organization Departments</option>
                            @foreach (var d in departments)
                            {
                                <option value="@d.DepartmentId">@d.Name</option>
                            }
                        </select>
                    </div>
                }

                <div class="col-md-2">
                    <label class="form-label small text-muted mb-1">SEARCH WORKER</label>
                    <input @bind="filter.SearchName" class="form-control form-control-sm" placeholder="Search by name or code..." />
                </div>
                <div class="col-md-2">
                    <button class="btn btn-primary btn-sm w-100" @onclick="ApplyFilter">
                        <i class="bi bi-funnel me-1"></i>Filter Queue
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            @if (isLoading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary"></div>
                </div>
            }
            else if (pagedResult?.Items == null || !pagedResult.Items.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-inbox fs-2 d-block mb-2 opacity-25"></i>
                    No correction records loaded matching your active access scope boundaries.
                </div>
            }
            else
            {
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 text-muted small fw-bold">EMPLOYEE DETAILS</th>
                            <th class="text-muted small fw-bold">WORK DATE</th>
                            <th class="text-muted small fw-bold">TYPE</th>
                            <th class="text-center text-muted small fw-bold">ORIGINAL ENTRIES</th>
                            <th class="text-center text-muted small fw-bold">REQUESTED ENTRIES</th>
                            <th class="text-muted small fw-bold">SUBMITTED TIMELINE</th>
                            <th class="text-muted small fw-bold">STATUS</th>
                            <th class="text-muted small fw-bold text-end pe-4">ACTIONS</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var req in pagedResult.Items)
                        {
                            <tr class="@(req.Status == CorrectionStatuses.Pending && IsOverdue(req.SubmittedAt) ? "table-warning" : "")">
                              <td class="ps-4">
    <div class="fw-semibold text-dark">@req.EmployeeName</div>
    <div class="small text-muted">
        @req.Department ·
        <span class="text-uppercase fw-bold text-secondary">
            @req.EmployeeCode
        </span>
    </div>
</td>

<td class="fw-semibold">
    @req.WorkDate.ToString("dd MMM yyyy")
</td>
<td>
                                    <span class="badge bg-light text-dark border fw-normal">
                                        @FormatType(req.CorrectionType)
                                    </span>
                                    @if (req.IsHrInitiated)
                                    {
                                        <span class="ms-1 badge bg-dark text-white" title="HR manual submission entry">HR INITIATED</span>
                                    }
                                </td>
                                <td class="text-center small">
                                    <div class="font-monospace text-muted">
                                        @FormatTime(req.OriginalCheckIn) → @FormatTime(req.OriginalCheckOut)
                                    </div>
                                    @if (!string.IsNullOrEmpty(req.OriginalStatus))
                                    {
                                        <span class="badge @GetAttendanceStatusClass(req.OriginalStatus) rounded-pill" style="font-size:.65rem">
                                            @req.OriginalStatus
                                        </span>
                                    }
                                </td>
                                <td class="text-center small">
                                    <div class="font-monospace fw-bold text-primary">
                                        @FormatTime(req.RequestedCheckIn) → @FormatTime(req.RequestedCheckOut)
                                    </div>
                                </td>
                                <td class="small text-muted">
                                    @{
                                        var localSubmittedAt = TimeZoneInfo.ConvertTimeFromUtc(req.SubmittedAt, orgTimeZone);
                                    }
                                    <div class="fw-semibold text-dark">@localSubmittedAt.ToString("dd MMM yyyy")</div>
                                    <div class="small text-secondary d-flex align-items-center">
                                        @localSubmittedAt.ToString("hh:mm tt")
                                        @if (req.Status == CorrectionStatuses.Pending && IsOverdue(req.SubmittedAt))
                                        {
                                            <span class="badge bg-danger ms-1 px-1 py-0" style="font-size: 0.65rem;" title="Overdue Item">! OVERDUE</span>
                                        }
                                    </div>
                                </td>
                                <td>
                                    <span class="badge rounded-pill @GetCorrectionStatusClass(req.Status)">
                                        @req.Status
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    @if (req.Status == CorrectionStatuses.Pending)
                                    {
                                        @if (isOrgAdmin && !req.CanOrgAdminReview)
                                        {
                                            <span class="badge bg-secondary" style="font-size: 0.75rem;">
                                                <i class="bi bi-clock-history me-1"></i>Awaiting HR Review
                                            </span>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-success me-1 shadow-sm" @onclick="() => OpenReviewModal(req, true)" title="Approve Changes">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                            <button class="btn btn-sm btn-danger shadow-sm" @onclick="() => OpenReviewModal(req, false)" title="Reject Changes">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted small italic">Processed by: @(req.ReviewedByName ?? "—")</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <div class="d-flex justify-content-between align-items-center px-4 py-3 border-top bg-light">
                    <small class="text-muted fw-semibold">
                        Displaying @pagedResult.Items.Count of @pagedResult.TotalCount structural entries
                    </small>
                    <div class="btn-group btn-group-sm shadow-sm">
                        <button class="btn btn-white text-dark border" disabled="@(!pagedResult.HasPreviousPage)" @onclick="PreviousPage">
                            ← Back
                        </button>
                        <span class="btn btn-white border disabled text-dark font-monospace fw-bold">
                            @pagedResult.Page / @pagedResult.TotalPages
                        </span>
                        <button class="btn btn-white text-dark border" disabled="@(!pagedResult.HasNextPage)" @onclick="NextPage">
                            Next →
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@if (reviewRequest != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5)">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header border-0 bg-light">
                    <h5 class="modal-title fw-bold text-dark">
                        @(reviewDto.Approve ? "Authorize and Approve" : "Reject and Dismiss") Record Adjustment
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseReviewModal" disabled="@isReviewing"></button>
                </div>
                <div class="modal-body p-4">
                    @if (!string.IsNullOrEmpty(reviewModalError))
                    {
                        <div class="alert alert-danger border-0 shadow-sm">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>@reviewModalError
                        </div>
                    }

                    <div class="mb-3 text-muted small fw-bold">
                        TARGET WORKER: <span class="text-dark">@reviewRequest.EmployeeName (@reviewRequest.EmployeeCode)</span> | DATE: <span class="text-dark">@reviewRequest.WorkDate.ToString("dd MMMM yyyy")</span>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded border">
                                <div class="small text-muted fw-bold mb-2 text-uppercase">Original System Metrics</div>
                                <div class="font-monospace text-secondary">
                                    IN:  @FormatTime(reviewRequest.OriginalCheckIn)<br />
                                    OUT: @FormatTime(reviewRequest.OriginalCheckOut)
                                </div>
                                <span class="badge @GetAttendanceStatusClass(reviewRequest.OriginalStatus) mt-2">
                                    @(reviewRequest.OriginalStatus ?? "No System Records")
                                </span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded border border-primary">
                                <div class="small text-primary fw-bold mb-2 text-uppercase">Proposed Overwrite Times</div>
                                <div class="font-monospace text-dark fw-bold">
                                    IN:  @FormatTime(reviewRequest.RequestedCheckIn)<br />
                                    OUT: @FormatTime(reviewRequest.RequestedCheckOut)
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3 p-3 bg-light rounded border-start border-3 border-info">
                        <div class="small text-muted fw-bold mb-1">SUBMISSION STATEMENT REASON</div>
                        <p class="mb-0 text-dark italic">"@reviewRequest.Reason"</p>
                    </div>

                    @if (reviewDto.Approve)
                    {
                        <div class="alert alert-info border-0 small mb-3 shadow-sm">
                            <i class="bi bi-info-circle-fill me-2"></i>
                            Leave clear if accepting requested entries exactly as submitted. Input data fields only to force system-level overrides.
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label small fw-semibold">Administrative Check-In Override</label>
                                <input type="text" class="form-control" placeholder="e.g. 09:30 AM or 14:00" @bind="hrOverrideCheckInText" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-semibold">Administrative Check-Out Override</label>
                                <input type="text" class="form-control" placeholder="e.g. 06:00 PM or 22:30" @bind="hrOverrideCheckOutText" />
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="mb-3">
                            <label class="form-label fw-semibold text-danger">Reason for Denial *</label>
                            <textarea @bind="reviewDto.RejectionReason" class="form-control" rows="2" placeholder="Provide reason detailing why request was denied..."></textarea>
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Administrative Notes (Internal Audit Log)</label>
                        <textarea @bind="reviewDto.HrNote" class="form-control" rows="2" placeholder="Optional notes visible within management layers..."></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 bg-light">
                    <button class="btn btn-outline-secondary btn-sm px-3" @onclick="CloseReviewModal" disabled="@isReviewing">
                        Dismiss
                    </button>
                    <button class="btn @(reviewDto.Approve ? "btn-success" : "btn-danger") btn-sm px-4 shadow-sm" @onclick="HandleReview" disabled="@isReviewing">
                        @if (isReviewing)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        @(reviewDto.Approve ? "Confirm Authorization" : "Confirm Rejection")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (showManualModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5)">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header border-0 bg-light">
                    <h5 class="modal-title fw-bold text-dark">Submit Manual Adjustment Logs</h5>
                    <button type="button" class="btn-close" @onclick="CloseManualModal" disabled="@isManualSubmitting"></button>
                </div>
                <div class="modal-body p-4">
                    @if (!string.IsNullOrEmpty(manualModalError))
                    {
                        <div class="alert alert-danger border-0 shadow-sm">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>@manualModalError
                        </div>
                    }
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Target Employee Profile <span class="text-danger">*</span></label>
                        <select @bind="manualDto.EmployeeId" class="form-select">
                            <option value="">— Select Target Employee Account —</option>
                            @foreach (var emp in employees)
                            {
                                <option value="@emp.EmployeeId">@emp.FullName (@emp.EmployeeCode)</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Target Shift Work Date <span class="text-danger">*</span></label>
                        <InputDate @bind-Value="manualDto.WorkDate" class="form-control" />
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label fw-semibold">Adjustment Check-In Time</label>
                                <input type="text" class="form-control" placeholder="e.g. 09:30 AM or 13:00" @bind="manualCheckInText" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label fw-semibold">Adjustment Check-Out Time</label>
                                <input type="text" class="form-control" placeholder="e.g. 06:30 PM or 18:00" @bind="manualCheckOutText" />
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Justification Statement / Audit Log Note <span class="text-danger">*</span></label>
                        <textarea @bind="manualDto.HrNote" class="form-control" rows="3" placeholder="Provide justification explanation details for manual entry insertions..."></textarea>
                    </div>
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" @bind="manualDto.AutoApply" id="autoApply" />
                        <label class="form-check-label fw-semibold" for="autoApply">
                            Commit and Auto-Approve Immediately
                        </label>
                        <div class="form-text text-muted">
                            When bypassed, entry parameters are tracked as pending until another admin executes structural clearance verification.
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 bg-light">
                    <button class="btn btn-outline-secondary btn-sm px-3" @onclick="CloseManualModal" disabled="@isManualSubmitting">
                        Cancel
                    </button>
                    <button class="btn btn-primary btn-sm px-4 shadow-sm" style="background:#5c4ac7;border:none;" @onclick="HandleManualCorrection" disabled="@isManualSubmitting">
                        @if (isManualSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Commit Adjustment Logs
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private PagedResult<CorrectionRequestListDto> pagedResult = new();
    private CorrectionQueueSummaryDto? summary;
    private List<DepartmentListItem> departments = new();
    private Guid? selectedDepartmentId;
    private List<EmployeeListItem> employees = new();
    private CorrectionQueueFilterDto filter = new() { Status = CorrectionStatuses.Pending, Page = 1, PageSize = 25 };
    private bool isLoading;
    private string? successMessage;
    private string? errorMessage;
    private TimeZoneInfo orgTimeZone = TimeZoneInfo.Utc;
    private string? hrOverrideCheckInText;
    private string? hrOverrideCheckOutText;
    private string? manualCheckInText;
    private string? manualCheckOutText;
    private bool isHr;
    private bool isOrgAdmin;

    private CorrectionRequestListDto? reviewRequest;
    private ReviewCorrectionDto reviewDto = new();
    private TimeOnly? hrOverrideCheckInTime;
    private TimeOnly? hrOverrideCheckOutTime;
    private bool isReviewing;
    private string? reviewModalError;
    private bool showManualModal;
    private HrManualCorrectionDto manualDto = new() { AutoApply = true };
    private bool isManualSubmitting;
    private string? manualModalError;

    private record DepartmentListItem(Guid DepartmentId, string Name);
    private record EmployeeListItem(Guid EmployeeId, string FullName, string EmployeeCode);

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        isHr = user.IsInRole("HR");
        isOrgAdmin = user.IsInRole("OrgAdmin");

        await LoadOrgTimezone();
        await LoadDropdownsAsync();
        await LoadAll();
    }

    private static DateTime? ParseUserDateTime(DateTime baseDate, string? input)
    {
        if (string.IsNullOrWhiteSpace(input)) return null;
        input = input.Trim().Replace(".", ":").ToUpperInvariant();
        string[] formats = { "h:mm tt", "hh:mm tt", "h:mmtt", "hh:mmtt", "H:mm", "HH:mm" };
        if (DateTime.TryParseExact(input, formats, CultureInfo.InvariantCulture, DateTimeStyles.None, out var parsed))
        {
            return DateTime.SpecifyKind(baseDate.Date.Add(parsed.TimeOfDay), DateTimeKind.Unspecified);
        }
        return null;
    }

    private async Task LoadOrgTimezone()
    {
        try
        {
            var user = await CurrentUserService.GetUserAsync();
            if (user?.OrganizationId == null) return;

            await using var db = await DbFactory.CreateDbContextAsync();
            var tzId = await db.Organizations
                .AsNoTracking()
                .Where(o => o.OrganizationId == user.OrganizationId)
                .Select(o => o.TimeZoneId)
                .FirstOrDefaultAsync();
            orgTimeZone = TimeHelper.GetOrgTimeZone(tzId);
        }
        catch
        {
            orgTimeZone = TimeZoneInfo.Utc;
        }
    }

    private async Task LoadDropdownsAsync()
    {
        try
        {
            var user = await CurrentUserService.GetUserAsync();
            if (user?.OrganizationId == null) return;
            var orgId = user.OrganizationId.Value;
            await using var db = await DbFactory.CreateDbContextAsync();

            var currentEmp = await db.Employees.AsNoTracking().FirstOrDefaultAsync(e => e.UserId == user.Id);

            // Populating department dropdown list
            if (isOrgAdmin)
            {
                departments = await db.Departments
                    .AsNoTracking()
                    .Where(d => d.OrganizationId == orgId)
                    .OrderBy(d => d.Name)
                    .Select(d => new DepartmentListItem(d.DepartmentId, d.Name))
                    .ToListAsync();
            }

            // Populate actionable employee lists contextually
            var empQuery = db.Employees.AsNoTracking().Where(e => e.OrganizationId == orgId && e.Status == "Active");
            if (!isOrgAdmin && isHr && currentEmp != null)
            {
                empQuery = empQuery.Where(e => e.DepartmentId == currentEmp.DepartmentId && e.EmployeeId != currentEmp.EmployeeId);
            }

            employees = await empQuery
                .OrderBy(e => e.FirstName)
                .Select(e => new EmployeeListItem(e.EmployeeId, e.FirstName + " " + e.LastName, e.EmployeeCode))
                .ToListAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load lookup items: {ex.Message}";
        }
    }

    private async Task LoadAll()
    {
        isLoading = true;
        errorMessage = null;
        filter.DepartmentId = selectedDepartmentId == Guid.Empty ? null : selectedDepartmentId;

        try
        {
            summary = await CorrectionService.GetQueueSummaryAsync();
            pagedResult = await CorrectionService.GetHrQueueAsync(filter);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ApplyFilter()
    {
        filter.Page = 1;
        await LoadAll();
    }

    private async Task PreviousPage()
    {
        if (pagedResult.HasPreviousPage)
        {
            filter.Page--;
            await LoadAll();
        }
    }

    private async Task NextPage()
    {
        if (pagedResult.HasNextPage)
        {
            filter.Page++;
            await LoadAll();
        }
    }

