        border: 1px solid #eceff4;
    }

    .modal-content {
        border-radius: 18px;
    }

</style>

@code {

    private List<CorrectionRequestDto> requests = new();

    private readonly string[] Filters =
    [
        "",
        "Pending",
        "Approved",
        "Rejected",
        "Cancelled"
    ];

    private string selectedStatus = "Pending";

    private bool isLoading;
    private bool actionLoading;
    private bool isError;

    private string orgTimeZone = "India Standard Time";

    private string? message;

    private bool showRejectModal;

    private CorrectionRequestDto? rejectTarget;

    private string rejectReason = string.Empty;

    private string? rejectError;


    private IEnumerable<CorrectionRequestDto> FilteredRequests =>
        string.IsNullOrWhiteSpace(selectedStatus)
            ? requests
            : requests.Where(r => r.Status == selectedStatus);


    protected override async Task OnInitializedAsync()
    {
        orgTimeZone =
            await CorrectionService.GetCurrentOrganizationTimeZoneAsync();

        await LoadData();
    }


    private async Task LoadData()
    {
        try
        {
            isLoading = true;

            isError = false;

            message = null;

            requests =
                await CorrectionService.GetAllForHRAsync();
        }
        catch (Exception ex)
        {
            isError = true;

            message = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }


    private void ChangeFilter(string status)
    {
        selectedStatus = status;
    }


    private async Task Approve(Guid requestId)
    {
        try
        {
            actionLoading = true;

            isError = false;

            message = null;

            await CorrectionService.ReviewRequestAsync(
                new ReviewCorrectionDto
                {
                    CorrectionRequestId = requestId,
                    Approve = true
                });

            message =
                "Attendance correction approved successfully.";

            await LoadData();
        }
        catch (Exception ex)
        {
            isError = true;

            message = ex.Message;
        }
        finally
        {
            actionLoading = false;
        }
    }


    private void OpenRejectModal(CorrectionRequestDto request)
    {
        rejectTarget = request;

        rejectReason = string.Empty;

        rejectError = null;

        showRejectModal = true;
    }

    private void CloseRejectModal()
    {
        showRejectModal = false;

        rejectTarget = null;

        rejectReason = string.Empty;

        rejectError = null;
    }

    private async Task ConfirmReject()
    {
        if (rejectTarget == null)
            return;

        if (string.IsNullOrWhiteSpace(rejectReason))
        {
            rejectError =
                "Please provide rejection reason.";

            return;
        }

        try
        {
            actionLoading = true;

            rejectError = null;

            isError = false;

            await CorrectionService.ReviewRequestAsync(
                new ReviewCorrectionDto
                {
                    CorrectionRequestId =
                        rejectTarget.CorrectionRequestId,

                    Approve = false,

                    RejectionReason =
                        rejectReason.Trim()
                });

            message =
                "Attendance correction request rejected.";

            CloseRejectModal();

            await LoadData();
        }
        catch (Exception ex)
        {
            isError = true;

            rejectError = ex.Message;
        }
        finally
        {
            actionLoading = false;
        }
    }


    private string FormatOrgTime(DateTime? utc)
    {
        if (!utc.HasValue)
            return "--:--";

        try
        {
            var tz =
                TimeZoneInfo.FindSystemTimeZoneById(orgTimeZone);

            var local =
                TimeZoneInfo.ConvertTimeFromUtc(
                    DateTime.SpecifyKind(
                        utc.Value,
                        DateTimeKind.Utc),
                    tz);

            return local.ToString("hh:mm tt");
        }
        catch
        {
            return utc.Value.ToString("hh:mm tt");
        }
    }

    private string FormatOrgDateTime(DateTime? utc)
    {
        if (!utc.HasValue)
            return "--";

        try
        {
            var tz =
                TimeZoneInfo.FindSystemTimeZoneById(orgTimeZone);

            var local =
                TimeZoneInfo.ConvertTimeFromUtc(
                    DateTime.SpecifyKind(
                        utc.Value,
                        DateTimeKind.Utc),
                    tz);

            return local.ToString("dd MMM yyyy hh:mm tt");
        }
        catch
        {
            return utc.Value
                .ToString("dd MMM yyyy hh:mm tt");
        }
    }


    private void ClearMessage()
    {
        message = null;
    }

    private string GetStatusClass(string status) => status switch
    {
        "Approved" => "bg-success",
        "Rejected" => "bg-danger",
        "Cancelled" => "bg-secondary",
        "Pending" => "bg-warning text-dark",
        _ => "bg-dark"
    };

}