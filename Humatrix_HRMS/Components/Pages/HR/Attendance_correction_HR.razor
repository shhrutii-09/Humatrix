    }

    .custom-card {
        background: #fff;
        border: 1px solid #e8ebf0;
        border-radius: 16px;
        box-shadow: 0 4px 14px rgba(0,0,0,.04);
    }

    .stats-card {
        background: #fff;
        border-radius: 16px;
        padding: 20px;
        border: 1px solid #eceff3;
        box-shadow: 0 3px 10px rgba(0,0,0,.04);
        border-left: 4px solid #dee2e6;
    }

    .pending-card {
        border-left-color: #ffc107;
    }

    .approved-card {
        border-left-color: #198754;
    }

    .rejected-card {
        border-left-color: #dc3545;
    }

    .total-card {
        border-left-color: #5c4ac7;
    }

    .stats-label {
        font-size: .72rem;
        text-transform: uppercase;
        font-weight: 700;
        color: #6c757d;
        letter-spacing: .7px;
        margin-bottom: 8px;
    }

    .stats-value {
        font-size: 2rem;
        font-weight: 700;
        line-height: 1;
    }

    .filter-btn {
        border-radius: 30px;
        padding: .45rem .95rem;
        font-weight: 600;
    }

    .active-filter {
        background: #5c4ac7 !important;
        color: white !important;
        border-color: #5c4ac7 !important;
    }

    .table-custom thead th {
        background: #fcfcfd;
        color: #6c757d;
        font-size: .72rem;
        letter-spacing: .7px;
        font-weight: 700;
        padding: 15px 10px;
        border-bottom: 1px solid #ececec;
