@code {
    private PagedResult<CorrectionRequestListDto> pagedResult = new();
    private CorrectionQueueSummaryDto? summary;
    private List<DepartmentListItem> departments = new();
    private Guid? selectedDepartmentId;
    private List<EmployeeListItem> employees = new();
    private CorrectionQueueFilterDto filter = new() { Status = CorrectionStatuses.Pending, Page = 1, PageSize = 25 };
    private bool isLoading;
    private string? message;
    private bool isError;
    private TimeZoneInfo orgTimeZone = TimeZoneInfo.Utc;
    private string? hrOverrideCheckInText;
    private string? hrOverrideCheckOutText;
    private string? manualCheckInText;
    private string? manualCheckOutText;
    private bool isHr;
    private bool isOrgAdmin;
    private string dashboardPath = "/";
    private System.Timers.Timer? _debounceTimer;

    private CorrectionRequestListDto? reviewRequest;
    private ReviewCorrectionDto reviewDto = new();
    private bool isReviewing;
    private string? reviewModalError;
    private bool showManualModal;
    private HrManualCorrectionDto manualDto = new() { AutoApply = true, WorkDate = DateTime.Today };
    private bool isManualSubmitting;
    private string? manualModalError;

    private record DepartmentListItem(Guid DepartmentId, string Name);
    private record EmployeeListItem(Guid EmployeeId, string FullName, string EmployeeCode);

    protected override async Task OnInitializedAsync()
    {
        var user = await CurrentUserService.GetUserAsync();
        if (user != null)
        {
            using var db = await DbFactory.CreateDbContextAsync();
            var userRoles = await db.UserRoles
                .Where(ur => ur.UserId == user.Id)
                .Join(db.Roles, ur => ur.RoleId, r => r.Id, (ur, r) => r.Name.ToLower())
                .ToListAsync();

            isOrgAdmin = userRoles.Contains("orgadmin");
            isHr = userRoles.Contains("hr");
            dashboardPath = isOrgAdmin ? "/org/dashboard" : "/hr/dashboard";
        }

        await LoadOrgTimezone();
        await LoadDropdownsAsync();
        await LoadAll();
    }

    private async Task OnFilterChanged()
    {
        _debounceTimer?.Dispose();
        _debounceTimer = new System.Timers.Timer(400);
        _debounceTimer.Elapsed += async (_, _) =>
        {
            _debounceTimer?.Dispose();
            await InvokeAsync(async () =>
            {
                filter.Page = 1;
                await LoadAll();
                StateHasChanged();
            });
        };
        _debounceTimer.AutoReset = false;
        _debounceTimer.Start();
    }

    private static DateTime? ParseUserDateTime(DateTime baseDate, string? input)
    {
        if (string.IsNullOrWhiteSpace(input)) return null;
        input = input.Trim().Replace(".", ":").ToUpperInvariant();
        string[] formats = { "h:mm tt", "hh:mm tt", "h:mmtt", "hh:mmtt", "H:mm", "HH:mm" };
        if (DateTime.TryParseExact(input, formats, CultureInfo.InvariantCulture, DateTimeStyles.None, out var parsed))
        {
            return DateTime.SpecifyKind(baseDate.Date.Add(parsed.TimeOfDay), DateTimeKind.Unspecified);
        }
        return null;
    }

    private async Task LoadOrgTimezone()
    {
        try
        {
            var user = await CurrentUserService.GetUserAsync();
            if (user?.OrganizationId == null) return;

            await using var db = await DbFactory.CreateDbContextAsync();
            var tzId = await db.Organizations
                .AsNoTracking()
                .Where(o => o.OrganizationId == user.OrganizationId)
                .Select(o => o.TimeZoneId)
                .FirstOrDefaultAsync();
            orgTimeZone = TimeHelper.GetOrgTimeZone(tzId);
            StateHasChanged(); // ✅ FORCE UI REFRESH
        }
        catch
        {
            orgTimeZone = TimeZoneInfo.Utc;
        }
    }

    private async Task LoadDropdownsAsync()
    {
        try
        {
            var user = await CurrentUserService.GetUserAsync();
            if (user?.OrganizationId == null) return;
            var orgId = user.OrganizationId.Value;
            await using var db = await DbFactory.CreateDbContextAsync();

            var currentEmp = await db.Employees.AsNoTracking().FirstOrDefaultAsync(e => e.UserId == user.Id);

            if (isOrgAdmin)
            {
                departments = await db.Departments
                    .AsNoTracking()
                    .Where(d => d.OrganizationId == orgId)
                    .OrderBy(d => d.Name)
                    .Select(d => new DepartmentListItem(d.DepartmentId, d.Name))
                    .ToListAsync();
            }

            var empQuery = db.Employees.AsNoTracking().Where(e => e.OrganizationId == orgId && e.Status == "Active");
            if (!isOrgAdmin && isHr && currentEmp != null)
            {
                empQuery = empQuery.Where(e => e.DepartmentId == currentEmp.DepartmentId && e.EmployeeId != currentEmp.EmployeeId);
            }

            employees = await empQuery
                .OrderBy(e => e.FirstName)
                .Select(e => new EmployeeListItem(e.EmployeeId, e.FirstName + " " + e.LastName, e.EmployeeCode))
                .ToListAsync();
        }
        catch (Exception ex)
        {
            message = ex.Message;
            isError = true;
            TriggerAutoClose();
        }
    }

    private async Task LoadAll()
    {
        isLoading = true;
        isError = false;
        filter.DepartmentId = selectedDepartmentId == Guid.Empty ? null : selectedDepartmentId;

        try
        {
            summary = await CorrectionService.GetQueueSummaryAsync();
            pagedResult = await CorrectionService.GetHrQueueAsync(filter);
        }
        catch (Exception ex)
        {
            message = ex.Message;
            isError = true;
            TriggerAutoClose();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task PreviousPage()
    {
        if (pagedResult.HasPreviousPage)
        {
            filter.Page--;
            await LoadAll();
        }
    }

    private async Task NextPage()
    {
        if (pagedResult.HasNextPage)
        {
            filter.Page++;
            await LoadAll();
        }
    }

    private void OpenReviewModal(CorrectionRequestListDto req, bool approve)
    {
        reviewRequest = req;
        reviewDto = new ReviewCorrectionDto
        {
            AttendanceCorrectionRequestId = req.AttendanceCorrectionRequestId,
            Approve = approve,
            RejectionReason = "",
            HrNote = ""
        };
        hrOverrideCheckInText = null;
        hrOverrideCheckOutText = null;
        reviewModalError = null;
    }

    private void CloseReviewModal()
    {
        reviewRequest = null;
        reviewModalError = null;
    }

    private async Task HandleReview()
    {
        if (reviewRequest == null) return;
        reviewModalError = null;

        if (!reviewDto.Approve && string.IsNullOrWhiteSpace(reviewDto.RejectionReason))
        {
            reviewModalError = "Please provide a reason for rejection.";
            return;
        }

        reviewDto.HrOverrideCheckIn = ParseUserDateTime(reviewRequest.WorkDate, hrOverrideCheckInText);
        reviewDto.HrOverrideCheckOut = ParseUserDateTime(reviewRequest.WorkDate, hrOverrideCheckOutText);

        isReviewing = true;
        try
        {
            await CorrectionService.ReviewAsync(reviewDto);
            message = reviewDto.Approve ? "Correction request approved successfully." : "Correction request rejected.";
            isError = false;
            CloseReviewModal();
            await LoadAll();
            TriggerAutoClose();
        }
        catch (Exception ex)
        {
            reviewModalError = ex.Message;
        }
        finally
        {
            isReviewing = false;
        }
    }

    private void CloseManualModal()
    {
        showManualModal = false;
        manualDto = new HrManualCorrectionDto { AutoApply = true, WorkDate = DateTime.Today };
        manualCheckInText = null;
        manualCheckOutText = null;
        manualModalError = null;
    }

    private async Task HandleManualCorrection()
    {
        manualModalError = null;

        if (manualDto.EmployeeId == Guid.Empty)
        {
            manualModalError = "Please select a target employee.";
            return;
        }
        if (string.IsNullOrWhiteSpace(manualDto.HrNote))
        {
            manualModalError = "Please provide justification for this manual correction.";
            return;
        }

        manualDto.NewCheckIn = ParseUserDateTime(manualDto.WorkDate, manualCheckInText);
        manualDto.NewCheckOut = ParseUserDateTime(manualDto.WorkDate, manualCheckOutText);

        if (manualDto.NewCheckIn == null && manualDto.NewCheckOut == null)
        {
            manualModalError = "Please enter at least one valid time (Check-In or Check-Out).";
            return;
        }

        isManualSubmitting = true;
        try
        {
            await CorrectionService.HrManualCorrectionAsync(manualDto);
            message = "Manual correction submitted successfully.";
            isError = false;
            CloseManualModal();
            await LoadAll();
            TriggerAutoClose();
        }
        catch (Exception ex)
        {
            manualModalError = ex.Message;
        }
        finally
        {
            isManualSubmitting = false;
        }
    }

    private string FormatTime(DateTime? utcTime)
    {
        if (!utcTime.HasValue) return "—";
        try
        {
            var localTime = TimeZoneInfo.ConvertTimeFromUtc(utcTime.Value, orgTimeZone);
            return localTime.ToString("hh:mm tt");
        }
        catch
        {
            return utcTime.Value.ToString("hh:mm tt");
        }
    }
    private static bool IsOverdue(DateTime submittedAt) => (DateTime.UtcNow - submittedAt).TotalDays >= 2;

    private static string FormatType(string type) => type switch
    {
        CorrectionTypes.ForgotCheckIn => "Forgot In",
        CorrectionTypes.ForgotCheckOut => "Forgot Out",
        CorrectionTypes.WrongTime => "Wrong Time",
        CorrectionTypes.AbsentButWorked => "Absent But Worked",
        CorrectionTypes.OvertimeCorrection => "OT Correction",
        CorrectionTypes.HrManualCorrection => "HR Manual",
        _ => type
    };

    private static string GetAttendanceStatusClass(string? status) => status switch
    {
        "Present" => "bg-success-soft text-success",
        "Late" => "bg-warning-soft text-warning",
        "Absent" => "bg-danger-soft text-danger",
        "WorkFromHome" => "bg-info-soft text-info",
        _ => "bg-secondary-soft text-secondary"
    };

    private static string GetCorrectionStatusClass(string? status) => status switch
    {
        CorrectionStatuses.Pending => "bg-warning-soft text-warning",
        CorrectionStatuses.Approved => "bg-success-soft text-success",
        CorrectionStatuses.Rejected => "bg-danger-soft text-danger",
        CorrectionStatuses.Cancelled => "bg-secondary-soft text-secondary",
        _ => "bg-light text-dark border"
    };

    private void TriggerAutoClose()
    {
        _ = Task.Run(async () =>
        {
            await Task.Delay(4000);
            message = null;
            await InvokeAsync(StateHasChanged);
        });
    }
}