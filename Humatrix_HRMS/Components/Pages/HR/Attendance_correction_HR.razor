    private async Task HandleReview()
    {
        if (reviewRequest == null) return;
        reviewModalError = null;

        if (!reviewDto.Approve && string.IsNullOrWhiteSpace(reviewDto.RejectionReason))
        {
            reviewModalError = "Rejection explanation reason is mandatory.";
            return;
        }

        reviewDto.HrOverrideCheckIn = ParseUserDateTime(reviewRequest.WorkDate, hrOverrideCheckInText);
        reviewDto.HrOverrideCheckOut = ParseUserDateTime(reviewRequest.WorkDate, hrOverrideCheckOutText);

        isReviewing = true;
        try
        {
            // ✅ 1. Call the method directly without assigning it to a variable
            await CorrectionService.ReviewAsync(reviewDto);

            // ✅ 2. If no exception was thrown, it executed cleanly. Handle success states here.
            successMessage = "Correction adjustments applied successfully.";
            CloseReviewModal();
            await LoadAll();
        }
        catch (Exception ex)
        {
            // Business validation exceptions thrown from your engine will end up here
            reviewModalError = ex.Message;
        }
        finally
        {
            isReviewing = false;
        }
    }

    private void CloseManualModal()
    {
        showManualModal = false;
        manualDto = new HrManualCorrectionDto { AutoApply = true };
        manualCheckInText = null;
        manualCheckOutText = null;
        manualModalError = null;
    }

    private async Task HandleManualCorrection()
    {
        manualModalError = null;

        if (manualDto.EmployeeId == Guid.Empty)
        {
            manualModalError = "Target Employee selection field is required.";
            return;
        }
        if (string.IsNullOrWhiteSpace(manualDto.HrNote))
        {
            manualModalError = "Justification text statement explanation is mandatory.";
            return;
        }

        var checkInParsed = ParseUserDateTime(manualDto.WorkDate, manualCheckInText);
        var checkOutParsed = ParseUserDateTime(manualDto.WorkDate, manualCheckOutText);

        if (checkInParsed == null && checkOutParsed == null)
        {
            manualModalError = "Input at least one valid check time specification parameter.";
            return;
        }

        // manualDto.NewCheckIn = checkInParsed.HasValue ? TimeOnly.FromDateTime(checkInParsed.Value) : null;
        // manualDto.NewCheckOut = checkOutParsed.HasValue ? TimeOnly.FromDateTime(checkOutParsed.Value) : null;
        
        manualDto.NewCheckIn = ParseUserDateTime(manualDto.WorkDate, manualCheckInText);
        manualDto.NewCheckOut = ParseUserDateTime(manualDto.WorkDate, manualCheckOutText);

        try
        {
            await CorrectionService.HrManualCorrectionAsync(manualDto);
            successMessage = "Manual tracking transaction adjustments stored successfully.";
            CloseManualModal();
            await LoadAll();
        }
        catch (Exception ex)
        {
            manualModalError = ex.Message;
        }
        finally
        {
            isManualSubmitting = false;
        }
    }

