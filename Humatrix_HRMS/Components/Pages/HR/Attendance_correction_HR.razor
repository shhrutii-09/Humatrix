@page "/hr/corrections"
@rendermode InteractiveServer

@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Helpers
@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Humatrix_HRMS.Data
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using System.Globalization
@attribute [Authorize(Roles = "HR,OrgAdmin")]

@inject AttendanceCorrectionService CorrectionService
@inject DepartmentService DeptService
@inject NavigationManager Nav
@inject CurrentUserService CurrentUserService
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Correction Desk | Humatrix HRMS</PageTitle>

@* Toast Notification Container *@
<div class="position-fixed top-0 end-0 p-3" style="z-index: 1080;">
    @if (!string.IsNullOrEmpty(message))
    {
        <div class="toast show align-items-center border-0 shadow-lg mb-2" role="alert" style="background-color: @(isError ? "#fef2f2" : "#f0fdf4"); color: @(isError ? "#991b1b" : "#166534"); border-left: 4px solid @(isError ? "#ef4444" : "#10b981") !important; border-radius: 10px;">
            <div class="d-flex p-3">
                <div class="toast-body d-flex align-items-center p-0">
                    <i class="bi @(isError ? "bi-exclamation-triangle-fill" : "bi-check-circle-fill") me-2 fs-5"></i>
                    <span class="small fw-medium">@message</span>
                </div>
                <button type="button" class="btn-close m-auto me-0 shadow-none" @onclick="() => message = null"></button>
            </div>
        </div>
    }
</div>

<div class="container-fluid px-4 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom row-gap-3 flex-wrap">
        <div>
            <h2 class="fw-bold tracking-tight text-dark mb-1">Attendance Correction Desk</h2>
            @* @if (isOrgAdmin)
            {
                <span class="badge bg-danger mt-1 me-2">OrgAdmin Privilege Mode</span>
                <span class="text-muted small">You can view all organizational requests, including those submitted by HR teams.</span>
            }
            else
            {
                <span class="badge bg-primary mt-1 me-2">Department HR Mode</span>
                <span class="text-muted small">Managing requests from standard employees within your assigned department branch.</span>
            } *@
        </div>
        <div class="d-flex gap-2">
            @if (isHr)
            {
                <button class="btn btn-add-task d-flex align-items-center gap-2 shadow-sm" @onclick="() => showManualModal = true">
                    <i class="bi bi-pencil-square"></i> MANUAL CORRECTION
                </button>
            }
            <button class="btn btn-interactive-back shadow-sm d-flex align-items-center gap-2" @onclick='() => Nav.NavigateTo(dashboardPath)'>
                <i class="bi bi-speedometer2"></i> DASHBOARD
            </button>
        </div>
    </div>

    @* Metrics Section *@
    @if (summary != null)
    {
        <div class="row g-3 mb-4">
            <div class="col-md-3 col-sm-6">
                <div class="card border-0 shadow-sm metric-panel-card" style="border-left: 4px solid #ffc107 !important;">
                    <div class="card-body d-flex align-items-center justify-content-between p-3">
                        <div>
                            <span class="text-secondary small fw-bold tracking-wider text-uppercase d-block mb-1">Pending Action</span>
                            <h3 class="fw-bold text-dark mb-0">@summary.TotalPending</h3>
                        </div>
                        <div class="metric-icon-box" style="background-color: rgba(255, 193, 7, 0.08); color: #ffc107;">
                            <i class="bi bi-clock-history"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="card border-0 shadow-sm metric-panel-card" style="border-left: 4px solid #dc3545 !important;">
                    <div class="card-body d-flex align-items-center justify-content-between p-3">
                        <div>
                            <span class="text-secondary small fw-bold tracking-wider text-uppercase d-block mb-1">Overdue (2+ Days)</span>
                            <h3 class="fw-bold text-dark mb-0">@summary.PendingOlderThan2Days</h3>
                        </div>
                        <div class="metric-icon-box" style="background-color: rgba(220, 53, 69, 0.08); color: #dc3545;">
                            <i class="bi bi-exclamation-triangle"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="card border-0 shadow-sm metric-panel-card" style="border-left: 4px solid #10b981 !important;">
                    <div class="card-body d-flex align-items-center justify-content-between p-3">
                        <div>
                            <span class="text-secondary small fw-bold tracking-wider text-uppercase d-block mb-1">Approved (This Week)</span>
                            <h3 class="fw-bold text-dark mb-0">@summary.ApprovedThisWeek</h3>
                        </div>
                        <div class="metric-icon-box" style="background-color: rgba(16, 185, 129, 0.08); color: #10b981;">
                            <i class="bi bi-check-lg"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="card border-0 shadow-sm metric-panel-card" style="border-left: 4px solid #6c757d !important;">
                    <div class="card-body d-flex align-items-center justify-content-between p-3">
                        <div>
                            <span class="text-secondary small fw-bold tracking-wider text-uppercase d-block mb-1">Rejected (This Week)</span>
                            <h3 class="fw-bold text-dark mb-0">@summary.RejectedThisWeek</h3>
                        </div>
                        <div class="metric-icon-box" style="background-color: rgba(108, 117, 125, 0.08); color: #6c757d;">
                            <i class="bi bi-x-lg"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    @* Filters Section - Auto-refresh on change *@
    <div class="card border-0 shadow-sm p-3 mb-4 bg-light-gradient">
        <div class="row g-3 align-items-center">
            <div class="col-12 col-md-3">
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-search"></i></span>
                    <input class="form-control border-start-0 ps-0 text-input" placeholder="Search employee or code..." @bind="filter.SearchName" @bind:event="oninput" @bind:after="OnFilterChanged" />
                </div>
            </div>
            <div class="col-6 col-md-2">
                <select class="form-select custom-select" @bind="filter.Status" @bind:after="OnFilterChanged">
                    <option value="">All Statuses</option>
                    <option value="@CorrectionStatuses.Pending">Pending</option>
                    <option value="@CorrectionStatuses.Approved">Approved</option>
                    <option value="@CorrectionStatuses.Rejected">Rejected</option>
                    <option value="@CorrectionStatuses.Cancelled">Cancelled</option>
                </select>
            </div>
            <div class="col-6 col-md-2">
                <select class="form-select custom-select" @bind="filter.CorrectionType" @bind:after="OnFilterChanged">
                    <option value="">All Types</option>
                    <option value="@CorrectionTypes.ForgotCheckIn">Forgot Check-In</option>
                    <option value="@CorrectionTypes.ForgotCheckOut">Forgot Check-Out</option>
                    <option value="@CorrectionTypes.WrongTime">Wrong Time</option>
                    <option value="@CorrectionTypes.AbsentButWorked">Absent But Worked</option>
                    <option value="@CorrectionTypes.OvertimeCorrection">OT Correction</option>
                    <option value="@CorrectionTypes.HrManualCorrection">HR Manual</option>
                </select>
            </div>
            @if (isOrgAdmin)
            {
                <div class="col-6 col-md-3">
                    <select class="form-select custom-select" @bind="selectedDepartmentId" @bind:after="OnFilterChanged">
                        <option value="">All Organization Departments</option>
                        @foreach (var d in departments)
                        {
                            <option value="@d.DepartmentId">@d.Name</option>
                        }
                    </select>
                </div>
            }
        </div>
    </div>

    @* Main Table *@
    <div class="card border-0 shadow-sm overflow-hidden mb-5">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 custom-table">
                <thead>
                    <tr>
                        <th class="ps-4">Employee / Department</th>
                        @if (isOrgAdmin)
                        {
                            <th>Requested By</th>
                        }
                        <th>Work Date</th>
                        <th>Type</th>
                        <th>Original Records</th>
                        <th>Requested Records</th>
                        <th>Submitted On</th>
                        <th>Status</th>
                        <th class="pe-4 text-end">Actions / Reviewer</th>
                    </tr>
                </thead>
                <tbody>
                    @if (isLoading)
                    {
                        <tr>
                            <td colspan="@(isOrgAdmin ? 9 : 8)" class="text-center py-5">
                                <div class="spinner-border text-primary" role="status"></div>
                            </td>
                        </tr>
                    }
                    else if (pagedResult?.Items == null || !pagedResult.Items.Any())
                    {
                        <tr>
                            <td colspan="@(isOrgAdmin ? 9 : 8)" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox fs-2 d-block mb-2 opacity-25"></i>
                                No correction records loaded.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var req in pagedResult.Items)
                        {
                            <tr class="@(req.Status == CorrectionStatuses.Pending && IsOverdue(req.SubmittedAt) ? "overdue-row" : "")">
                                <td class="ps-4">
                                    <div class="fw-bold text-dark">@req.EmployeeName</div>
                                    <div class="small text-muted">@req.Department · @req.EmployeeCode</div>
                                </td>
                                @if (isOrgAdmin)
                                {
                                    <td>
                                        <span class="badge bg-secondary-soft text-secondary">@(req.IsHrInitiated ? "HR" : "Employee")</span>
                                    </td>
                                }
                                <td>
                                    <span class="fw-semibold">@req.WorkDate.ToString("dd MMM yyyy")</span>
                                </td>
                                <td>
                                    <span class="badge bg-secondary-soft text-secondary">@FormatType(req.CorrectionType)</span>
                                    @if (req.IsHrInitiated)
                                    {
                                        <span class="ms-1 badge bg-dark text-white small">HR</span>
                                    }
                                </td>
                                <td>
                                    <div class="small font-monospace text-muted">
                                        @FormatTime(req.OriginalCheckIn) → @FormatTime(req.OriginalCheckOut)
                                    </div>
                                    @if (!string.IsNullOrEmpty(req.OriginalStatus))
                                    {
                                        <span class="badge @GetAttendanceStatusClass(req.OriginalStatus) rounded-pill" style="font-size: 0.65rem;">
                                            @req.OriginalStatus
                                        </span>
                                    }
                                </td>
                                <td>
                                    <div class="small font-monospace fw-semibold text-primary">
                                        @FormatTime(req.RequestedCheckIn) → @FormatTime(req.RequestedCheckOut)
                                    </div>
                                </td>
                                <td>
                                    @{
                                        string submittedDate = "—";
                                        string submittedTime = "—";
                                        try
                                        {
                                            var localSubmitted = TimeZoneInfo.ConvertTimeFromUtc(req.SubmittedAt, orgTimeZone);
                                            submittedDate = localSubmitted.ToString("dd MMM yyyy");
                                            submittedTime = localSubmitted.ToString("hh:mm tt");
                                        }
                                        catch
                                        {
                                            submittedDate = req.SubmittedAt.ToString("dd MMM yyyy");
                                            submittedTime = req.SubmittedAt.ToString("hh:mm tt");
                                        }
                                    }
                                    <div class="small">@submittedDate</div>
                                    <div class="small text-muted">@submittedTime</div>
                                </td>
                                <td>
                                    <span class="badge rounded-pill status-badge @GetCorrectionStatusClass(req.Status)">
                                        <i class="bi bi-circle-fill me-1 small-dot"></i>@req.Status
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    @if (req.Status == CorrectionStatuses.Pending)
                                    {
                                        @if (isOrgAdmin && !req.CanOrgAdminReview)
                                        {
                                            <span class="badge bg-secondary-soft text-secondary">
                                                <i class="bi bi-clock-history me-1"></i>Awaiting HR
                                            </span>
                                        }
                                        else
                                        {
                                            <div class="d-flex justify-content-end gap-2">
                                                <button class="btn btn-sm btn-success rounded-pill px-3" @onclick="() => OpenReviewModal(req, true)">
                                                    <i class="bi bi-check-lg me-1"></i>Approve
                                                </button>
                                                <button class="btn btn-sm btn-outline-danger rounded-pill px-3" @onclick="() => OpenReviewModal(req, false)">
                                                    <i class="bi bi-x-lg me-1"></i>Reject
                                                </button>
                                            </div>
                                        }
                                    }
                                    else if (!string.IsNullOrEmpty(req.ReviewedByName))
                                    {
                                        <div class="text-end small">
                                            <div class="fw-bold text-dark">@req.ReviewedByName</div>
                                            <div class="text-muted">@(req.Status == CorrectionStatuses.Approved ? "Approved" : "Processed")</div>
                                        </div>
                                    }
                                    else if (req.Status != CorrectionStatuses.Pending && string.IsNullOrEmpty(req.ReviewedByName))
                                    {
                                        // If request is processed (Approved/Rejected) but ReviewedByName is empty, show "OrgAdmin"
                                        <div class="text-end small">
                                            <div class="fw-bold text-dark">OrgAdmin</div>
                                            <div class="text-muted">@(req.Status == CorrectionStatuses.Approved ? "Approved" : "Processed")</div>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        @if (pagedResult?.Items != null && pagedResult.Items.Any() && pagedResult.TotalPages > 1)
        {
            <div class="d-flex justify-content-between align-items-center px-4 py-3 border-top bg-light">
                <small class="text-muted fw-semibold">
                    Showing @pagedResult.Items.Count of @pagedResult.TotalCount entries
                </small>
                <div class="btn-group btn-group-sm shadow-sm">
                    <button class="btn btn-white text-dark border" disabled="@(!pagedResult.HasPreviousPage)" @onclick="PreviousPage">
                        ← Back
                    </button>
                    <span class="btn btn-white border disabled text-dark font-monospace fw-bold">
                        @pagedResult.Page / @pagedResult.TotalPages
                    </span>
                    <button class="btn btn-white text-dark border" disabled="@(!pagedResult.HasNextPage)" @onclick="NextPage">
                        Next →
                    </button>
                </div>
            </div>
        }
    </div>
</div>

@* Review Modal *@
@if (reviewRequest != null)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header border-0 bg-light">
                    <h5 class="modal-title fw-bold text-dark">
                        <i class="bi @(reviewDto.Approve ? "bi-check-circle-fill text-success" : "bi-x-circle-fill text-danger") me-2"></i>
                        @(reviewDto.Approve ? "Approve Correction Request" : "Reject Correction Request")
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseReviewModal" disabled="@isReviewing"></button>
                </div>
                <div class="modal-body p-4">
                    @if (!string.IsNullOrEmpty(reviewModalError))
                    {
                        <div class="alert alert-danger border-0 shadow-sm">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>@reviewModalError
                        </div>
                    }

                    <div class="mb-4 p-3 bg-light rounded">
                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <div>
                                <span class="text-muted small fw-bold text-uppercase">Employee</span>
                                <div class="fw-bold text-dark">@reviewRequest.EmployeeName</div>
                                <div class="small text-muted">@reviewRequest.EmployeeCode · @reviewRequest.Department</div>
                            </div>
                            <div class="text-end">
                                <span class="text-muted small fw-bold text-uppercase">Work Date</span>
                                <div class="fw-bold">@reviewRequest.WorkDate.ToString("dd MMMM yyyy")</div>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <div class="p-3 bg-white rounded border">
                                <div class="small text-muted fw-bold mb-2 text-uppercase">
                                    <i class="bi bi-database me-1"></i> Original Records
                                </div>
                                <div class="font-monospace">
                                    <div><span class="text-muted">IN:</span> <strong>@FormatTime(reviewRequest.OriginalCheckIn)</strong></div>
                                    <div><span class="text-muted">OUT:</span> <strong>@FormatTime(reviewRequest.OriginalCheckOut)</strong></div>
                                </div>
                                @if (!string.IsNullOrEmpty(reviewRequest.OriginalStatus))
                                {
                                    <span class="badge @GetAttendanceStatusClass(reviewRequest.OriginalStatus) mt-2">
                                        @reviewRequest.OriginalStatus
                                    </span>
                                }
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-3 bg-white rounded border border-primary">
                                <div class="small text-primary fw-bold mb-2 text-uppercase">
                                    <i class="bi bi-pencil-square me-1"></i> Requested Changes
                                </div>
                                <div class="font-monospace">
                                    <div><span class="text-muted">IN:</span> <strong class="text-primary">@FormatTime(reviewRequest.RequestedCheckIn)</strong></div>
                                    <div><span class="text-muted">OUT:</span> <strong class="text-primary">@FormatTime(reviewRequest.RequestedCheckOut)</strong></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4 p-3 bg-white rounded border-start border-3 border-info">
                        <div class="small text-muted fw-bold mb-1 text-uppercase">
                            <i class="bi bi-chat-text me-1"></i> Employee Reason
                        </div>
                        <p class="mb-0 text-dark">"@reviewRequest.Reason"</p>
                    </div>

                    @if (reviewDto.Approve)
                    {
                        <div class="alert alert-info border-0 small mb-3 shadow-sm">
                            <i class="bi bi-info-circle-fill me-2"></i>
                            Leave empty to accept requested times as submitted. Enter times to override them.
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label small fw-semibold text-uppercase">Override Check-In</label>
                                <input type="text" class="form-control" placeholder="e.g. 09:30 AM" @bind="hrOverrideCheckInText" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-semibold text-uppercase">Override Check-Out</label>
                                <input type="text" class="form-control" placeholder="e.g. 06:00 PM" @bind="hrOverrideCheckOutText" />
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="mb-3">
                            <label class="form-label fw-semibold text-danger text-uppercase small">Reason for Rejection *</label>
                            <textarea @bind="reviewDto.RejectionReason" class="form-control" rows="3" placeholder="Provide detailed reason why this request was denied..."></textarea>
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label fw-semibold text-uppercase small">Internal Notes (Audit Log)</label>
                        <textarea @bind="reviewDto.HrNote" class="form-control" rows="2" placeholder="Optional internal notes for audit trail..."></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 bg-light">
                    <button class="btn btn-outline-secondary px-4" @onclick="CloseReviewModal" disabled="@isReviewing">
                        Cancel
                    </button>
                    <button class="btn @(reviewDto.Approve ? "btn-success" : "btn-danger") px-4" @onclick="HandleReview" disabled="@isReviewing">
                        @if (isReviewing)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        @(reviewDto.Approve ? "Confirm Approval" : "Confirm Rejection")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* Manual Correction Modal *@
@if (showManualModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header border-0 bg-light">
                    <h5 class="modal-title fw-bold text-dark">
                        <i class="bi bi-pencil-square text-primary me-2"></i>HR Manual Correction
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseManualModal" disabled="@isManualSubmitting"></button>
                </div>
                <div class="modal-body p-4">
                    @if (!string.IsNullOrEmpty(manualModalError))
                    {
                        <div class="alert alert-danger border-0 shadow-sm">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>@manualModalError
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label fw-semibold text-uppercase small">Target Employee *</label>
                        <select @bind="manualDto.EmployeeId" class="form-select">
                            <option value="">— Select Employee —</option>
                            @foreach (var emp in employees)
                            {
                                <option value="@emp.EmployeeId">@emp.FullName (@emp.EmployeeCode)</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold text-uppercase small">Work Date *</label>
                        <InputDate @bind-Value="manualDto.WorkDate" class="form-control" />
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-uppercase small">Check-In Time</label>
                            <input type="text" class="form-control" placeholder="e.g. 09:30 AM" @bind="manualCheckInText" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-uppercase small">Check-Out Time</label>
                            <input type="text" class="form-control" placeholder="e.g. 06:00 PM" @bind="manualCheckOutText" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold text-uppercase small">Justification / Note *</label>
                        <textarea @bind="manualDto.HrNote" class="form-control" rows="3" placeholder="Provide detailed justification for this manual correction..."></textarea>
                    </div>

                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" @bind="manualDto.AutoApply" id="autoApply" />
                        <label class="form-check-label fw-semibold" for="autoApply">
                            Auto-Approve Immediately
                        </label>
                        <div class="form-text text-muted small">
                            When enabled, changes are applied directly. When disabled, request goes to OrgAdmin for review.
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 bg-light">
                    <button class="btn btn-outline-secondary px-4" @onclick="CloseManualModal" disabled="@isManualSubmitting">
                        Cancel
                    </button>
                    <button class="btn btn-primary px-4 shadow-sm" @onclick="HandleManualCorrection" disabled="@isManualSubmitting">
                        @if (isManualSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Submit Correction
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .tracking-tight {
        letter-spacing: -0.025em;
    }

    .tracking-wider {
        letter-spacing: 0.04em;
        font-size: 11px;
    }

    .btn-add-task {
        background-color: #5c4ac7 !important;
        color: #ffffff !important;
        border: none !important;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
        transition: all 0.2s ease;
    }

    .btn-add-task:hover {
        background-color: #4b3ba6 !important;
        transform: translateY(-1px);
    }

    .btn-interactive-back {
        background: #ffffff !important;
        border: 1px solid #e5e7eb !important;
        color: #4b5563 !important;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
        transition: all 0.2s ease;
    }

    .btn-interactive-back:hover {
        background-color: #f8fafc !important;
