@page "/hr/attendance-corrections"
@rendermode InteractiveServer

@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.DTOs.Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize(Roles = "HR,OrgAdmin")]

@inject AttendanceCorrectionService CorrectionService

<PageTitle>Attendance Corrections | HR | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">

    <!-- HEADER -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">

        <div>
            <h2 class="fw-semibold mb-1">
                Attendance Corrections
            </h2>

            <p class="text-muted small mb-0">
                Review and manage employee attendance correction requests
            </p>
        </div>

        <button class="btn btn-outline-secondary shadow-sm"
                @onclick="LoadData"
                disabled="@isLoading">

            @if (isLoading)
            {
                <span class="spinner-border spinner-border-sm me-2"></span>
            }

            <i class="bi bi-arrow-clockwise me-1"></i>
            Refresh

        </button>

    </div>

    <!-- ALERT -->
    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="alert @(isError ? "alert-danger" : "alert-success") alert-dismissible fade show border-0 shadow-sm mb-4">

            <div class="d-flex align-items-start">

                <i class="bi @(isError ? "bi-exclamation-triangle-fill" : "bi-check-circle-fill") me-2 fs-5"></i>

                <div class="flex-grow-1">
                    @message
                </div>

                <button type="button"
                        class="btn-close"
                        @onclick="ClearMessage">
                </button>

            </div>

        </div>
    }

    <!-- STATS -->
    <div class="row g-3 mb-4">

        <div class="col-md-3">

            <div class="stats-card pending-card">

                <div class="stats-label">
                    Pending
                </div>

                <div class="stats-value text-warning">
                    @requests.Count(r => r.Status == "Pending")
                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="stats-card approved-card">

                <div class="stats-label">
                    Approved
                </div>

                <div class="stats-value text-success">
                    @requests.Count(r => r.Status == "Approved")
                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="stats-card rejected-card">

                <div class="stats-label">
                    Rejected
                </div>

                <div class="stats-value text-danger">
                    @requests.Count(r => r.Status == "Rejected")
                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="stats-card total-card">

                <div class="stats-label">
                    Total
                </div>

                <div class="stats-value">
                    @requests.Count
                </div>

            </div>

        </div>

    </div>

    <!-- FILTER -->
    <div class="custom-card mb-4">

        <div class="p-3 d-flex flex-wrap align-items-center gap-2">

            <span class="small fw-bold text-uppercase text-muted me-2">
                Filter:
            </span>

            @foreach (var filter in Filters)
            {
                <button class="btn btn-sm filter-btn @(selectedStatus == filter ? "active-filter" : "")"
                        @onclick="() => ChangeFilter(filter)">

                    @(string.IsNullOrWhiteSpace(filter)
                                    ? "All Requests"
                                    : filter)

            </button>
                        }

        </div>

    </div>

    <!-- TABLE -->
    <div class="custom-card overflow-hidden">

        @if (isLoading)
        {
            <div class="text-center py-5">

                <div class="spinner-border text-primary mb-3"></div>

                <div class="text-muted">
                    Loading attendance correction requests...
                </div>

            </div>
        }
        else if (!FilteredRequests.Any())
        {
            <div class="text-center py-5">

                <i class="bi bi-inbox fs-1 text-muted opacity-50 d-block mb-3"></i>

                <div class="fw-semibold text-muted">
                    No correction requests found
                </div>

                <small class="text-muted">
                    @(string.IsNullOrWhiteSpace(selectedStatus)
                                    ? "No requests available."
                                    : $"No {selectedStatus.ToLower()} requests available.")
            </small>

            </div>
                }
        else
        {
            <div class="table-responsive">

                <table class="table table-custom align-middle mb-0">

                    <thead>
                        <tr>
                            <th class="ps-4">EMPLOYEE</th>
                            <th>DEPARTMENT</th>
                            <th>DATE</th>
                            <th>CURRENT</th>
                            <th>REQUESTED</th>
                            <th>REASON</th>
                            <th>SUBMITTED</th>
                            <th>STATUS</th>
                            <th class="text-end pe-4">ACTION</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var req in FilteredRequests)
                        {
                            <tr class="@(req.Status == "Pending" ? "pending-row" : "")">

                                <!-- EMPLOYEE -->
                                <td class="ps-4">

                                    <div class="fw-semibold">
                                        @req.EmployeeName
                                    </div>

                                </td>

                                <!-- DEPARTMENT -->
                                <td>

                                    <span class="department-badge">
                                        @req.Department
                                    </span>

                                </td>

                                <!-- DATE -->
                                <td>

                                    <div class="fw-semibold">
                                        @req.Date.ToString("dd MMM yyyy")
                                    </div>

                                    <small class="text-muted">
                                        @req.Date.ToString("dddd")
                                    </small>

                                </td>

                                <!-- CURRENT -->
                                <td class="small font-monospace">

                                    <div class="mb-1">

                                        <i class="bi bi-box-arrow-in-right text-muted me-1"></i>

                                        @FormatOrgTime(req.CurrentCheckIn)

                                    </div>

                                    <div>

                                        <i class="bi bi-box-arrow-right text-muted me-1"></i>

                                        @FormatOrgTime(req.CurrentCheckOut)

                                    </div>

                                </td>

                                <!-- REQUESTED -->
                                <td class="small font-monospace">

                                    <div class="mb-1">

                                        <i class="bi bi-box-arrow-in-right text-success me-1"></i>

                                        @FormatOrgTime(req.RequestedCheckIn)

                                    </div>

                                    <div>

                                        <i class="bi bi-box-arrow-right text-danger me-1"></i>

                                        @FormatOrgTime(req.RequestedCheckOut)

                                    </div>

                                </td>

                                <!-- REASON -->
                                <td style="max-width:250px;">

                                    <div class="reason-text"
                                         title="@req.Reason">

                                        @req.Reason

                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(req.RejectionReason))
                                    {
                                        <div class="small text-danger mt-1"
                                             title="@req.RejectionReason">

                                            ↳ @req.RejectionReason

                                        </div>
                                    }

                                </td>

                                <!-- SUBMITTED -->
                                <td>

                                    <div class="small text-muted">
                                        @FormatOrgDateTime(req.AppliedAt)
                                    </div>

                                </td>

                                <!-- STATUS -->
                                <td>

                                    <span class="badge status-badge @GetStatusClass(req.Status)">
                                        @req.Status
                                    </span>

                                    @if (req.ReviewedAt.HasValue)
                                    {
                                        <div class="small text-muted mt-1">
                                            Reviewed:
                                            @FormatOrgDateTime(req.ReviewedAt)
                                        </div>
                                    }

                                </td>

                                <!-- ACTION -->
                                <td class="text-end pe-4">

                                    @if (req.Status == "Pending")
                                    {
                                        <div class="d-flex justify-content-end gap-2">

                                            <button class="btn btn-success btn-sm"
                                                    disabled="@actionLoading"
                                                    @onclick="() => Approve(req.CorrectionRequestId)">

                                                @if (actionLoading)
                                                {
                                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                                }

                                                <i class="bi bi-check2 me-1"></i>
                                                Approve

                                            </button>

                                            <button class="btn btn-outline-danger btn-sm"
                                                    disabled="@actionLoading"
                                                    @onclick="() => OpenRejectModal(req)">

                                                <i class="bi bi-x-lg me-1"></i>
                                                Reject

                                            </button>

                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">
                                            —
                                        </span>
                                    }

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>
        }

    </div>

</div>

<!-- REJECT MODAL -->
@if (showRejectModal && rejectTarget != null)
{
    <div class="modal fade show d-block" tabindex="-1">

        <div class="modal-dialog modal-dialog-centered">

            <div class="modal-content border-0 shadow-lg">

                <div class="modal-header border-0 pb-0">

                    <h5 class="modal-title fw-semibold">
                        Reject Correction Request
                    </h5>

                    <button class="btn-close"
                            @onclick="CloseRejectModal">
                    </button>

                </div>

                <div class="modal-body pt-3">

                    <div class="request-preview mb-4">

                        <div class="fw-semibold mb-1">
                            @rejectTarget.EmployeeName
                        </div>

                        <div class="small text-muted mb-2">
                            @rejectTarget.Date.ToString("dd MMM yyyy")
                        </div>

                        <div class="small">
                            @rejectTarget.Reason
                        </div>

                    </div>

                    <div class="mb-2">

                        <label class="form-label fw-semibold">
                            Rejection Reason
                            <span class="text-danger">*</span>
                        </label>

                        <textarea class="form-control"
                                  rows="4"
                                  maxlength="300"
                                  placeholder="Explain why this request is rejected..."
                                  @bind="rejectReason">
                            </textarea>

                    </div>

                    @if (!string.IsNullOrWhiteSpace(rejectError))
                    {
                        <div class="small text-danger mt-2">
                            @rejectError
                        </div>
                    }

                </div>

                <div class="modal-footer border-0">

                    <button class="btn btn-light border"
                            @onclick="CloseRejectModal">

                        Cancel

                    </button>

                    <button class="btn btn-danger"
                            disabled="@actionLoading"
                            @onclick="ConfirmReject">

                        @if (actionLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }

                        Reject Request

                    </button>

                </div>

            </div>

        </div>

    </div>

    <div class="modal-backdrop fade show"></div>
}

<style>

