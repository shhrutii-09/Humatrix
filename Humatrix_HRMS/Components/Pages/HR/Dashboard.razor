@page "/hr/dashboard"
@implements IAsyncDisposable
@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Data
@using Humatrix_HRMS.Services
@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Components.Account.Shared
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using Humatrix_HRMS.DTOs.Dashboard
@inject NavigationManager Nav
@using Microsoft.AspNetCore.SignalR.Client

@attribute [Authorize(Roles = "HR")]
@inject LeaveService LeaveService
@inject EmployeeService EmployeeService
@inject CurrentUserService CurrentUserService

@rendermode InteractiveServer

<PageTitle>HR Dashboard | Humatrix</PageTitle>

@if (!string.IsNullOrEmpty(error))
{
    <div class="container-fluid px-4 mt-3">
        <div class="alert alert-danger shadow-sm border-0 d-flex align-items-center">
            <i class="bi bi-exclamation-triangle-fill fs-5 me-2"></i>
            <pre class="mb-0 text-wrap">@error</pre>
        </div>
    </div>
}

<div class="container-fluid px-4 mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h2 class="fw-normal mb-1">
                Welcome back, @(currentUser?.FirstName ?? "HR Manager")!
            </h2>
            <p class="text-muted small mb-0">
                Here is what's happening in your department today.
            </p>
        </div>

        <div class="d-flex align-items-center gap-3">
            @if (currentUser != null)
            {
                <NotificationBell />
            }
            <span class="status-badge-compact system-role-badge shadow-sm">
                <i class="bi bi-shield-lock-fill me-1"></i> HR Management
            </span>
        </div>
    </div>

    <div class="row mb-4 g-3">
        <div class="col-md-6 col-xl-4">
            <div class="card border-0 shadow-sm bg-purple text-white p-3 h-100 position-relative overflow-hidden">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="small text-uppercase tracking-wider opacity-75 mb-1">Total Team Members</h6>
                        <h2 class="mb-0 fw-bold">@(employees?.Count ?? 0)</h2>
                    </div>
                    <div class="metric-icon-overlay">
                        <i class="bi bi-people-fill"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-4">
            <div class="card border-0 shadow-sm p-3 border-start border-warning border-4 h-100 bg-white d-flex flex-column justify-content-between">
                <div class="d-flex align-items-start justify-content-between">
                    <div>
                        <h6 class="text-muted small text-uppercase tracking-wider fw-bold mb-1">Pending Leaves</h6>
                        <h2 class="text-warning mb-0 fw-bold">@pendingLeaveCount</h2>
                    </div>
                    <span class="metric-side-icon text-warning opacity-50"><i class="bi bi-calendar2-check-fill fs-2"></i></span>
                </div>
                @if (pendingLeaveCount > 0)
                {
                    <div class="mt-2 pt-2 border-top border-light">
                        <a href="/hr/leaves" class="small text-warning text-decoration-none fw-semibold d-inline-flex align-items-center gap-1 hover-link">
                            Review requests <i class="bi bi-arrow-right"></i>
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="row g-4">

        <div class="col-lg-8 col-xl-9 order-2 order-lg-1">
            <div class="card border-0 shadow-sm h-100 bg-white p-3">

                <div class="card-header bg-white border-0 pb-3 pt-2 px-2 d-flex justify-content-between align-items-center flex-wrap gap-3">
                    <h5 class="mb-0 text-secondary fw-semibold d-flex align-items-center">
                        <i class="bi bi-list-ul me-2 text-muted"></i> Recent Employee List
                    </h5>

                    <div class="d-flex gap-2 min-width-search">
                        <div class="input-group shadow-sm">
                            <span class="input-group-text bg-white text-muted border-end-0"><i class="bi bi-search"></i></span>
                            <input type="text"
                                   @bind="searchTerm"
                                   @bind:event="oninput"
                                   @onkeyup="HandleSearch"
                                   class="form-control border-start-0 ps-0 form-control-clean"
                                   placeholder="Search employee..." />
                        </div>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table align-middle mb-0 clean-theme-table">
                        <thead>
                            <tr>
                                <th class="ps-3 text-uppercase tracking-wider">Employee</th>
                                <th class="text-uppercase tracking-wider">Designation</th>
                                <th class="text-uppercase tracking-wider">Department</th>
                                <th class="text-uppercase tracking-wider">Shift</th>
                                <th class="text-uppercase tracking-wider text-end pe-3">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (employees == null)
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-5">
                                        <div class="spinner-border text-primary spinner-border-sm me-2" role="status"></div>
                                        <span class="text-muted small">Loading records...</span>
                                    </td>
                                </tr>
                            }
                            else if (!employees.Any())
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted small">
                                        <i class="bi bi-folder-x fs-3 d-block mb-2 text-light"></i> No employees found matching criteria.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var emp in employees)
                                {
                                    <tr class="clickable-row-style" @onclick='() => Nav.NavigateTo($"/hr/profile/{emp.Email}")'>
                                        <td class="ps-3">
                                            <div class="d-flex align-items-center">
                                                <div class="avatar-table-badge me-3 shadow-sm">
                                                    @((!string.IsNullOrWhiteSpace(emp?.FirstName) ? emp.FirstName[0] : '?'))@((!string.IsNullOrWhiteSpace(emp?.LastName) ? emp.LastName[0] : '?'))
                                                </div>
                                                <div>
                                                    <div class="fw-semibold text-dark text-hover-purple">@(emp?.Name ?? "Unknown Employee")</div>
                                                    <small class="text-muted table-subtext">@(emp?.Email ?? "No Email Address")</small>
                                                </div>
                                            </div>
                                        </td>

                                        <td class="text-secondary small">
                                            @(emp?.Designation ?? "N/A")
                                        </td>

                                        <td>
                                            <span class="status-badge-compact bg-info-subtle text-info">
                                                @(emp?.Department ?? "N/A")
                                            </span>
                                        </td>

                                        <td class="text-secondary small">
                                            <i class="bi bi-clock me-1 text-muted"></i> @(emp?.ShiftName ?? "Unassigned")
                                        </td>

                                        <td class="text-end pe-3">
                                            @if (emp?.IsActive == true)
                                            {
                                                <span class="status-badge-compact active-badge">Active</span>
                                            }
                                            else
                                            {
                                                <span class="status-badge-compact inactive-badge">Inactive</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>

            </div>
        </div>

        <div class="col-lg-4 col-xl-3 order-1 order-lg-2">
            <div class="card border-0 shadow-sm text-center p-4 bg-white justify-content-center h-100">

                <div class="position-relative d-inline-block mx-auto mb-3">
                    <div class="avatar-sidebar-container shadow-sm">
                        @(!string.IsNullOrWhiteSpace(currentUser?.FirstName) ? currentUser.FirstName[0] : '?')@(!string.IsNullOrWhiteSpace(currentUser?.LastName) ? currentUser.LastName[0] : '?')
                    </div>
                </div>

                <h5 class="fw-normal text-dark mb-1">
                    @currentUser?.FirstName @currentUser?.LastName
                </h5>
                <p class="text-muted small text-truncate mb-3">
                    @(currentUser?.Email ?? "System Operator")
                </p>

                <div class="border-top border-light pt-3 text-start px-2">
                    <div class="mb-3">
                        <small class="text-uppercase tracking-wider text-muted fw-bold d-block mb-1" style="font-size: 0.65rem;">
                            Assigned Department
                        </small>
                        <span class="text-dark small fw-medium"><i class="bi bi-building me-1 text-muted"></i> Admin / HR Division</span>
                    </div>

                    <div>
                        <small class="text-uppercase tracking-wider text-muted fw-bold d-block mb-1" style="font-size: 0.65rem;">
                            Joined On
                        </small>
                        <span class="text-dark small fw-medium">
                            <i class="bi bi-calendar-event me-1 text-muted"></i> @(currentUser?.CreatedAt.ToString("MMM dd, yyyy") ?? "System Epoch")
                        </span>
                    </div>
                </div>

                <button class="btn btn-action-password btn-sm mt-4 w-100 py-2 shadow-sm" @onclick='() => Nav.NavigateTo("/hr/profile")'>
                    <i class="bi bi-pencil-square me-1"></i> Edit My Profile
                </button>

            </div>
        </div>

    </div>
</div>

<style>
    /* Styling Palette Configuration Definitions */
    .bg-purple {
        background: linear-gradient(135deg, #5c4ac7 0%, #7c6be3 100%) !important;
    }

    .card {
        border-radius: 12px;
    }

    /* Core Compact Labels Integration Rules */
    .status-badge-compact {
        padding: 5px 12px;
        border-radius: 50px;
        font-size: 0.78rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        white-space: nowrap;
    }

    .active-badge {
        background-color: #d1fae5;
        color: #047857;
        border: 1px solid #a7f3d0;
    }

    .inactive-badge {
        background-color: #fee2e2;
        color: #b91c1c;
        border: 1px solid #fecaca;
    }

    .bg-info-subtle {
        background-color: #f0f9ff;
        color: #0369a1;
        border: 1px solid #bae6fd;
    }

    .system-role-badge {
        background-color: #f1f0fb;
        color: #5c4ac7;
        border: 1px solid #e1dff7;
        font-size: 0.82rem;
        padding: 6px 14px;
    }

    /* Clean Uniform Data Inputs */
    .form-control-clean {
        border: 1px solid #e5e7eb;
        padding: 0.55rem 0.75rem;
        font-size: 0.88rem;
        border-radius: 8px;
    }

        .form-control-clean:focus {
            border-color: #5c4ac7 !important;
            box-shadow: none !important;
        }

    .input-group-text {
        border: 1px solid #e5e7eb;
        border-radius: 8px;
    }

    .min-width-search {
        min-width: 260px;
    }

    /* Modern Minimalist Table View Restructuring UI */
    .clean-theme-table thead th {
        background-color: #f8fafc;
        color: #64748b;
        font-weight: 600;
        font-size: 0.75rem;
        border-bottom: 1px solid #ebdbe2;
        padding: 12px 10px;
    }

    .clean-theme-table tbody tr {
        border-bottom: 1px solid #f1f5f9;
        transition: background-color 0.15s ease;
    }

    .clickable-row-style {
        cursor: pointer;
    }

        .clickable-row-style:hover {
            background-color: #fafafa;
        }

            .clickable-row-style:hover .text-hover-purple {
                color: #5c4ac7 !important;
            }

    .clean-theme-table tbody td {
        padding: 14px 10px;
    }

    .table-subtext {
        font-size: 0.78rem;
    }

    /* Custom Responsive Avatar Formats */
    .avatar-table-badge {
        width: 38px;
        height: 38px;
        font-size: 0.85rem;
        font-weight: 600;
        color: #5c4ac7;
        background-color: #f1f0fb;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .avatar-sidebar-container {
        width: 85px;
        height: 85px;
        font-size: 1.8rem;
        color: #5c4ac7;
        background-color: #f1f0fb;
        border: 2px solid #5c4ac7;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
    }

    /* Primary Profile Actions Link Styles */
    .btn-action-password {
        background-color: #ffffff !important;
        color: #5c4ac7 !important;
        border: 1px solid #5c4ac7 !important;
        font-weight: 600;
        border-radius: 8px;
        transition: all 0.2s ease;
    }

        .btn-action-password:hover {
            background-color: #5c4ac7 !important;
            color: #ffffff !important;
        }

    .metric-icon-overlay {
        font-size: 2.8rem;
        opacity: 0.18;
        position: absolute;
        right: 15px;
        bottom: -5px;
    }

    .hover-link:hover {
        text-decoration: underline !important;
    }

    .tracking-wider {
        letter-spacing: 0.05em;
    }
</style>

@code {

    private List<EmployeeListDto>? employees;

    private ApplicationUser? currentUser;
    private HrDashboardContextDto? dashboardContext;

    private int pendingWfhCount;
    private int pendingOtCount;
    private string searchTerm = "";
    private string? error;
    private int pendingLeaveCount;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            currentUser = await CurrentUserService.GetUserAsync();

            dashboardContext = await CurrentUserService.GetHrDashboardContextAsync();
            await LoadEmployees();
            await LoadPendingLeaveCount();
        }
        catch (Exception ex)
        {
            error = ex.ToString();
        }
    }

    private async Task LoadPendingLeaveCount()
    {
        try
        {
            var allLeaves = await LeaveService.GetAllForHRAsync("Pending");
            pendingLeaveCount = allLeaves.Count;
        }
        catch
        {
            pendingLeaveCount = 0;
        }
    }

    private async Task LoadEmployees()
    {
        try
        {
            var result = await EmployeeService.GetEmployeesForListAsync(searchTerm);
            employees = result.Items ?? new List<EmployeeListDto>();
        }
        catch (Exception ex)
        {
            error = ex.Message;
            employees = new List<EmployeeListDto>();
        }
    }

    private async Task HandleSearch()
    {
        await LoadEmployees();
    }

    private HubConnection? _dashHub;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _dashHub = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/notificationHub"))
            .WithAutomaticReconnect()
            .Build();

        _dashHub.On("DashboardRefresh", async () =>
        {
            await LoadPendingLeaveCount();
            await LoadPendingWfhCount();
            await LoadPendingOtCount();

            await InvokeAsync(StateHasChanged);
        });

        await _dashHub.StartAsync();

        if (dashboardContext != null)
        {
            await _dashHub.SendAsync(
                "JoinHrDashboardGroup",
                dashboardContext.OrganizationId.ToString(),
                dashboardContext.DepartmentId.ToString());
        }
    }

    private async Task LoadPendingWfhCount()
    {
        try
        {
            pendingWfhCount = 0;
        }
        catch
        {
            pendingWfhCount = 0;
        }
    }

    private async Task LoadPendingOtCount()
    {
        try
        {
            pendingOtCount = 0;
        }
        catch
        {
            pendingOtCount = 0;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_dashHub != null)
        {
            await _dashHub.DisposeAsync();
        }
    }
}