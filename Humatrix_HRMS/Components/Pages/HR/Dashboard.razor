@page "/hr/dashboard"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "HR")]

<PageTitle>HR Dashboard</PageTitle>

<div class="container mt-4">
    <h1>HR Administration</h1>

    <div class="row">
        <div class="col-md-3">
            <div class="card text-center p-3 mb-3">
                <h3>45</h3>
                <p>Employees</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center p-3 mb-3">
                <h3>3</h3>
                <p>New Requests</p>
            </div>
        </div>
    </div>

    <table class="table table-hover mt-3 shadow-sm border">
        <thead class="table-light">
            <tr>
                <th>Name</th>
                <th>Department</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            <tr><td>John Doe</td><td>IT</td><td><span class="badge bg-success">Active</span></td></tr>
            <tr><td>Jane Smith</td><td>Sales</td><td><span class="badge bg-warning">On Leave</span></td></tr>
        </tbody>
    </table>
</div>