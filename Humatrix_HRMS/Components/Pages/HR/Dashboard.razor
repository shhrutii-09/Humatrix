@page "/hr/dashboard"
@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Data
@using Humatrix_HRMS.Services
@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Components.Account.Shared
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims

@attribute [Authorize(Roles = "HR")]
@inject LeaveService LeaveService
@inject EmployeeService EmployeeService
@inject CurrentUserService CurrentUserService

@rendermode InteractiveServer

<PageTitle>HR Dashboard | Humatrix</PageTitle>

@if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-danger mx-4 mt-3">
        <pre class="mb-0">@error</pre>
    </div>
}

<div class="container-fluid px-4 mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">

        <div>
            <h2 class="fw-bold">
                Welcome back, @currentUser?.FirstName!
            </h2>

            <p class="text-muted mb-0">
                Here is what's happening in your department today.
            </p>
        </div>

        <!-- RIGHT SIDE -->
        <div class="d-flex align-items-center gap-3">

            <!-- NOTIFICATION BELL -->
            @* <NotificationBell /> *@

            @if (currentUser != null)
            {
                <NotificationBell />
            }
            <!-- ROLE BADGE -->
            <span class="badge bg-primary p-2">
                HR Role
            </span>

        </div>

    </div>

    <!-- STATS -->
    <div class="row mb-4 g-3">

        <!-- TOTAL -->
        <div class="col-md-4">

            <div class="card border-0 shadow-sm bg-purple text-white p-3">

                <h6 class="small opacity-75">
                    Total Team Members
                </h6>

                <h2 class="mb-0 fw-bold">
                    @(employees?.Count ?? 0)
                </h2>

            </div>

        </div>

        <!-- ACTIVE -->
        @* <div class="col-md-4">

            <div class="card border-0 shadow-sm p-3 border-start border-success border-4">

                <h6 class="text-muted small fw-bold">
                    Active Employees
                </h6>

                <h2 class="text-success mb-0 fw-bold">
                    @(employees?.Count(e => e?.IsActive == true) ?? 0)
                </h2>

            </div>

        </div> *@
        <!-- PENDING LEAVE APPROVALS -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-3 border-start border-warning border-4">
                <h6 class="text-muted small fw-bold">Pending Leave Approvals</h6>
                <h2 class="text-warning mb-0 fw-bold">@pendingLeaveCount</h2>
                @if (pendingLeaveCount > 0)
                {
                    <a href="/hr/leaves" class="small text-warning">Review now →</a>
                }
            </div>
        </div>

    </div>

    <!-- MAIN CONTENT -->
    <div class="row g-4">

        <!-- EMPLOYEE TABLE -->
        <div class="col-lg-9">

            <div class="card border-0 shadow-sm">

                <!-- HEADER -->
                <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">

                    <h5 class="mb-0 fw-bold">
                        Recent Employee List
                    </h5>

                    <!-- SEARCH -->
                    <div class="d-flex gap-2">

                        <input type="text"
                               @bind="searchTerm"
                               @bind:event="oninput"
                               @onkeyup="HandleSearch"
                               class="form-control form-control-sm"
                               placeholder="Search employee..." />

                    </div>

                </div>

                <!-- TABLE -->
                <div class="table-responsive p-0">

                    <table class="table align-middle mb-0">

                        <thead class="bg-light text-muted small text-uppercase">

                            <tr>

                                <th class="ps-4">
                                    Employee
                                </th>

                                <th>
                                    Designation
                                </th>

                                <th>
                                    Department
                                </th>

                                <th>
                                    Shift
                                </th>

                                <th>
                                    Status
                                </th>

                            </tr>

                        </thead>

                        <tbody>

                            @if (employees == null)
                            {
                                <tr>

                                    <td colspan="5"
                                        class="text-center py-4">

                                        Loading...

                                    </td>

                                </tr>
                            }
                            else if (!employees.Any())
                            {
                                <tr>

                                    <td colspan="5"
                                        class="text-center py-4">

                                        No employees found.

                                    </td>

                                </tr>
                            }
                            else
                            {
                                @foreach (var emp in employees)
                                {
                                    <tr>

                                        <!-- EMPLOYEE -->
                                        <td class="ps-4">

                                            <div class="d-flex align-items-center">

                                                <!-- AVATAR -->
                                                <div class="avatar-sm bg-light rounded-circle text-primary d-flex align-items-center justify-content-center me-3"
                                                     style="width:40px; height:40px;">

                                                    @((!string.IsNullOrWhiteSpace(emp?.FirstName)
                                                                                                ? emp.FirstName[0]
                                                                                                : '?'))

                                                    @((!string.IsNullOrWhiteSpace(emp?.LastName)
                                                                                                ? emp.LastName[0]
                                                                                                : '?'))

                                        </div>

                                                <!-- INFO -->
                                                <div>

                                                    <div class="fw-bold">
                                                        @(emp?.Name ?? "Unknown Employee")
                                                    </div>

                                                    <small class="text-muted">
                                                        @(emp?.Email ?? "No Email")
                                                    </small>

                                                </div>

                                            </div>

                                        </td>

                                        <!-- DESIGNATION -->
                                        <td>
                                            @(emp?.Designation ?? "N/A")
                                        </td>

                                        <!-- DEPARTMENT -->
                                        <td>

                                            <span class="badge bg-info-subtle text-info">

                                                @(emp?.Department ?? "N/A")

                                            </span>

                                        </td>

                                        <!-- SHIFT -->
                                        <td>
                                            @(emp?.ShiftName ?? "No Shift")
                                        </td>

                                        <!-- STATUS -->
                                        <td>

                                    @if (emp?.IsActive == true)
                                            {
                                                <span class="badge rounded-pill bg-success-subtle text-success">

                                                    Active

                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge rounded-pill bg-danger-subtle text-danger">

                                                    Inactive

                                                </span>
                                            }

                                        </td>

                                    </tr>
                                }
                            }

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

        <!-- PROFILE CARD -->
        <div class="col-lg-3">

            <div class="card border-0 shadow-sm text-center p-4">

                <!-- AVATAR -->
                <div class="mx-auto mb-3 bg-primary rounded-circle text-white d-flex align-items-center justify-content-center"
                     style="width:80px; height:80px; font-size: 2rem;">

                    @(!string.IsNullOrWhiteSpace(currentUser?.FirstName)
                                        ? currentUser.FirstName[0]
                                        : '?')

                </div>

                <!-- NAME -->
                <h5 class="fw-bold">

                    @currentUser?.FirstName
                    @currentUser?.LastName

                </h5>

                <!-- EMAIL -->
                <p class="text-muted small">

                    @(currentUser?.Email ?? "No Email")

                </p>

                <hr />

                <!-- INFO -->
                <div class="text-start">

                    <small class="text-uppercase text-muted fw-bold"
                           style="font-size: 0.7rem;">

                        Your Department

                    </small>

                    <p class="mb-2">
                        Admin / HR
                    </p>

                    <small class="text-uppercase text-muted fw-bold"
                           style="font-size: 0.7rem;">

                        Joined On

                    </small>

                    <p class="mb-0">

                        @(currentUser?.CreatedAt.ToString("MMM dd, yyyy") ?? "N/A")

                    </p>

                </div>

                <!-- BUTTON -->
                <a href="/hr/profile"
                   class="btn btn-primary btn-sm mt-4 w-100">

                    Edit My Profile

                </a>

            </div>

        </div>

    </div>

</div>

<style>

    .bg-purple {
        background-color: #6f42c1;
    }

    .bg-success-subtle {
        background-color: #d1e7dd;
        color: #0f5132;
    }

    .bg-danger-subtle {
        background-color: #f8d7da;
        color: #842029;
    }

    .bg-info-subtle {
        background-color: #cff4fc;
        color: #055160;
    }

    .card {
        border-radius: 12px;
    }

    .table tbody tr {
        transition: 0.2s ease;
    }

        .table tbody tr:hover {
            background-color: #f8f9fa;
        }

</style>

@code {

    private List<EmployeeListDto>? employees;

    private ApplicationUser? currentUser;

    private string searchTerm = "";
    private string? error;
    private int pendingLeaveCount;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // currentUser = await CurrentUserService.GetUserAsync();

            // await LoadEmployees();
            currentUser = await CurrentUserService.GetUserAsync();
            await LoadEmployees();
            await LoadPendingLeaveCount();
        }
        catch (Exception ex)
        {
            error = ex.ToString();
        }
    }
    private async Task LoadPendingLeaveCount()
    {
        try
        {
            // Inject LeaveService at top of file: @inject LeaveService LeaveService
            var allLeaves = await LeaveService.GetAllForHRAsync("Pending");
            pendingLeaveCount = allLeaves.Count;
        }
        catch
        {
            pendingLeaveCount = 0;
        }
    }
    private async Task LoadEmployees()
    {
        try
        {
            var result = await EmployeeService
                .GetEmployeesForListAsync(searchTerm);

            employees = result.Items ?? new List<EmployeeListDto>();
        }
        catch (Exception ex)
        {
            error = ex.Message;
            employees = new List<EmployeeListDto>();
        }
    }

    private async Task HandleSearch()
    {
        await LoadEmployees();
    }
}