@page "/hr/dashboard"

@using Humatrix_HRMS.Data
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize(Roles = "HR")]

@inject EmployeeService EmployeeService

<PageTitle>HR Dashboard</PageTitle>

<div class="container mt-4">
    <h1>HR Dashboard</h1>

    <div class="card p-3 mb-4">
        <h5>Total Employees: @employees.Count</h5>
    </div>

    <table class="table table-hover shadow-sm border">
        <thead class="table-light">
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>DepartmentId</th>
                <th>Status</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var emp in employees)
            {
                <tr>
                    <td>@emp.FirstName @emp.LastName  <p><strong>Role:</strong> HR</p></td>
                   

                    <td>@emp.Email</td>
                    <td>@emp.DepartmentId</td>
                    <td>
                        <span class="badge bg-success">Active</span>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    private List<ApplicationUser> employees = new();

    protected override async Task OnInitializedAsync()
    {
        employees = await EmployeeService.GetEmployeesAsync();
    }
}