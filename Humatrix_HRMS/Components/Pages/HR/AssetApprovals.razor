@* @page "/hr/asset-approvals"
@attribute [Authorize(Roles = "HR,OrgAdmin")]
@rendermode InteractiveServer

@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.DTOs.Asset
@using Humatrix_HRMS.Infrastructure.Constants
@using Humatrix_HRMS.Infrastructure.Services
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.SignalR.Client

@inject AssetRequestService AssetRequestService
@inject CurrentUserService CurrentUserService
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Asset Approvals | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 py-4">

    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">

        <div>
            <h2 class="fw-bold mb-1">
                Asset Approval Queue
            </h2>

            <p class="text-muted mb-0">
                Review and process employee asset requests
            </p>
        </div>

        <button class="btn btn-primary"
                @onclick="LoadRequestsAsync">

            <i class="bi bi-arrow-clockwise me-2"></i>
            Refresh

        </button>

    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">

            <div class="spinner-border text-primary"></div>

        </div>
    }
    else if (!requests.Any())
    {
        <div class="card border-0 shadow-sm">

            <div class="card-body text-center py-5">

                <i class="bi bi-check-circle fs-1 text-success"></i>

                <h5 class="fw-semibold mt-3">
                    No Pending Requests
                </h5>

                <p class="text-muted mb-0">
                    All asset requests are processed.
                </p>

            </div>

        </div>
    }
    else
    {
        <div class="row g-4">

            @foreach (var req in requests)
            {
                <div class="col-xl-4 col-lg-6">

                    <div class="card border-0 shadow-sm h-100">

                        <div class="card-body d-flex flex-column">

                            <div class="d-flex justify-content-between align-items-start mb-3">

                                <div>

                                    <h5 class="fw-bold mb-1">
                                        @req.RequestType
                                    </h5>

                                    <div class="text-muted small">
                                        @req.EmployeeName
                                        (@req.EmployeeCode)
                                    </div>

                                </div>

                                <span class="badge bg-warning text-dark">
                                    Pending
                                </span>

                            </div>

                            <div class="small mb-2">

                                <strong>Asset:</strong>
                                @(string.IsNullOrWhiteSpace(req.AssetName)
                                                        ? "N/A"
                                                        : req.AssetName)

                            </div>

                            <div class="small mb-2">

                                <strong>Asset Code:</strong>
                                @(string.IsNullOrWhiteSpace(req.AssetCode)
                                                        ? "-"
                                                        : req.AssetCode)

                            </div>

                            <div class="small mb-2">

                                <strong>Department:</strong>
                                @(string.IsNullOrWhiteSpace(req.DepartmentName)
                                                        ? "-"
                                                        : req.DepartmentName)

                    </div>

                            <div class="small mb-3">

                                <strong>Requested:</strong>
                                @req.RequestedAt.ToLocalTime()
                                .ToString("dd MMM yyyy hh:mm tt")

                            </div>

                            <div class="border rounded p-3 bg-light small mb-4 flex-grow-1">

                                @req.Reason

                            </div>

                            <div class="d-flex gap-2 mt-auto">

                                <button class="btn btn-success flex-fill"
                                        @onclick="() => OpenApproveModal(req)">

                                    <i class="bi bi-check-circle me-2"></i>
                                    Approve

                                </button>

                                <button class="btn btn-danger flex-fill"
                                        @onclick="() => OpenRejectModal(req)">

                                    <i class="bi bi-x-circle me-2"></i>
                                    Reject

                                </button>

                            </div>

                        </div>

                    </div>

                </div>
                }

        </div>
    }

</div>

@if (selectedRequest != null)
{
    <div class="modal fade show d-block"
         style="background-color: rgba(0,0,0,0.5);">

        <div class="modal-dialog modal-dialog-centered">

            <div class="modal-content border-0 shadow">

                <div class="modal-header">

                    <h5 class="modal-title fw-bold">

                        @(isRejecting
                                            ? "Reject Request"
                                            : "Approve Request")

                </h5>

                    <button class="btn-close"
                            @onclick="CloseModal">
                    </button>

                </div>

                <div class="modal-body">

                    <div class="mb-3">

                        <label class="form-label fw-semibold">
                            Comments
                        </label>

                        <textarea class="form-control"
                                  rows="4"
                                  @bind="reviewComments">
                            </textarea>

                    </div>

                @if (isRejecting)
                    {
                        <div class="mb-3">

                            <label class="form-label fw-semibold">
                                Rejection Reason
                            </label>

                            <textarea class="form-control"
                                      rows="3"
                                      @bind="rejectionReason">
                                    </textarea>

                        </div>
                    }

                </div>

                <div class="modal-footer">

                    <button class="btn btn-light"
                            @onclick="CloseModal">

                        Cancel

                    </button>

                    <button class="btn @(isRejecting ? "btn-danger" : "btn-success")"
                            disabled="@isSubmitting"
                            @onclick="SubmitReviewAsync">

                        @if (isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }

                        @(isRejecting ? "Reject" : "Approve")

                    </button>

                </div>

            </div>

        </div>

    </div>
}

<style>

    .text-primary {
        color: #5c4ac7 !important;
    }

    .btn-primary {
        background-color: #5c4ac7;
        border-color: #5c4ac7;
    }

        .btn-primary:hover {
            background-color: #4d3db0;
            border-color: #4d3db0;
        }

</style>

@code {

    private List<AssetRequestDto> requests = new();

    private AssetRequestDto? selectedRequest;

    private bool isLoading = true;

    private bool isSubmitting;

    private bool isRejecting;

    private string reviewComments = string.Empty;

    private string rejectionReason = string.Empty;

    private Guid organizationId;

    private Guid employeeId;

    private Guid? departmentId;

    private string userId = string.Empty;

    private string role = string.Empty;

    private HubConnection? _hub;

    protected override async Task OnInitializedAsync()
    {
        var context = await CurrentUserService
            .GetEmployeeDashboardContextAsync();

        if (context == null)
        {
            await JS.InvokeVoidAsync(
                "showToastNotification",
                "Error",
                "Unable to load user context.",
                "",
                "error");

            return;
        }

        organizationId = context.OrganizationId;

        employeeId = context.EmployeeId;

        departmentId = context.DepartmentId;

        userId = context.UserId;

        role = context.Role;

        await LoadRequestsAsync();
    }

    private async Task LoadRequestsAsync()
    {
        isLoading = true;

        try
        {
            requests = await AssetRequestService
                .GetPendingForApproverAsync(
                    organizationId,
                    role,
                    departmentId);

            requests = requests
                .OrderByDescending(r => r.RequestedAt)
                .ToList();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync(
                "showToastNotification",
                "Error",
                ex.Message,
                "",
                "error");
        }
        finally
        {
            isLoading = false;

            await InvokeAsync(StateHasChanged);
        }
    }

    private void OpenApproveModal(AssetRequestDto req)
    {
        selectedRequest = req;

        isRejecting = false;

        reviewComments = string.Empty;

        rejectionReason = string.Empty;
    }

    private void OpenRejectModal(AssetRequestDto req)
    {
        selectedRequest = req;

        isRejecting = true;

        reviewComments = string.Empty;

        rejectionReason = string.Empty;
    }

    private void CloseModal()
    {
        selectedRequest = null;

        reviewComments = string.Empty;

        rejectionReason = string.Empty;
    }

    private async Task SubmitReviewAsync()
    {
        if (selectedRequest == null)
            return;

        if (isRejecting &&
            string.IsNullOrWhiteSpace(rejectionReason))
        {
            await JS.InvokeVoidAsync(
                "showToastNotification",
                "Validation",
                "Please provide rejection reason.",
                "",
                "warning");

            return;
        }

        isSubmitting = true;

        try
        {
            var dto = new ReviewAssetRequestDto
            {
                AssetRequestId = selectedRequest.AssetRequestId,

                ApprovalRequestId =
                    selectedRequest.ApprovalRequestId
                    ?? throw new Exception(
                        "Approval request ID missing."),

                Comments = reviewComments,

                RejectionReason = rejectionReason
            };

            if (isRejecting)
            {
                await AssetRequestService.RejectRequestAsync(
                    organizationId,
                    dto,
                    userId,
                    role,
                    employeeId,
                    departmentId);
            }
            else
            {
                await AssetRequestService.ApproveRequestAsync(
                    organizationId,
                    dto,
                    userId,
                    role,
                    employeeId,
                    departmentId);
            }

            await JS.InvokeVoidAsync(
                "showToastNotification",
                "Success",
                $"Request {(isRejecting ? "rejected" : "approved")} successfully.",
                "",
                "success");

            CloseModal();

            await LoadRequestsAsync();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync(
                "showToastNotification",
                "Error",
                ex.Message,
                "",
                "error");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        _hub = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/notificationHub"))
            .WithAutomaticReconnect()
            .Build();

        _hub.On<NotificationPushDto>(
            "ReceiveNotification",
            async payload =>
            {
                await LoadRequestsAsync();

                await InvokeAsync(StateHasChanged);
            });

        await _hub.StartAsync();

        await _hub.SendAsync(
            "JoinUserGroup",
            userId);
    }

    public async ValueTask DisposeAsync()
    {
        if (_hub != null)
        {
            await _hub.DisposeAsync();
        }
    }

} *@