@page "/hr/employees/{EmployeeId:guid}/documents"
@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization
@using Humatrix_HRMS.Services.Documents
@using Humatrix_HRMS.DTOs.Documents

@attribute [Authorize(Roles = "OrgAdmin,HR")]
@inject EmployeeService EmployeeService
@inject IEmployeeDocumentService EmployeeDocumentService
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Employee Documents Vault | Humatrix</PageTitle>

<div class="container py-4">
    <div class="mb-4">
        <button class="btn btn-link text-decoration-none p-0 text-muted" @onclick="NavigateBackToDetails">
            <i class="bi bi-arrow-left me-1"></i> Back to Profile Details
        </button>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <div class="mt-2 text-muted">Loading employee document vault...</div>
        </div>
    }
    else if (employeeData == null)
    {
        <div class="alert alert-danger text-center shadow-sm">
            <i class="bi bi-exclamation-octagon me-2"></i> Employee record not found.
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0 p-4 mb-4 bg-light">
            <div class="row align-items-center">
                <div class="col-md-7">
                    <span class="text-uppercase tracking-wider small fw-bold text-muted">Document Vault For</span>
                    <h3 class="fw-bold text-dark mb-1">@employeeData.FullName</h3>
                    <p class="text-muted mb-0">
                        Code: <span class="fw-bold text-secondary">@employeeData.EmployeeCode</span> |
                        Dept: <span class="fw-bold text-secondary">@employeeData.DepartmentName</span> |
                        Designation: <span class="fw-bold text-secondary">@employeeData.DesignationName</span>
                    </p>
                </div>
                <div class="col-md-5 mt-3 mt-md-0">
                    <div class="d-flex justify-content-between small text-muted mb-1">
                        <span>Profile Compliance Status</span>
                        <span class="fw-bold text-dark">@(dashboardData?.ProfileCompletionPercentage ?? 0)%</span>
                    </div>
                    @* <div class="progress" style="height: 10px;">
                        <div class="progress-bar bg-success" role="progressbar"
                             style="width: @(dashboardData?.ProfileCompletionPercentage ?? 0)%"
                             aria-valuenow="@(dashboardData?.ProfileCompletionPercentage ?? 0)"
                             aria-valuemin="0"
                             aria-valuemax="100"></div>
                    </div> *@
                    @* <div class="col-md-5 mt-3 mt-md-0">
                        <div class="d-flex justify-content-between small text-muted mb-1">
                            <span>Profile Compliance Status</span>
                            <span class="fw-bold text-dark">@(dashboardData?.ProfileCompletionPercentage ?? 0)%</span>
                        </div>
                        <div class="progress" style="height: 10px;">
                            <div class="progress-bar bg-success" role="progressbar" style="width: @(dashboardData?.ProfileCompletionPercentage ?? 0)%" aria-valuenow="@(dashboardData?.ProfileCompletionPercentage ?? 0)" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                    </div> *@

                    <div class="col-md-5 mt-3 mt-md-0">
                        <div class="d-flex justify-content-between small text-muted mb-1">
                            <span>Profile Compliance Status</span>
                            @if (dashboardData?.ProfileCompletionPercentage.HasValue == true)
                            {
                                <span class="fw-bold text-dark">@dashboardData.ProfileCompletionPercentage.Value%</span>
                            }
                            else
                            {
                                <span class="fw-bold text-muted">No requirements set</span>
                            }
                        </div>
                        <div class="progress mb-2" style="height: 10px;">
                            @if (dashboardData?.ProfileCompletionPercentage.HasValue == true)
                            {
                                <div class="progress-bar bg-success" role="progressbar"
                                     style="width: @dashboardData.ProfileCompletionPercentage.Value%"
                                     aria-valuenow="@dashboardData.ProfileCompletionPercentage.Value"
                                     aria-valuemin="0"
                                     aria-valuemax="100"></div>
                            }
                            else
                            {
                                <div class="progress-bar bg-secondary" role="progressbar"
                                     style="width: 100%"
                                     aria-valuenow="100"
                                     aria-valuemin="0"
                                     aria-valuemax="100">
                                    <span class="small text-white">No mandatory docs defined</span>
                                </div>
                            }
                        </div>
                        <div class="d-flex gap-3 flex-wrap small text-muted">
                            <div>📄 @(dashboardData?.UploadedDocuments ?? 0) / @(dashboardData?.TotalRequiredDocuments ?? 0) Uploaded</div>
                            <div>✓ @(dashboardData?.VerifiedDocuments ?? 0) Verified</div>
                            <div>⏳ @(dashboardData?.PendingDocuments ?? 0) Pending</div>
                        </div>

                        @if (dashboardData?.TotalRequiredDocuments == 0)
                        {
                            <div class="alert alert-info mt-2 p-1 small mb-0">
                                <i class="bi bi-info-circle me-1"></i> No mandatory document requirements configured for this organization.
                            </div>
                        }
                        else if (dashboardData?.MissingMandatoryCount > 0)
                        {
                            <div class="alert alert-warning mt-2 p-1 small mb-0">
                                ⚠️ @dashboardData.MissingMandatoryCount mandatory document(s) missing
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-6 col-md-2">
                <div class="card shadow-sm border-0 p-3 text-center bg-white h-100">
                    <div class="text-muted small fw-bold mb-1">Total Needed</div>
                    <div class="fs-4 fw-bold text-dark">@(dashboardData?.TotalRequiredDocuments ?? 0)</div>
                </div>
            </div>
            <div class="col-6 col-md-2">
                <div class="card shadow-sm border-0 p-3 text-center bg-white h-100 border-start border-success border-3">
                    <div class="text-success small fw-bold mb-1">Verified</div>
                    <div class="fs-4 fw-bold text-success">@(dashboardData?.VerifiedDocuments ?? 0)</div>
                </div>
            </div>
            <div class="col-6 col-md-2">
                <div class="card shadow-sm border-0 p-3 text-center bg-white h-100 border-start border-warning border-3">
                    <div class="text-warning small fw-bold mb-1">Pending Review</div>
                    <div class="fs-4 fw-bold text-warning">@(dashboardData?.PendingDocuments ?? 0)</div>
                </div>
            </div>
            <div class="col-6 col-md-2">
                <div class="card shadow-sm border-0 p-3 text-center bg-white h-100 border-start border-danger border-3">
                    <div class="text-danger small fw-bold mb-1">Rejected</div>
                    <div class="fs-4 fw-bold text-danger">@(dashboardData?.RejectedDocuments ?? 0)</div>
                </div>
            </div>
            <div class="col-12 col-md-4">
                <div class="card shadow-sm border-0 p-3 text-center h-100 @(dashboardData?.MissingMandatoryCount > 0 ? "bg-danger-subtle border border-danger-subtle" : "bg-success-subtle")">
                    <div class="@(dashboardData?.MissingMandatoryCount > 0 ? "text-danger" : "text-success") small fw-bold mb-1">
                        Missing Mandatory Docs
                    </div>
                    <div class="fs-4 fw-bold @(dashboardData?.MissingMandatoryCount > 0 ? "text-danger" : "text-success")">
                        @(dashboardData?.MissingMandatoryCount ?? 0)
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold text-secondary">All Document Status Tracks</h5>
                @if (dashboardData?.MissingMandatoryDocuments != null && dashboardData.MissingMandatoryDocuments.Any())
                {
                    <span class="badge bg-danger rounded-pill px-3">Action Required</span>
                }
            </div>
            <div class="card-body p-0">
                @if (dashboardData?.Documents == null || !dashboardData.Documents.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-folder-x fs-1 d-block mb-2"></i>
                        <p class="mb-0">No documents trackable or matching requirements defined.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light text-muted small text-uppercase">
                                <tr>
                                    <th class="ps-4" style="width: 30%;">Document Requirement</th>
                                    <th style="width: 15%;">Category</th>
                                    <th style="width: 15%;">Status</th>
                                    <th style="width: 10%;">Version</th>
                                    <th style="width: 15%;">Last Upload Event</th>
                                    <th class="text-end pe-4" style="width: 15%;">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var doc in dashboardData.Documents)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="fw-bold text-dark mb-1">@doc.DocumentTypeName</div>
                                            <div class="d-flex gap-1 align-items-center flex-wrap">
                                                @if (doc.IsMandatory)
                                                {
                                                    <span class="badge bg-danger bg-opacity-10 text-danger px-2 py-1" style="font-size: 0.7rem;">Required</span>
                                                }
                                                @if (doc.RequiresVerification)
                                                {
                                                    <span class="badge bg-primary bg-opacity-10 text-primary px-2 py-1" style="font-size: 0.7rem;">Requires Verification</span>
                                                }
                                            </div>
                                        </td>
                                        <td>
                                            <span class="text-muted small text-capitalize">@doc.Category</span>
                                        </td>
                                        <td>
                                            <span class="badge @doc.StatusBadgeClass px-2 py-1 fw-semibold">
                                                <span class="me-1">@doc.StatusIcon</span>@doc.Status
                                            </span>
                                        </td>
                                        <td>
                                            <span class="badge bg-light text-dark border">v@(doc.Version)</span>
                                        </td>
                                        <td>
                                            @if (doc.UploadedAt.HasValue && doc.Status != "NotUploaded")
                                            {
                                                <div class="small text-dark fw-semibold">
                                                    @doc.UploadedAt.Value.ToString("dd MMM yyyy")
                                                </div>
                                                <div class="text-muted" style="font-size: 0.75rem;">
                                                    @doc.UploadedAt.Value.ToString("hh:mm tt")
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">-</span>
                                            }
                                        </td>
                                        <td class="text-end pe-4">
                                            @if (doc.Status != "NotUploaded" && doc.DocumentId != Guid.Empty)
                                            {
                                                <button class="btn btn-sm btn-outline-primary shadow-sm"
                                                        @onclick="() => TriggerDownload(doc.DocumentId)"
                                                        title="Download File">
                                                    <i class="bi bi-download me-1"></i> View File
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-sm btn-light border text-muted" disabled>
                                                    <i class="bi bi-cloud-slash me-1"></i> Missing
                                                </button>
                                            }
                                        </td>
                                    </tr>

                                    @if (!string.IsNullOrWhiteSpace(doc.RejectionRemarks) && doc.Status == "Rejected")
                                    {
                                        <tr class="table-danger-subtle border-0">
                                            <td colspan="6" class="ps-4 py-2 border-0">
                                                <div class="text-danger small d-flex align-items-center">
                                                    <i class="bi bi-exclamation-triangle-fill me-2 fs-6"></i>
                                                    <div>
                                                        <strong>Rejection Feedback:</strong> @doc.RejectionRemarks
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public Guid EmployeeId { get; set; }

    private EmployeeDetailsDto? employeeData;
    private EmployeeDocumentDashboardDto? dashboardData;
    private bool isLoading = true;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;

        if (EmployeeId == Guid.Empty)
        {
            Nav.NavigateTo("/employees");
            return;
        }

        try
        {
            employeeData = await EmployeeService.GetEmployeeDetailsByIdAsync(EmployeeId);

            if (employeeData != null)
            {
                dashboardData = await EmployeeDocumentService.GetEmployeeDocumentDashboardAsync(EmployeeId, employeeData.OrganizationId);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error reading profiles data for employee validation: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }

        if (employeeData == null)
        {
            Nav.NavigateTo("/employees");
        }
    }

    private void NavigateBackToDetails()
    {
        Nav.NavigateTo($"/employee/details/{EmployeeId}");
    }

    private void TriggerDownload(Guid documentId)
    {
        if (documentId != Guid.Empty)
        {
            Nav.NavigateTo($"api/documents/download/{documentId}", forceLoad: true);
        }
    }
}