@page "/hr/leaves"
@rendermode InteractiveServer

@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize(Roles = "HR")]

@inject LeaveService LeaveService

<PageTitle>HR Leave Approval | Humatrix</PageTitle>

<div class="container-fluid px-4 mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-semibold mb-0">Leave Approvals</h2>
            <small class="text-muted">Review and manage employee leave requests</small>
        </div>

        @* Changed to @onchange to properly handle async state *@
        <select class="form-select w-auto" @onchange="HandleStatusChange">
            <option value="">All Requests</option>
            <option value="Pending">Pending Only</option>
            <option value="Approved">Approved</option>
            <option value="Rejected">Rejected</option>
        </select>
    </div>

    <!-- ALERT -->
    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert alert-@messageType alert-dismissible fade show">
            @message
            <button class="btn-close" @onclick="() => message = null"></button>
        </div>
    }

    <!-- TABLE -->
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">

            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Employee</th>
                        <th>Department</th>
                        <th>Type</th>
                        <th>Dates</th>
                        <th>Days</th>
                        <th>Status</th>
                        <th class="text-end" style="width:220px;"></th>
                    </tr>
                </thead>

                <tbody>
                    @if (loading)
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4">
                                <div class="spinner-border text-primary"></div>
                                <div class="mt-2"><small class="text-muted">Loading requests...</small></div>
                            </td>
                        </tr>
                    }
                    else if (leaves.Count == 0)
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                No leave requests found
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var l in leaves.OrderBy(x => x.Status != "Pending"))
                        {
                            <tr class="@(l.Status == "Pending" ? "table-warning" : "")">
                                <td>
                                    <div class="fw-semibold">@l.EmployeeName</div>
                                    <small class="text-muted">@l.Reason</small>
                                </td>
                                <td>@l.Department</td>
                                <td>@l.LeaveTypeName</td>
                                <td>
                                    <small>
                                        @l.FromDate.ToString("dd MMM") →
                                        @l.ToDate.ToString("dd MMM")
                                    </small>
                                </td>
                                <td>@l.TotalDays</td>
                                <td>
                                    <span class="badge @GetStatusClass(l.Status)">
                                        @l.Status
                                    </span>
                                </td>
                                <td class="text-end">
                                    @if (l.Status == "Pending")
                                    {
                                        <div class="d-flex justify-content-end gap-2">
                                            <button class="btn btn-sm btn-success"
                                                    disabled="@actionLoading"
                                                    @onclick="() => ConfirmApprove(l.LeaveRequestId)">
                                                Approve
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger"
                                                    disabled="@actionLoading"
                                                    @onclick="() => OpenReject(l)">
                                                Reject
                                            </button>
                                        </div>
                                    }
                                    else if (l.Status == "Rejected")
                                    {
                                        <small class="text-danger">
                                            @l.RejectionReason
                                        </small>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- REJECT MODAL -->
    @if (showRejectModal)
    {
        <div class="modal fade show d-block" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content shadow">
                    <div class="modal-header">
                        <h5 class="modal-title">Reject Leave</h5>
                        <button class="btn-close" @onclick="CloseReject"></button>
                    </div>
                    <div class="modal-body">
                        <label class="form-label">Reason</label>
                        <textarea class="form-control"
                                  rows="3"
                                  @bind="rejectReason"></textarea>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="CloseReject">Cancel</button>
                        <button class="btn btn-danger"
                                disabled="@actionLoading"
                                @onclick="ConfirmReject">
                            Reject
                        </button>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal-backdrop fade show"></div>
    }
</div>

<style>
    .badge-success {
        background: #198754;
        color: white;
    }

    .badge-danger {
        background: #dc3545;
        color: white;
    }

    .badge-warning {
        background: #ffc107;
        color: black;
    }
</style>

@code {
    private List<LeaveRequestDto> leaves = new();
    private bool loading = false;
    private bool actionLoading = false;
    private string? message;
    private string messageType = "success";
    private bool showRejectModal = false;
    private Guid selectedLeaveId;
    private string rejectReason = "";
    private string? selectedStatus;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task HandleStatusChange(ChangeEventArgs e)
    {
        selectedStatus = e.Value?.ToString();
        await LoadData();
    }

    private async Task LoadData()
    {
        // Guard to prevent multiple simultaneous loads
        if (loading) return;

        try
        {
            loading = true;
            StateHasChanged(); // Ensure the UI shows the spinner immediately

            leaves = await LeaveService.GetAllForHRAsync(selectedStatus);
        }
        catch (Exception ex)
        {
            message = "Error loading data: " + ex.Message;
            messageType = "danger";
        }
        finally
        {
            loading = false;
            StateHasChanged(); // Ensure the spinner hides
        }
    }

    private async Task ConfirmApprove(Guid id)
    {
        try
        {
            actionLoading = true;
            await LeaveService.UpdateStatusAsync(id, "Approved");
            message = "Leave approved successfully";
            messageType = "success";
            await LoadData();
        }
        catch (Exception ex)
        {
            message = ex.Message;
            messageType = "danger";
        }
        finally
        {
            actionLoading = false;
        }
    }

    private void OpenReject(LeaveRequestDto l)
    {
        selectedLeaveId = l.LeaveRequestId;
        rejectReason = "";
        showRejectModal = true;
    }

    private void CloseReject() => showRejectModal = false;

    private async Task ConfirmReject()
    {
        if (string.IsNullOrWhiteSpace(rejectReason))
        {
            message = "Rejection reason is required";
            messageType = "danger";
            return;
        }

        try
        {
            actionLoading = true;
            await LeaveService.UpdateStatusAsync(selectedLeaveId, "Rejected", rejectReason);
            message = "Leave rejected";
            messageType = "warning";
            showRejectModal = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            message = ex.Message;
            messageType = "danger";
        }
        finally
        {
            actionLoading = false;
        }
    }

    private string GetStatusClass(string status) => status switch
    {
        "Approved" => "badge-success",
        "Rejected" => "badge-danger",
        _ => "badge-warning"
    };
}