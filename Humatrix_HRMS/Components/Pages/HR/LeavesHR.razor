@page "/hr/leaves"
@rendermode InteractiveServer
@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize(Roles = "HR,OrgAdmin")]
@inject LeaveService LeaveService
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Leave Approvals | Humatrix HRMS</PageTitle>

@* Toast Notification Container *@
<div class="position-fixed top-0 end-0 p-3" style="z-index: 1080;">
    @if (!string.IsNullOrEmpty(message))
    {
        <div class="toast show align-items-center border-0 shadow-lg mb-2" role="alert" style="background-color: @(isError ? "#fef2f2" : "#f0fdf4"); color: @(isError ? "#991b1b" : "#166534"); border-left: 4px solid @(isError ? "#ef4444" : "#10b981") !important; border-radius: 10px;">
            <div class="d-flex p-3">
                <div class="toast-body d-flex align-items-center p-0">
                    <i class="bi @(isError ? "bi-exclamation-triangle-fill" : "bi-check-circle-fill") me-2 fs-5"></i>
                    <span class="small fw-medium">@message</span>
                </div>
                <button type="button" class="btn-close m-auto me-0 shadow-none" @onclick="() => message = null"></button>
            </div>
        </div>
    }
</div>

<div class="container-fluid px-4 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom row-gap-3 flex-wrap">
        <div>
            <h2 class="fw-bold tracking-tight text-dark mb-1">Leave Approvals</h2>
            <p class="text-muted small mb-0">Review and manage employee leave requests.</p>
        </div>
        <div class="d-flex gap-2">
            <input type="text" class="form-control premium-edit-input" style="width: 200px;"
                   placeholder="Search employee..." @bind="searchTerm" @bind:event="oninput" />

            <select class="form-select premium-edit-input" style="width: 150px;" @onchange="HandleFilterChange">
                <option value="">All Statuses</option>
                <option value="Pending">Pending</option>
                <option value="Approved">Approved</option>
                <option value="Rejected">Rejected</option>
            </select>

            <button class="btn btn-dashboard d-flex align-items-center gap-2 shadow-sm" @onclick="GoDashboard">
                <i class="bi bi-speedometer2"></i> DASHBOARD
            </button>
        </div>
    </div>

    <div class="card border-0 shadow-sm panel-container-card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4 text-secondary small fw-bold tracking-wider py-3">EMPLOYEE / DEPARTMENT</th>
                        @if (isOrgAdmin)
                        {
                            <th class="text-secondary small fw-bold tracking-wider py-3">REQUESTED BY</th>
                        }
                        <th class="text-secondary small fw-bold tracking-wider py-3">TYPE</th>
                        <th class="text-secondary small fw-bold tracking-wider py-3">DATES</th>
                        <th class="text-secondary small fw-bold tracking-wider py-3">DAYS</th>
                        <th class="text-secondary small fw-bold tracking-wider py-3 text-center">STATUS</th>
                        <th class="text-secondary small fw-bold tracking-wider py-3 text-end pe-4">ACTION/REVIEWER</th>
                    </tr>
                </thead>
                <tbody>
                    @if (loading)
                    {
                        <tr><td colspan="@(isOrgAdmin ? 7 : 6)" class="text-center py-5"><div class="spinner-border text-primary"></div></td></tr>
                    }
                    else if (!FilteredLeaves.Any())
                    {
                        <tr><td colspan="@(isOrgAdmin ? 7 : 6)" class="text-center py-5 text-muted">No requests found.</td></tr>
                    }
                    else
                    {
                        @foreach (var l in FilteredLeaves.OrderByDescending(x => x.AppliedAt))
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-dark">@l.EmployeeName</div>
                                    <small class="text-muted">@l.Department</small>
                                </td>
                                @if (isOrgAdmin)
                                {
                                    <td>
                                        <span class="badge bg-light text-dark border">@l.RequestedByRole</span>
                                    </td>
                                }
                                <td class="small">@l.LeaveTypeName</td>
                                <td class="small">@l.FromDate.ToString("dd MMM") – @l.ToDate.ToString("dd MMM yyyy")</td>
                                <td class="fw-bold">@l.TotalDays</td>
                                <td class="text-center">
                                    <span class="status-indicator-pill @GetStatusClass(l.Status)">@l.Status</span>
                                </td>
                                <td class="text-end pe-4">
                                    @if (l.Status == "Pending")
                                    {
                                        <button class="btn btn-sm btn-action-approve" @onclick="() => Approve(l.LeaveRequestId)">Approve</button>
                                        <button class="btn btn-sm btn-action-cancel" @onclick="() => OpenRejectModal(l)">Reject</button>
                                    }
                                    else if (l.ApprovedBy.HasValue && reviewerCache.ContainsKey(l.ApprovedBy.Value))
                                    {
                                        <div class="small">
                                            <div class="fw-bold text-dark">@reviewerCache[l.ApprovedBy.Value].Name</div>
                                            <div class="text-muted" style="font-size: 10px;">@reviewerCache[l.ApprovedBy.Value].Role</div>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (showRejectModal && selectedLeave != null)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 14px;">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Reject Request</h5>
                    <button class="btn-close" @onclick="CloseRejectModal"></button>
                </div>
                <div class="modal-body">
                    <textarea class="form-control premium-edit-input" rows="3" placeholder="Reason for rejection..." @bind="rejectReason"></textarea>
                </div>
                <div class="modal-footer border-0">
                    <button class="btn btn-action-cancel" @onclick="CloseRejectModal">Cancel</button>
                    <button class="btn btn-action-danger" @onclick="ConfirmReject">Reject Request</button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .tracking-tight {
        letter-spacing: -0.025em;
    }

    .tracking-wider {
        letter-spacing: 0.04em;
        font-size: 11px;
    }

    .panel-container-card {
        border-radius: 14px;
        background-color: #ffffff;
        overflow: hidden;
    }

    .premium-edit-input {
        font-size: 13.5px;
        padding: 8px 12px;
        border-radius: 8px;
        border: 1px solid #cbd5e1;
    }

    .btn-dashboard {
        background: #ffffff !important;
        border: 1px solid #e5e7eb !important;
        color: #4b5563 !important;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
    }

        .btn-dashboard:hover {
            border-color: #5c4ac7 !important;
            color: #5c4ac7 !important;
        }

    .btn-action-approve {
        background: #10b981;
        color: white;
        border-radius: 6px;
        font-size: 12px;
        margin-right: 5px;
    }

    .btn-action-cancel {
        background: #f1f5f9;
        color: #475569;
        border: 1px solid #e2e8f0;
        border-radius: 6px;
        padding: 4px 12px;
        font-size: 12px;
    }

    .btn-action-danger {
        background: #ef4444;
        color: white;
        border-radius: 8px;
        font-size: 13px;
    }

    .status-indicator-pill {
        font-size: 11px;
        font-weight: 600;
        padding: 2px 10px;
        border-radius: 6px;
    }
</style>

@code {
    private List<LeaveRequestDto> leaves = new();
    private Dictionary<Guid, (string Name, string Role)> reviewerCache = new();
    private LeaveRequestDto? selectedLeave;
    private bool loading, showRejectModal, isOrgAdmin, isError;
    private string? message, selectedStatus, rejectReason, searchTerm;

    private IEnumerable<LeaveRequestDto> FilteredLeaves =>
        leaves.Where(l => (string.IsNullOrEmpty(selectedStatus) || l.Status == selectedStatus) &&
                         (string.IsNullOrWhiteSpace(searchTerm) || l.EmployeeName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)));

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        isOrgAdmin = authState.User.IsInRole("OrgAdmin");
        await LoadData();
    }

    private async Task LoadData()
    {
        loading = true;
        try
        {
            leaves = await LeaveService.GetAllForHRAsync(null);
            foreach (var l in leaves.Where(x => x.ApprovedBy.HasValue && !reviewerCache.ContainsKey(x.ApprovedBy.Value)))
            {
                reviewerCache[l.ApprovedBy.Value] = await LeaveService.GetReviewerInfoAsync(l.ApprovedBy);
            }
        }
        catch (Exception ex) { message = ex.Message; isError = true; TriggerToastAutoClose(); }
        finally { loading = false; }
    }

    private async Task HandleFilterChange(ChangeEventArgs e)
    {
        selectedStatus = e.Value?.ToString();
        await LoadData();
    }

    private async Task GoDashboard()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.IsInRole("OrgAdmin")) Nav.NavigateTo("/org/dashboard");
        else if (user.IsInRole("HR")) Nav.NavigateTo("/hr/dashboard");
    }

    private void OpenRejectModal(LeaveRequestDto l) { selectedLeave = l; rejectReason = string.Empty; showRejectModal = true; }
    private void CloseRejectModal() => showRejectModal = false;

    private async Task Approve(Guid id)
    {
        try
        {
            await LeaveService.UpdateStatusAsync(id, "Approved");
            message = "Request approved successfully.";
            isError = false;
            await LoadData();
        }
        catch (Exception ex) { message = ex.Message; isError = true; }
        TriggerToastAutoClose();
    }

    private async Task ConfirmReject()
    {
        try
        {
            await LeaveService.UpdateStatusAsync(selectedLeave!.LeaveRequestId, "Rejected", rejectReason);
            message = "Request rejected.";
            isError = false;
            CloseRejectModal();
            await LoadData();
        }
        catch (Exception ex) { message = ex.Message; isError = true; }
        TriggerToastAutoClose();
    }

    private void TriggerToastAutoClose()
    {
        _ = Task.Run(async () =>
        {
            await Task.Delay(4000);
            message = null;
            await InvokeAsync(StateHasChanged);
        });
    }

    private static string GetStatusClass(string? status) => status switch { "Approved" => "bg-success text-white", "Pending" => "bg-warning text-dark", "Rejected" => "bg-danger text-white", _ => "bg-light" };
}