@page "/hr/tasks"
@rendermode InteractiveServer

@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Data
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.WebUtilities

@attribute [Authorize(Roles = "HR,OrgAdmin")]

@inject TaskService TaskService
@inject NavigationManager Nav
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject CurrentUserService CurrentUser

<PageTitle>Task Management | Humatrix HRMS</PageTitle>

@* Toast Notification Container *@
<div class="position-fixed top-0 end-0 p-3" style="z-index: 1080;">
    @if (!string.IsNullOrEmpty(message))
    {
        <div class="toast show align-items-center border-0 shadow-lg mb-2" role="alert" style="background-color: #f0fdf4; color: #166534; border-left: 4px solid #10b981 !important; border-radius: 10px;">
            <div class="d-flex p-3">
                <div class="toast-body d-flex align-items-center p-0">
                    <i class="bi bi-check-circle-fill me-2 fs-5" style="color: #10b981;"></i>
                    <span class="small fw-medium">@message</span>
                </div>
                <button type="button" class="btn-close m-auto me-0 shadow-none" @onclick="() => message = null"></button>
            </div>
        </div>
    }
</div>

<div class="container-fluid px-4 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom row-gap-3 flex-wrap">
        <div>
            <h2 class="fw-bold tracking-tight text-dark mb-1">Task Management</h2>
            <p class="text-muted small mb-0">Monitor, assign, and track organizational operational tasks.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-add-task d-flex align-items-center gap-2 shadow-sm"
                    @onclick='() => Nav.NavigateTo("/hr/assign-task")'>
                <i class="bi bi-plus-circle"></i> ASSIGN TASK
            </button>
            <button class="btn btn-interactive-back shadow-sm d-flex align-items-center gap-2"
                    @onclick='() => Nav.NavigateTo(dashboardPath)'>
                <i class="bi bi-speedometer2"></i> DASHBOARD
            </button>
        </div>
    </div>

    @* Metrics Section *@
    <div class="row g-3 mb-4">
        <div class="col-md-3 col-sm-6">
            <div class="card border-0 shadow-sm metric-panel-card" style="border-left: 4px solid #5c4ac7 !important;">
                <div class="card-body d-flex align-items-center justify-content-between p-3">
                    <div>
                        <span class="text-secondary small fw-bold tracking-wider text-uppercase d-block mb-1">Total Tasks</span>
                        <h3 class="fw-bold text-dark mb-0">@tasks.Count</h3>
                    </div>
                    <div class="metric-icon-box" style="background-color: rgba(92, 74, 199, 0.08); color: #5c4ac7;">
                        <i class="bi bi-list-task"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="card border-0 shadow-sm metric-panel-card" style="border-left: 4px solid #ffc107 !important;">
                <div class="card-body d-flex align-items-center justify-content-between p-3">
                    <div>
                        <span class="text-secondary small fw-bold tracking-wider text-uppercase d-block mb-1">Pending</span>
                        <h3 class="fw-bold text-dark mb-0">@tasks.Count(t => t.Status == "Pending")</h3>
                    </div>
                    <div class="metric-icon-box" style="background-color: rgba(255, 193, 7, 0.08); color: #ffc107;">
                        <i class="bi bi-clock-history"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="card border-0 shadow-sm metric-panel-card" style="border-left: 4px solid #0dcaf0 !important;">
                <div class="card-body d-flex align-items-center justify-content-between p-3">
                    <div>
                        <span class="text-secondary small fw-bold tracking-wider text-uppercase d-block mb-1">In Progress</span>
                        <h3 class="fw-bold text-dark mb-0">@tasks.Count(t => t.Status == "In Progress")</h3>
                    </div>
                    <div class="metric-icon-box" style="background-color: rgba(13, 202, 240, 0.08); color: #0dcaf0;">
                        <i class="bi bi-gear-slide"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="card border-0 shadow-sm metric-panel-card" style="border-left: 4px solid #10b981 !important;">
                <div class="card-body d-flex align-items-center justify-content-between p-3">
                    <div>
                        <span class="text-secondary small fw-bold tracking-wider text-uppercase d-block mb-1">Completed</span>
                        <h3 class="fw-bold text-dark mb-0">@tasks.Count(t => t.Status == "Completed")</h3>
                    </div>
                    <div class="metric-icon-box" style="background-color: rgba(16, 185, 129, 0.08); color: #10b981;">
                        <i class="bi bi-check2-circle"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Filters Section *@
    <div class="card border-0 shadow-sm p-3 mb-4 bg-light-gradient">
        <div class="row g-3 align-items-center">
            <div class="col-12 col-md-4">
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-search"></i></span>
                    <input class="form-control border-start-0 ps-0 text-input" placeholder="Search tasks or employees..." @bind="searchText" @bind:event="oninput" />
                </div>
            </div>
            <div class="col-6 col-md-4">
                <select class="form-select custom-select" @bind="selectedStatus">
                    <option value="">All Statuses</option>
                    <option>Pending</option>
                    <option>In Progress</option>
                    <option>Completed</option>
                </select>
            </div>
            <div class="col-6 col-md-4">
                <select class="form-select custom-select" @bind="selectedPriority">
                    <option value="">All Priorities</option>
                    <option>Low</option>
                    <option>Medium</option>
                    <option>High</option>
                </select>
            </div>
        </div>
    </div>

    @* Table Section *@
    <div class="card border-0 shadow-sm overflow-hidden mb-5">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 custom-table">
                <thead>
                    <tr>
                        <th class="ps-4">Task Details</th>
                        <th>Assigned To</th>
                        <th>Priority</th>
                        <th>Status</th>
                        <th>Progress</th>
                        <th>Due Date</th>
                        <th class="pe-4">Assigned Date</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!filteredTasks.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5">
                                <div class="empty-state">
                                    <i class="bi bi-clipboard-x display-4 text-muted"></i>
                                    <h5 class="mt-3 fw-semibold text-secondary">No tasks available</h5>
                                    <p class="text-muted small">Try modifying your filters or assign a new task.</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var t in filteredTasks)
                        {
                            <tr class="@(IsOverdue(t) ? "overdue-row" : "")">
                                <td class="ps-4 style-title-cell" style="min-width: 280px;">
                                    <div class="fw-bold text-dark mb-1">@t.Title</div>
                                    <div class="text-muted text-truncate-custom small">@(string.IsNullOrEmpty(t.Description) ? "No description provided." : t.Description)</div>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="avatar-circle">@(!string.IsNullOrEmpty(t.AssignedToName) ? t.AssignedToName[0].ToString() : "?")</div>
                                        <div>
                                            <div class="text-primary fw-semibold">@t.AssignedToName</div>
                                            @if (userRoles != null && userRoles.Contains("orgadmin"))
                                            {
                                                <div class="text-muted small" style="font-size: 0.7rem;">@t.DepartmentName</div>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge rounded-pill priority-badge @GetPriorityClass(t.Priority)">@t.Priority</span>
                                </td>
                                <td>
                                    <span class="badge rounded-pill status-badge @GetStatusClass(t.Status)">
                                        <i class="bi bi-circle-fill me-1 small-dot"></i>@t.Status
                                    </span>
                                </td>
                                <td style="min-width: 180px;">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="progress flex-grow-1 card-progress">
                                            <div class="progress-bar progress-bar-striped progress-bar-animated @GetProgressColor(t.Status)" style="width:@t.Progress%"></div>
                                        </div>
                                        <span class="fw-bold small text-secondary">@t.Progress%</span>
                                    </div>
                                </td>
                                <td>
                                    @if (t.DueDate.HasValue)
                                    {
                                        <div class="small fw-medium @(IsOverdue(t) ? "text-danger fw-bold" : "text-dark")">
                                            @t.DueDate.Value.ToString("dd MMM yyyy")
                                        </div>
                                        @if (IsOverdue(t))
                                        {
                                            <span class="badge bg-danger-soft text-danger overdue-tag" style="font-size: 0.65rem; padding: 2px 6px;">Overdue</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted small">-</span>
                                    }
                                </td>
                                <td class="pe-4 text-dark small fw-medium">
                                    @t.CreatedAt.ToString("dd MMM yyyy")
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .tracking-tight {
        letter-spacing: -0.025em;
    }

    .tracking-wider {
        letter-spacing: 0.04em;
        font-size: 11px;
    }

    .btn-add-task {
        background-color: #5c4ac7 !important;
        color: #ffffff !important;
        border: none !important;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
        transition: all 0.2s ease;
    }

        .btn-add-task:hover {
            background-color: #4b3ba6 !important;
            transform: translateY(-1px);
        }

    .btn-interactive-back {
        background: #ffffff !important;
        border: 1px solid #e5e7eb !important;
        color: #4b5563 !important;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
        transition: all 0.2s ease;
    }

        .btn-interactive-back:hover {
            background-color: #f8fafc !important;
            border-color: #5c4ac7 !important;
            color: #5c4ac7 !important;
            transform: translateY(-1px);
        }

    .metric-panel-card {
        border-radius: 12px;
        background-color: #ffffff;
        overflow: hidden;
        transition: transform 0.2s;
    }

        .metric-panel-card:hover {
            transform: translateY(-3px);
        }

    .metric-icon-box {
        width: 42px;
        height: 42px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
    }

    .bg-light-gradient {
        background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
        border: 1px solid #e9ecef !important;
        border-radius: 12px;
    }

    .custom-table th {
        color: #4a5568;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.75rem;
        padding: 16px 12px;
    }

    .custom-table tbody tr:hover {
        background-color: rgba(248, 249, 250, 0.85) !important;
    }

    .card-progress {
        height: 6px;
        background-color: #edf2f7;
        border-radius: 10px;
        overflow: hidden;
    }

    .avatar-circle {
        width: 28px;
        height: 28px;
        background-color: #e2e8f0;
        color: #4a5568;
        font-weight: bold;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.8rem;
        text-transform: uppercase;
    }

    .overdue-tag {
        margin-left: 5px;
    }

    .bg-success-soft {
        background-color: rgba(25, 135, 84, 0.1);
    }

    .bg-warning-soft {
        background-color: rgba(255, 193, 7, 0.15);
    }

    .bg-info-soft {
        background-color: rgba(13, 202, 240, 0.15);
    }

    .bg-danger-soft {
        background-color: rgba(220, 53, 69, 0.1);
    }
</style>

@code {
    private List<TaskDto> tasks = new();
    private List<string>? userRoles; // Nullable banaya

    private string? searchText;
    private string? selectedStatus;
    private string? selectedPriority;
    private string? message;
    private string dashboardPath = "/";

    protected override async Task OnInitializedAsync()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("success", out var msg))
        {
            message = msg;
            _ = Task.Run(async () => { await Task.Delay(4000); message = null; await InvokeAsync(StateHasChanged); });
        }

        using var db = DbFactory.CreateDbContext();
        var sessionUser = await CurrentUser.GetUserAsync();
        if (sessionUser == null) return;

        userRoles = await (from ur in db.UserRoles
                           join r in db.Roles on ur.RoleId equals r.Id
                           where ur.UserId == sessionUser.Id
                           select r.Name.ToLower()).ToListAsync();

        bool isOrgAdmin = userRoles != null && userRoles.Contains("orgadmin");
        dashboardPath = isOrgAdmin ? "/org/dashboard" : "/hr/dashboard";
        tasks = await TaskService.GetTasksAssignedByMeAsync();
    }

    private List<TaskDto> filteredTasks => tasks.Where(t =>
        (string.IsNullOrWhiteSpace(searchText) || t.Title.Contains(searchText, StringComparison.OrdinalIgnoreCase) || (t.AssignedToName != null && t.AssignedToName.Contains(searchText, StringComparison.OrdinalIgnoreCase))) &&
        (string.IsNullOrEmpty(selectedStatus) || t.Status == selectedStatus) &&
        (string.IsNullOrEmpty(selectedPriority) || t.Priority == selectedPriority)).OrderBy(t => t.Status == "Completed").ThenByDescending(t => t.CreatedAt).ToList();

    private bool IsOverdue(TaskDto t) => t.DueDate.HasValue && t.DueDate.Value.Date < DateTime.Today && t.Status != "Completed";

    private string GetStatusClass(string status) => status switch { "Completed" => "bg-success-soft text-success", "Pending" => "bg-warning-soft text-warning", "In Progress" => "bg-info-soft text-info", _ => "bg-secondary text-dark" };
    private string GetPriorityClass(string priority) => priority switch { "High" => "bg-danger text-danger bg-opacity-10", "Medium" => "bg-primary text-primary bg-opacity-10", "Low" => "bg-secondary text-secondary bg-opacity-10", _ => "bg-light text-dark" };
    private string GetProgressColor(string status) => status switch { "Completed" => "bg-success", "In Progress" => "bg-info", _ => "bg-warning" };
}