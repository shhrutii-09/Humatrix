    private async Task CompleteExit()
    {
        if (_selectedExit == null) return;

        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm",
            "⚠️ Are you sure you want to complete this exit?\n\n" +
            "This will:\n" +
            "• Mark the employee as INACTIVE\n" +
            "• Revoke all system access\n" +
            "• Mark the exit as COMPLETED\n\n" +
            "This action cannot be undone.");

        if (!confirmed) return;

        _isProcessing = true;
        _processError = null;

        try
        {
            await ExitService.CompleteExitAsync(
                _selectedExit.ExitId,
                _issueExperienceLetter,
                _issueRelievingLetter);

            await JSRuntime.InvokeVoidAsync("alert", "🎉 Exit process completed successfully!");
            CloseModal();
            await LoadExits();
            await LoadStats();
        }
        catch (Exception ex)
        {
            _processError = ex.Message;
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private async Task SaveExitInterview()
    {
        if (_selectedExit == null) return;

        if (string.IsNullOrWhiteSpace(_interviewFeedback))
        {
            _processError = "Please enter interview feedback before saving.";
            return;
        }

        _isProcessing = true;
        _processError = null;

        try
        {
            await ExitService.RecordExitInterviewAsync(_selectedExit.ExitId, _interviewFeedback);
            await JSRuntime.InvokeVoidAsync("alert", "📝 Exit interview feedback saved!");
            await LoadExits();
        }
        catch (Exception ex)
        {
            _processError = ex.Message;
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private string GetStatusBadgeClass(string status) => status switch
    {
        "Pending" => "bg-warning text-dark",
        "Approved" => "bg-info",
        "ClearanceInProgress" => "bg-primary",
        "Completed" => "bg-success",
        "Rejected" => "bg-danger",
        _ => "bg-secondary"
    };

    private string GetStatusText(string status) => status switch
    {
        "Pending" => "Pending Review",
        "Approved" => "Approved",
        "ClearanceInProgress" => "Clearance In Progress",
        "Completed" => "Completed",
        "Rejected" => "Rejected",
        _ => status
    };
}