    private async Task ProcessApproval()
    {
        if (_selectedExit == null) return;

        _isProcessing = true;
        _processError = null;

        try
        {
            if (_approveAction == "approve")
            {
                await ExitService.ApproveExitAsync(_selectedExit.ExitId, _approvalRemarks);
                await ExitService.StartClearanceAsync(_selectedExit.ExitId);
                await JSRuntime.InvokeVoidAsync("alert", "✅ Exit request approved successfully! Clearance process has been started.");
            }
            else
            {
                await ExitService.RejectExitAsync(_selectedExit.ExitId, _approvalRemarks);
                await JSRuntime.InvokeVoidAsync("alert", "❌ Exit request rejected.");
            }

            CloseModal();
            await LoadExits();
            await LoadStats();
        }
        catch (Exception ex)
        {
            _processError = ex.Message;
        }
        finally
        {
            _isProcessing = false;
        }
    }

