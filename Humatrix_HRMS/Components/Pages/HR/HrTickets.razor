@page "/hr/tickets"
@page "/admin/tickets"
@page "/hr/tickets/{TicketId:guid}"
@page "/admin/tickets/{TicketId:guid}"
@attribute [Authorize(Roles = "HR,OrgAdmin")]
@using Humatrix_HRMS.Data
@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Humatrix_HRMS.Services.AI
@using Microsoft.AspNetCore.Authorization
@using static Humatrix_HRMS.Services.AI.TicketService
@inject TicketService TicketService
@inject CurrentUserService CurrentUserService
@rendermode InteractiveServer

<PageTitle>Support Tickets</PageTitle>

<div class="container-fluid py-4">

    <!-- ── Header ──────────────────────────────────────────────────────── -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-0">🎫 Support Tickets</h4>
            <small class="text-muted">
                @if (_isOrgAdmin)
                {
                    <span>All departments</span>
                }
                else
                {

                    <span>Your department only</span>
                }
            </small>
        </div>
        <button class="btn btn-outline-secondary btn-sm" @onclick="RefreshAsync">
            <i class="bi bi-arrow-clockwise"></i> Refresh
        </button>
    </div>

    <!-- ── KPI Cards ───────────────────────────────────────────────────── -->
    @if (_stats != null)
    {
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-2">
                <div class="card kpi-card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="text-muted small">Open</div>
                        <div class="fs-3 fw-bold text-primary">@_stats.OpenTickets</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-2">
                <div class="card kpi-card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="text-muted small">In Progress</div>
                        <div class="fs-3 fw-bold text-warning">@_stats.InProgressTickets</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-2">
                <div class="card kpi-card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="text-muted small">Resolved</div>
                        <div class="fs-3 fw-bold text-success">@_stats.ResolvedTickets</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-2">
                <div class="card kpi-card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="text-muted small">Unassigned</div>
                        <div class="fs-3 fw-bold text-danger">@_stats.UnassignedTickets</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-2">
                <div class="card kpi-card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="text-muted small">This Month</div>
                        <div class="fs-3 fw-bold">@_stats.TotalTicketsThisMonth</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-2">
                <div class="card kpi-card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="text-muted small">Avg. Resolution</div>
                        <div class="fs-3 fw-bold">@_stats.AverageResolutionHours<small class="fs-6 text-muted"> hrs</small></div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- ── Filters ─────────────────────────────────────────────────────── -->
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body py-2">
            <div class="row g-2 align-items-center">
                <div class="col-auto">
                    <ul class="nav nav-pills mb-0">
                        @foreach (var tab in StatusTabs)
                        {
                            <li class="nav-item">
                                <button class="nav-link py-1 px-3 @(_activeStatus == tab ? "active" : "")"
                                        @onclick="@(() => SetStatusFilter(tab))">
                                    @tab
                                </button>
                            </li>
                        }
                    </ul>
                </div>
                <div class="col-auto ms-auto">
                    <select class="form-select form-select-sm" @onchange="OnPriorityChange">
                        <option value="">All Priorities</option>
                        <option>Low</option>
                        <option>Medium</option>
                        <option>High</option>
                        <option>Urgent</option>
                    </select>
                </div>
                <div class="col-auto">
                    <select class="form-select form-select-sm" @onchange="OnCategoryChange">
                        <option value="">All Categories</option>
                        @foreach (var cat in TicketCategories.All)
                        {
                            <option>@cat</option>
                        }
                    </select>
                </div>
                <div class="col-auto">
                    <input class="form-control form-control-sm"
                           placeholder="Search…"
                           value="@_searchText"
                           @oninput="OnSearchInput" />
                </div>
            </div>
        </div>
    </div>

    <!-- ── Ticket Table ────────────────────────────────────────────────── -->
    @if (_loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (!_tickets.Any())
    {
        <div class="text-center text-muted py-5">
            <div style="font-size:48px;">✅</div>
            <p class="mt-2">No tickets match the current filters.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle bg-white shadow-sm rounded mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Employee</th>
                        <th>Category</th>
                        <th>Description</th>
                        <th>Priority</th>
                        <th>Status</th>
                        <th>Assigned To</th>
                        <th>Resolved/Closed By</th>
                        <th>Created</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in _tickets)
                    {
                        var isHrTicket = IsHrTicket(t);

                        string actionByName = null;

                        if (t.Status == "Resolved" && t.ResolvedBy != null)
                        {
                            actionByName = $"{t.ResolvedBy.FirstName} {t.ResolvedBy.LastName}".Trim();
                            if (actionByName == "OrgAdmin") actionByName = "OrgAdmin";
                        }
                        else if (t.Status == "Closed" && t.ClosedBy != null)
                        {
                            actionByName = $"{t.ClosedBy.FirstName} {t.ClosedBy.LastName}".Trim();
                            if (actionByName == "OrgAdmin") actionByName = "OrgAdmin";
                        }

                        <tr @onclick="@(() => OpenTicket(t.TicketId))" style="cursor:pointer;">
                            <td class="fw-semibold">#@t.TicketNumber</td>
                            <td>
                                @(t.Employee != null ? $"{t.Employee.FirstName} {t.Employee.LastName}" : "—")
                                @if (isHrTicket)
                                {
                                    <span class="badge bg-warning text-dark ms-1" style="font-size: 10px;">HR</span>
                                }
                            </td>
                            <td>@t.Category</td>
                            <td class="text-truncate" style="max-width:220px;">@t.Description</td>
                            <td class="text-nowrap"><span class="badge @PriorityBadge(t.Priority)">@t.Priority</span></td>
                            <td class="text-nowrap"><span class="badge @StatusBadge(t.Status)">@t.Status</span></td>
                            <td>
                                @if (t.AssignedTo != null)
                                {
                                    <span class="badge bg-light text-dark border">
                                        @t.AssignedTo.FirstName @t.AssignedTo.LastName
                                    </span>
                                }
                                else if (isHrTicket)
                                {
                                    <span class="text-muted small">N/A (HR Ticket)</span>
                                }
                                else
                                {
                                    <span class="text-muted small">Unassigned</span>
                                }
                            </td>
                            <td class="small">
                                @if (!string.IsNullOrEmpty(actionByName))
                                {
                                    <span>@actionByName</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="text-nowrap">@t.CreatedAt.ToLocalTime().ToString("dd MMM, hh:mm tt")</td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary"
                                        @onclick:stopPropagation="true"
                                        @onclick="@(() => OpenTicket(t.TicketId))">
                                    Open
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- TICKET DETAIL PANEL -->
@if (_selectedTicket != null)
{
    <div class="ticket-overlay" @onclick="CloseTicket"></div>
    <div class="ticket-panel shadow-lg">

        <div class="panel-header d-flex justify-content-between align-items-start p-3 border-bottom">
            <div>
                <h5 class="mb-1">#@_selectedTicket.TicketNumber — @_selectedTicket.Category</h5>
                <div class="d-flex flex-wrap gap-2 align-items-center">
                    <span class="badge @PriorityBadge(_selectedTicket.Priority)">@_selectedTicket.Priority</span>
                    <span class="badge @StatusBadge(_selectedTicket.Status)">@_selectedTicket.Status</span>
                    <span class="text-muted small">
                        @(_selectedTicket.Employee != null
                                            ? $"{_selectedTicket.Employee.FirstName} {_selectedTicket.Employee.LastName}"
                                            : "Unknown employee")
                    • @_selectedTicket.CreatedAt.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")
                </span>
            </div>
        </div>
        <button class="btn-close" @onclick="CloseTicket"></button>
    </div>

        <div class="panel-body p-3">

            <!-- Original description -->
            <div class="bg-light rounded p-3 mb-3">
                <div class="small text-muted fw-semibold mb-1">ORIGINAL ISSUE</div>
                <p class="mb-0" style="white-space:pre-wrap;">@_selectedTicket.Description</p>
            </div>

            <!-- Resolution banner -->
        @if (_selectedTicket.Status == "Resolved" && !string.IsNullOrWhiteSpace(_selectedTicket.Resolution))
            {
                <div class="alert alert-success py-2">
                    <div class="fw-semibold small">✅ RESOLUTION</div>
                    <p class="mb-0" style="white-space:pre-wrap;">@_selectedTicket.Resolution</p>
                    @if (_selectedTicket.ResolvedAt.HasValue)
                    {
                        // Simple logic without async calls
                        string resolvedByName = GetResolvedDisplayName();
                        <div class="small text-muted mt-1">
                            Resolved by @resolvedByName
                            on @_selectedTicket.ResolvedAt.Value.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")
                        </div>
                    }
                </div>
            }

            <!-- Closed banner -->
            @if (_selectedTicket.Status == "Closed")
            {
                <div class="alert alert-secondary py-2">
                    <div class="fw-semibold small">🗄 CLOSED</div>
                    @if (_selectedTicket.ClosedAt.HasValue)
                    {
                        string closedByName = GetClosedDisplayName();
                        <div class="small text-muted mt-1">
                            Closed by @closedByName
                            on @_selectedTicket.ClosedAt.Value.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")
                        </div>
                    }
                </div>
            }

            <!-- Assignment (OrgAdmin only) -->
            @if (_isOrgAdmin && _hrStaff.Any() && _selectedTicket != null && !IsHrTicket(_selectedTicket))
            {
                <div class="card border mb-3">
                    <div class="card-body py-2 px-3">
                        <div class="d-flex align-items-center gap-2">
                            <span class="small fw-semibold text-muted">
                                ASSIGN TO (Dept: @(_selectedTicket.Employee?.Department?.Name ?? "Unknown"))
                            </span>
                            <select class="form-select form-select-sm"
                                    value="@(_selectedTicket.AssignedToUserId ?? "")"
                                    @onchange="OnAssigneeChange">
                                <option value="">— Select HR from this department —</option>
                                @foreach (var hr in _hrStaff)
                                {
                                    <option value="@hr.UserId">@hr.FullName (@hr.DepartmentName)</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
            }

            <!-- Show warning for HR tickets -->
            @if (_isOrgAdmin && _selectedTicket != null && IsHrTicket(_selectedTicket))
            {
                <div class="alert alert-warning py-2 mb-3">
                    <i class="bi bi-shield-lock"></i>
                    <strong>HR Support Ticket</strong> - This ticket was raised by an HR staff member.
                    Only OrgAdmin can handle this ticket directly (no assignment needed).
                </div>
            }

            <!-- Conversation thread -->
            <div class="fw-semibold small text-muted mb-2">CONVERSATION</div>
            <div class="ticket-thread mb-3" id="threadScroll">
                @if (!_replies.Any(r => !r.IsInternalNote))
                {
                    <p class="text-muted small text-center py-3">No replies yet.</p>
                }
                @foreach (var r in _replies.Where(r => !r.IsInternalNote))
                {
                    var isCurrentUser = r.UserId == _currentUserId;
                    <div class="thread-msg @(r.IsStaff ? "staff" : "employee")">
                        <div class="thread-meta">
                            <strong>
                                @if (isCurrentUser)
                                {
                                    <span>You</span>
                                }
                                else
                                {
                                    @r.AuthorName
                                }
                                @if (!isCurrentUser && r.IsOrgAdmin)
                                {
                                    <span class="badge bg-danger ms-1" style="font-size: 9px;">OrgAdmin</span>
                                }
                                else if (!isCurrentUser && r.IsHR)
                                {
                                    <span class="badge bg-info ms-1" style="font-size: 9px;">HR</span>
                                }
                                else if (isCurrentUser && _isOrgAdmin)
                                {
                                    <span class="badge bg-danger ms-1" style="font-size: 9px;">OrgAdmin</span>
                                }
                                else if (isCurrentUser && !_isOrgAdmin && r.IsHR)
                                {
                                    <span class="badge bg-info ms-1" style="font-size: 9px;">HR</span>
                                }
                            </strong>
                            <span>@r.CreatedAt.ToLocalTime().ToString("dd MMM, hh:mm tt")</span>
                        </div>
                        <div class="thread-body">@r.Message</div>
                    </div>
                }
            </div>

            <!-- Internal notes section -->
            @if (_replies.Any(r => r.IsInternalNote))
            {
                <div class="fw-semibold small text-muted mb-2">🔒 INTERNAL NOTES</div>
                <div class="mb-3">
                    @foreach (var r in _replies.Where(r => r.IsInternalNote))
                    {
                        var isCurrentUser = r.UserId == _currentUserId;
                        <div class="thread-msg internal-note">
                            <div class="thread-meta">
                                <strong>
                                    @if (isCurrentUser)
                                    {
                                        <span>You</span>
                                    }
                                    else
                                    {
                                        @r.AuthorName
                                    }
                                    @if (!isCurrentUser && r.IsOrgAdmin)
                                    {
                                        <span class="badge bg-danger ms-1" style="font-size: 9px;">OrgAdmin</span>
                                    }
                                    else if (!isCurrentUser && r.IsHR)
                                    {
                                        <span class="badge bg-info ms-1" style="font-size: 9px;">HR</span>
                                    }
                                    else if (isCurrentUser && _isOrgAdmin)
                                    {
                                        <span class="badge bg-danger ms-1" style="font-size: 9px;">OrgAdmin</span>
                                    }
                                    else if (isCurrentUser && !_isOrgAdmin && r.IsHR)
                                    {
                                        <span class="badge bg-info ms-1" style="font-size: 9px;">HR</span>
                                    }
                                </strong>
                                <span>@r.CreatedAt.ToLocalTime().ToString("dd MMM, hh:mm tt")</span>
                            </div>
                            <div class="thread-body">@r.Message</div>
                        </div>
                    }
                </div>
            }

            <!-- Reply textarea -->
            @if (_selectedTicket.Status != "Resolved" && _selectedTicket.Status != "Closed")
            {
                <textarea class="form-control mb-2"
                          rows="3"
                          placeholder="Type a reply…"
                          @bind="_replyText"></textarea>

                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" id="chkInternal" @bind="_isInternalNote" />
                    <label class="form-check-label small text-muted" for="chkInternal">
                        🔒 Internal note (only visible to HR/OrgAdmin, not the employee)
                    </label>
                </div>
            }
        </div>

        <!-- Panel Footer -->
        <div class="panel-footer border-top p-3">

            @if (_errorMessage != null)
            {
                <div class="alert alert-danger py-1 small mb-2">@_errorMessage</div>
            }

            <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap">
                <div class="d-flex gap-2">
                    @if (_selectedTicket.Status == "Resolved")
                    {
                        <button class="btn btn-outline-warning btn-sm" @onclick="ReopenAsync">
                            🔄 Reopen
                        </button>
                    }
                    @if (_isOrgAdmin && _selectedTicket.Status != "Closed")
                    {
                        <button class="btn btn-outline-secondary btn-sm" @onclick="CloseTicketAsync">
                            🗄 Close
                        </button>
                    }
                </div>

                <div class="d-flex gap-2">
                    @if (_selectedTicket.Status != "Resolved" && _selectedTicket.Status != "Closed")
                    {
                        <button class="btn btn-outline-primary btn-sm"
                                @onclick="SendReplyAsync"
                                disabled="@string.IsNullOrWhiteSpace(_replyText)">
                            💬 Send
                        </button>

                        <button class="btn btn-success btn-sm"
                                @onclick="@(() => _showResolveBox = !_showResolveBox)">
                            ✅ Resolve
                        </button>
                    }
                    <button class="btn btn-secondary btn-sm" @onclick="CloseTicket">
                        Close
                    </button>
                </div>
            </div>

            @if (_showResolveBox)
            {
                <div class="mt-3 border-top pt-3">
                    <label class="form-label small fw-semibold">Resolution note (shown to the employee)</label>
                    <textarea class="form-control mb-2" rows="2" @bind="_resolutionText"></textarea>
                    <button class="btn btn-success btn-sm"
                            @onclick="ResolveAsync"
                            disabled="@string.IsNullOrWhiteSpace(_resolutionText)">
                        Confirm Resolve
                    </button>
                </div>
            }
        </div>
    </div>
}

<style>
    .kpi-card {
        border-radius: 12px;
    }

    .ticket-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.4);
        z-index: 1040;
    }

    .ticket-panel {
        position: fixed;
        top: 0;
        right: 0;
        bottom: 0;
        width: min(680px, 100vw);
        background: white;
        z-index: 1050;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .panel-header {
        flex-shrink: 0;
    }

    .panel-footer {
        flex-shrink: 0;
    }

    .panel-body {
        flex: 1;
        overflow-y: auto;
    }

    .ticket-thread {
        max-height: 280px;
        overflow-y: auto;
    }

    .thread-msg {
        border-radius: 10px;
        padding: 8px 12px;
        margin-bottom: 8px;
        max-width: 88%;
    }

        .thread-msg.employee {
            background: #f1f2f6;
        }

        .thread-msg.staff {
            background: #e7e9ff;
            margin-left: auto;
        }

        .thread-msg.internal-note {
            background: #fff8e1;
            border-left: 3px solid #f59e0b;
        }

    .thread-meta {
        display: flex;
        justify-content: space-between;
        font-size: 11px;
        color: #6b7280;
        margin-bottom: 3px;
    }

    .thread-body {
        font-size: 13.5px;
        white-space: pre-wrap;
    }
</style>

@code {
    [Parameter] public Guid? TicketId { get; set; }

    private static readonly string[] StatusTabs = { "Open", "InProgress", "Resolved", "Closed", "All" };

    private string _activeStatus = "Open";
    private string? _activePriority;
    private string? _activeCategory;
    private string _searchText = "";

    private List<SupportTicket> _tickets = new();
    private DashboardStatsDto? _stats;
    private List<HrStaffDto> _hrStaff = new();
    private bool _isOrgAdmin;
    private bool _loading = true;

    private SupportTicket? _selectedTicket;
    private List<TicketReplyViewDto> _replies = new();

    private Dictionary<string, bool> _isTicketCreatorHR = new();
    private string _currentUserId = string.Empty;
    private string _replyText = "";
    private bool _isInternalNote = false;
    private string _resolutionText = "";
    private bool _showResolveBox = false;
    private string? _errorMessage;

    private System.Timers.Timer? _searchDebounce;

    // Helper methods to get display names without async calls
    private string GetResolvedDisplayName()
    {
        if (_selectedTicket == null) return "Unknown";

        if (_selectedTicket.ResolvedBy != null)
        {
            var name = $"{_selectedTicket.ResolvedBy.FirstName} {_selectedTicket.ResolvedBy.LastName}".Trim();
            return name == "OrgAdmin" ? "OrgAdmin" : name;
        }

        return "Unknown";
    }

    private string GetClosedDisplayName()
    {
        if (_selectedTicket == null) return "Unknown";

        if (_selectedTicket.ClosedBy != null)
        {
            var name = $"{_selectedTicket.ClosedBy.FirstName} {_selectedTicket.ClosedBy.LastName}".Trim();
            return name == "OrgAdmin" ? "OrgAdmin" : name;
        }

        return "Unknown";
    }

    // private string GetClosedDisplayName()
    // {
    //     if (_selectedTicket == null) return "Unknown";

    //     if (_selectedTicket.ClosedBy != null)
    //     {
    //         return $"{_selectedTicket.ClosedBy.FirstName} {_selectedTicket.ClosedBy.LastName}".Trim();
    //     }

    //     if (!string.IsNullOrEmpty(_selectedTicket.ClosedByUserId))
    //     {
    //         If ClosedBy is null but has an ID, assume it was OrgAdmin
    //         return "OrgAdmin";
    //     }

    //     return "Unknown";
    // }

    protected override async Task OnInitializedAsync()
    {
        var currentUser = await CurrentUserService.GetUserAsync();
        _currentUserId = currentUser?.Id ?? string.Empty;

        _isOrgAdmin = await CurrentUserService.IsInRoleAsync("OrgAdmin");

        if (TicketId.HasValue)
            _activeStatus = "All";

        await RefreshAsync();

        if (TicketId.HasValue)
            await OpenTicket(TicketId.Value);
    }

    private async Task RefreshAsync()
    {
        _loading = true;
        StateHasChanged();

        _stats = await TicketService.GetTicketDashboardStatsAsync();
        _tickets = await TicketService.GetTicketsForHRAsync(
            status: _activeStatus == "All" ? null : _activeStatus,
            priority: _activePriority,
            category: _activeCategory,
            search: string.IsNullOrWhiteSpace(_searchText) ? null : _searchText);

        _isTicketCreatorHR.Clear();
        foreach (var ticket in _tickets)
        {
            if (!_isTicketCreatorHR.ContainsKey(ticket.UserId))
            {
                var user = await CurrentUserService.GetUserAsync(ticket.UserId);
                if (user != null)
                {
                    var isHR = await CurrentUserService.IsInRoleAsync(user, "HR");
                    _isTicketCreatorHR[ticket.UserId] = isHR;
                }
                else
                {
                    _isTicketCreatorHR[ticket.UserId] = false;
                }
            }
        }

        _loading = false;
    }

    private bool IsHrTicket(SupportTicket ticket)
    {
        return _isTicketCreatorHR.GetValueOrDefault(ticket.UserId, false);
    }

    private async Task SetStatusFilter(string status)
    {
        _activeStatus = status;
        await RefreshAsync();
    }

    private async Task OnPriorityChange(ChangeEventArgs e)
    {
        _activePriority = e.Value?.ToString();
        await RefreshAsync();
    }

    private async Task OnCategoryChange(ChangeEventArgs e)
    {
        _activeCategory = e.Value?.ToString();
        await RefreshAsync();
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        _searchText = e.Value?.ToString() ?? "";
        _searchDebounce?.Dispose();
        _searchDebounce = new System.Timers.Timer(400);
        _searchDebounce.Elapsed += async (_, _) =>
        {
            _searchDebounce?.Dispose();
            await InvokeAsync(async () =>
            {
                await RefreshAsync();
                StateHasChanged();
            });
        };
        _searchDebounce.AutoReset = false;
        _searchDebounce.Start();
    }

    private async Task OpenTicket(Guid ticketId)
    {
        _errorMessage = null;
        _showResolveBox = false;
        _replyText = "";
        _resolutionText = "";
        _isInternalNote = false;

        _selectedTicket = await TicketService.GetTicketByIdAsync(ticketId, isManagementView: true);
        _replies = _selectedTicket != null
            ? await TicketService.GetRepliesAsync(ticketId, includeInternalNotes: true)
            : new List<TicketReplyViewDto>();

        if (_isOrgAdmin && _selectedTicket != null && _selectedTicket.Employee != null)
        {
            var employeeDeptId = _selectedTicket.Employee.DepartmentId;
            _hrStaff = await TicketService.GetAssignableHRUsersAsync(employeeDeptId);
        }
        else if (_isOrgAdmin)
        {
            _hrStaff = await TicketService.GetAssignableHRUsersAsync();
        }
    }

    private void CloseTicket()
    {
        _selectedTicket = null;
        _replies.Clear();
        _errorMessage = null;
    }

    private async Task SendReplyAsync()
    {
        if (_selectedTicket == null || string.IsNullOrWhiteSpace(_replyText)) return;
        _errorMessage = null;

        try
        {
            await TicketService.AddReplyAsync(
                _selectedTicket.TicketId,
                _replyText.Trim(),
                isInternalNote: _isInternalNote,
                isManagementView: true);

            _replyText = "";
            _isInternalNote = false;

            await OpenTicket(_selectedTicket.TicketId);
            await RefreshAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private async Task ResolveAsync()
    {
        if (_selectedTicket == null || string.IsNullOrWhiteSpace(_resolutionText)) return;
        _errorMessage = null;

        try
        {
            _selectedTicket = await TicketService.ResolveTicketAsync(
                _selectedTicket.TicketId, _resolutionText.Trim());
            _showResolveBox = false;
            _resolutionText = "";
            await RefreshAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private async Task ReopenAsync()
    {
        if (_selectedTicket == null) return;
        _errorMessage = null;

        try
        {
            _selectedTicket = await TicketService.ReopenTicketAsync(
                _selectedTicket.TicketId, "Reopened by HR");
            await RefreshAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private async Task CloseTicketAsync()
    {
        if (_selectedTicket == null) return;
        _errorMessage = null;

        try
        {
            _selectedTicket = await TicketService.CloseTicketAsync(_selectedTicket.TicketId);
            await RefreshAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private async Task OnAssigneeChange(ChangeEventArgs e)
    {
        if (_selectedTicket == null) return;
        var userId = e.Value?.ToString();
        if (string.IsNullOrEmpty(userId)) return;
        _errorMessage = null;

        try
        {
            await TicketService.AssignTicketAsync(_selectedTicket.TicketId, userId);
            await OpenTicket(_selectedTicket.TicketId);
            await RefreshAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private static string PriorityBadge(string p) => p switch
    {
        "Urgent" => "bg-danger",
        "High" => "bg-warning text-dark",
        "Medium" => "bg-info text-dark",
        _ => "bg-secondary"
    };

    private static string StatusBadge(string s) => s switch
    {
        "Open" => "bg-primary",
        "InProgress" => "bg-warning text-dark",
        "Resolved" => "bg-success",
        "Closed" => "bg-secondary",
        _ => "bg-light text-dark"
    };
}