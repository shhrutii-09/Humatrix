@page "/employee/dashboard"

@using Humatrix_HRMS.Data
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize(Roles = "Employee")]

@inject CurrentUserService CurrentUserService

<PageTitle>My Dashboard</PageTitle>

<div class="container mt-4">

    <div class="alert alert-light border-start border-primary border-5">
        <h4>Welcome, @user?.FirstName!</h4>
        <p>Email: @user?.Email</p>
        <p>Department: @user?.DepartmentId</p>
    </div>

    <div class="card p-3">
        <h5>Quick Actions</h5>
        <button class="btn btn-outline-success w-100 mb-2">Clock In</button>
        <button class="btn btn-outline-primary w-100">View Profile</button>
    </div>

</div>

@code {
    private ApplicationUser? user;

    protected override async Task OnInitializedAsync()
    {
        user = await CurrentUserService.GetUserAsync();
    }
}