@page "/employee/assets"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Employee,HR")]

@using Humatrix_HRMS.DTOs.Assets
@using Humatrix_HRMS.Services
@using Humatrix_HRMS.Services.Assets
@using Humatrix_HRMS.Infrastructure.Constants
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization

@inject AssetService AssetService
@inject CurrentUserService CurrentUserService
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>My Workspace Assets | Humatrix HRMS</PageTitle>

@if (showRequestModal && selectedAsset != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(15, 23, 42, 0.45); backdrop-filter: blur(3px);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg panel-container-card">
                <div class="modal-header bg-light border-bottom p-3">
                    <h5 class="modal-title fw-bold text-dark d-flex align-items-center gap-2">
                        <i class="bi bi-file-earmark-plus text-primary"></i>
                        Submit Asset @targetRequestType
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseRequestModal" aria-label="Close"></button>
                </div>
                <EditForm Model="createRequestModel" OnValidSubmit="HandleSubmitRequest">
                    <DataAnnotationsValidator />
                    <div class="modal-body p-4">
                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert alert-danger p-2 small mb-3" style="border-radius: 10px;">@errorMessage</div>
                        }

                        <div class="bg-light rounded-3 p-3 mb-3" style="border: 1px solid #e2e8f0;">
                            <span class="text-muted small fw-bold tracking-wider d-block mb-1">TARGET INVENTORY ITEM</span>
                            <div class="fw-bold text-dark text-heading-field">@selectedAsset.Name</div>
                            <div class="text-muted font-monospace small">@selectedAsset.AssetCode</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold small text-secondary tracking-wider">REASON / JUSTIFICATION <span class="text-danger">*</span></label>
                            <InputTextArea @bind-Value="createRequestModel.Reason"
                                           class="form-control premium-edit-input"
                                           rows="4"
                                           placeholder="@GetPlaceholderText()" />
                            <ValidationMessage For="() => createRequestModel.Reason" class="text-danger small mt-1" />
                        </div>

                        @if (targetRequestType == AssetRequestType.Replacement)
                        {
                            <div class="alert alert-info small mt-2" style="border-radius: 10px;">
                                <i class="bi bi-info-circle me-1"></i>
                                Replacement requests will be reviewed by HR/OrgAdmin. Upon approval, you'll receive a different asset of the same category.
                            </div>
                        }
                    </div>
                    <div class="modal-footer bg-light border-top p-3 d-flex justify-content-end gap-2">
                        <button type="button" class="btn btn-dashboard px-3"
                                @onclick="CloseRequestModal">
                            Cancel
                        </button>
                        <button type="submit" class="btn btn-primary-action px-4" disabled="@submitting">
                            @if (submitting)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            }
                            Confirm Submission
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

<div class="container-fluid px-4 mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom row-gap-3 flex-wrap">
        <div>
            <h2 class="fw-bold tracking-tight text-dark mb-1">My Workplace Assets</h2>
            <p class="text-muted small mb-0">Track hardware, inventory configurations, and active technical requests assigned to you.</p>
        </div>
        <button class="btn btn-dashboard d-flex align-items-center gap-2 shadow-sm" @onclick="GoDashboard">
            <i class="bi bi-speedometer2"></i>
            DASHBOARD
        </button>
    </div>

    @* Tab Navigation *@
    <div class="d-flex gap-1 mb-4 tab-nav-wrapper">
        <button class="btn tab-btn @(activeTab == "my-items" ? "tab-btn-active" : "")"
                @onclick='() => ChangeTab("my-items")'>
            <i class="bi bi-box-seam me-2"></i>My Possessed Items
            <span class="tab-count-badge ms-2">@myAssets.Count</span>
        </button>
        <button class="btn tab-btn @(activeTab == "my-requests" ? "tab-btn-active" : "")"
                @onclick='() => ChangeTab("my-requests")'>
            <i class="bi bi-chat-square-text me-2"></i>Request Tracking Logs
            <span class="tab-count-badge ms-2">@myRequests.Count</span>
        </button>
        <button class="btn tab-btn @(activeTab == "history" ? "tab-btn-active" : "")"
                @onclick='() => ChangeTab("history")'>
            <i class="bi bi-clock-history me-2"></i>Asset History
            <span class="tab-count-badge ms-2">@assetHistory.Count</span>
        </button>
    </div>

    @if (loading)
    {
        <div class="text-center py-5 my-5">
            <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status"></div>
            <p class="mt-3 text-muted fw-medium">Synchronizing inventory registries...</p>
        </div>
    }
    else
    {
        @* ── TAB: My Items ── *@
        @if (activeTab == "my-items")
        {
            @if (!myAssets.Any())
            {
                <div class="card border-0 shadow-sm panel-container-card">
                    <div class="text-center py-5">
                        <div class="icon-shape bg-primary-subtle text-primary rounded-circle fs-2 mx-auto mb-3" style="width: 64px; height: 64px;">
                            <i class="bi bi-patch-check"></i>
                        </div>
                        <h5 class="fw-bold text-dark mb-1">No Assets Assigned</h5>
                        <p class="text-muted small mx-auto" style="max-width: 400px;">
                            There are currently no physical organisational items mapped under your custody account profile.
                        </p>
                    </div>
                </div>
            }
            else
            {
                <div class="row g-3">
                    @foreach (var item in myAssets)
                    {
                        <div class="col-md-6 col-lg-4">
                            <div class="card h-100 border-0 shadow-sm asset-card">
                                <div class="card-body p-4 d-flex flex-column justify-content-between">
                                    <div>
                                        <div class="d-flex align-items-start justify-content-between mb-2">
                                            <span class="badge premium-soft-dept-badge">@item.Category</span>
                                            <span class="status-indicator-pill @GetAssetStatusPillClass(item.Status)">
                                                @item.Status
                                            </span>
                                        </div>
                                        <h5 class="card-title fw-bold text-dark mb-1 text-heading-field" style="font-size: 1.05rem;">@item.Name</h5>
                                        <div class="text-muted small font-monospace mb-3 bg-light px-2 py-1 rounded d-inline-block">@item.AssetCode</div>

                                        <div class="border-top pt-2 mt-2" style="font-size: 0.85rem;">
                                            <div class="d-flex justify-content-between mb-1">
                                                <span class="text-muted">Brand / Model</span>
                                                <span class="text-dark fw-semibold">@(string.IsNullOrEmpty(item.Brand) ? "—" : $"{item.Brand} {item.Model}".Trim())</span>
                                            </div>
                                            <div class="d-flex justify-content-between">
                                                <span class="text-muted">Serial No</span>
                                                <span class="text-dark font-monospace text-truncate ms-2" style="max-width: 180px;">@(string.IsNullOrEmpty(item.SerialNumber) ? "—" : item.SerialNumber)</span>
                                            </div>
                                        </div>
                                    </div>

                                    @{
                                        var activeRequest = GetActiveRequest(item.AssetId);
                                    }
                                    @if (activeRequest != null)
                                    {
                                        <div class="alert alert-info small mb-0 mt-3" style="border-radius: 10px;">
                                            Active Request: <strong>@activeRequest.RequestType</strong> (@activeRequest.Status)
                                        </div>
                                    }
                                    else if (item.Status == AssetStatus.InRepair)
                                    {
                                        <div class="alert alert-warning small mb-0 mt-3" style="border-radius: 10px;">
                                            This asset is currently under repair.
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="mt-4 pt-3 border-top d-flex gap-2">
                                            <button class="btn btn-sm btn-action-warn w-100 py-2 d-flex align-items-center justify-content-center gap-1"
                                                    @onclick='() => OpenRequestModal(item, AssetRequestType.Repair)'>
                                                <i class="bi bi-tools"></i> Report
                                            </button>
                                            <button class="btn btn-sm btn-action-info w-100 py-2 d-flex align-items-center justify-content-center gap-1"
                                                    @onclick='() => OpenRequestModal(item, AssetRequestType.Replacement)'>
                                                <i class="bi bi-arrow-repeat"></i> Replace
                                            </button>
                                            <button class="btn btn-sm btn-action-primary w-100 py-2 d-flex align-items-center justify-content-center gap-1"
                                                    @onclick='() => OpenRequestModal(item, AssetRequestType.Return)'>
                                                <i class="bi bi-arrow-left-right"></i> Return
                                            </button>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        }

        @* ── TAB: My Requests ── *@
        @if (activeTab == "my-requests")
        {
            @if (!myRequests.Any())
            {
                <div class="card border-0 shadow-sm panel-container-card">
                    <div class="text-center py-5">
                        <div class="icon-shape bg-primary-subtle text-primary rounded-circle fs-2 mx-auto mb-3" style="width: 64px; height: 64px;">
                            <i class="bi bi-chat-square-text"></i>
                        </div>
                        <h5 class="fw-bold text-dark mb-1">No Requests Found</h5>
                        <p class="text-muted small" style="max-width: 400px; margin: 0 auto;">
                            You have not initiated or logged any technical asset requests yet.
                        </p>
                    </div>
                </div>
            }
            else
            {
                <div class="card border-0 shadow-sm panel-container-card">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th class="ps-4 text-secondary small fw-bold tracking-wider py-3">ASSET / CODE</th>
                                    <th class="text-secondary small fw-bold tracking-wider py-3">REQUEST TYPE</th>
                                    <th class="text-secondary small fw-bold tracking-wider py-3">SUBMITTED DATE / TIME</th>
                                    <th class="text-secondary small fw-bold tracking-wider py-3">STATUS</th>
                                    <th class="text-secondary small fw-bold tracking-wider py-3">REASON</th>
                                    <th class="pe-4 text-secondary small fw-bold tracking-wider py-3 text-end">REVIEW FEED</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var req in myRequests)
                                {
                                    <tr class="table-row-interactive">
                                        <td class="ps-4 py-3">
                                            <div class="fw-bold text-dark text-heading-field">@req.AssetName</div>
                                            <div class="text-muted font-monospace small">@req.AssetCode</div>
                                            @if (req.RequestType == AssetRequestType.Replacement && req.Status == AssetRequestStatus.Completed && !string.IsNullOrEmpty(req.ReplacementAssetCode))
                                            {
                                                <div class="mt-1">
                                                    <span class="badge premium-soft-dept-badge" style="font-size: 11px;">
                                                        <i class="bi bi-arrow-right-circle-fill me-1"></i>Replaced by: <strong class="font-monospace ms-1">@req.ReplacementAssetCode</strong>
                                                    </span>
                                                </div>
                                            }
                                        </td>
                                        <td class="py-3">
                                            <span class="badge @GetRequestTypeClass(req.RequestType)" style="font-size: 11px; padding: 4px 10px; border-radius: 6px; font-weight: 600;">
                                                @req.RequestType
                                            </span>
                                        </td>
                                        <td class="py-3 text-muted small">
                                            @req.RequestedAt.ToLocalTime().ToString("g")
                                        </td>
                                        <td class="py-3">
                                            <span class="status-indicator-pill @GetStatusPillClass(req.Status)">
                                                @req.Status
                                            </span>
                                        </td>
                                        <td class="py-3 row-description-text text-secondary" style="max-width: 240px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="@req.Reason">
                                            @req.Reason
                                        </td>
                                        <td class="pe-4 py-3 text-end text-muted small">
                                            @(string.IsNullOrEmpty(req.ReviewNotes) ? "Pending corporate response." : $"\"{req.ReviewNotes}\"")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        }

        @* ── TAB: History ── *@
        @if (activeTab == "history")
        {
            @if (!assetHistory.Any())
            {
                <div class="card border-0 shadow-sm panel-container-card">
                    <div class="text-center py-5">
                        <div class="icon-shape bg-primary-subtle text-primary rounded-circle fs-2 mx-auto mb-3" style="width: 64px; height: 64px;">
                            <i class="bi bi-clock-history"></i>
                        </div>
                        <h5 class="fw-bold text-dark mb-1">No History Found</h5>
                        <p class="text-muted small">No asset assignment history available.</p>
                    </div>
                </div>
            }
            else
            {
                <div class="card border-0 shadow-sm panel-container-card">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th class="ps-4 text-secondary small fw-bold tracking-wider py-3">ASSET</th>
                                    <th class="text-secondary small fw-bold tracking-wider py-3">CODE</th>
                                    <th class="text-secondary small fw-bold tracking-wider py-3">ASSIGNED ON</th>
                                    <th class="text-secondary small fw-bold tracking-wider py-3">RETURNED ON</th>
                                    <th class="text-secondary small fw-bold tracking-wider py-3">ASSIGNED BY</th>
                                    <th class="text-secondary small fw-bold tracking-wider py-3">RETURNED BY</th>
                                    <th class="pe-4 text-secondary small fw-bold tracking-wider py-3">STATUS</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var h in assetHistory)
                                {
                                    <tr class="table-row-interactive">
                                        <td class="ps-4 py-3">
                                            <div class="fw-bold text-dark text-heading-field">@h.AssetName</div>
                                            @if (h.IsReplacementAction == true)
                                            {
                                                <div class="mt-1">
                                                    <span class="badge premium-soft-dept-badge" style="font-size: 11px;">
                                                        <i class="bi bi-arrow-repeat me-1"></i>
                                                        @(h.ReturnedAt.HasValue ? "Replaced By New Asset" : "Acquired via Replacement")
                                                    </span>
                                                </div>
                                            }
                                        </td>
                                        <td class="py-3 text-muted font-monospace small">@h.AssetCode</td>
                                        <td class="py-3 text-muted small">@h.AssignedAt.ToLocalTime().ToString("g")</td>
                                        <td class="py-3 text-muted small">@(h.ReturnedAt?.ToLocalTime().ToString("g") ?? "—")</td>
                                        <td class="py-3">
                                            @if (!string.IsNullOrWhiteSpace(h.AssignedByName))
                                            {
                                                <span class="text-dark fw-semibold small">@h.AssignedByName</span>
                                            }
                                            else if (h.IsReplacementAction == true && !string.IsNullOrWhiteSpace(h.ActionedByName))
                                            {
                                                <span class="text-dark fw-semibold small">@h.ActionedByName</span>
                                                <br />
                                                <small class="text-muted font-monospace" style="font-size: 11px;">via Replacement</small>
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                        <td class="py-3 text-dark small">
                                            @(string.IsNullOrWhiteSpace(h.ReturnedByName) ? "—" : h.ReturnedByName)
                                            @if (!string.IsNullOrWhiteSpace(h.ReturnedByRole))
                                            {
                                                <br />
                                                <small class="text-muted" style="font-size: 11px;">@h.ReturnedByRole</small>
                                            }
                                        </td>
                                        <td class="pe-4 py-3">
                                            @if (h.ReturnedAt.HasValue)
                                            {
                                                <span class="status-indicator-pill pill-secondary">Returned</span>
                                                @if (!string.IsNullOrEmpty(h.RelatedAssetCode))
                                                {
                                                    <div class="text-muted mt-1" style="font-size: 11px;">
                                                        Next: <strong class="font-monospace" style="color: #5c4ac7;">@h.RelatedAssetCode</strong>
                                                    </div>
                                                }
                                            }
                                            else
                                            {
                                                <span class="status-indicator-pill pill-active">Active</span>
                                                @if (!string.IsNullOrEmpty(h.RelatedAssetCode))
                                                {
                                                    <div class="text-muted mt-1" style="font-size: 11px;">
                                                        Prev: <strong class="font-monospace text-secondary">@h.RelatedAssetCode</strong>
                                                    </div>
                                                }
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        }
    }
</div>

