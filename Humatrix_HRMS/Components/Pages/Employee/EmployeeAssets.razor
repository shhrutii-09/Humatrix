    }

    .pill-approved {
        background-color: #ecfdf5;
        color: #065f46;
    }

    .pill-rejected {
        background-color: #fef2f2;
        color: #991b1b;
    }

    .pill-completed {
        background-color: #eff6ff;
        color: #1e40af;
    }

    .pill-warning {
        background-color: #fffbeb;
        color: #92400e;
    }

    .pill-info {
        background-color: #eff6ff;
        color: #1e40af;
    }
</style>

@code {
    private string activeTab = "my-items";
    private bool loading = true;
    private bool submitting = false;
    private bool showRequestModal = false;
    private string errorMessage = "";

    private Guid currentEmployeeId;
    private Guid currentOrganizationId;
    private string currentUserId = "";
    private string currentUserRole = "Employee";

    private List<AssetDto> myAssets = new();
    private List<AssetRequestDto> myRequests = new();
    private List<EmployeeAssetHistoryDto> assetHistory = new();

    private AssetDto? selectedAsset;
    private string targetRequestType = "";
    private CreateAssetRequestDto createRequestModel = new();

    protected override async Task OnInitializedAsync() => await LoadContextAndDataAsync();

    private async Task LoadContextAndDataAsync()
    {
        try
        {
            loading = true;
            errorMessage = "";
            var empContext = await CurrentUserService.GetEmployeeDashboardContextAsync();
            if (empContext != null)
            {
                currentEmployeeId = empContext.EmployeeId;
                currentOrganizationId = empContext.OrganizationId;
                currentUserId = empContext.UserId;
                currentUserRole = !string.IsNullOrWhiteSpace(empContext.Role) ? empContext.Role : "Employee";
                await RefreshInventoryDataAsync();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error mapping context values: {ex.Message}");
            errorMessage = "Failed to synchronize workspace context data.";
        }
        finally { loading = false; }
    }

    private async Task RefreshInventoryDataAsync()
    {
        myAssets = await AssetService.GetCurrentEmployeeAssetsAsync(currentEmployeeId, currentOrganizationId);
        myRequests = await AssetService.GetAssetRequestsByEmployeeIdAsync(currentEmployeeId, currentOrganizationId);
        assetHistory = await AssetService.GetEmployeeAssetHistoryAsync(currentEmployeeId, currentOrganizationId);
    }

    private void ChangeTab(string tabKey) => activeTab = tabKey;

    private async Task GoDashboard()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        Nav.NavigateTo(authState.User.IsInRole("HR") ? "/hr/dashboard" : "/employee/dashboard");
    }

    private void OpenRequestModal(AssetDto asset, string requestType)
    {
        selectedAsset = asset;
        targetRequestType = requestType;
        createRequestModel = new CreateAssetRequestDto { AssetId = asset.AssetId, RequestType = requestType, Reason = "" };
        errorMessage = "";
        showRequestModal = true;
    }

    private void CloseRequestModal()
    {
        showRequestModal = false;
        selectedAsset = null;
        createRequestModel = new CreateAssetRequestDto();
        errorMessage = "";
    }

    private async Task HandleSubmitRequest()
    {
        if (submitting || selectedAsset == null) return;
        try
        {
            submitting = true;
            errorMessage = "";
            await AssetService.CreateAssetRequestAsync(
                organizationId: currentOrganizationId,
                requestedByEmployeeId: currentEmployeeId,
                requestorRole: currentUserRole,
                dto: createRequestModel,
                callerDepartmentId: null
            );
            showRequestModal = false;
            await RefreshInventoryDataAsync();
            activeTab = "my-requests";
        }
        catch (Exception ex) { errorMessage = ex.Message; }
        finally { submitting = false; }
    }

    private string GetAssetStatusPillClass(string status) => status switch
    {
        AssetStatus.Assigned => "pill-approved",
        AssetStatus.InRepair => "pill-warning",
        AssetStatus.Available => "pill-info",
        AssetStatus.Retired => "pill-secondary",
        _ => "pill-secondary"
    };

    private AssetRequestDto? GetActiveRequest(Guid assetId) =>
        myRequests.FirstOrDefault(r =>
            r.AssetId == assetId &&
            (r.Status == AssetRequestStatus.Pending || r.Status == AssetRequestStatus.Approved));

    private string GetPlaceholderText() => targetRequestType switch
    {
        AssetRequestType.Repair => "Please describe the issue with this asset (e.g., screen cracked, battery not charging)...",
        AssetRequestType.Replacement => "Please explain why you need a replacement (e.g., physically damaged beyond repair, outdated)...",
        AssetRequestType.Return => "Please provide the reason for returning this asset (e.g., no longer needed, received new asset)...",
        _ => "Please detail your request justification notes here..."
    };

    private string GetRequestTypeClass(string type) => type switch
    {
        AssetRequestType.Repair => "bg-warning-subtle text-warning border border-warning-subtle",
        AssetRequestType.Replacement => "bg-primary-subtle text-primary border border-primary-subtle",
        AssetRequestType.Return => "bg-info-subtle text-info border border-info-subtle",
        _ => "bg-light text-dark border"
    };

    private string GetStatusPillClass(string status) => status switch
    {
        AssetRequestStatus.Pending => "pill-pending",
        AssetRequestStatus.Approved => "pill-approved",
        AssetRequestStatus.Rejected => "pill-rejected",
        AssetRequestStatus.Completed => "pill-completed",
        _ => "pill-secondary"
    };
}