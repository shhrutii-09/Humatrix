@page "/employee/exit"
@rendermode InteractiveServer

@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using System.ComponentModel.DataAnnotations

@attribute [Authorize(Roles = "Employee,HR")]

@inject EmployeeExitService ExitService
@inject CurrentUserService CurrentUserService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@inject IJSRuntime JSRuntime

<PageTitle>My Exit | Humatrix HRMS</PageTitle>

@* Premium Toast Notifications *@
<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 9999;">
    @if (!string.IsNullOrEmpty(_toastMessage))
    {
        <div class="toast show premium-side-toast toast-success-border animate-slide-in" role="alert">
            <div class="toast-body d-flex align-items-center gap-3 p-3">
                <div class="toast-icon-circle bg-light-success text-success">
                    <i class="bi bi-check-circle-fill fs-5"></i>
                </div>
                <div class="flex-grow-1">
                    <h6 class="mb-0 fw-bold text-success" style="font-size: 13.5px;">Action Completed</h6>
                    <small class="text-secondary d-block" style="font-size: 12px; line-height: 1.3;">@_toastMessage</small>
                </div>
                <button type="button" class="btn-close shadow-none ms-auto" @onclick='() => _toastMessage = null'></button>
            </div>
        </div>
    }
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="toast show premium-side-toast toast-danger-border animate-slide-in" role="alert">
            <div class="toast-body d-flex align-items-center gap-3 p-3">
                <div class="toast-icon-circle bg-light-danger text-danger">
                    <i class="bi bi-shield-fill-x fs-5"></i>
                </div>
                <div class="flex-grow-1">
                    <h6 class="mb-0 fw-bold text-danger" style="font-size: 13.5px;">Execution Failure</h6>
                    <small class="text-secondary d-block" style="font-size: 12px; line-height: 1.3;">@_errorMessage</small>
                </div>
                <button type="button" class="btn-close shadow-none ms-auto" @onclick='() => _errorMessage = null'></button>
            </div>
        </div>
    }
</div>

<div class="container-fluid px-4 mt-4">

    @* ── Page Header ── *@
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom row-gap-3 flex-wrap">
        <div>
            <h2 class="fw-bold tracking-tight text-dark mb-1">Exit Management</h2>
            <p class="text-muted small mb-0">
                @if (_isHr)
                {
                    <span>Submit your resignation · HR exits are reviewed by OrgAdmin</span>
                }
                else
                {
                    <span>Submit your resignation or track your exit process</span>
                }
            </p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-dashboard d-flex align-items-center gap-2 shadow-sm"
                    @onclick='() => Nav.NavigateTo(_isHr ? "/hr/dashboard" : "/employee/dashboard")'>
                <i class="bi bi-speedometer2"></i>
                DASHBOARD
            </button>
        </div>
    </div>

    @* ── Info banner for HR ── *@
    @if (_isHr && _activeExit == null)
    {
        <div class="alert alert-info d-flex gap-2 align-items-start mb-4 border-0 shadow-sm" role="alert" style="border-radius: 12px;">
            <i class="bi bi-info-circle-fill fs-5 flex-shrink-0 mt-1"></i>
            <div>
                <strong>HR Resignation Policy</strong><br />
                Your resignation request will be routed directly to the OrgAdmin for review.
                Your department employees will continue to be managed by OrgAdmin until a replacement is assigned.
            </div>
        </div>
    }

    @* ── Active Exit Status Card ── *@
    @if (_activeExit != null)
    {
        <div class="row mb-4">
            <div class="col-lg-8 mx-auto">
                <div class="card border-0 shadow-sm panel-container-card">
                    <div class="card-header bg-white border-0 pt-4 pb-3 px-4 d-flex justify-content-between align-items-center">
                        <h5 class="fw-bold mb-0 text-dark">Current Exit Request Status</h5>
                        <span class="status-indicator-pill @GetStatusPillClass(_activeExit.Status)">
                            @GetStatusLabel(_activeExit.Status)
                        </span>
                    </div>
                    <div class="card-body px-4 pb-4">

                        @* Progress timeline *@
                        <div class="mb-4">
                            <div class="d-flex justify-content-between mb-3">
                                @foreach (var (step, label) in _steps)
                                {
                                    var done = StepDone(step);
                                    <span class="small text-center @(done ? "text-success fw-bold" : "text-muted")" style="flex:1;">
                                        <i class="bi @(done ? "bi-check-circle-fill" : "bi-circle") d-block mb-1 fs-5"></i>
                                        @label
                                    </span>
                                }
                            </div>
                            <div class="progress" style="height: 6px; border-radius: 10px;">
                                <div class="progress-bar bg-success" style="width:@GetProgressPct()%; border-radius: 10px;"></div>
                            </div>
                        </div>

                        @* Details grid *@
                        <div class="bg-light rounded-3 p-3 mb-4" style="border: 1px solid #e2e8f0;">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="text-muted small fw-bold tracking-wider mb-1">RESIGNATION DATE</div>
                                    <div class="fw-semibold text-dark">@_activeExit.ResignationDate.ToString("dd MMM yyyy")</div>
                                </div>
                                <div class="col-md-6">
                                    <div class="text-muted small fw-bold tracking-wider mb-1">LAST WORKING DAY</div>
                                    <div class="fw-semibold text-dark">@_activeExit.LastWorkingDay.ToString("dd MMM yyyy")</div>
                                </div>
                                <div class="col-12">
                                    <div class="text-muted small fw-bold tracking-wider mb-1">REASON</div>
                                    <div class="text-dark">@_activeExit.Reason</div>
                                </div>
                                @if (!string.IsNullOrEmpty(_activeExit.Remarks))
                                {
                                    <div class="col-12">
                                        <div class="text-muted small fw-bold tracking-wider mb-1">YOUR REMARKS</div>
                                        <div class="text-dark">@_activeExit.Remarks</div>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(_activeExit.ApprovalRemarks))
                                {
                                    <div class="col-12">
                                        <div class="text-muted small fw-bold tracking-wider mb-1">
                                            @(_activeExit.Status == ExitStatus.Rejected ? "REJECTION REASON" : "APPROVAL REMARKS")
                                        </div>
                                        <div class="@(_activeExit.Status == ExitStatus.Rejected ? "text-danger" : "text-info")">
                                            @_activeExit.ApprovalRemarks
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        @* Clearance Checklist *@
                        @if (_activeExit.Status is ExitStatus.Approved or ExitStatus.ClearanceInProgress or ExitStatus.Completed)
                        {
                            <h6 class="fw-bold mb-3 text-dark">Clearance Checklist</h6>
                            <div class="list-group mb-4" style="border-radius: 10px; overflow: hidden;">
                                @ChecklistRow("bi-laptop", "Assets Returned", _activeExit.AssetsReturned)
                                @ChecklistRow("bi-shield-lock", "Access Revoked", _activeExit.AccessRevoked)
                                @ChecklistRow("bi-people", "Knowledge Transfer", _activeExit.KnowledgeTransferred)
                                @ChecklistRow("bi-cash-stack", "No Dues Cleared", _activeExit.NoDuesCleared)
                                <div class="list-group-item d-flex justify-content-between align-items-center py-2">
                                    <span>
                                        <i class="bi bi-kanban me-2 text-secondary"></i>
                                        Tasks Completed
                                        @if (_pendingTasksCount > 0)
                                        {
                                            <span class="badge bg-danger rounded-pill ms-2">@_pendingTasksCount pending</span>
                                        }
                                    </span>
                                    <span class="status-indicator-pill @(_tasksCompleted ? "pill-active" : "pill-warning")">
                                        @(_tasksCompleted ? "✓ Done" : $"Pending ({_pendingTasksCount})")
                                    </span>
                                </div>
                            </div>
                        }

                        @* Documents *@
                        @if (_activeExit.ExperienceLetterIssued || _activeExit.RelievingLetterIssued)
                        {
                            <h6 class="fw-bold mb-2 text-dark">Documents Issued</h6>
                            <div class="d-flex gap-2 mb-4 flex-wrap">
                                @if (_activeExit.ExperienceLetterIssued)
                                {
                                    <span class="badge premium-soft-dept-badge px-3 py-2">Experience Letter</span>
                                }
                                @if (_activeExit.RelievingLetterIssued)
                                {
                                    <span class="badge premium-soft-dept-badge px-3 py-2">Relieving Letter</span>
                                }
                            </div>
                        }

                        @* Cancel section *@
                        @if (_activeExit.Status != ExitStatus.Completed && _activeExit.Status != ExitStatus.Rejected)
                        {
                            var isAfterLwd = _activeExit.LastWorkingDay.Date <= DateTime.Today;
                            @if (isAfterLwd)
                            {
                                <div class="alert alert-danger py-2 small mb-3" style="border-radius: 10px;">
                                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                    <strong>Warning:</strong> Your last working day (@_activeExit.LastWorkingDay.ToString("dd MMM yyyy")) has passed.
                                    Cancelling now may require HR approval.
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-warning py-2 small mb-3" style="border-radius: 10px;">
                                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                    <strong>You can cancel your resignation anytime before your last working day</strong>
                                    (@_activeExit.LastWorkingDay.ToString("dd MMM yyyy")).
                                </div>
                            }

                            <button class="btn btn-outline-danger w-100" style="border-radius: 10px;" @onclick="ConfirmCancel" disabled="@_isProcessing">
                                @if (_isProcessing)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                <i class="bi bi-x-circle me-1"></i> Cancel Resignation
                            </button>
                        }

                        @if (_activeExit.Status == ExitStatus.Completed)
                        {
                            <div class="alert alert-success py-2" style="border-radius: 10px;">
                                <i class="bi bi-check-circle-fill me-2"></i>
                                Your exit process is complete. Thank you for your contribution to the organisation.
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    @* ── Exit History ── *@
    @if (_exitHistory.Any())
    {
        <div class="row mb-4">
            <div class="col-lg-8 mx-auto">
                <div class="card border-0 shadow-sm panel-container-card">
                    <div class="card-header bg-white border-0 pt-4 pb-3 px-4">
                        <h5 class="fw-bold mb-0 text-dark">Previous Exit Requests</h5>
                    </div>
                    <div class="card-body px-4 pb-4">
                        @foreach (var exit in _exitHistory)
                        {
                            <div class="bg-light rounded-3 p-3 mb-3" style="border: 1px solid #e2e8f0;">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div>
                                        <span class="status-indicator-pill @GetStatusPillClass(exit.Status) me-2">
                                            @GetStatusLabel(exit.Status)
                                        </span>
                                        <span class="text-muted small">@exit.CreatedAt.ToString("dd MMM yyyy")</span>
                                    </div>
                                </div>
                                <div class="small text-muted">
                                    <div>Last Working Day: <span class="text-dark fw-semibold">@exit.LastWorkingDay.ToString("dd MMM yyyy")</span></div>
                                    <div>Reason: @exit.Reason</div>
                                    @if (!string.IsNullOrEmpty(exit.ApprovalRemarks))
                                    {
                                        <div class="text-danger mt-1">Remarks: @exit.ApprovalRemarks</div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    @* ── New Resignation Form ── *@
    @if (_activeExit == null)
    {
        <div class="row">
            <div class="col-lg-7 mx-auto">
                <div class="card border-0 shadow-sm panel-container-card">
                    <div class="card-header bg-white border-0 pt-4 pb-0 px-4">
                        <h5 class="fw-bold text-dark mb-1">Submit New Resignation</h5>
                        <p class="text-muted small mb-3">
                            Please review the terms carefully. Minimum notice period is
                            <strong>@MinNoticeDays days</strong>.
                        </p>
                    </div>

                    <div class="card-body px-4 pb-4">

                        <div class="mb-4">
                            <label class="form-label fw-semibold small text-secondary tracking-wider">LAST WORKING DAY <span class="text-danger">*</span></label>
                            <input type="date"
                                   class="form-control premium-edit-input @(string.IsNullOrEmpty(_lwdError) ? "" : "is-invalid")"
                                   @bind="_model.LastWorkingDay"
                                   @bind:format="yyyy-MM-dd"
                                   min="@DateTime.Today.AddDays(MinNoticeDays).ToString("yyyy-MM-dd")" />
                            <div class="form-text text-muted">
                                Earliest: @DateTime.Today.AddDays(MinNoticeDays).ToString("dd MMM yyyy")
                            </div>
                            @if (!string.IsNullOrEmpty(_lwdError))
                            {
                                <div class="invalid-feedback d-block">@_lwdError</div>
                            }
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold small text-secondary tracking-wider">REASON FOR LEAVING <span class="text-danger">*</span></label>
                            <select class="form-select premium-edit-input @(string.IsNullOrEmpty(_reasonError) ? "" : "is-invalid")"
                                    @bind="_model.Reason">
                                <option value="">Select a reason…</option>
                                <option>Better Career Opportunity</option>
                                <option>Higher Studies</option>
                                <option>Personal Reason</option>
                                <option>Health Issues</option>
                                <option>Relocation</option>
                                <option>Work-Life Balance</option>
                                <option>Company Culture</option>
                                <option>Other</option>
                            </select>
                            @if (!string.IsNullOrEmpty(_reasonError))
                            {
                                <div class="invalid-feedback d-block">@_reasonError</div>
                            }
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold small text-secondary tracking-wider">ADDITIONAL REMARKS <span class="text-danger">*</span></label>
                            <textarea class="form-control premium-edit-input @(string.IsNullOrEmpty(_remarksError) ? "" : "is-invalid")"
                                      rows="4"
                                      placeholder="Provide any additional information about your departure…"
                                      @bind="_model.Remarks"></textarea>
                            @if (!string.IsNullOrEmpty(_remarksError))
                            {
                                <div class="invalid-feedback d-block">@_remarksError</div>
                            }
                        </div>

                        <div class="bg-light rounded-3 p-3 mb-4" style="border: 1px solid #e2e8f0;">
                            <div class="form-check">
                                <input type="checkbox"
                                       id="chkTerms"
                                       class="form-check-input"
                                       @bind="_confirmed" />
                                <label class="form-check-label small text-secondary" for="chkTerms">
                                    I understand that this resignation is final and I agree to complete all
                                    exit formalities, including:
                                    <ul class="mt-2 mb-0 ps-3">
                                        <li>Returning all company assets</li>
                                        <li>Completing knowledge transfer</li>
                                        <li>Serving the full notice period</li>
                                        <li>Clearing all outstanding dues</li>
                                    </ul>
                                </label>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button class="btn btn-danger px-4"
                                    style="border-radius: 10px; font-size: 13px; font-weight: 600;"
                                    disabled="@(!_confirmed || _isSubmitting)"
                                    @onclick="SubmitResignation">
                                @if (_isSubmitting)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                Submit Resignation
                            </button>
                            <button class="btn btn-dashboard px-4"
                                    @onclick='() => Nav.NavigateTo(_isHr ? "/hr/dashboard" : "/employee/dashboard")'>
                                Cancel
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .tracking-tight {
        letter-spacing: -0.025em;
    }

    .tracking-wider {
        letter-spacing: 0.04em;
        font-size: 11px;
        text-transform: uppercase;
    }

    .panel-container-card {
        border-radius: 14px;
        background-color: #ffffff;
        overflow: hidden;
    }

    .btn-dashboard {
        background: #ffffff !important;
        border: 1px solid #e5e7eb !important;
        color: #4b5563 !important;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
    }

        .btn-dashboard:hover {
            border-color: #5c4ac7 !important;
