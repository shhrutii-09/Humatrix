</style>
@code {

    private const int MinNoticeDays = 15;

    private class ResignationModel
    {
        public DateTime LastWorkingDay { get; set; } = DateTime.Today.AddDays(MinNoticeDays);
        public string Reason { get; set; } = string.Empty;
        public string? Remarks { get; set; }
    }

    private bool _isProcessing;
    private ResignationModel _model = new();
    private EmployeeExit? _activeExit;
    private List<EmployeeExit> _exitHistory = new();
    private bool _isHr;
    private bool _isSubmitting;
    private bool _confirmed;

    private string? _errorMessage;
    private string? _toastMessage;
    private string? _lwdError;
    private string? _reasonError;
    private string? _remarksError;

    private int _pendingTasksCount = 0;
    private bool _tasksCompleted => _pendingTasksCount == 0;

    private static readonly (string step, string label)[] _steps =
    [
        ("Submitted",  "Submitted"),
        ("Approved",   "Approved"),
        ("Clearance",  "Clearance"),
        ("Completed",  "Completed"),
    ];

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        _isHr = auth.User.IsInRole("HR");
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        // Get ALL exits including cancelled ones
        var allExits = await ExitService.GetAllMyExitsAsync();

        // Find active exit (not cancelled or rejected)
        _activeExit = allExits
            .Where(x => x.Status != ExitStatus.Cancelled && x.Status != ExitStatus.Rejected)
            .OrderByDescending(x => x.CreatedAt)
            .FirstOrDefault();

        // History = everything except the active one
        _exitHistory = allExits
            .Where(x => _activeExit == null || x.ExitId != _activeExit.ExitId)
            .OrderByDescending(x => x.CreatedAt)
            .ToList();

        if (_activeExit != null)
        {
            _pendingTasksCount = await ExitService.GetPendingTasksCountAsync(_activeExit.EmployeeId);
        }

        StateHasChanged();
    }

    private async Task SubmitResignation()
    {
        ClearErrors();

        var valid = true;

        if (_model.LastWorkingDay.Date < DateTime.Today.AddDays(MinNoticeDays))
        {
            _lwdError = $"Last working day must be at least {MinNoticeDays} days from today (min: {DateTime.Today.AddDays(MinNoticeDays):dd MMM yyyy}).";
            valid = false;
        }

        if (string.IsNullOrWhiteSpace(_model.Reason))
        {
            _reasonError = "Please select a reason.";
            valid = false;
        }

        if (string.IsNullOrWhiteSpace(_model.Remarks))
        {
            _remarksError = "Additional remarks are required.";
            valid = false;
        }

        if (!_confirmed)
        {
            _errorMessage = "Please accept the resignation terms.";
            valid = false;
        }

        if (!valid) { StateHasChanged(); return; }

        _isSubmitting = true;
        StateHasChanged();

        try
        {
            await ExitService.SubmitResignationAsync(
                _model.LastWorkingDay,
                _model.Reason,
                _model.Remarks);

            await LoadAsync();
            ShowToast("Resignation submitted successfully!");

            _model = new ResignationModel();
            _confirmed = false;
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isSubmitting = false;
            StateHasChanged();
        }
    }

    private async Task ConfirmCancel()
    {
        if (_activeExit == null) return;

        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm",
            "Are you sure you want to cancel your resignation? This action cannot be undone.");

        if (!confirmed) return;

        _isProcessing = true;
        StateHasChanged();

        try
        {
            var result = await ExitService.CancelExitRequestAsync(_activeExit.ExitId);

            if (result.Success)
            {
                await LoadAsync();
                ShowToast("Resignation cancelled successfully");
            }
            else
            {
                _errorMessage = result.Message;
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isProcessing = false;
            StateHasChanged();
        }
    }

    private void ShowToast(string message)
    {
        _toastMessage = message;
        _ = Task.Delay(3000).ContinueWith(_ =>
        {
            _toastMessage = null;
            InvokeAsync(StateHasChanged);
        });
    }

    private void ResetAndResubmit()
    {
        _activeExit = null;
        _model = new ResignationModel();
        _confirmed = false;
        ClearErrors();
        StateHasChanged();
    }

    private void ClearErrors()
    {
        _errorMessage = null;
        _lwdError = null;
        _reasonError = null;
        _remarksError = null;
    }

    private bool StepDone(string step) => _activeExit?.Status switch
    {
        ExitStatus.Pending => step == "Submitted",
        ExitStatus.Approved => step is "Submitted" or "Approved",
        ExitStatus.ClearanceInProgress => step is "Submitted" or "Approved" or "Clearance",
        ExitStatus.Completed => true,
        ExitStatus.Rejected => step == "Submitted",
        ExitStatus.Cancelled => step == "Submitted",
        _ => false
    };

    private int GetProgressPct() => _activeExit?.Status switch
    {
        ExitStatus.Pending => 20,
        ExitStatus.Approved => 45,
        ExitStatus.ClearanceInProgress => 70,
        ExitStatus.Completed => 100,
        ExitStatus.Cancelled => 100,
        _ => 0
    };

    private string GetStatusPillClass(string status) => status switch
    {
        ExitStatus.Pending => "pill-warning",
        ExitStatus.Approved => "pill-info",
        ExitStatus.ClearanceInProgress => "pill-primary",
        ExitStatus.Completed => "pill-active",
        ExitStatus.Rejected => "pill-inactive",
        ExitStatus.Cancelled => "pill-secondary",
        _ => "pill-secondary"
    };

    private static string GetStatusLabel(string status) => status switch
    {
        ExitStatus.Pending => "Pending Review",
        ExitStatus.Approved => "Approved — Clearance Pending",
        ExitStatus.ClearanceInProgress => "Clearance In Progress",
        ExitStatus.Completed => "Completed",
        ExitStatus.Rejected => "Rejected",
        ExitStatus.Cancelled => "Cancelled",
        _ => status
    };

    private RenderFragment ChecklistRow(string icon, string label, bool done) =>
        @<div class="list-group-item d-flex justify-content-between align-items-center py-2">
        <span><i class="bi @icon me-2 text-secondary"></i>@label</span>
        <span class="status-indicator-pill @(done ? "pill-active" : "pill-warning")">
            @(done ? "✓ Done" : "Pending")
        </span>
    </div>;
}
