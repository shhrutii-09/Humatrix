    }

    .pill-inactive {
        background-color: #fef2f2;
        color: #991b1b;
    }

    .pill-warning {
        background-color: #fffbeb;
        color: #92400e;
    }

    .pill-info {
        background-color: #eff6ff;
        color: #1e40af;
    }

    .pill-primary {
        background-color: rgba(92,74,199,0.08);
        color: #5c4ac7;
    }

    .pill-secondary {
        background-color: #f1f5f9;
        color: #475569;
    }

    .premium-soft-dept-badge {
        background-color: rgba(92, 74, 199, 0.08) !important;
        color: #5c4ac7 !important;
        font-size: 12px;
