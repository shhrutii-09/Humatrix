@page "/employee/exit"
@rendermode InteractiveServer

@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using System.ComponentModel.DataAnnotations

@attribute [Authorize(Roles = "Employee,HR")]

@inject EmployeeExitService ExitService
@inject CurrentUserService CurrentUserService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@inject IJSRuntime JSRuntime

<PageTitle>My Exit | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">
    @* Toast Messages *@
    @if (!string.IsNullOrEmpty(_toastMessage))
    {
        <div class="position-fixed top-0 end-0 p-3" style="z-index: 1090;">
            <div class="toast show align-items-center border-0 shadow-lg"
                 style="background: #d1e7dd; color: #0f5132; border-left: 4px solid #198754!important; border-radius: 10px; min-width: 300px;">
                <div class="d-flex p-3">
                    <div class="toast-body d-flex align-items-center p-0">
                        <i class="bi bi-check-circle-fill me-2 fs-5"></i>
                        <span class="small fw-medium">@_toastMessage</span>
                    </div>
                    <button type="button" class="btn-close m-auto me-0 shadow-none"
                            @onclick='() => _toastMessage = null'></button>
                </div>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="position-fixed top-0 end-0 p-3" style="z-index: 1090;">
            <div class="toast show align-items-center border-0 shadow-lg mt-2"
                 style="background: #f8d7da; color: #842029; border-left: 4px solid #dc3545!important; border-radius: 10px; min-width: 300px;">
                <div class="d-flex p-3">
                    <div class="toast-body d-flex align-items-center p-0">
                        <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
                        <span class="small fw-medium">@_errorMessage</span>
                    </div>
                    <button type="button" class="btn-close m-auto me-0 shadow-none"
                            @onclick='() => _errorMessage = null'></button>
                </div>
            </div>
        </div>
    }

    @* ── Page Header ── *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">
                <i class="bi bi-box-arrow-right me-2"></i> Exit Management
            </h2>
            <p class="text-muted small mb-0">
                @if (_isHr)
                {
                    <span>Submit your resignation · HR exits are reviewed by OrgAdmin</span>
                }
                else
                {
                    <span>Submit your resignation or track your exit process</span>
                }
            </p>
        </div>
        <button class="btn btn-secondary px-4"
                @onclick='() => Nav.NavigateTo(_isHr ? "/hr/dashboard" : "/employee/dashboard")'>
            ← Back to Dashboard
        </button>
    </div>

    @* ── Info banner for HR ── *@
    @if (_isHr && _activeExit == null)
    {
        <div class="alert alert-info d-flex gap-2 align-items-start mb-4" role="alert">
            <i class="bi bi-info-circle-fill fs-5 flex-shrink-0 mt-1"></i>
            <div>
                <strong>HR Resignation Policy</strong><br />
                Your resignation request will be routed directly to the OrgAdmin for review.
                Your department employees will continue to be managed by OrgAdmin until a replacement is assigned.
            </div>
        </div>
    }

    @* ── Show Active Exit Status Card (if exists) ── *@
    @if (_activeExit != null)
    {
        <div class="row mb-4">
            <div class="col-lg-8 mx-auto">
                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-header bg-white border-0 pt-4 d-flex justify-content-between align-items-center">
                        <h5 class="fw-bold mb-0">Current Exit Request Status</h5>
                        <span class="badge @GetStatusBadgeClass(_activeExit.Status) fs-6 px-3 py-2">
                            @GetStatusLabel(_activeExit.Status)
                        </span>
                    </div>
                    <div class="card-body px-4 pb-4">
                        @* Progress timeline *@
                        <div class="mb-4">
                            <div class="d-flex justify-content-between mb-2">
                                @foreach (var (step, label) in _steps)
                                {
                                    var done = StepDone(step);
                                    <span class="small text-center @(done ? "text-success fw-bold" : "text-muted")" style="flex:1;">
                                        <i class="bi @(done ? "bi-check-circle-fill" : "bi-circle") d-block mb-1 fs-5"></i>
                                        @label
                                    </span>
                                }
                            </div>
                            <div class="progress" style="height:6px;">
                                <div class="progress-bar bg-success" style="width:@GetProgressPct()%"></div>
                            </div>
                        </div>

                        @* Details grid *@
                        <div class="bg-light rounded-3 p-3 mb-4">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="text-muted small">Resignation Date</div>
                                    <div class="fw-semibold">@_activeExit.ResignationDate.ToString("dd MMM yyyy")</div>
                                </div>
                                <div class="col-md-6">
                                    <div class="text-muted small">Last Working Day</div>
                                    <div class="fw-semibold">@_activeExit.LastWorkingDay.ToString("dd MMM yyyy")</div>
                                </div>
                                <div class="col-12">
                                    <div class="text-muted small">Reason</div>
                                    <div>@_activeExit.Reason</div>
                                </div>
                                @if (!string.IsNullOrEmpty(_activeExit.Remarks))
                                {
                                    <div class="col-12">
                                        <div class="text-muted small">Your Remarks</div>
                                        <div>@_activeExit.Remarks</div>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(_activeExit.ApprovalRemarks))
                                {
                                    <div class="col-12">
                                        <div class="text-muted small">
                                            @(_activeExit.Status == ExitStatus.Rejected ? "Rejection Reason" : "Approval Remarks")
                                        </div>
                                        <div class="@(_activeExit.Status == ExitStatus.Rejected ? "text-danger" : "text-info")">
                                            @_activeExit.ApprovalRemarks
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        @* Clearance Checklist (post-approval) *@
                        @if (_activeExit.Status is ExitStatus.Approved or ExitStatus.ClearanceInProgress or ExitStatus.Completed)
                        {
                            <h6 class="fw-bold mb-3">📋 Clearance Checklist</h6>
                            <div class="list-group mb-4">
                                @ChecklistRow("bi-laptop", "Assets Returned", _activeExit.AssetsReturned)
                                @ChecklistRow("bi-shield-lock", "Access Revoked", _activeExit.AccessRevoked)
                                @ChecklistRow("bi-people", "Knowledge Transfer", _activeExit.KnowledgeTransferred)
                                @ChecklistRow("bi-cash-stack", "No Dues Cleared", _activeExit.NoDuesCleared)
                                <div class="list-group-item d-flex justify-content-between align-items-center py-2">
                                    <span>
                                        <i class="bi bi-kanban me-2 text-secondary"></i>
                                        Tasks Completed
                                        @if (_pendingTasksCount > 0)
                                        {
                                            <span class="badge bg-danger rounded-pill ms-2">@_pendingTasksCount pending</span>
                                        }
                                    </span>
                                    <span class="badge @(_tasksCompleted ? "bg-success-subtle text-success border border-success-subtle" : "bg-warning-subtle text-warning border border-warning-subtle") px-2 py-1">
                                        @(_tasksCompleted ? "✓ Done" : $"Pending ({_pendingTasksCount} tasks)")
                                    </span>
                                </div>
                            </div>
                        }

                        @* Documents *@
                        @if (_activeExit.ExperienceLetterIssued || _activeExit.RelievingLetterIssued)
                        {
                            <h6 class="fw-bold mb-2">📄 Documents Issued</h6>
                            <div class="d-flex gap-2 mb-4 flex-wrap">
                                @if (_activeExit.ExperienceLetterIssued)
                                {
                                    <span class="badge bg-info-subtle text-info border border-info-subtle px-3 py-2">Experience Letter</span>
                                }
                                @if (_activeExit.RelievingLetterIssued)
                                {
                                    <span class="badge bg-info-subtle text-info border border-info-subtle px-3 py-2">Relieving Letter</span>
                                }
                            </div>
                        }

                        @* ── CANCEL BUTTON (MOVED HERE - INSIDE THE ACTIVE EXIT CARD) ── *@
                        @if (_activeExit.Status != ExitStatus.Completed && _activeExit.Status != ExitStatus.Rejected)
                        {
                            var isAfterLwd = _activeExit.LastWorkingDay.Date <= DateTime.Today;

                            if (isAfterLwd)
                            {
                                <div class="alert alert-danger py-2 small mb-3">
                                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                    <strong>Warning:</strong> Your last working day (@_activeExit.LastWorkingDay.ToString("dd MMM yyyy")) has passed.
                                    Cancelling now may require HR approval.
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-warning py-2 small mb-3">
                                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                    <strong>You can cancel your resignation anytime before your last working day</strong>
                                    (@_activeExit.LastWorkingDay.ToString("dd MMM yyyy")).
                                </div>
                            }

                            <button class="btn btn-outline-danger w-100" @onclick="ConfirmCancel" disabled="@_isProcessing">
                                @if (_isProcessing)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                <i class="bi bi-x-circle me-1"></i> Cancel Resignation
                            </button>
                        }

                        @if (_activeExit.Status == ExitStatus.Completed)
                        {
                            <div class="alert alert-success py-2">
                                <i class="bi bi-check-circle-fill me-2"></i>
                                Your exit process is complete. Thank you for your contribution to the organisation.
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    @* ── Show Cancelled/Rejected History ── *@
    @if (_exitHistory.Any())
    {
        <div class="row mb-4">
            <div class="col-lg-8 mx-auto">
                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-header bg-white border-0 pt-4">
                        <h5 class="fw-bold mb-0 text-muted">
                            <i class="bi bi-clock-history me-2"></i> Previous Exit Requests
                        </h5>
                    </div>
                    <div class="card-body px-4 pb-4">
                        @foreach (var exit in _exitHistory)
                        {
                            <div class="border-bottom pb-3 mb-3" style="border-bottom: 1px solid #dee2e6 !important;">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div>
                                        <span class="badge @GetStatusBadgeClass(exit.Status) me-2">
                                            @GetStatusLabel(exit.Status)
                                        </span>
                                        <span class="text-muted small">
                                            @exit.CreatedAt.ToString("dd MMM yyyy")
                                        </span>
                                    </div>
                                </div>
                                <div class="small text-muted">
                                    <div>Last Working Day: @exit.LastWorkingDay.ToString("dd MMM yyyy")</div>
                                    <div>Reason: @exit.Reason</div>
                                    @if (!string.IsNullOrEmpty(exit.ApprovalRemarks))
                                    {
                                        <div class="text-danger">Remarks: @exit.ApprovalRemarks</div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    @* ── New Resignation Form (shown when no active exit) ── *@
    @if (_activeExit == null)
    {
        <div class="row">
            <div class="col-lg-7 mx-auto">
                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-header bg-white border-0 pt-4 pb-0">
                        <h5 class="fw-bold text-danger">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i> Submit New Resignation
                        </h5>
                        <p class="text-muted small">
                            Please review the terms carefully. Minimum notice period is
                            <strong>@MinNoticeDays days</strong>.
                        </p>
                    </div>

                    <div class="card-body px-4 pb-4">
                        @if (!string.IsNullOrEmpty(_errorMessage))
                        {
                            <div class="alert alert-danger alert-dismissible fade show py-2" role="alert">
                                <i class="bi bi-exclamation-triangle-fill me-2"></i>@_errorMessage
                                <button type="button" class="btn-close" @onclick="ClearErrors"></button>
                            </div>
                        }

                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                Last Working Day <span class="text-danger">*</span>
                            </label>
                            <input type="date"
                                   class="form-control @(string.IsNullOrEmpty(_lwdError) ? "" : "is-invalid")"
                                   @bind="_model.LastWorkingDay"
                                   @bind:format="yyyy-MM-dd"
                                   min="@DateTime.Today.AddDays(MinNoticeDays).ToString("yyyy-MM-dd")" />
                            <div class="form-text text-muted">
                                Earliest: @DateTime.Today.AddDays(MinNoticeDays).ToString("dd MMM yyyy")
                            </div>
                            @if (!string.IsNullOrEmpty(_lwdError))
                            {
                                <div class="invalid-feedback d-block">@_lwdError</div>
                            }
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                Reason for Leaving <span class="text-danger">*</span>
                            </label>
                            <select class="form-select @(string.IsNullOrEmpty(_reasonError) ? "" : "is-invalid")"
                                    @bind="_model.Reason">
                                <option value="">Select a reason…</option>
                                <option>Better Career Opportunity</option>
                                <option>Higher Studies</option>
                                <option>Personal Reason</option>
                                <option>Health Issues</option>
                                <option>Relocation</option>
                                <option>Work-Life Balance</option>
                                <option>Company Culture</option>
                                <option>Other</option>
                            </select>
                            @if (!string.IsNullOrEmpty(_reasonError))
                            {
                                <div class="invalid-feedback d-block">@_reasonError</div>
                            }
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                Additional Remarks <span class="text-danger">*</span>
                            </label>
                            <textarea class="form-control @(string.IsNullOrEmpty(_remarksError) ? "" : "is-invalid")"
                                      rows="4"
                                      placeholder="Provide any additional information about your departure…"
                                      @bind="_model.Remarks"></textarea>
                            @if (!string.IsNullOrEmpty(_remarksError))
                            {
                                <div class="invalid-feedback d-block">@_remarksError</div>
                            }
                        </div>

                        <div class="alert alert-warning py-3 mb-4">
                            <div class="form-check">
                                <input type="checkbox"
                                       id="chkTerms"
                                       class="form-check-input"
                                       @bind="_confirmed" />
                                <label class="form-check-label small" for="chkTerms">
                                    I understand that this resignation is final and I agree to complete all
                                    exit formalities, including:
                                    <ul class="mt-2 mb-0 ps-3">
                                        <li>Returning all company assets</li>
                                        <li>Completing knowledge transfer</li>
                                        <li>Serving the full notice period</li>
                                        <li>Clearing all outstanding dues</li>
                                    </ul>
                                </label>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button class="btn btn-danger px-4"
                                    disabled="@(!_confirmed || _isSubmitting)"
                                    @onclick="SubmitResignation">
                                @if (_isSubmitting)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                Submit Resignation
                            </button>
                            <button class="btn btn-outline-secondary px-4"
                                    @onclick='() => Nav.NavigateTo(_isHr ? "/hr/dashboard" : "/employee/dashboard")'>
                                Cancel
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {

    private const int MinNoticeDays = 15;

    private class ResignationModel
    {
        public DateTime LastWorkingDay { get; set; } = DateTime.Today.AddDays(MinNoticeDays);
        public string Reason { get; set; } = string.Empty;
        public string? Remarks { get; set; }
    }

    private bool _isProcessing;
    private ResignationModel _model = new();
    private EmployeeExit? _activeExit;
    private List<EmployeeExit> _exitHistory = new();
    private bool _isHr;
    private bool _isSubmitting;
    private bool _confirmed;

    private string? _errorMessage;
    private string? _toastMessage;
    private string? _lwdError;
    private string? _reasonError;
    private string? _remarksError;

    private int _pendingTasksCount = 0;
    private bool _tasksCompleted => _pendingTasksCount == 0;

    private static readonly (string step, string label)[] _steps =
    [
        ("Submitted",  "Submitted"),
        ("Approved",   "Approved"),
        ("Clearance",  "Clearance"),
        ("Completed",  "Completed"),
    ];

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        _isHr = auth.User.IsInRole("HR");
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _activeExit = await ExitService.GetMyActiveExitRequestAsync();
        _exitHistory = await ExitService.GetAllMyExitsAsync();

        if (_activeExit != null)
        {
            _exitHistory = _exitHistory.Where(x => x.ExitId != _activeExit.ExitId).ToList();
            _pendingTasksCount = await ExitService.GetPendingTasksCountAsync(_activeExit.EmployeeId);
        }

        StateHasChanged();
    }

    private async Task SubmitResignation()
    {
        ClearErrors();

        var valid = true;

        if (_model.LastWorkingDay.Date < DateTime.Today.AddDays(MinNoticeDays))
        {
            _lwdError = $"Last working day must be at least {MinNoticeDays} days from today (min: {DateTime.Today.AddDays(MinNoticeDays):dd MMM yyyy}).";
            valid = false;
        }

        if (string.IsNullOrWhiteSpace(_model.Reason))
        {
            _reasonError = "Please select a reason.";
            valid = false;
        }

        if (string.IsNullOrWhiteSpace(_model.Remarks))
        {
            _remarksError = "Additional remarks are required.";
            valid = false;
        }

        if (!_confirmed)
        {
            _errorMessage = "Please accept the resignation terms.";
            valid = false;
        }

        if (!valid) { StateHasChanged(); return; }

        _isSubmitting = true;
        StateHasChanged();

        try
        {
            await ExitService.SubmitResignationAsync(
                _model.LastWorkingDay,
                _model.Reason,
                _model.Remarks);

            await LoadAsync();
            ShowToast("Resignation submitted successfully!");

            _model = new ResignationModel();
            _confirmed = false;
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isSubmitting = false;
            StateHasChanged();
        }
    }

    private async Task ConfirmCancel()
    {
        if (_activeExit == null) return;

        var daysRemaining = (_activeExit.LastWorkingDay.Date - DateTime.Today).Days;
        var message = daysRemaining > 0
            ? $"⚠️ WARNING: You are about to cancel your resignation.\n\n" +
              $"• Days remaining until last working day: {daysRemaining}\n" +
              $"• Last working day: {_activeExit.LastWorkingDay:dd MMM yyyy}\n\n" +
              $"This will:\n" +
              $"✓ Reassign all assets back to you\n" +
              $"✓ Restore your system access\n" +
              $"✓ Reactivate your employee status\n" +
              $"✓ Keep your tasks as they were\n\n" +
              $"Are you sure you want to cancel your resignation?"
            : $"⚠️ WARNING: Your last working day ({_activeExit.LastWorkingDay:dd MMM yyyy}) has already passed.\n\n" +
              $"Are you sure you want to cancel your resignation?\n\n" +
              $"This action cannot be undone.";

        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", message);
        if (!confirmed) return;

        _isProcessing = true;
        StateHasChanged();

        try
        {
            var result = await ExitService.CancelExitRequestAsync(_activeExit.ExitId);

            if (result.Success)
            {
                await LoadAsync();
                ShowToast("✅ Your resignation has been cancelled successfully.");
            }
            else
            {
                _errorMessage = result.Message;
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isProcessing = false;
            StateHasChanged();
        }
    }

    private void ShowToast(string message)
    {
        _toastMessage = message;
        _ = Task.Delay(3000).ContinueWith(_ =>
        {
            _toastMessage = null;
            InvokeAsync(StateHasChanged);
        });
    }

    private void ResetAndResubmit()
    {
        _activeExit = null;
        _model = new ResignationModel();
        _confirmed = false;
        ClearErrors();
        StateHasChanged();
    }

    private void ClearErrors()
    {
        _errorMessage = null;
        _lwdError = null;
        _reasonError = null;
        _remarksError = null;
    }

    private bool StepDone(string step) => _activeExit?.Status switch
    {
        ExitStatus.Pending => step == "Submitted",
        ExitStatus.Approved => step is "Submitted" or "Approved",
        ExitStatus.ClearanceInProgress => step is "Submitted" or "Approved" or "Clearance",
        ExitStatus.Completed => true,
        ExitStatus.Rejected => step == "Submitted",
        ExitStatus.Cancelled => step == "Submitted",
        _ => false
    };

    private int GetProgressPct() => _activeExit?.Status switch
    {
        ExitStatus.Pending => 20,
        ExitStatus.Approved => 45,
        ExitStatus.ClearanceInProgress => 70,
        ExitStatus.Completed => 100,
        ExitStatus.Cancelled => 100,
        _ => 0
    };

    private static string GetStatusBadgeClass(string status) => status switch
    {
        ExitStatus.Pending => "bg-warning-subtle text-warning border border-warning-subtle",
        ExitStatus.Approved => "bg-info-subtle text-info border border-info-subtle",
        ExitStatus.ClearanceInProgress => "bg-primary-subtle text-primary border border-primary-subtle",
        ExitStatus.Completed => "bg-success-subtle text-success border border-success-subtle",
        ExitStatus.Rejected => "bg-danger-subtle text-danger border border-danger-subtle",
        ExitStatus.Cancelled => "bg-secondary-subtle text-secondary border border-secondary-subtle",
        _ => "bg-secondary-subtle text-secondary"
    };

    private static string GetStatusLabel(string status) => status switch
    {
        ExitStatus.Pending => "Pending Review",
        ExitStatus.Approved => "Approved — Clearance Pending",
        ExitStatus.ClearanceInProgress => "Clearance In Progress",
        ExitStatus.Completed => "Completed",
        ExitStatus.Rejected => "Rejected",
        ExitStatus.Cancelled => "Cancelled",
        _ => status
    };

    private RenderFragment ChecklistRow(string icon, string label, bool done) =>
        @<div class="list-group-item d-flex justify-content-between align-items-center py-2">
        <span><i class="bi @icon me-2 text-secondary"></i>@label</span>
        <span class="badge @(done ? "bg-success-subtle text-success border border-success-subtle" : "bg-warning-subtle text-warning border border-warning-subtle") px-2 py-1">
            @(done ? "✓ Done" : "Pending")
        </span>
    </div>;
}