@page "/employee/wfh"
@rendermode InteractiveServer
@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize(Roles = "Employee , HR")]
@inject WorkFromHomeService WfhService
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Work From Home | Humatrix HRMS</PageTitle>

<div class="position-fixed top-0 end-0 p-3" style="z-index: 1080;">
    @if (!string.IsNullOrEmpty(message))
    {
        <div class="toast show align-items-center border-0 shadow-lg mb-2" role="alert" style="background-color: #f0fdf4; color: #166534; border-left: 4px solid #10b981 !important; border-radius: 10px;">
            <div class="d-flex p-3">
                <div class="toast-body d-flex align-items-center p-0">
                    <i class="bi bi-check-circle-fill me-2 fs-5" style="color: #10b981;"></i>
                    <span class="small fw-medium">@message</span>
                </div>
                <button type="button" class="btn-close m-auto me-0 shadow-none" @onclick="() => message = null"></button>
            </div>
        </div>
    }
    @if (!string.IsNullOrEmpty(error))
    {
        <div class="toast show align-items-center border-0 shadow-lg mb-2" role="alert" style="background-color: #fef2f2; color: #991b1b; border-left: 4px solid #ef4444 !important; border-radius: 10px;">
            <div class="d-flex p-3">
                <div class="toast-body d-flex align-items-center p-0">
                    <i class="bi bi-exclamation-triangle-fill me-2 fs-5" style="color: #ef4444;"></i>
                    <span class="small fw-medium">@error</span>
                </div>
                <button type="button" class="btn-close m-auto me-0 shadow-none" @onclick="() => error = null"></button>
            </div>
        </div>
    }
</div>

<div class="container-fluid px-4 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom row-gap-3 flex-wrap">
        <div>
            <h2 class="fw-bold tracking-tight text-dark mb-1">Work From Home</h2>
            <p class="text-muted small mb-0">Submit and track your remote work requests.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-add-dept d-flex align-items-center gap-2 shadow-sm" @onclick="OpenApplyModal">
                <i class="bi bi-house-add"></i> APPLY WFH
            </button>
            <button class="btn btn-interactive-back shadow-sm" @onclick="GoDashboard">
                <i class="bi bi-speedometer2"></i> DASHBOARD
            </button>
        </div>
    </div>

    <div class="card border-0 shadow-sm panel-container-card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4 text-secondary small fw-bold tracking-wider py-3">DATE</th>
                        <th class="text-secondary small fw-bold tracking-wider py-3">REASON</th>
                        <th class="text-secondary small fw-bold tracking-wider py-3">APPLIED ON</th>
                        <th class="text-secondary small fw-bold tracking-wider py-3 text-center">STATUS</th>
                        <th class="text-secondary small fw-bold tracking-wider py-3 text-end pe-4">ACTIONS</th>
                    </tr>
                </thead>
                <tbody>
                    @if (isLoading)
                    {
                        <tr><td colspan="5" class="text-center py-5"><div class="spinner-border text-primary"></div></td></tr>
                    }
                    else
                    {
                        @foreach (var r in requests.OrderByDescending(x => x.Date))
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark">@r.Date.ToString("dd MMM yyyy")</td>
                                <td class="text-muted small">@r.Reason</td>
                                <td class="small text-muted">@r.AppliedAt.ToLocalTime().ToString("dd MMM yyyy")</td>
                                <td class="text-center"><span class="badge rounded-pill @GetStatusClass(r.Status)">@r.Status</span></td>
                                <td class="pe-4 text-end">
                                    @if (r.Status == "Pending")
                                    {
                                        <button class="btn btn-sm btn-action-cancel" @onclick="() => Cancel(r.Id)">Cancel</button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (showModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 14px;">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Apply for WFH</h5>
                    <button class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-uppercase text-muted">Date</label>
                        <input type="date" class="form-control" min="@DateTime.Today.ToString("yyyy-MM-dd")" @bind="model.Date" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-uppercase text-muted">Reason</label>
                        <textarea class="form-control" rows="3" @bind="model.Reason"></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button class="btn btn-action-cancel" @onclick="CloseModal">Cancel</button>
                    <button class="btn btn-add-dept" @onclick="SubmitWfh">Submit Request</button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .tracking-tight {
        letter-spacing: -0.025em;
    }

    .tracking-wider {
        letter-spacing: 0.04em;
        font-size: 11px;
    }

    .panel-container-card {
        border-radius: 14px;
        background-color: #ffffff;
        overflow: hidden;
    }

    .btn-add-dept {
        background-color: #5c4ac7 !important;
        color: #ffffff !important;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
        border: none;
    }

    .btn-interactive-back {
        background: #ffffff !important;
        border: 1px solid #e5e7eb !important;
        color: #4b5563 !important;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
    }

    .btn-action-cancel {
        background-color: #f1f5f9;
        color: #475569;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        padding: 5px 12px;
        font-size: 12.5px;
    }
</style>

@code {
    private List<WorkFromHomeRequest> requests = new();
    private WorkFromHomeRequest model = new();
    private bool isLoading, showModal;
    private string? message, error;

    protected override async Task OnInitializedAsync() => await LoadRequests();

    private async void TriggerAutoDismiss(bool isSuccess)
    {
        await Task.Delay(4000);
        if (isSuccess) message = null; else error = null;
        StateHasChanged();
    }

    private async Task LoadRequests() { isLoading = true; requests = await WfhService.GetMyAsync(); isLoading = false; }

    private void OpenApplyModal() { model = new WorkFromHomeRequest { Date = DateTime.Today.AddDays(1) }; showModal = true; }
    private void CloseModal() => showModal = false;

    private async Task SubmitWfh()
    {
        try
        {
            await WfhService.ApplyAsync(model);
            message = "WFH request submitted successfully.";
            showModal = false;
            await LoadRequests();
            TriggerAutoDismiss(true);
        }
        catch (Exception ex) { error = ex.Message; TriggerAutoDismiss(false); }
    }

    private async Task Cancel(Guid id)
    {
        try
        {
            await WfhService.CancelAsync(id);
            message = "WFH request cancelled.";
            await LoadRequests();
            TriggerAutoDismiss(true);
        }
        catch (Exception ex) { error = ex.Message; TriggerAutoDismiss(false); }
    }

    private async Task GoDashboard()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        Nav.NavigateTo(authState.User.IsInRole("HR") ? "/hr/dashboard" : "/employee/dashboard");
    }

    private static string GetStatusClass(string? status) => status switch { "Approved" => "bg-success", "Rejected" => "bg-danger", "Cancelled" => "bg-secondary", _ => "bg-warning" };
}