@page "/employee/wfh"
@rendermode InteractiveServer
@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Employee , HR")]
@inject WorkFromHomeService WfhService

<PageTitle>Work From Home | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-0">Work From Home</h4>
            <small class="text-muted">Submit and track your WFH requests</small>
        </div>
        <button class="btn btn-primary shadow-sm"
                style="background-color:#5c4ac7;border:none;"
                @onclick="OpenApplyModal">
            <i class="bi bi-house me-1"></i>+ Apply WFH
        </button>
    </div>

    <!-- ALERT BANNER -->
    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert alert-@(isError ? "danger" : "success") alert-dismissible shadow-sm border-0 d-flex gap-2">
            <i class="bi bi-@(isError ? "exclamation-triangle-fill" : "check-circle-fill") mt-1"></i>
            <div class="flex-grow-1">@message</div>
            <button class="btn-close" @onclick="() => message = null"></button>
        </div>
    }

    <!-- TABLE -->
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-bottom py-3 px-4">
            <span class="text-muted small fw-bold">@requests.Count REQUEST(S)</span>
        </div>

        @if (isLoading)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-primary"></div>
                <p class="text-muted small mt-2">Loading...</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 text-muted small fw-bold border-0">DATE</th>
                            <th class="text-muted small fw-bold border-0">REASON</th>
                            <th class="text-muted small fw-bold border-0">APPLIED ON</th>
                            <th class="text-muted small fw-bold border-0">STATUS</th>
                            <th class="text-muted small fw-bold border-0 pe-4"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!requests.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <i class="bi bi-house-door fs-2 d-block mb-2 opacity-25"></i>
                                    No WFH requests found.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var r in requests.OrderByDescending(x => x.Date))
                            {
                                <tr class="@(r.Status == "Pending" ? "table-warning" : "")">
                                    <td class="ps-4 fw-semibold">@r.Date.ToString("dd MMM yyyy")</td>
                                    <td class="text-muted small">@r.Reason</td>
                                    <td class="small text-muted">
                                        @r.AppliedAt.ToLocalTime().ToString("dd MMM yyyy")
                                    </td>
                                    <td>
                                        <span class="badge rounded-pill @GetStatusClass(r.Status)">
                                            @r.Status
                                        </span>
                                    </td>
                                    <td class="pe-4 text-end">
                                        @if (r.Status == "Pending")
                                        {
                                            <button class="btn btn-sm btn-outline-danger"
                                                    disabled="@actionLoading"
                                                    @onclick="() => Cancel(r.Id)">
                                                Cancel
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

</div>

<!-- APPLY WFH MODAL -->
@if (showModal)
{
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content shadow">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">
                        <i class="bi bi-house-fill text-primary me-2"></i>Apply for WFH
                    </h5>
                    <button class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body pt-2">

                    <!-- MODAL INLINE ERROR -->
                    @if (!string.IsNullOrEmpty(modalError))
                    {
                        <div class="alert alert-danger border-0 d-flex gap-2 small">
                            <i class="bi bi-exclamation-triangle-fill mt-1"></i>
                            <div>@modalError</div>
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-uppercase text-muted">
                            Date <span class="text-danger">*</span>
                        </label>
                        <input type="date"
                               class="form-control @(showModalValidation && model.Date == default ? "is-invalid" : "")"
                               min="@DateTime.Today.ToString("yyyy-MM-dd")"
                               @bind="model.Date" />
                        @if (showModalValidation && model.Date == default)
                        {
                            <div class="invalid-feedback">Date is required.</div>
                        }
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-uppercase text-muted">
                            Reason <span class="text-danger">*</span>
                        </label>
                        <textarea class="form-control @(showModalValidation && string.IsNullOrWhiteSpace(model.Reason) ? "is-invalid" : "")"
                                  rows="3"
                                  placeholder="Briefly explain why you need to work from home..."
                                  @bind="model.Reason"></textarea>
                        @if (showModalValidation && string.IsNullOrWhiteSpace(model.Reason))
                        {
                            <div class="invalid-feedback">Reason is required.</div>
                        }
                    </div>

                </div>
                <div class="modal-footer border-0">
                    <button class="btn btn-secondary" @onclick="CloseModal" disabled="@actionLoading">
                        Cancel
                    </button>
                    <button class="btn btn-primary"
                            style="background-color:#5c4ac7;border:none;"
                            @onclick="SubmitWfh"
                            disabled="@actionLoading">
                        @if (actionLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Submit Request
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {

    // ── State ────────────────────────────────────────────────────────────────────
    private List<WorkFromHomeRequest> requests = new();
    private WorkFromHomeRequest model = new();

    private bool isLoading;
    private bool actionLoading;
    private bool showModal;
    private bool showModalValidation;
    private bool isError;
    private string? message;
    private string? modalError;

    // ── Lifecycle ────────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync() => await LoadRequests();

    private async Task LoadRequests()
    {
        isLoading = true;
        try
        {
            requests = await WfhService.GetMyAsync();
        }
        catch (Exception ex)
        {
            isError = true;
            message = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    // ── Modal ────────────────────────────────────────────────────────────────────
    private void OpenApplyModal()
    {
        model = new WorkFromHomeRequest { Date = DateTime.Today.AddDays(1) };
        modalError = null;
        showModalValidation = false;
        showModal = true;
    }

    private void CloseModal() => showModal = false;

    // ── Actions ──────────────────────────────────────────────────────────────────
    private async Task SubmitWfh()
    {
        showModalValidation = true;
        modalError = null;

        if (model.Date == default || string.IsNullOrWhiteSpace(model.Reason))
            return;

        actionLoading = true;
        try
        {
            await WfhService.ApplyAsync(model);
            isError = false;
            message = "WFH request submitted successfully. Pending HR approval.";
            showModal = false;
            await LoadRequests();
        }
        catch (Exception ex)
        {
            modalError = ex.Message;
        }
        finally
        {
            actionLoading = false;
        }
    }

    private async Task Cancel(Guid id)
    {
        actionLoading = true;
        message = null;
        try
        {
            await WfhService.CancelAsync(id);
            isError = false;
            message = "WFH request cancelled.";
            await LoadRequests();
        }
        catch (Exception ex)
        {
            isError = true;
            message = ex.Message;
        }
        finally
        {
            actionLoading = false;
        }
    }

    // ── Helpers ──────────────────────────────────────────────────────────────────
    private static string GetStatusClass(string? status) => status switch
    {
        "Approved" => "bg-success",
        "Rejected" => "bg-danger",
        "Cancelled" => "bg-secondary",
        _ => "bg-warning text-dark"
    };
}
