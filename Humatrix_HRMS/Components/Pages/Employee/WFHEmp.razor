@page "/employee/wfh"
@rendermode InteractiveServer
@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize(Roles = "Employee , HR")]
@inject WorkFromHomeService WfhService
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Work From Home | Humatrix HRMS</PageTitle>

<div class="position-fixed top-0 end-0 p-3" style="z-index: 1080;">
    @if (!string.IsNullOrEmpty(message))
    {
        <div class="toast show align-items-center border-0 shadow-lg mb-2" role="alert" style="background-color: #f0fdf4; color: #166534; border-left: 4px solid #10b981 !important; border-radius: 10px;">
            <div class="d-flex p-3">
                <div class="toast-body d-flex align-items-center p-0">
                    <i class="bi bi-check-circle-fill me-2 fs-5" style="color: #10b981;"></i>
                    <span class="small fw-medium">@message</span>
                </div>
                <button type="button" class="btn-close m-auto me-0 shadow-none" @onclick="() => message = null"></button>
            </div>
        </div>
    }
</div>

<div class="container-fluid px-4 mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom row-gap-3 flex-wrap">
        <div>
            <h2 class="fw-bold tracking-tight text-dark mb-1">Work From Home</h2>
            <p class="text-muted small mb-0">Submit and track your remote work requests.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-add-dept d-flex align-items-center gap-2 shadow-sm" @onclick="OpenApplyModal">
                <i class="bi bi-house-add"></i>
                APPLY WFH
            </button>
            <button class="btn btn-dashboard d-flex align-items-center gap-2 shadow-sm" @onclick="GoDashboard">
                <i class="bi bi-speedometer2"></i>
                DASHBOARD
            </button>
        </div>
    </div>

    <div class="card border-0 shadow-sm panel-container-card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4 text-secondary small fw-bold tracking-wider py-3">DATE</th>
                        <th class="text-secondary small fw-bold tracking-wider py-3">REASON</th>
                        <th class="text-secondary small fw-bold tracking-wider py-3 text-center">STATUS</th>
                        <th class="text-secondary small fw-bold tracking-wider py-3 text-end pe-4">ACTIONS / REVIEWER</th>
                    </tr>
                </thead>
                <tbody>
                    @if (isLoading)
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5">
                                <div class="spinner-border text-primary" style="width: 2rem; height: 2rem;" role="status"></div>
                                <p class="mt-2 text-muted small mb-0">Loading system data...</p>
                            </td>
                        </tr>
                    }
                    else if (!requests.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <span class="fw-medium">No WFH requests found.</span>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var r in requests.OrderByDescending(x => x.Date))
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark">@r.Date.ToString("dd MMM yyyy")</td>
                                <td class="text-muted small">@r.Reason</td>
                                <td class="text-center">
                                    <span class="status-indicator-pill @GetStatusClass(r.Status)">@r.Status</span>
                                </td>
                                <td class="pe-4 text-end">
                                    @if (r.Status == "Pending")
                                    {
                                        <button class="btn btn-sm btn-action-cancel" @onclick="() => Cancel(r.Id)">Cancel</button>
                                    }
                                    else if (r.ApprovedBy.HasValue && reviewerCache.ContainsKey(r.ApprovedBy.Value))
                                    {
                                        <div class="small">
                                            <div class="fw-bold">@reviewerCache[r.ApprovedBy.Value].Name</div>
                                            <div class="text-muted" style="font-size: 10px;">@reviewerCache[r.ApprovedBy.Value].Role</div>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (showModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 14px;">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Apply for WFH</h5>
                    <button class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-uppercase text-muted">Date</label>
                        <input type="date" class="form-control premium-edit-input" min="@DateTime.Today.ToString("yyyy-MM-dd")" @bind="model.Date" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-uppercase text-muted">Reason</label>
                        <textarea class="form-control premium-edit-input" rows="3" @bind="model.Reason"></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button class="btn btn-action-cancel" @onclick="CloseModal">Cancel</button>
                    <button class="btn btn-add-dept" @onclick="SubmitWfh">Submit Request</button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .tracking-tight {
        letter-spacing: -0.025em;
    }

    .tracking-wider {
        letter-spacing: 0.04em;
        font-size: 11px;
    }

    .panel-container-card {
        border-radius: 14px;
        background-color: #ffffff;
        overflow: hidden;
    }

    .btn-add-dept {
        background-color: #5c4ac7 !important;
        color: #ffffff !important;
        border: none !important;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
    }

    .btn-dashboard {
        background: #ffffff !important;
        border: 1px solid #e5e7eb !important;
        color: #4b5563 !important;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
    }

        .btn-dashboard:hover {
            border-color: #5c4ac7 !important;
            color: #5c4ac7 !important;
        }

    .btn-action-cancel {
        background-color: #f1f5f9;
        color: #475569;
        border: 1px solid #e2e8f0;
        border-radius: 6px;
        padding: 4px 12px;
        font-size: 12.5px;
    }

    .premium-edit-input {
        font-size: 13.5px;
        padding: 8px 12px;
        border-radius: 8px;
        border: 1px solid #cbd5e1;
    }

    .status-indicator-pill {
        font-size: 11px;
        font-weight: 600;
        padding: 2px 10px;
        border-radius: 6px;
    }
</style>

@code {
    private List<WorkFromHomeRequest> requests = new();
    private Dictionary<Guid, (string Name, string Role)> reviewerCache = new();
    private WorkFromHomeRequest model = new();
    private bool isLoading, showModal;
    private string? message;

    protected override async Task OnInitializedAsync() => await LoadRequests();

    private async Task LoadRequests()
    {
        isLoading = true;
        requests = await WfhService.GetMyAsync();
        foreach (var r in requests.Where(x => x.ApprovedBy.HasValue && !reviewerCache.ContainsKey(x.ApprovedBy.Value)))
            reviewerCache[r.ApprovedBy.Value] = await WfhService.GetReviewerInfoAsync(r.ApprovedBy);
        isLoading = false;
    }

    private void OpenApplyModal() { model = new WorkFromHomeRequest { Date = DateTime.Today.AddDays(1) }; showModal = true; }
    private void CloseModal() => showModal = false;

    private async Task SubmitWfh() { await WfhService.ApplyAsync(model); showModal = false; await LoadRequests(); }
    private async Task Cancel(Guid id) { await WfhService.CancelAsync(id); await LoadRequests(); }
    private async Task GoDashboard() { var authState = await AuthStateProvider.GetAuthenticationStateAsync(); Nav.NavigateTo(authState.User.IsInRole("HR") ? "/hr/dashboard" : "/employee/dashboard"); }

    private static string GetStatusClass(string? status) => status switch
    {
        "Approved" => "pill-active",
        "Rejected" => "pill-inactive",
        _ => "bg-light text-dark"
    };
}