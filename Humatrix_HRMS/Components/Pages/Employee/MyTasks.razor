@page "/employee/my-tasks"
@rendermode InteractiveServer

@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Services
@using Humatrix_HRMS.Data
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.EntityFrameworkCore

@attribute [Authorize(Roles = "Employee,HR")]

@inject TaskService TaskService
@inject NavigationManager Nav
@inject CurrentUserService CurrentUser
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>My Tasks | Humatrix HRMS</PageTitle>

@* Toast Notification Container *@
<div class="position-fixed top-0 end-0 p-3" style="z-index: 1080;">
    @if (!string.IsNullOrEmpty(message))
    {
        <div class="toast show align-items-center border-0 shadow-lg mb-2" role="alert" style="background-color: #f0fdf4; color: #166534; border-left: 4px solid #10b981 !important; border-radius: 10px;">
            <div class="d-flex p-3">
                <div class="toast-body d-flex align-items-center p-0">
                    <i class="bi bi-check-circle-fill me-2 fs-5" style="color: #10b981;"></i>
                    <span class="small fw-medium">@message</span>
                </div>
                <button type="button" class="btn-close m-auto me-0 shadow-none" @onclick="() => message = null"></button>
            </div>
        </div>
    }
</div>

<div class="container-fluid px-4 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom row-gap-3 flex-wrap">
        <div>
            <h2 class="fw-bold tracking-tight text-dark mb-1">My Tasks</h2>
            <p class="text-muted small mb-0">Track and update your assigned operational tasks.</p>
        </div>
        <button class="btn btn-interactive-back shadow-sm" @onclick='() => Nav.NavigateTo(dashboardPath)'>
            DASHBOARD
        </button>
    </div>

    @* METRICS *@
    <div class="row g-3 mb-4">
        <div class="col-md-3 col-sm-6">
            <div class="card border-0 shadow-sm metric-panel-card" style="border-left: 4px solid #5c4ac7 !important;">
                <div class="card-body d-flex align-items-center justify-content-between p-3">
                    <div>
                        <span class="text-secondary small fw-bold tracking-wider text-uppercase d-block mb-1">Total Tasks</span>
                        <h3 class="fw-bold text-dark mb-0">@tasks.Count</h3>
                    </div>
                    <div class="metric-icon-box" style="background-color: rgba(92, 74, 199, 0.08); color: #5c4ac7;">
                        <i class="bi bi-list-task"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="card border-0 shadow-sm metric-panel-card" style="border-left: 4px solid #ffc107 !important;">
                <div class="card-body d-flex align-items-center justify-content-between p-3">
                    <div>
                        <span class="text-secondary small fw-bold tracking-wider text-uppercase d-block mb-1">Pending</span>
                        <h3 class="fw-bold text-dark mb-0">@tasks.Count(t => t.Status == "Pending")</h3>
                    </div>
                    <div class="metric-icon-box" style="background-color: rgba(255, 193, 7, 0.08); color: #ffc107;">
                        <i class="bi bi-clock-history"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="card border-0 shadow-sm metric-panel-card" style="border-left: 4px solid #0dcaf0 !important;">
                <div class="card-body d-flex align-items-center justify-content-between p-3">
                    <div>
                        <span class="text-secondary small fw-bold tracking-wider text-uppercase d-block mb-1">In Progress</span>
                        <h3 class="fw-bold text-dark mb-0">@tasks.Count(t => t.Status == "In Progress")</h3>
                    </div>
                    <div class="metric-icon-box" style="background-color: rgba(13, 202, 240, 0.08); color: #0dcaf0;">
                        <i class="bi bi-gear-slide"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="card border-0 shadow-sm metric-panel-card" style="border-left: 4px solid #10b981 !important;">
                <div class="card-body d-flex align-items-center justify-content-between p-3">
                    <div>
                        <span class="text-secondary small fw-bold tracking-wider text-uppercase d-block mb-1">Completed</span>
                        <h3 class="fw-bold text-dark mb-0">@tasks.Count(t => t.Status == "Completed")</h3>
                    </div>
                    <div class="metric-icon-box" style="background-color: rgba(16, 185, 129, 0.08); color: #10b981;">
                        <i class="bi bi-check2-circle"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* FILTERS *@
    <div class="card border-0 shadow-sm p-3 mb-4 bg-light-gradient">
        <div class="row g-3">
            <div class="col-md-4">
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-search"></i></span>
                    <input class="form-control border-start-0 ps-0" placeholder="Search my tasks..." @bind="searchText" @bind:event="oninput" />
                </div>
            </div>
            <div class="col-md-4">
                <select class="form-select custom-select" @bind="selectedStatus">
                    <option value="">All Statuses</option>
                    <option>Pending</option>
                    <option>In Progress</option>
                    <option>Completed</option>
                </select>
            </div>
            <div class="col-md-4">
                <select class="form-select custom-select" @bind="selectedPriority">
                    <option value="">All Priorities</option>
                    <option>Low</option>
                    <option>Medium</option>
                    <option>High</option>
                </select>
            </div>
        </div>
    </div>

    @* TASK GRID *@
    @if (isLoading)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    }
    else if (!filteredTasks.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-clipboard-x display-4 text-muted"></i>
            <h5 class="mt-3 text-secondary">No tasks found</h5>
        </div>
    }
    else
    {
        <div class="row g-4 mb-5">
            @foreach (var t in filteredTasks)
            {
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm p-3">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h6 class="fw-bold text-dark">@t.Title</h6>
                            @if (IsOverdue(t))
                            {
                                <span class="badge bg-danger-soft text-danger">Overdue</span>
                            }
                        </div>
                        <p class="text-muted small mb-3">@(string.IsNullOrEmpty(t.Description) ? "No description provided." : t.Description)</p>

                        <div class="d-flex gap-2 mb-3">
                            <span class="badge rounded-pill priority-badge @GetPriorityClass(t.Priority)">@t.Priority</span>
                            <span class="badge rounded-pill status-badge @GetStatusClass(t.Status)">@t.Status</span>
                        </div>

                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <small class="fw-bold">Progress</small>
                                <small class="fw-bold">@t.Progress%</small>
                            </div>
                            <div class="progress card-progress">
                                <div class="progress-bar @GetProgressColor(t.Status)" style="width:@t.Progress%"></div>
                            </div>
                        </div>

                        <input type="range" class="form-range mb-3" min="0" max="100" step="10" value="@t.Progress"
                               disabled="@(t.Status == "Completed")" @onchange="(e) => UpdateProgress(t, e)" />

                        <div class="mt-auto pt-2 border-top">
                            <div class="d-flex justify-content-between">
                                <small class="text-muted"><i class="bi bi-calendar3 me-1"></i> Due: @(t.DueDate?.ToString("dd MMM yyyy") ?? "N/A")</small>
                                <small class="text-primary fw-bold">
                                    <i class="bi bi-person-badge"></i> @t.AssignedByName
                                </small>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .tracking-tight {
        letter-spacing: -0.025em;
    }

    .metric-panel-card {
        border-radius: 12px;
        background-color: #ffffff;
        transition: transform 0.2s;
    }

        .metric-panel-card:hover {
            transform: translateY(-3px);
        }

    .metric-icon-box {
        width: 42px;
        height: 42px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .card-progress {
        height: 6px;
        background-color: #edf2f7;
        border-radius: 10px;
        overflow: hidden;
    }

    .bg-light-gradient {
        background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
        border: 1px solid #e9ecef;
        border-radius: 12px;
    }

    .btn-interactive-back {
        background: #ffffff !important;
        border: 1px solid #e5e7eb !important;
        color: #4b5563 !important;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
        transition: all 0.2s ease;
    }

        .btn-interactive-back:hover {
            background-color: #f8fafc !important;
            border-color: #5c4ac7 !important;
            color: #5c4ac7 !important;
            transform: translateY(-1px);
        }

    .priority-badge {
        font-size: 11px;
        padding: 5px 10px;
    }

    .status-badge {
        font-size: 11px;
        padding: 5px 10px;
    }

    .bg-danger-soft {
        background-color: rgba(220, 53, 69, 0.1);
    }
</style>

@code {
    private List<TaskDto> tasks = new();
    private bool isLoading = true;
    private string? searchText;
    private string? selectedStatus;
    private string? selectedPriority;
    private string? message;
    private string dashboardPath = "/employee/dashboard";

    protected override async Task OnInitializedAsync()
    {
        var user = await CurrentUser.GetUserAsync();
        if (user != null)
        {
            using var db = DbFactory.CreateDbContext();
            var roles = await db.UserRoles
                .Where(ur => ur.UserId == user.Id)
                .Join(db.Roles, ur => ur.RoleId, r => r.Id, (ur, r) => r.Name.ToLower())
                .ToListAsync();

            if (roles.Contains("hr")) dashboardPath = "/hr/dashboard";
            else dashboardPath = "/employee/dashboard";
        }

        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("success", out var msg))
        {
            message = msg;
            TriggerToastAutoClose();
        }

        await TaskService.CreateTaskReminderNotificationsAsync();
        tasks = await TaskService.GetMyTasksAsync();
        isLoading = false;
    }

    private List<TaskDto> filteredTasks => tasks.Where(t =>
        (string.IsNullOrWhiteSpace(searchText) || t.Title.Contains(searchText, StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrEmpty(selectedStatus) || t.Status == selectedStatus) &&
        (string.IsNullOrEmpty(selectedPriority) || t.Priority == selectedPriority)
    ).OrderBy(t => t.Status == "Completed").ThenByDescending(t => t.CreatedAt).ToList();

    private async Task UpdateProgress(TaskDto task, ChangeEventArgs e)
    {
        int progress = Convert.ToInt32(e.Value);
        task.Progress = progress;
        task.Status = progress == 100 ? "Completed" : progress > 0 ? "In Progress" : "Pending";

        await TaskService.UpdateTaskAsync(new UpdateTaskDto { TaskId = task.TaskId, Progress = progress });

        message = "Task progress updated successfully!";
        TriggerToastAutoClose();
    }

    private void TriggerToastAutoClose()
    {
        _ = Task.Run(async () =>
        {
            await Task.Delay(4000);
            message = null;
            await InvokeAsync(StateHasChanged);
        });
    }

    private bool IsOverdue(TaskDto t) => t.DueDate.HasValue && t.DueDate.Value.Date < DateTime.Today && t.Status != "Completed";
    private string GetStatusClass(string status) => status switch { "Completed" => "bg-success text-white", "Pending" => "bg-warning text-dark", "In Progress" => "bg-info text-dark", _ => "bg-secondary" };
    private string GetPriorityClass(string priority) => priority switch { "High" => "bg-danger text-white", "Medium" => "bg-primary text-white", _ => "bg-secondary text-white" };
    private string GetProgressColor(string status) => status switch { "Completed" => "bg-success", "In Progress" => "bg-info", _ => "bg-warning" };
}