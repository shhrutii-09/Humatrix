@page "/employee/attendance-correction"
@rendermode InteractiveServer

@using Humatrix_HRMS.Data
@using Microsoft.EntityFrameworkCore

@inject ApplicationDbContext DbContext
@inject CurrentUserService CurrentUserService
@using Humatrix_HRMS.DTOs.AttendanceCorrections
@using Humatrix_HRMS.Helpers
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize(Roles = "Employee,HR,OrgAdmin")]

@inject AttendanceCorrectionService CorrectionService

<PageTitle>Attendance Correction | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-normal">Attendance Correction</h2>

        <button class="btn btn-outline-secondary shadow-sm"
                @onclick="LoadRequests">
            <i class="bi bi-arrow-clockwise"></i>
            REFRESH
        </button>
    </div>

    <!-- CREATE REQUEST -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-white border-0 pt-4 px-4">
            <h5 class="fw-normal mb-0">Submit Correction Request</h5>
        </div>

        <div class="card-body p-4">

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="alert alert-danger">
                    @errorMessage
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(successMessage))
            {
                <div class="alert alert-success">
                    @successMessage
                </div>
            }

            <div class="row g-3">

                <!-- DATE -->
                <div class="col-md-4">
                    <label class="form-label small fw-bold text-muted">
                        Work Date
                    </label>

                    <InputDate class="form-control"
                               @bind-Value="model.WorkDate" />
                </div>

                <!-- TYPE -->
                <div class="col-md-4">
                    <label class="form-label small fw-bold text-muted">
                        Request Type
                    </label>

                    <select class="form-select"
                            @bind="model.RequestType">

                        <option value="">Select Request Type</option>

                        <option value="@AttendanceCorrectionTypes.MissingCheckIn">
                            Missing Check-In
                        </option>

                        <option value="@AttendanceCorrectionTypes.MissingCheckOut">
                            Missing Check-Out
                        </option>

                        <option value="@AttendanceCorrectionTypes.WrongCheckIn">
                            Wrong Check-In
                        </option>

                        <option value="@AttendanceCorrectionTypes.WrongCheckOut">
                            Wrong Check-Out
                        </option>

                        <option value="@AttendanceCorrectionTypes.FullCorrection">
                            Full Correction
                        </option>

                    </select>
                </div>

                <!-- CHECK IN -->
                <div class="col-md-4">
                    <label class="form-label small fw-bold text-muted">
                        Requested Check-In
                    </label>

                    <input type="datetime-local" @bind="model.RequestedCheckIn" class="form-control" />"

                    @* <InputDateTime class="form-control"
                                   @bind-Value="model.RequestedCheckIn" /> *@
                </div>

                <!-- CHECK OUT -->
                <div class="col-md-4">
                    <label class="form-label small fw-bold text-muted">
                        Requested Check-Out
                    </label>
                    <input type="datetime-local" @bind="model.RequestedCheckOut" class="form-control" />"

                    @* <InputDateTime class="form-control"
                                   @bind-Value="model.RequestedCheckOut" /> *@
                </div>

                <!-- REASON -->
                <div class="col-12">
                    <label class="form-label small fw-bold text-muted">
                        Reason
                    </label>

                    <textarea class="form-control"
                              rows="4"
                              @bind="model.Reason">
                    </textarea>
                </div>

                <!-- BUTTON -->
                <div class="col-12">
                    <button class="btn btn-primary shadow-sm"
                            style="background-color:#5c4ac7;border:none;"
                            @onclick="SubmitRequest"
                            disabled="@isSubmitting">

                        @if (isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }

                        SUBMIT REQUEST
                    </button>
                </div>

            </div>

        </div>
    </div>

    <!-- REQUEST HISTORY -->
    <div class="card shadow-sm border-0">

        <div class="card-header bg-white border-0 pt-4 px-4">
            <h5 class="fw-normal mb-0">My Correction Requests</h5>
        </div>

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 text-muted small">DATE</th>
                        <th class="text-muted small">TYPE</th>
                        <th class="text-muted small">REQUESTED IN</th>
                        <th class="text-muted small">REQUESTED OUT</th>
                        <th class="text-muted small">STATUS</th>
                        <th class="text-muted small">REMARKS</th>
                    </tr>
                </thead>

                <tbody>

                    @if (isLoading)
                    {
                        <tr>
                            <td colspan="6"
                                class="text-center py-5 text-muted">

                                <span class="spinner-border spinner-border-sm me-2"></span>
                                Loading requests...

                            </td>
                        </tr>
                    }
                    else if (requests.Any())
                    {
                        @foreach (var item in requests)
                        {
                            <tr>

                                <td class="ps-4 fw-semibold">
                                    @item.WorkDate.ToString("dd MMM yyyy")
                                </td>

                                <td>
                                    @FormatType(item.RequestType)
                                </td>

                                <td class="font-monospace">
                                    @FormatTime(item.RequestedCheckIn)
                                </td>

                                <td class="font-monospace">
                                    @FormatTime(item.RequestedCheckOut)
                                </td>

                                <td>
                                    <span class="badge rounded-pill @GetStatusClass(item.Status)">
                                        @item.Status
                                    </span>
                                </td>

                                <td>
                                    @(string.IsNullOrWhiteSpace(item.HRRemarks)
                                        ? "-"
                                        : item.HRRemarks)
                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6"
                                class="text-center py-5 text-muted">

                                No correction requests found.

                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>
    </div>

</div>

@code {

    private List<AttendanceCorrectionListDto> requests = new();

    private CreateAttendanceCorrectionDto model = new()
    {
        WorkDate = DateTime.Today
    };
    private async Task LoadOrgTimezone()
    {
        var user = await CurrentUserService.GetUserAsync();

        if (user?.OrganizationId == null)
        {
            orgTimeZone = TimeZoneInfo.Utc;
            return;
        }

        var org = await DbContext.Organizations
            .AsNoTracking()
            .FirstOrDefaultAsync(x =>
                x.OrganizationId == user.OrganizationId);

        try
        {
            orgTimeZone = TimeZoneInfo.FindSystemTimeZoneById(
                org?.TimeZoneId ?? "UTC");
        }
        catch
        {
            orgTimeZone = TimeZoneInfo.Utc;
        }
    }
    private bool isLoading;
    private bool isSubmitting;

    private string? errorMessage;
    private string? successMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrgTimezone();

        await LoadRequests();
    }

    private async Task LoadRequests()
    {
        isLoading = true;

        try
        {
            requests = await CorrectionService.GetMyRequestsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SubmitRequest()
    {
        errorMessage = null;
        successMessage = null;

        isSubmitting = true;

        try
        {
            await CorrectionService.CreateRequestAsync(model);

            successMessage =
                "Attendance correction request submitted successfully.";

            model = new CreateAttendanceCorrectionDto()
            {
                WorkDate = DateTime.Today
            };

            await LoadRequests();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    // private string FormatTime(DateTime? value)
    // {
    //     if (value == null)
    //         return "--";

    //     return value.Value.ToLocalTime()
    //         .ToString("dd MMM yyyy hh:mm tt");
    // }

    private TimeZoneInfo orgTimeZone = TimeZoneInfo.Utc;

    private string FormatTime(DateTime? utcTime)
    {
        if (!utcTime.HasValue)
            return "--:--";

        var localTime = TimeZoneInfo.ConvertTimeFromUtc(
            DateTime.SpecifyKind(
                utcTime.Value,
                DateTimeKind.Utc),
            orgTimeZone);

        return localTime.ToString("dd MMM yyyy hh:mm tt");
    }

    private string FormatType(string type)
    {
        return type switch
        {
            AttendanceCorrectionTypes.MissingCheckIn => "Missing Check-In",
            AttendanceCorrectionTypes.MissingCheckOut => "Missing Check-Out",
            AttendanceCorrectionTypes.WrongCheckIn => "Wrong Check-In",
            AttendanceCorrectionTypes.WrongCheckOut => "Wrong Check-Out",
            AttendanceCorrectionTypes.FullCorrection => "Full Correction",
            _ => type
        };
    }

    private string GetStatusClass(string? status)
    {
        return status switch
        {
            AttendanceCorrectionStatuses.Pending
                => "bg-warning text-dark",

            AttendanceCorrectionStatuses.Approved
                => "bg-success",

            AttendanceCorrectionStatuses.Rejected
                => "bg-danger",

            _ => "bg-secondary"
        };
    }
}