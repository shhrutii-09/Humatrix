@page "/employee/corrections"
@rendermode InteractiveServer
@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Helpers
@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Humatrix_HRMS.Data
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@attribute [Authorize(Roles = "Employee,HR")]

@inject AttendanceCorrectionService CorrectionService
@inject CurrentUserService CurrentUserService
@using System.Globalization
@inject NavigationManager Nav
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Attendance Corrections | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">

    @* Premium Floating Notifications Container with Auto-Dismiss *@
    <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 9999;">
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="toast show premium-side-toast animate-slide-in toast-success-border" role="alert">
                <div class="toast-body d-flex align-items-center gap-3 p-3">
                    <div class="toast-icon-circle bg-light-success text-success">
                        <i class="bi bi-check-circle-fill fs-5"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h6 class="mb-0 fw-bold text-success" style="font-size: 13.5px;">Action Completed</h6>
                        <small class="text-secondary d-block mt-0.5" style="font-size: 12px; line-height: 1.3;">@successMessage</small>
                    </div>
                    <button type="button" class="btn-close shadow-none ms-auto" @onclick="() => successMessage = null"></button>
                </div>
            </div>
        }
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="toast show premium-side-toast animate-slide-in toast-danger-border" role="alert">
                <div class="toast-body d-flex align-items-center gap-3 p-3">
                    <div class="toast-icon-circle bg-light-danger text-danger">
                        <i class="bi bi-shield-fill-x fs-5"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h6 class="mb-0 fw-bold text-danger" style="font-size: 13.5px;">Execution Failure</h6>
                        <small class="text-secondary d-block mt-0.5" style="font-size: 12px; line-height: 1.3;">@errorMessage</small>
                    </div>
                    <button type="button" class="btn-close shadow-none ms-auto" @onclick="() => errorMessage = null"></button>
                </div>
            </div>
        }
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom row-gap-3 flex-wrap">
        <div>
            <h2 class="fw-bold tracking-tight text-dark mb-1">Attendance Corrections</h2>
            <p class="text-muted small mb-0">Request corrections for missed or incorrect check-in / check-out</p>
        </div>
        <div class="d-flex align-items-center gap-2">
            <button class="btn btn-add-dept d-flex align-items-center gap-2 shadow-sm"
                    @onclick="OpenSubmitModal"
                    disabled="@isLoading">
                <i class="bi bi-plus-circle"></i>NEW REQUEST
            </button>
            <button class="btn btn-interactive-back shadow-sm" @onclick='() => Nav.NavigateTo(dashboardPath)'>
                <i class="bi bi-speedometer2"></i>
                DASHBOARD
            </button>
        </div>
    </div>

    <div class="card border-0 shadow-sm panel-container-card">
        <div class="card-body border-bottom py-3 d-flex justify-content-between align-items-center">
            <h6 class="mb-0 fw-bold text-dark">My Correction Requests</h6>
            @* <button class="btn btn-dashboard d-flex align-items-center gap-2 shadow-sm" @onclick="LoadRequests">
                <i class="bi bi-arrow-clockwise"></i> Refresh
            </button> *@
        </div>
        <div class="table-responsive">
            @if (isLoading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary"></div>
                    <p class="text-muted small mt-2">Loading requests...</p>
                </div>
            }
            else if (!requests.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-inbox fs-2 d-block mb-2 opacity-25"></i>
                    No correction requests yet.
                </div>
            }
            else
            {
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4 text-secondary small fw-bold tracking-wider py-3">DATE</th>
                            <th class="text-secondary small fw-bold tracking-wider py-3">TYPE</th>
                            <th class="text-center text-secondary small fw-bold tracking-wider py-3">ORIGINAL IN</th>
                            <th class="text-center text-secondary small fw-bold tracking-wider py-3">ORIGINAL OUT</th>
                            <th class="text-center text-secondary small fw-bold tracking-wider py-3">REQUESTED IN</th>
                            <th class="text-center text-secondary small fw-bold tracking-wider py-3">REQUESTED OUT</th>
                            <th class="text-secondary small fw-bold tracking-wider py-3">STATUS</th>
                            <th class="text-secondary small fw-bold tracking-wider py-3">SUBMITTED</th>
                            <th class="text-secondary small fw-bold tracking-wider py-3 pe-4">ACTIONS</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var req in requests)
                        {
                            <tr class="table-row-interactive">
                                <td class="ps-4 fw-bold text-dark text-heading-field">@req.WorkDate.ToString("dd MMM yyyy")</td>
                                <td>
                                    <span class="badge bg-light text-dark fw-normal border">
                                        @FormatCorrectionType(req.CorrectionType)
                                    </span>
                                </td>
                                <td class="text-center font-monospace small text-muted">@FormatTime(req.OriginalCheckIn)</td>
                                <td class="text-center font-monospace small text-muted">@FormatTime(req.OriginalCheckOut)</td>
                                <td class="text-center font-monospace small">@FormatTime(req.RequestedCheckIn)</td>
                                <td class="text-center font-monospace small">@FormatTime(req.RequestedCheckOut)</td>
                                <td>
                                    <span class="status-indicator-pill @GetStatusClass(req.Status)">
                                        @req.Status
                                    </span>

                                    @if (!string.IsNullOrWhiteSpace(req.ReviewLevel))
                                    {
                                        <div class="small text-muted mt-1">
                                            @* → @req.ReviewLevel *@
                                        </div>
                                    }
                                </td>
                                <td class="small text-muted">
                                    @{
                                        string submittedDisplay = "—";
                                        try
                                        {
                                            if (orgTimeZone != null)
                                            {
                                                var localSubmittedAt = TimeZoneInfo.ConvertTimeFromUtc(req.SubmittedAt, orgTimeZone);
                                                submittedDisplay = localSubmittedAt.ToString("dd MMM yyyy, hh:mm tt");
                                            }
                                            else
                                            {
                                                submittedDisplay = req.SubmittedAt.ToString("dd MMM yyyy, HH:mm") + " UTC";
                                            }
                                        }
                                        catch
                                        {
                                            submittedDisplay = req.SubmittedAt.ToString("dd MMM yyyy, HH:mm") + " UTC";
                                        }
                                    }
                                    @submittedDisplay

                                    @if (req.IsOverdue)
                                    {
                                        <span class="badge bg-danger ms-1" title="Pending for more than 2 days">!</span>
                                    }
                                </td>

                                <td class="pe-4">
                                    @* FIX: CanCancel comes from the DTO (set in service).
                                       No need to re-check status here — keeps logic in one place. *@
                                    @if (req.CanCancel)
                                    {
                                        <button class="btn btn-sm btn-action-cancel"
                                                @onclick="() => ConfirmCancel(req.AttendanceCorrectionRequestId)">
                                            <i class="bi bi-x-circle me-1"></i>Cancel
                                        </button>
                                    }
                                    @if (!string.IsNullOrEmpty(req.HrNote) || !string.IsNullOrEmpty(req.RejectionReason))
                                    {
                                        <span class="ms-1 text-muted"
                                              title="@(req.RejectionReason ?? req.HrNote)">
                                            <i class="bi bi-chat-text"></i>
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>

<!-- ── SUBMIT MODAL ────────────────────────────────────────────────────────── -->
@if (showSubmitModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(15, 23, 42, 0.45); backdrop-filter: blur(2px);">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 14px;">
                <div class="modal-header border-0">
                    <h5 class="modal-title fw-bold text-dark">Submit Attendance Correction</h5>
                    <button type="button" class="btn-close" @onclick="CloseSubmitModal"></button>
                </div>
                <div class="modal-body p-4">
                    @if (!string.IsNullOrEmpty(modalError))
                    {
                        <div class="alert alert-danger border-0 shadow-sm">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>@modalError
                        </div>
                    }
                    @if (preValidation != null && !preValidation.IsAllowed)
                    {
                        <div class="alert alert-warning border-0 shadow-sm">
                            <i class="bi bi-exclamation-circle-fill me-2"></i>

                            <strong>Cannot submit request:</strong>
                            @preValidation.BlockReason

                            @if (preValidation.IsHoliday)
                            {
                                <div class="small mt-1">• This date is a public holiday.</div>
                            }

                            @if (preValidation.IsWeeklyOff)
                            {
                                <div class="small">• This is a weekly off / non-working day.</div>
                            }

                            @if (preValidation.IsOnLeave)
                            {
                                <div class="small">• You already have approved leave.</div>
                            }

                            @if (preValidation.IsOnWfh)
                            {
                                <div class="small">• You already have approved WFH.</div>
                            }

                            @if (preValidation.HasExistingPending)
                            {
                                <div class="small">• A pending correction already exists.</div>
                            }
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Work Date <span class="text-danger">*</span></label>
                        @* <InputDate @bind-Value="submitDto.WorkDate" class="form-control" /> *@
                        <InputDate @bind-Value="submitDto.WorkDate"
                                   @bind-Value:after="OnWorkDateChanged"
                                   class="form-control" />

                        <div class="form-text">Cannot be a future date or older than 30 days.</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Correction Type <span class="text-danger">*</span></label>
                        @* FIX: Use @bind:after to reset time fields when type changes,
                           preventing stale times from a previous selection being sent. *@
                        <select class="form-select"
                                value="@submitDto.CorrectionType"
                                @onchange="OnCorrectionTypeChanged">
                            <option value="">-- Select --</option>
                            <option value="@CorrectionTypes.ForgotCheckIn">Forgot to Check In</option>
                            <option value="@CorrectionTypes.ForgotCheckOut">Forgot to Check Out</option>
                            <option value="@CorrectionTypes.WrongTime">Wrong Time (In / Out)</option>
                            <option value="@CorrectionTypes.AbsentButWorked">Absent but Worked</option>
                            <option value="@CorrectionTypes.OvertimeCorrection">Overtime Correction</option>
                        </select>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(submitDto.CorrectionType)
                                    && preValidation?.AttendanceRecordExists == true)
                    {
                        <div class="alert alert-info border-0 small mt-3">
                            <i class="bi bi-info-circle me-1"></i>

                            Current attendance status:
                            <strong>@(preValidation.ExistingStatus ?? "Unknown")</strong>
                        </div>
                    }

                    @* FIX: Time inputs — use @bind:event="oninput" so the value is
                       captured immediately on every keystroke, not just on blur.
                       This prevents the "fields reset when clicking elsewhere" bug
                       caused by Blazor's default onchange binding conflicting with
                       the browser's native time-picker focus cycle.

                       We bind to TimeOnly? fields. TimeOnly is the correct type for
                       <input type="time"> in .NET 8 Blazor — not TimeSpan, not string.
                       In HandleSubmit we call .ToTimeSpan() to get the TimeSpan needed
                       by DateTime.Add(). *@
                    @if (ShowCheckInField)
                    {
                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Requested Check-In Time
                                @if (CorrectionTypes.RequiresCheckIn.Contains(submitDto.CorrectionType ?? ""))
                                {
                                    <span class="text-danger">*</span>
                                }
                            </label>
                            <input type="text"
                                   class="form-control"
                                   placeholder="e.g. 09:30 AM or 18:30" @bind="requestedCheckInText" />

                            <div class="form-text">
                                Overnight shifts are supported (example: 02:00 AM next day).
                            </div>
                            @* <input type="time"
                                   class="form-control"
                                   value="@(requestedCheckInTime?.ToString("HH:mm"))"
                                   @onchange="e => requestedCheckInTime = ParseTimeOnly(e.Value?.ToString())" /> *@
                            <div class="form-text">24-hour format — e.g. 09:00, 14:30</div>
                        </div>
                    }

                    @if (ShowCheckOutField)
                    {
                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Requested Check-Out Time
                                @if (CorrectionTypes.RequiresCheckOut.Contains(submitDto.CorrectionType ?? ""))
                                {
                                    <span class="text-danger">*</span>
                                }
                            </label>
                            @* <input type="time"
                                   class="form-control"
                                   value="@(requestedCheckOutTime?.ToString("HH:mm"))"
                                   @onchange="e => requestedCheckOutTime = ParseTimeOnly(e.Value?.ToString())" /> *@

                            <input type="text"
                                   class="form-control"
                                   placeholder="e.g. 09:30 AM or 18:30" @bind="requestedCheckOutText" />

                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Reason <span class="text-danger">*</span></label>
                        <textarea @bind="submitDto.Reason" class="form-control" rows="3"
                                  placeholder="Provide a detailed reason (min. 10 characters)..."></textarea>
                    </div>

                    <div class="alert alert-info border-0 small">
                        <i class="bi bi-info-circle me-2"></i>
                        Times must be entered in your organisation's local time. The system converts them automatically.
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button class="btn btn-action-cancel px-3" @onclick="CloseSubmitModal">Cancel</button>
                    <button class="btn btn-add-dept px-4"
                            @onclick="HandleSubmit"
                            disabled="@(isSubmitting || preValidation?.IsAllowed == false)">
                        @if (isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Submit Request
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- ── CANCEL CONFIRM MODAL ────────────────────────────────────────────────── -->
@if (cancelRequestId.HasValue)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(15, 23, 42, 0.45); backdrop-filter: blur(2px);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 14px;">
                <div class="modal-body p-4 text-center">
                    <i class="bi bi-exclamation-triangle-fill text-warning fs-2 mb-3 d-block"></i>
                    <h5 class="fw-bold text-dark">Cancel Correction Request?</h5>
                    <p class="text-muted">This action cannot be undone.</p>
                    <div class="mb-3">
                        <textarea @bind="cancelReason"
                                  class="form-control premium-edit-input"
                                  rows="2"
                                  placeholder="Optional cancellation reason"></textarea>
                    </div>
                    <div class="d-flex justify-content-center gap-3 mt-4">
                        <button class="btn btn-action-cancel px-4"
                                @onclick="() => cancelRequestId = null"
                                disabled="@isCancelling">
                            Keep Request
                        </button>
                        @* FIX: disabled during async cancel to prevent double-click. *@
                        <button class="btn btn-danger px-4"
                                @onclick="HandleCancel"
                                disabled="@isCancelling">
                            @if (isCancelling)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                            }
                            Yes, Cancel It
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

