@page "/employee/documents"
@rendermode InteractiveServer

@using Humatrix_HRMS.DTOs.Dashboard
@using Humatrix_HRMS.DTOs.Documents
@using Humatrix_HRMS.Models.Documents
@using Humatrix_HRMS.Services
@using Humatrix_HRMS.Services.Documents
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@using System.IO

@attribute [Authorize(Roles = "Employee,HR")]

@inject IEmployeeDocumentService EmployeeDocumentService
@inject IDocumentTypeService DocumentTypeService
@inject CurrentUserService CurrentUserService
@inject NavigationManager Nav
@inject IJSRuntime JsRuntime

<PageTitle>My Documents | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <h2 class="fw-bold">📄 My Documents</h2>
            <p class="text-muted small mb-0">
                Manage your employee documents. Upload, replace, and track verification status.
            </p>
        </div>
        <button class="btn btn-secondary" @onclick="GoBack">
            Dashboard
        </button>
    </div>

    <!-- Profile Completion Card -->
    @if (Dashboard != null)
    {
        <div class="card shadow-sm border-0 mb-4" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-md-8">
                        <h4 class="fw-bold mb-2 text-white">Profile Completion</h4>
                        <div class="progress mb-3" style="height: 12px; background-color: rgba(255,255,255,0.3);">
                            <div class="progress-bar bg-white"
                                 role="progressbar"
                                 style="width: @Dashboard.ProfileCompletionPercentage%;"
                                 aria-valuenow="@Dashboard.ProfileCompletionPercentage"
                                 aria-valuemin="0"
                                 aria-valuemax="100">
                            </div>
                        </div>
                        <div class="d-flex gap-4 flex-wrap text-white">
                            <div><span class="fw-bold">@Dashboard.ProfileCompletionPercentage%</span> Complete</div>
                            <div>📄 @Dashboard.UploadedDocuments / @Dashboard.TotalRequiredDocuments Uploaded</div>
                            <div>✓ @Dashboard.VerifiedDocuments Verified</div>
                            <div>⏳ @Dashboard.PendingDocuments Pending</div>
                            <div>✗ @Dashboard.RejectedDocuments Rejected</div>
                        </div>
                    </div>
                    <div class="col-md-4 text-end">
                        @if (Dashboard.MissingMandatoryCount > 0)
                        {
                            <div class="alert alert-warning mb-0 p-2 bg-warning text-dark">
                                ⚠️ @Dashboard.MissingMandatoryCount mandatory document(s) missing
                            </div>
                        }
                        else if (Dashboard.ProfileCompletionPercentage == 100)
                        {
                            <div class="alert alert-success mb-0 p-2 bg-white text-success">
                                ✓ All documents verified!
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Upload Modal -->
    <div class="modal fade" id="uploadModal" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                    <h5 class="modal-title text-white">Upload @SelectedDocumentType?.DocumentTypeName</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="@UploadModel" OnValidSubmit="@HandleUpload">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="alert alert-danger" />

                        <div class="mb-3">
                            <label class="form-label fw-bold">Document Type</label>
                            <input type="text" class="form-control" value="@SelectedDocumentType?.DocumentTypeName" disabled />
                            <small class="text-muted">
                                @if (SelectedDocumentType?.IsMandatory == true)
                                {
                                    <span class="text-danger">* Mandatory document</span>
                                }
                                @if (SelectedDocumentType?.RequiresVerification == true)
                                {
                                    <span class="text-warning ms-2">⏳ Requires verification</span>
                                }
                                @if (SelectedDocumentType?.TrackExpiry == true)
                                {
                                    <span class="text-info ms-2">📅 Expiry tracking enabled</span>
                                }
                            </small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Document File</label>
                            <InputFile id="documentFile" OnChange="@OnFileSelected" class="form-control" />
                            <small class="text-muted">
                                Allowed: @SelectedDocumentType?.AllowedFileTypes |
                                Max Size: @SelectedDocumentType?.MaxFileSizeMB MB
                            </small>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Document Number (Optional)</label>
                                <InputText class="form-control" @bind-Value="UploadModel.DocumentNumber"
                                           placeholder="e.g., ABC123XYZ" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Issuing Authority (Optional)</label>
                                <InputText class="form-control" @bind-Value="UploadModel.IssuingAuthority"
                                           placeholder="e.g., Government of India" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Issue Date</label>
                                <InputDate class="form-control" @bind-Value="UploadModel.IssueDate"
                                           ParsingErrorMessage="Invalid date" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Expiry Date</label>
                                <InputDate class="form-control" @bind-Value="UploadModel.ExpiryDate" />
                                @if (SelectedDocumentType?.TrackExpiry == true)
                                {
                                    <small class="text-warning d-block">⚠️ Expiry tracking is enabled for this document</small>
                                }
                            </div>
                        </div>

                        <div class="modal-footer px-0 pb-0">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-primary" disabled="@isUploading">
                                @if (isUploading)
                                {
                                    <span>
                                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                        Uploading...
                                    </span>
                                }
                                else
                                {
                                    <span>Upload Document</span>
                                }
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>

    <!-- Documents Table -->
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-0 pt-3">
            <div class="row align-items-center">
                <div class="col">
                    <h5 class="mb-0">Document Center</h5>
                </div>
                <div class="col-auto">
                    <div class="input-group">
                        <span class="input-group-text">🔍</span>
                        <input type="text" class="form-control" placeholder="Search documents..."
                               @bind="SearchText" @bind:event="oninput" />
                    </div>
                </div>
            </div>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Document Type</th>
                            <th>Category</th>
                            <th>Status</th>
                            <th>Version</th>
                            <th>Uploaded Date</th>
                            <th>Expiry</th>
                            <th style="width: 200px">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (FilteredDocuments.Any())
                        {
                            @foreach (var doc in FilteredDocuments)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-bold">
                                            @doc.DocumentTypeName
                                            @if (doc.IsMandatory)
                                            {
                                                <span class="badge bg-danger ms-1">Required</span>
                                            }
                                        </div>
                                        @if (!string.IsNullOrEmpty(doc.RejectionRemarks) && doc.Status == "Rejected")
                                        {
                                            <small class="text-danger d-block mt-1">
                                                <strong>Reason:</strong> @doc.RejectionRemarks
                                            </small>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary">@doc.Category</span>
                                    </td>
                                    <td>
                                        <span class="badge @doc.StatusBadgeClass">
                                            @doc.StatusIcon @doc.Status
                                        </span>
                                        @if (doc.Status == "Verified" && !string.IsNullOrEmpty(doc.VerifiedByName))
                                        {
                                            <small class="d-block text-muted mt-1">by @doc.VerifiedByName</small>
                                        }
                                    </td>
                                    <td>
                                        @if (doc.Version > 0)
                                        {
                                            <span class="badge bg-info">v@(doc.Version)</span>
                                        }
                                        else
                                        {
                                            <span>-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (doc.UploadedAt.HasValue)
                                        {
                                            <span title="@doc.UploadedAt.Value.ToString("yyyy-MM-dd HH:mm")">
                                                @doc.UploadedAt.Value.ToString("dd MMM yyyy")
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Not uploaded</span>
                                        }
                                    </td>
                                    <td>
                                        @if (doc.ExpiryDate.HasValue)
                                        {
                                            var daysUntilExpiry = (doc.ExpiryDate.Value.ToDateTime(TimeOnly.MinValue) - DateTime.UtcNow).Days;
                                            if (daysUntilExpiry < 0)
                                            {
                                                <span class="text-danger fw-bold">Expired</span>
                                            }
                                            else if (daysUntilExpiry < 30)
                                            {
                                                <span class="text-warning fw-bold">@daysUntilExpiry days left</span>
                                            }
                                            else
                                            {
                                                <span>@doc.ExpiryDate.Value.ToString("dd MMM yyyy")</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm" role="group">
                                            @if (doc.Status != "NotUploaded")
                                            {
                                                <button class="btn btn-outline-primary"
                                                        @onclick="() => DownloadDocument(doc.DocumentId)">
                                                    📥 View
                                                </button>
                                            }
                                            <button class="btn btn-outline-secondary"
                                                    @onclick="() => OpenUploadModal(doc)">
                                                @(doc.Status == "NotUploaded" ? "Upload" : "Replace")
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5">
                                    <div class="text-muted">
                                        <h5>No documents found</h5>
                                        <p>Try adjusting your search or upload your first document</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private EmployeeDocumentDashboardDto? Dashboard { get; set; }
    private EmployeeDocumentViewDto? SelectedDocumentType { get; set; }
    private DocumentUploadDto UploadModel { get; set; } = new();
    private IBrowserFile? SelectedFile { get; set; }
    private bool isUploading = false;
    private string SearchText = string.Empty;

    private IEnumerable<EmployeeDocumentViewDto> FilteredDocuments =>
        string.IsNullOrWhiteSpace(SearchText)
            ? Dashboard?.Documents ?? new List<EmployeeDocumentViewDto>()
            : Dashboard?.Documents.Where(x =>
                x.DocumentTypeName.Contains(SearchText, StringComparison.OrdinalIgnoreCase) ||
                x.Status.Contains(SearchText, StringComparison.OrdinalIgnoreCase) ||
                x.Category.Contains(SearchText, StringComparison.OrdinalIgnoreCase))
                ?? new List<EmployeeDocumentViewDto>();

    private EmployeeDashboardContextDto? EmployeeContext { get; set; }

    protected override async Task OnInitializedAsync()
    {
        EmployeeContext = await CurrentUserService.GetEmployeeDashboardContextAsync();

        if (EmployeeContext == null)
        {
            Nav.NavigateTo("/login");
            return;
        }

        await LoadDashboard();
    }

    private async Task LoadDashboard()
    {
        Dashboard = await EmployeeDocumentService.GetEmployeeDocumentDashboardAsync(
            EmployeeContext!.EmployeeId,
            EmployeeContext.OrganizationId);

        StateHasChanged();
    }

    private void OpenUploadModal(EmployeeDocumentViewDto documentType)
    {
        SelectedDocumentType = documentType;
        UploadModel = new DocumentUploadDto
        {
            EmployeeId = EmployeeContext!.EmployeeId,
            DocumentTypeId = documentType.DocumentTypeId
        };
        SelectedFile = null;

        JsRuntime.InvokeVoidAsync("window.showModal", "uploadModal");
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        SelectedFile = e.File;

        if (SelectedFile == null) return;

        // Validate file size
        if (SelectedDocumentType != null && SelectedFile.Size > SelectedDocumentType.MaxFileSizeMB * 1024 * 1024)
        {
            await JsRuntime.InvokeVoidAsync("alert",
                $"File size exceeds maximum allowed size of {SelectedDocumentType.MaxFileSizeMB} MB.\n" +
                $"Your file size: {SelectedFile.Size / 1024 / 1024} MB");
            SelectedFile = null;
            return;
        }

        // Validate file extension
        if (SelectedDocumentType != null && !string.IsNullOrEmpty(SelectedDocumentType.AllowedFileTypes))
        {
            var allowedExtensions = SelectedDocumentType.AllowedFileTypes
                .Split(',', StringSplitOptions.RemoveEmptyEntries)
                .Select(ext => ext.Trim().ToLower());

            var fileExtension = Path.GetExtension(SelectedFile.Name).ToLower();

            if (!allowedExtensions.Contains(fileExtension))
            {
                await JsRuntime.InvokeVoidAsync("alert",
                    $"File type '{fileExtension}' not allowed.\n" +
                    $"Allowed types: {SelectedDocumentType.AllowedFileTypes}");
                SelectedFile = null;
            }
        }

        StateHasChanged();
    }

    private async Task HandleUpload()
    {
        if (SelectedFile == null)
        {
            await JsRuntime.InvokeVoidAsync("alert", "Please select a file to upload");
            return;
        }

        isUploading = true;
        StateHasChanged();

        try
        {
            UploadModel.File = SelectedFile;

            var currentUser = await CurrentUserService.GetUserAsync();
            if (currentUser == null)
            {
                throw new Exception("User not found");
            }

            // Get user role - you might want to inject UserManager for this
            var userRole = "Employee"; // You can get this from claims

            var result = await EmployeeDocumentService.UploadDocumentAsync(
                UploadModel,
                EmployeeContext!.OrganizationId,
                currentUser.Id,
                userRole
            );

            // Close modal
            await JsRuntime.InvokeVoidAsync("hideModal", "uploadModal");

            // Reload dashboard
            await LoadDashboard();

            // Show success message
            await JsRuntime.InvokeVoidAsync("showToast", "success", "Document uploaded successfully!");
        }
        catch (Exception ex)
        {
            await JsRuntime.InvokeVoidAsync("showToast", "error", ex.Message);
        }
        finally
        {
            isUploading = false;
            StateHasChanged();
        }
    }

    private async Task DownloadDocument(Guid documentId)
    {
        // Navigate to download endpoint
        Nav.NavigateTo($"/api/documents/download/{documentId}", forceLoad: true);
    }

    private void GoBack()
    {
        Nav.NavigateTo("/employee/dashboard");
    }
}