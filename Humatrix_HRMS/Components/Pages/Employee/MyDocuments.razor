@page "/employee/documents"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Employee,HR")]
@using Humatrix_HRMS.DTOs.Dashboard
@using Humatrix_HRMS.DTOs.Documents
@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Models.Documents
@using Humatrix_HRMS.Services
@using Humatrix_HRMS.Services.Documents
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using System.IO
@inject IEmployeeDocumentService EmployeeDocumentService
@inject IOrgDocumentGenerationService OrgDocumentService
@inject IDocumentTypeService DocumentTypeService
@inject CurrentUserService CurrentUserService
@inject NavigationManager Nav
@inject IJSRuntime JsRuntime
@inject EmployeeService EmployeeServiceHelper

<PageTitle>My Documents | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">

    @* Header Section *@
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <h2 class="fw-bold">📄 My Documents</h2>
            <p class="text-muted small mb-0">View, upload, and acknowledge your documents</p>
        </div>
        <button class="btn btn-secondary btn-sm" @onclick='() => Nav.NavigateTo("/employee/dashboard")'>
            ← Dashboard
        </button>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
            <p class="mt-2 text-muted">Loading documents...</p>
        </div>
    }
    else
    {
        @* Profile completion banner *@
        @if (employeeDashboard != null)
        {
            <div class="card shadow-sm border-0 mb-4" style="background: linear-gradient(135deg, #667eea, #764ba2)">
                <div class="card-body text-white">
                    <div class="row align-items-center">
                        <div class="col-md-8">
                            <h5 class="fw-bold mb-2">Profile Completion</h5>
                            <div class="progress mb-3" style="height: 10px; background: rgba(255, 255, 255, 0.3)">
                                <div class="progress-bar bg-white" style="width: @(employeeDashboard.ProfileCompletionPercentage)%"></div>
                            </div>
                            <div class="d-flex gap-4 flex-wrap small">
                                <span>📄 @employeeDashboard.UploadedDocuments / @employeeDashboard.TotalRequiredDocuments uploaded</span>
                                <span>✓ @employeeDashboard.VerifiedDocuments verified</span>
                                <span>⏳ @employeeDashboard.PendingDocuments pending</span>
                                <span>✗ @employeeDashboard.RejectedDocuments rejected</span>
                            </div>
                        </div>
                        <div class="col-md-4 text-md-end mt-3 mt-md-0">
                            @if (employeeDashboard.MissingMandatoryCount > 0)
                            {
                                <div class="badge bg-warning text-dark px-3 py-2 fs-6">
                                    ⚠️ @employeeDashboard.MissingMandatoryCount required doc(s) missing
                                </div>
                            }
                            else
                            {
                                <div class="badge bg-white text-success px-3 py-2 fs-6">✓ All required documents uploaded</div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        @* Alert Messages *@
        @if (!string.IsNullOrEmpty(message))
        {
            <div class="alert alert-@(messageIsError ? "danger" : "success") alert-dismissible fade show mb-3">
                @message
                <button type="button" class="btn-close" @onclick="() => message = null"></button>
            </div>
        }

        @* Navigation Tabs *@
        <ul class="nav nav-tabs mb-4">
            <li class="nav-item">
                <button class="nav-link @(activeTab == "mine" ? "active fw-bold" : "")" @onclick='() => SetTab("mine")'>
                    My Uploads
                    <span class="badge bg-secondary ms-1">@employeeDocuments.Count</span>
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(activeTab == "org" ? "active fw-bold" : "") position-relative" @onclick='() => SetTab("org")'>
                    Company Documents
                    <span class="badge bg-secondary ms-1">@orgDocuments.Count</span>
                    @if (pendingAckCount > 0)
                    {
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.6rem;">
                            @pendingAckCount
                        </span>
                    }
                </button>
            </li>
        </ul>

        @* TAB 1 — MY UPLOADS *@
        @if (activeTab == "mine")
        {
            @* Upload Form *@
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="mb-0 fw-semibold">📤 Upload a Document</h6>
                </div>
                <div class="card-body">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-5">
                            <label class="form-label small fw-bold">Document Type <span class="text-danger">*</span></label>
                            <select class="form-select" @bind="selectedDocumentTypeId">
                                <option value="">— Select Document Type —</option>
                                @foreach (var t in uploadableDocumentTypes)
                                {
                                    <option value="@t.DocumentTypeId">
                                        @t.Name @(t.IsMandatory ? " (Required)" : "")
                                    </option>
                                }
                            </select>

                            @if (!uploadableDocumentTypes.Any())
                            {
                                <div class="form-text text-warning">
                                    No uploadable document types configured. Contact HR.
                                </div>
                            }
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-bold">File <span class="text-danger">*</span></label>
                            <InputFile OnChange="@OnFileSelected" class="form-control" />
                            <div class="form-text">PDF, JPG, PNG — max 5 MB</div>
                        </div>
                        <div class="col-md-3">
                            <button class="btn btn-primary w-100" @onclick="UploadDocument" disabled="@isUploading">
                                @(isUploading ? "Uploading…" : "Upload")
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            @* My Documents Table *@
            @if (!employeeDocuments.Any())
            {
                <div class="alert alert-info">
                    No documents uploaded yet. Use the form above to get started.
                </div>
            }
            else
            {
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white border-bottom py-3">
                        <h6 class="mb-0 fw-semibold">My Uploaded Documents</h6>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Document Type</th>
                                    <th>Category</th>
                                    <th>Status</th>
                                    <th>Uploaded</th>
                                    <th class="pe-4">File</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var doc in employeeDocuments)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="fw-bold">@doc.DocumentTypeName</div>
                                            @if (doc.IsMandatory)
                                            {
                                                <span class="badge bg-danger" style="font-size: 0.7rem;">Required</span>
                                            }
                                        </td>
                                        <td><span class="badge bg-light text-dark border">@doc.Category</span></td>
                                        <td>
                                            <span class="badge @GetStatusBadge(doc.Status)">
                                                @GetStatusIcon(doc.Status) @doc.Status
                                            </span>
                                            @if (doc.Status == "Rejected" && !string.IsNullOrEmpty(doc.RejectionRemarks))
                                            {
                                                <div class="text-danger small mt-1">
                                                    <i>Reason: @doc.RejectionRemarks</i>
                                                </div>
                                            }
                                        </td>
                                        <td class="small text-muted">@doc.UploadedAt?.ToString("dd MMM yyyy")</td>
                                        @* <td class="pe-4">
                                            <a href="api/documents/download/@doc.DocumentId" target="_blank" class="btn btn-sm btn-outline-primary">
                                                📄 View
                                            </a>
                                        </td> *@
                                        <td class="pe-4 text-end">
                                            @if (doc.DocumentId != Guid.Empty && !string.IsNullOrWhiteSpace(doc.FilePath))
                                            {
                                                <a href="@doc.FilePath" target="_blank" class="btn btn-sm btn-primary">
                                                    📄 View File
                                                </a>
                                            }
                                            else if (doc.DocumentId != Guid.Empty)
                                            {
                                                @* Fallback to API route if FilePath string isn't populated on the DTO yet *@
                                                <a href="api/documents/download/@doc.DocumentId" target="_blank" class="btn btn-sm btn-outline-primary">
                                                    📄 Download
                                                </a>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">No file attached</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        }

        @* TAB 2 — COMPANY DOCUMENTS (org-issued) *@
        @if (activeTab == "org")
        {
            @if (!orgDocuments.Any())
            {
                <div class="alert alert-info">No company documents have been issued to you yet.</div>
            }
            else
            {
                var pendingAck = orgDocuments.Where(d => d.Status == "Issued").ToList();
                var acknowledged = orgDocuments.Where(d => d.Status == "Acknowledged").ToList();
                var revoked = orgDocuments.Where(d => d.Status == "Revoked").ToList();

                @if (pendingAck.Any())
                {
                    <h6 class="fw-bold text-warning mb-3">⏳ Awaiting Your Acknowledgment (@pendingAck.Count)</h6>
                    <div class="row g-3 mb-4">
                        @foreach (var doc in pendingAck)
                        {
                            <div class="col-md-6 col-xl-4">
                                @OrgDocCard(doc, canAcknowledge: true)
                            </div>
                        }
                    </div>
                }

                @if (acknowledged.Any())
                {
                    <h6 class="fw-bold text-success mb-3">✓ Acknowledged (@acknowledged.Count)</h6>
                    <div class="row g-3 mb-4">
                        @foreach (var doc in acknowledged)
                        {
                            <div class="col-md-6 col-xl-4">
                                @OrgDocCard(doc, canAcknowledge: false)
                            </div>
                        }
                    </div>
                }

                @if (revoked.Any())
                {
                    <h6 class="fw-bold text-danger mb-3">🚫 Revoked Documents (@revoked.Count)</h6>
                    <div class="alert alert-danger py-2 small mb-3">
                        These documents have been <strong>revoked</strong> by your organisation. They are no longer valid. If you have questions, contact HR.
                    </div>
                    <div class="row g-3 mb-4">
                        @foreach (var doc in revoked)
                        {
                            <div class="col-md-6 col-xl-4">
                                @OrgDocCard(doc, canAcknowledge: false)
                            </div>
                        }
                    </div>
                }
            }
        }
    }
</div>

@code {
    // ── State ─────────────────────────────────────────────────────────────────
    private bool isLoading = true;
    private bool isUploading = false;
    private string activeTab = "mine";
    private string? message;
    private bool messageIsError = false;
    private EmployeeDocumentDashboardDto? employeeDashboard;
    private List<EmployeeDocumentViewDto> employeeDocuments = new();
    private List<OrgGeneratedDocument> orgDocuments = new();
    private List<DocumentType> uploadableDocumentTypes = new();
    private Guid selectedDocumentTypeId;
    private IBrowserFile? selectedFile;
    private Employee? currentEmployee;
    private Guid organizationId;
    private int pendingAckCount => orgDocuments.Count(d => d.Status == "Issued");

    // ── Lifecycle ─────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        try
        {
            isLoading = true;
            var user = await CurrentUserService.GetUserAsync();
            if (user?.OrganizationId == null)
            {
                Nav.NavigateTo("/login");
                return;
            }
            organizationId = user.OrganizationId.Value;

            currentEmployee = await EmployeeServiceHelper.GetEmployeeByUserIdAsync(user.Id);
            if (currentEmployee == null) return;

            employeeDashboard = await EmployeeDocumentService.GetEmployeeDocumentDashboardAsync(
                currentEmployee.EmployeeId, organizationId);
            employeeDocuments = employeeDashboard?.Documents ?? new();

            orgDocuments = await OrgDocumentService.GetDocumentsForEmployeeAsync(
                currentEmployee.EmployeeId, organizationId);

            var allTypes = await DocumentTypeService.GetOrganizationDocumentTypesAsync(organizationId);
            uploadableDocumentTypes = allTypes
                .Where(t => t.IsEmployeeUploadAllowed && t.IsActive)
                .ToList();
        }
        catch (Exception ex)
        {
            message = $"Error loading data: {ex.Message}";
            messageIsError = true;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void SetTab(string tab) => activeTab = tab;

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        await Task.CompletedTask;
    }

    private async Task UploadDocument()
    {
        if (selectedDocumentTypeId == Guid.Empty)
        {
            message = "Please select a document type.";
            messageIsError = true;
            return;
        }
        if (selectedFile == null)
        {
            message = "Please select a file.";
            messageIsError = true;
            return;
        }

        isUploading = true;
        message = null;
        try
        {
            var user = await CurrentUserService.GetUserAsync();
            await EmployeeDocumentService.UploadDocumentAsync(
                new DocumentUploadDto
                {
                    EmployeeId = currentEmployee!.EmployeeId,
                    DocumentTypeId = selectedDocumentTypeId,
                    File = selectedFile
                },
                organizationId, user!.Id, "Employee");

            message = "Document uploaded successfully. HR will review it shortly.";
            messageIsError = false;
            selectedDocumentTypeId = Guid.Empty;
            selectedFile = null;
            await LoadData();
        }
        catch (Exception ex)
        {
            message = $"Upload failed: {ex.Message}";
            messageIsError = true;
        }
        finally
        {
            isUploading = false;
        }
    }

    private async Task MarkAsViewed(Guid documentId)
    {
        try
        {
            await OrgDocumentService.MarkAsViewedAsync(documentId, currentEmployee!.EmployeeId);
        }
        catch
        {
            /* non-blocking */
        }
    }

    private async Task AcknowledgeOrgDocument(Guid documentId)
    {
        try
        {
            await OrgDocumentService.AcknowledgeDocumentAsync(
                documentId, currentEmployee!.EmployeeId, "Acknowledged via employee portal");
            message = "Document acknowledged.";
            messageIsError = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
            messageIsError = true;
        }
    }

    // ── Render helper for org doc cards ──────────────────────────────────────
    private RenderFragment OrgDocCard(OrgGeneratedDocument doc, bool canAcknowledge) =>
        @<div class="card h-100 shadow-sm @(doc.Status == "Revoked" ? "border-danger" : doc.Status == "Acknowledged" ? "border-success" : "border-warning")">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <span class="badge bg-light text-muted border small">@doc.GeneratedAt.ToString("dd MMM yyyy")</span>
            <span class="badge @GetIssuedBadge(doc.Status)">
                @GetIssuedIcon(doc.Status) @doc.Status
            </span>
        </div>
        <h6 class="fw-bold">@doc.DocumentName</h6>
        <small class="text-muted d-block">Ref: @doc.DocumentNumber</small>
        @if (!string.IsNullOrEmpty(doc.Description))
                {
        <p class="small text-muted mt-1 mb-0">@doc.Description</p>
                }
        @if (doc.Status == "Revoked")
                {
        <div class="alert alert-danger py-1 small mt-2 mb-0">
            🚫 This document has been revoked by your organisation.
        </div>
                }
        @if (doc.AcknowledgedAt.HasValue)
                {
        <small class="text-success d-block mt-2">
            ✓ You acknowledged this on @doc.AcknowledgedAt.Value.ToString("dd MMM yyyy")
        </small>
                }
    </div>
    <div class="card-footer bg-transparent d-flex gap-2">
        @if (doc.Status != "Revoked")
        {
            <a href="@doc.FilePath" target="_blank" class="btn btn-sm btn-outline-primary flex-fill" @onclick="() => MarkAsViewed(doc.DocumentId)">
                📄 View / Download
            </a>
        }
        @if (canAcknowledge)
        {
            <button class="btn btn-sm btn-success flex-fill" @onclick="() => AcknowledgeOrgDocument(doc.DocumentId)">
                ✓ Acknowledge
            </button>
        }
    </div>
</div>;

// ── Badge helpers ─────────────────────────────────────────────────────────
private static string GetStatusBadge(string s) => s switch
{
    "Verified" => "bg-success",
    "Pending" => "bg-warning text-dark",
    "PageTitle" => "bg-danger",
    "Rejected" => "bg-danger",
    _ => "bg-secondary"
};

private static string GetStatusIcon(string s) => s switch
{
    "Verified" => "✓",
    "Pending" => "⏳",
    "Rejected" => "✗",
    _ => "📄"
};

private static string GetIssuedBadge(string s) => s switch
{
    "Acknowledged" => "bg-success",
    "Issued" => "bg-warning text-dark",
    "Revoked" => "bg-danger",
    _ => "bg-secondary"
};

private static string GetIssuedIcon(string s) => s switch
{
    "Acknowledged" => "✓",
    "Issued" => "⏳",
    "Revoked" => "🚫",
    _ => "📄"
};
}