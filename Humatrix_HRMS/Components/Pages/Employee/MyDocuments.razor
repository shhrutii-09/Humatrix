@page "/employee/documents"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Employee,HR")]
@using Humatrix_HRMS.DTOs.Dashboard
@using Humatrix_HRMS.DTOs.Documents
@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Models.Documents
@using Humatrix_HRMS.Services
@using Humatrix_HRMS.Services.Documents
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using System.IO
@inject IEmployeeDocumentService EmployeeDocumentService
@inject IOrgDocumentGenerationService OrgDocumentService
@inject IDocumentTypeService DocumentTypeService
@inject CurrentUserService CurrentUserService
@inject NavigationManager Nav
@inject IJSRuntime JsRuntime
@inject EmployeeService EmployeeServiceHelper

<PageTitle>My Documents | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">

    @* Header Section *@
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom row-gap-3 flex-wrap">
        <div>
            <h2 class="fw-bold tracking-tight text-dark mb-1">📄 My Documents</h2>
            <p class="text-muted small mb-0">View, upload, and acknowledge your documents</p>
        </div>
        <button class="btn btn-dashboard px-4" @onclick='() => Nav.NavigateTo("/employee/dashboard")'>
            ← Dashboard
        </button>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5 my-5">
            <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status"></div>
            <p class="mt-3 text-muted fw-medium">Loading document registry...</p>
        </div>
    }
    else
    {
        @* Profile completion banner *@
        @if (employeeDashboard != null)
        {
            <div class="card border-0 shadow-sm panel-container-card mb-4" style="background: linear-gradient(135deg, #667eea, #764ba2)">
                <div class="card-body text-white p-4">
                    <div class="row align-items-center">
                        <div class="col-md-8">
                            <h5 class="fw-bold mb-2">Profile Completion</h5>
                            <div class="progress mb-3" style="height: 10px; background: rgba(255, 255, 255, 0.3)">
                                <div class="progress-bar bg-white" style="width: @(employeeDashboard.ProfileCompletionPercentage)%"></div>
                            </div>
                            <div class="d-flex gap-4 flex-wrap small">
                                <span>📄 @employeeDashboard.UploadedDocuments / @employeeDashboard.TotalRequiredDocuments uploaded</span>
                                <span>✓ @employeeDashboard.VerifiedDocuments verified</span>
                                <span>⏳ @employeeDashboard.PendingDocuments pending</span>
                                <span>✗ @employeeDashboard.RejectedDocuments rejected</span>
                            </div>
                        </div>
                        <div class="col-md-4 text-md-end mt-3 mt-md-0">
                            @if (employeeDashboard.MissingMandatoryCount > 0)
                            {
                                <span class="badge bg-warning text-dark px-3 py-2 fs-6">⚠️ @employeeDashboard.MissingMandatoryCount required doc(s) missing</span>
                            }
                            else
                            {
                                <span class="badge bg-white text-success px-3 py-2 fs-6">✓ All required documents uploaded</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        @* Alert Messages *@
        @if (!string.IsNullOrEmpty(message))
        {
            <div class="alert alert-@(messageIsError ? "danger" : "success") alert-dismissible fade show mb-3" style="border-radius: 12px;">
                @message
                <button type="button" class="btn-close" @onclick="() => message = null"></button>
            </div>
        }

        @* Navigation Tabs *@
        <div class="d-flex gap-1 mb-4 tab-nav-wrapper">
            <button class="btn tab-btn @(activeTab == "mine" ? "tab-btn-active" : "")"
                    @onclick='() => SetTab("mine")'>
                <i class="bi bi-cloud-upload me-2"></i>My Uploads
                <span class="tab-count-badge ms-2">@employeeDocuments.Count</span>
            </button>
            <button class="btn tab-btn @(activeTab == "org" ? "tab-btn-active" : "") position-relative"
                    @onclick='() => SetTab("org")'>
                <i class="bi bi-building me-2"></i>Company Documents
                <span class="tab-count-badge ms-2">@orgDocuments.Count</span>
                @if (pendingAckCount > 0)
                {
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.6rem;">
                        @pendingAckCount
                    </span>
                }
            </button>
        </div>

        @* TAB 1 — MY UPLOADS *@
        @if (activeTab == "mine")
        {
            @* Upload Form *@
            <div class="card border-0 shadow-sm panel-container-card mb-4">
                <div class="card-header bg-white border-bottom p-3">
                    <h6 class="mb-0 fw-semibold text-dark">📤 Upload a Document</h6>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-5">
                            <label class="form-label fw-semibold small text-secondary tracking-wider">Document Type <span class="text-danger">*</span></label>
                            <select class="form-select premium-edit-input" @bind="selectedDocumentTypeId">
                                <option value="">— Select Document Type —</option>
                                @foreach (var t in uploadableDocumentTypes)
                                {
                                    <option value="@t.DocumentTypeId">
                                        @t.Name @(t.IsMandatory ? " (Required)" : "")
                                    </option>
                                }
                            </select>
                            @if (!uploadableDocumentTypes.Any())
                            {
                                <div class="form-text text-warning mt-1 small">
                                    No uploadable document types configured. Contact HR.
                                </div>
                            }
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold small text-secondary tracking-wider">File <span class="text-danger">*</span></label>
                            <InputFile OnChange="@OnFileSelected" class="form-control premium-edit-input" />
                            <div class="form-text text-muted small mt-1">PDF, JPG, PNG — max 5 MB</div>
                        </div>
                        <div class="col-md-3">
                            <button class="btn btn-primary-action w-100" @onclick="UploadDocument" disabled="@isUploading">
                                @if (isUploading)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                }
                                <i class="bi bi-upload me-1"></i> Upload
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            @* My Documents Table *@
            @if (!employeeDocuments.Any())
            {
                <div class="card border-0 shadow-sm panel-container-card">
                    <div class="text-center py-5">
                        <div class="icon-shape bg-primary-subtle text-primary rounded-circle fs-2 mx-auto mb-3" style="width: 64px; height: 64px;">
                            <i class="bi bi-file-earmark-x"></i>
                        </div>
                        <h5 class="fw-bold text-dark mb-1">No Documents Uploaded</h5>
                        <p class="text-muted small mx-auto" style="max-width: 400px;">
                            Use the form above to upload your documents. HR will review them shortly.
                        </p>
                    </div>
                </div>
            }
            else
            {
                <div class="card border-0 shadow-sm panel-container-card">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th class="ps-4 text-secondary small fw-bold tracking-wider py-3">DOCUMENT TYPE</th>
                                    <th class="text-secondary small fw-bold tracking-wider py-3">CATEGORY</th>
                                    <th class="text-secondary small fw-bold tracking-wider py-3">STATUS</th>
                                    <th class="text-secondary small fw-bold tracking-wider py-3">UPLOADED</th>
                                    <th class="pe-4 text-secondary small fw-bold tracking-wider py-3 text-end">ACTION</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var doc in employeeDocuments)
                                {
                                    <tr class="table-row-interactive">
                                        <td class="ps-4 py-3">
                                            <div class="fw-bold text-dark text-heading-field">@doc.DocumentTypeName</div>
                                            @if (doc.IsMandatory)
                                            {
                                                <span class="badge premium-soft-dept-badge mt-1" style="font-size: 10px;">Required</span>
                                            }
                                        </td>
                                        <td class="py-3">
                                            <span class="badge premium-soft-dept-badge">@doc.Category</span>
                                        </td>
                                        <td class="py-3">
                                            <span class="status-indicator-pill @GetStatusPillClass(doc.Status)">
                                                @GetStatusIcon(doc.Status) @doc.Status
                                            </span>
                                            @if (doc.Status == "Rejected" && !string.IsNullOrEmpty(doc.RejectionRemarks))
                                            {
                                                <div class="text-danger small mt-1" style="font-size: 11px;">
                                                    <i class="bi bi-info-circle me-1"></i>@doc.RejectionRemarks
                                                </div>
                                            }
                                        </td>
                                        <td class="py-3 text-muted small">@doc.UploadedAt?.ToString("dd MMM yyyy")</td>
                                        <td class="pe-4 py-3 text-end">
                                            @if (doc.DocumentId != Guid.Empty && !string.IsNullOrWhiteSpace(doc.FilePath))
                                            {
                                                <a href="@doc.FilePath" target="_blank" class="btn btn-sm btn-outline-primary-action">
                                                    <i class="bi bi-eye me-1"></i> View
                                                </a>
                                            }
                                            else if (doc.DocumentId != Guid.Empty)
                                            {
                                                <a href="api/documents/download/@doc.DocumentId" target="_blank" class="btn btn-sm btn-outline-primary-action">
                                                    <i class="bi bi-download me-1"></i> Download
                                                </a>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">No file</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        }

        @* TAB 2 — COMPANY DOCUMENTS *@
        @if (activeTab == "org")
        {
            @if (!orgDocuments.Any())
            {
                <div class="card border-0 shadow-sm panel-container-card">
                    <div class="text-center py-5">
                        <div class="icon-shape bg-primary-subtle text-primary rounded-circle fs-2 mx-auto mb-3" style="width: 64px; height: 64px;">
                            <i class="bi bi-building"></i>
                        </div>
                        <h5 class="fw-bold text-dark mb-1">No Company Documents</h5>
                        <p class="text-muted small mx-auto" style="max-width: 400px;">
                            No company documents have been issued to you yet.
                        </p>
                    </div>
                </div>
            }
            else
            {
                var pendingAck = orgDocuments.Where(d => d.Status == "Issued").ToList();
                var acknowledged = orgDocuments.Where(d => d.Status == "Acknowledged").ToList();
                var revoked = orgDocuments.Where(d => d.Status == "Revoked").ToList();

                @if (pendingAck.Any())
                {
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <i class="bi bi-clock-history text-warning fs-5"></i>
                        <h6 class="fw-bold text-dark mb-0">Awaiting Your Acknowledgment</h6>
                        <span class="badge bg-warning text-dark ms-2">@pendingAck.Count</span>
                    </div>
                    <div class="row g-3 mb-4">
                        @foreach (var doc in pendingAck)
                        {
                            <div class="col-md-6 col-xl-4">
                                @OrgDocCard(doc, canAcknowledge: true)
                            </div>
                        }
                    </div>
                }

                @if (acknowledged.Any())
                {
                    <div class="d-flex align-items-center gap-2 mb-3 mt-4">
                        <i class="bi bi-check-circle-fill text-success fs-5"></i>
                        <h6 class="fw-bold text-dark mb-0">Acknowledged</h6>
                        <span class="badge bg-success ms-2">@acknowledged.Count</span>
                    </div>
                    <div class="row g-3 mb-4">
                        @foreach (var doc in acknowledged)
                        {
                            <div class="col-md-6 col-xl-4">
                                @OrgDocCard(doc, canAcknowledge: false)
                            </div>
                        }
                    </div>
                }

                @if (revoked.Any())
                {
                    <div class="d-flex align-items-center gap-2 mb-3 mt-4">
                        <i class="bi bi-exclamation-triangle-fill text-danger fs-5"></i>
                        <h6 class="fw-bold text-dark mb-0">Revoked Documents</h6>
                        <span class="badge bg-danger ms-2">@revoked.Count</span>
                    </div>
                    <div class="alert alert-danger py-2 small mb-3" style="border-radius: 10px;">
                        <i class="bi bi-info-circle me-1"></i>
                        These documents have been revoked by your organisation. They are no longer valid.
                    </div>
                    <div class="row g-3 mb-4">
                        @foreach (var doc in revoked)
                        {
                            <div class="col-md-6 col-xl-4">
                                @OrgDocCard(doc, canAcknowledge: false)
                            </div>
                        }
                    </div>
                }
            }
        }
    }
</div>

