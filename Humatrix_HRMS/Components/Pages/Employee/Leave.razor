@page "/employee/leaves"
@rendermode InteractiveServer
@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Employee")]
@inject LeaveService LeaveService
@inject NavigationManager Nav

<PageTitle>My Leaves | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-0">My Leaves</h4>
            <small class="text-muted">Manage your leave requests and balances</small>
        </div>
        <button class="btn btn-primary shadow-sm"
                style="background-color:#5c4ac7;border:none;"
                @onclick='() => Nav.NavigateTo("/employee/leaves/apply")'>
            <i class="bi bi-plus-lg me-1"></i>Apply Leave
        </button>
    </div>

    <!-- ALERT -->
    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert alert-@(isError ? "danger" : "success") alert-dismissible shadow-sm border-0 d-flex gap-2">
            <i class="bi bi-@(isError ? "exclamation-triangle-fill" : "check-circle-fill") mt-1"></i>
            <div class="flex-grow-1">@message</div>
            <button class="btn-close" @onclick="() => message = null"></button>
        </div>
    }

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
            <p class="text-muted small mt-2">Loading leaves...</p>
        </div>
    }
    else
    {
        <!-- BALANCE CARDS -->
        <div class="row g-3 mb-4">
            @if (!balances.Any())
            {
                <div class="col-12">
                    <div class="alert alert-info border-0 shadow-sm">
                        <i class="bi bi-info-circle me-2"></i>No leave balances configured yet.
                    </div>
                </div>
            }
            else
            {
                @foreach (var bal in balances)
                {
                    <div class="col-md-4 col-sm-6">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <span class="fw-semibold text-muted small text-uppercase">@bal.LeaveTypeName</span>
                                    <span class="badge @(bal.IsPaid ? "bg-success" : "bg-secondary")">
                                        @(bal.IsPaid ? "Paid" : "Unpaid")
                                    </span>
                                </div>
                                <h2 class="fw-bold mb-1">@bal.Remaining</h2>
                                <div class="small text-muted">
                                    Used: <strong>@bal.Used</strong> &nbsp;|&nbsp;
                                    Pending: <strong>@bal.Pending</strong>
                                </div>
                                @if (bal.CarriedForward > 0)
                                {
                                    <span class="badge bg-info-subtle text-info border border-info-subtle mt-2">
                                        <i class="bi bi-arrow-right me-1"></i>+@bal.CarriedForward carried forward
                                    </span>
                                }
                                <!-- MINI PROGRESS BAR -->
                                @{
                                    var total = bal.Remaining + bal.Used + bal.Pending;
                                    var pct = total > 0 ? (int)(bal.Used / total * 100) : 0;
                                }
                                <div class="progress mt-2" style="height:4px;">
                                    <div class="progress-bar bg-primary" style="width:@pct%"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

        <!-- LEAVE HISTORY TABLE -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-semibold">Leave History</h5>
                <span class="badge bg-secondary-subtle text-secondary">@leaves.Count requests</span>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 text-muted small fw-bold border-0">DATES</th>
                            <th class="text-muted small fw-bold border-0">TYPE</th>
                            <th class="text-muted small fw-bold border-0">DAYS</th>
                            <th class="text-muted small fw-bold border-0">STATUS</th>
                            <th class="text-muted small fw-bold border-0">APPLIED ON</th>
                            <th class="text-muted small fw-bold border-0 pe-4"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!leaves.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="bi bi-calendar-x fs-2 d-block mb-2 opacity-25"></i>
                                    No leave requests found.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var l in leaves.OrderByDescending(x => x.AppliedAt))
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="fw-semibold">
                                            @l.FromDate.ToString("dd MMM") – @l.ToDate.ToString("dd MMM yyyy")
                                        </div>
                                        <small class="text-muted">@l.Reason</small>
                                    </td>
                                    <td>@l.LeaveTypeName</td>
                                    <td><span class="fw-semibold">@l.TotalDays</span></td>
                                    <td>
                                        <span class="badge rounded-pill @GetStatusClass(l.Status)">
                                            @l.Status
                                        </span>
                                    </td>
                                    <td class="small text-muted">
                                        @l.AppliedAt.ToLocalTime().ToString("dd MMM yyyy")
                                    </td>
                                    <td class="pe-4">
                                        @if (l.Status == "Pending")
                                        {
                                            <button class="btn btn-sm btn-outline-danger"
                                                    disabled="@actionLoading"
                                                    @onclick="() => ConfirmCancel(l.LeaveRequestId)">
                                                Cancel
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <!-- CONFIRM CANCEL MODAL -->
    @if (showCancelModal)
    {
        <div class="modal fade show d-block" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content shadow">
                    <div class="modal-header border-0 pb-0">
                        <h5 class="modal-title fw-bold">
                            <i class="bi bi-exclamation-triangle-fill text-warning me-2"></i>Cancel Leave
                        </h5>
                        <button class="btn-close" @onclick="CloseCancel"></button>
                    </div>
                    <div class="modal-body pt-2">
                        Are you sure you want to cancel this leave request?
                        This action cannot be undone.
                    </div>
                    <div class="modal-footer border-0">
                        <button class="btn btn-secondary" @onclick="CloseCancel" disabled="@actionLoading">
                            Keep It
                        </button>
                        <button class="btn btn-danger" @onclick="CancelLeaveConfirmed" disabled="@actionLoading">
                            @if (actionLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            Yes, Cancel Leave
                        </button>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal-backdrop fade show"></div>
    }

</div>

@code {

    // ── State ────────────────────────────────────────────────────────────────────
    private List<LeaveRequestDto> leaves = new();
    private List<LeaveBalanceDto> balances = new();

    private bool isLoading = true;
    private bool actionLoading;
    private bool showCancelModal;
    private bool isError;
    private string? message;
    private Guid selectedLeaveId;

    // ── Lifecycle ────────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            leaves = await LeaveService.GetMyLeavesAsync();
            balances = await LeaveService.GetMyBalancesAsync();
        }
        catch (Exception ex)
        {
            isError = true;
            message = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    // ── Cancel flow ──────────────────────────────────────────────────────────────
    private void ConfirmCancel(Guid id)
    {
        selectedLeaveId = id;
        showCancelModal = true;
    }

    private void CloseCancel() => showCancelModal = false;

    private async Task CancelLeaveConfirmed()
    {
        actionLoading = true;
        try
        {
            await LeaveService.CancelRequestAsync(selectedLeaveId);
            isError = false;
            message = "Leave request cancelled successfully.";
            showCancelModal = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            isError = true;
            message = ex.Message;
        }
        finally
        {
            actionLoading = false;
        }
    }

    // ── Helpers ──────────────────────────────────────────────────────────────────
    private static string GetStatusClass(string? status) => status switch
    {
        "Approved" => "bg-success",
        "Pending" => "bg-warning text-dark",
        "Rejected" => "bg-danger",
        "Cancelled" => "bg-secondary",
        _ => "bg-light text-dark"
    };
}
