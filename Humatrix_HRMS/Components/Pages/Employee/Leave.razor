@page "/employee/leaves"
@rendermode InteractiveServer

@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Services
@using Humatrix_HRMS.Data
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore

@attribute [Authorize(Roles = "Employee,HR")]
@inject LeaveService LeaveService
@inject NavigationManager Nav
@inject CurrentUserService CurrentUser
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>My Leaves | Humatrix HRMS</PageTitle>

@* Toast Notification Container *@
<div class="position-fixed top-0 end-0 p-3" style="z-index: 1080;">
    @if (!string.IsNullOrEmpty(message))
    {
        <div class="toast show align-items-center border-0 shadow-lg mb-2" role="alert" style="background-color: @(isError ? "#fef2f2" : "#f0fdf4"); color: @(isError ? "#991b1b" : "#166534"); border-left: 4px solid @(isError ? "#ef4444" : "#10b981") !important; border-radius: 10px;">
            <div class="d-flex p-3">
                <div class="toast-body d-flex align-items-center p-0">
                    <i class="bi @(isError ? "bi-exclamation-triangle-fill" : "bi-check-circle-fill") me-2 fs-5"></i>
                    <span class="small fw-medium">@message</span>
                </div>
                <button type="button" class="btn-close m-auto me-0 shadow-none" @onclick="() => message = null"></button>
            </div>
        </div>
    }
</div>

<div class="container-fluid px-4 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom row-gap-3 flex-wrap">
        <div>
            <h2 class="fw-bold tracking-tight text-dark mb-1">My Leaves</h2>
            <p class="text-muted small mb-0">Manage your leave requests and monitor balances.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-add-dept d-flex align-items-center gap-2 shadow-sm" @onclick='() => Nav.NavigateTo("/employee/leaves/apply")'>
                <i class="bi bi-plus-circle"></i> APPLY LEAVE
            </button>
            <button class="btn btn-dashboard d-flex align-items-center gap-2 shadow-sm" @onclick='() => Nav.NavigateTo(dashboardPath)'>
                <i class="bi bi-speedometer2"></i> DASHBOARD
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    }
    else
    {
        <div class="row g-3 mb-5">
            @{
                var colors = new[] { "#5c4ac7", "#e11d48", "#059669", "#d97706", "#0284c7" };
                int i = 0;
            }
            @foreach (var bal in balances)
            {
                <div class="col-md-4 col-sm-6">
                    <div class="card border-0 shadow-sm panel-container-card p-3 h-100" style="border-left: 6px solid @colors[i % colors.Length] !important;">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="small text-secondary fw-bold tracking-wider text-uppercase">@bal.LeaveTypeName</span>
                            <span class="badge @(bal.IsPaid ? "bg-success-subtle text-success" : "bg-secondary-subtle text-secondary")" style="font-size: 10px;">@(bal.IsPaid ? "PAID" : "UNPAID")</span>
                        </div>
                        <h3 class="fw-bold text-dark mb-1">@bal.Remaining</h3>
                        <div class="small text-muted mb-2">Used: <strong>@bal.Used</strong> | Pending: <strong>@bal.Pending</strong></div>

                        @if (bal.CarriedForward > 0)
                        {
                            <span class="badge bg-info-subtle text-info mb-2 align-self-start" style="font-size: 10px;"><i class="bi bi-arrow-right me-1"></i>+@bal.CarriedForward carried forward</span>
                        }

                        <div class="progress mt-auto" style="height:6px; border-radius:3px;">
                            @{
                                var total = bal.Remaining + bal.Used + bal.Pending; var pct = total > 0 ? (int)(bal.Used * 100 / total) : 0;
                            }
                            <div class="progress-bar" style="width:@pct%; background-color:@colors[i % colors.Length];"></div>
                        </div>
                    </div>
                </div>
                i++;
            }
        </div>

        <div class="card border-0 shadow-sm panel-container-card">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 text-secondary small fw-bold tracking-wider py-3">DATES</th>
                            <th class="text-secondary small fw-bold tracking-wider py-3">TYPE</th>
                            <th class="text-secondary small fw-bold tracking-wider py-3">DAYS</th>
                            <th class="text-secondary small fw-bold tracking-wider py-3">REVIEWER</th>
                            <th class="text-secondary small fw-bold tracking-wider py-3">STATUS</th>
                            <th class="text-secondary small fw-bold tracking-wider py-3 text-end pe-4">ACTIONS</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var l in leaves.OrderByDescending(x => x.AppliedAt))
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-dark">@l.FromDate.ToString("dd MMM") - @l.ToDate.ToString("dd MMM yyyy")</div>
                                    <div class="small text-muted">@l.Reason</div>
                                </td>
                                <td>@l.LeaveTypeName</td>
                                <td>@l.TotalDays</td>
                                <td>
                                    @if (l.ApprovedBy.HasValue && reviewerCache.ContainsKey(l.ApprovedBy.Value))
                                    {
                                        <div class="small">
                                            <div class="fw-bold text-dark">@reviewerCache[l.ApprovedBy.Value].Name</div>
                                            <div class="text-muted" style="font-size: 10px;">@reviewerCache[l.ApprovedBy.Value].Role</div>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">-</span>
                                    }
                                </td>
                                <td><span class="badge rounded-pill status-indicator-pill @GetStatusClass(l.Status)">@l.Status</span></td>
                                <td class="text-end pe-4">
                                    @if (l.Status == "Pending")
                                    {
                                        <button class="btn btn-sm btn-outline-danger rounded-3" @onclick="() => HandleCancel(l.LeaveRequestId)">Cancel</button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<style>
    .panel-container-card {
        border-radius: 14px;
        background-color: #ffffff;
    }

    .tracking-wider {
        letter-spacing: 0.04em;
        font-size: 11px;
    }

    .btn-add-dept {
        background-color: #5c4ac7 !important;
        color: #ffffff !important;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
    }

    .btn-dashboard {
        background: #ffffff !important;
        border: 1px solid #e5e7eb !important;
        color: #4b5563 !important;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
    }

        .btn-dashboard:hover {
            border-color: #5c4ac7 !important;
            color: #5c4ac7 !important;
        }

    .status-indicator-pill {
        font-size: 11px;
        font-weight: 600;
        padding: 4px 10px;
        border-radius: 6px;
    }

    .bg-success-subtle {
        background-color: #dcfce7;
    }

    .bg-secondary-subtle {
        background-color: #f3f4f6;
    }
</style>

@code {
    private List<LeaveRequestDto> leaves = new();
    private List<LeaveBalanceDto> balances = new();
    private Dictionary<Guid, (string Name, string Role)> reviewerCache = new();
    private bool isLoading = true, isError;
    private string? message, dashboardPath = "/employee/dashboard";

    protected override async Task OnInitializedAsync()
    {
        var user = await CurrentUser.GetUserAsync();
        if (user != null)
        {
            using var db = DbFactory.CreateDbContext();
            var roles = await db.UserRoles.Where(ur => ur.UserId == user.Id).Join(db.Roles, ur => ur.RoleId, r => r.Id, (ur, r) => r.Name.ToLower()).ToListAsync();
            dashboardPath = roles.Contains("hr") ? "/hr/dashboard" : "/employee/dashboard";
        }
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            leaves = await LeaveService.GetMyLeavesAsync();
            balances = await LeaveService.GetMyBalancesAsync();
            foreach (var l in leaves.Where(x => x.ApprovedBy.HasValue && !reviewerCache.ContainsKey(x.ApprovedBy.Value)))
            {
                reviewerCache[l.ApprovedBy.Value] = await LeaveService.GetReviewerInfoAsync(l.ApprovedBy);
            }
        }
        catch (Exception ex) { isError = true; message = ex.Message; TriggerToastAutoClose(); }
        finally { isLoading = false; }
    }

    private async Task HandleCancel(Guid id)
    {
        try
        {
            // Calling the correct method found in your LeaveService
            await LeaveService.CancelRequestAsync(id);
            message = "Leave request cancelled successfully!";
            isError = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            message = ex.Message;
            isError = true;
        }
        TriggerToastAutoClose();
    }

    private void TriggerToastAutoClose()
    {
        _ = Task.Run(async () =>
        {
            await Task.Delay(4000);
            message = null;
            await InvokeAsync(StateHasChanged);
        });
    }

    private string GetStatusClass(string? status) => status switch { "Approved" => "bg-success-subtle text-success", "Pending" => "bg-warning-subtle text-warning", "Rejected" => "bg-danger-subtle text-danger", _ => "bg-secondary-subtle text-secondary" };
}