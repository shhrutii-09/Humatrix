@page "/employee/asset-requests"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Employee,HR,OrgAdmin")]

@using Humatrix_HRMS.DTOs.Assets
@using Humatrix_HRMS.Services
@using Humatrix_HRMS.Services.Assets
@using Humatrix_HRMS.Infrastructure.Constants
@using Microsoft.AspNetCore.Authorization

@inject AssetService AssetService
@inject CurrentUserService CurrentUserService
@inject NavigationManager Nav

<PageTitle>My Asset Requests | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom row-gap-3 flex-wrap">
        <div>
            <h2 class="fw-bold tracking-tight text-dark mb-1">My Asset Requests</h2>
            <p class="text-muted small mb-0">Track lifecycle ticket states, repairs, and return submissions</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-primary-action d-flex align-items-center gap-2 shadow-sm" @onclick="NavigateToInventory">
                <i class="bi bi-laptop"></i>
                VIEW MY ASSETS
            </button>
        </div>
    </div>

    @if (loading)
    {
        <div class="text-center py-5 my-5">
            <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status"></div>
            <p class="mt-3 text-muted fw-medium">Loading request history...</p>
        </div>
    }
    else if (!myRequests.Any())
    {
        <div class="card border-0 shadow-sm panel-container-card">
            <div class="text-center py-5">
                <div class="icon-shape bg-primary-subtle text-primary rounded-circle fs-2 mx-auto mb-3" style="width: 64px; height: 64px;">
                    <i class="bi bi-journal-x"></i>
                </div>
                <h5 class="fw-bold text-dark mb-1">No Requests Filed Yet</h5>
                <p class="text-muted small mx-auto mb-4" style="max-width: 400px;">
                    You haven't requested any actions or filed issue updates for physical hardware components yet.
                </p>
                <button class="btn btn-primary-action px-4" @onclick="NavigateToInventory">
                    <i class="bi bi-plus-circle me-2"></i> File New Request
                </button>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm panel-container-card">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4 text-secondary small fw-bold tracking-wider py-3">ASSET ITEM</th>
                            <th class="text-secondary small fw-bold tracking-wider py-3">REQUEST TYPE</th>
                            <th class="text-secondary small fw-bold tracking-wider py-3">DATE SUBMITTED</th>
                            <th class="text-secondary small fw-bold tracking-wider py-3">MY REASONING</th>
                            <th class="text-secondary small fw-bold tracking-wider py-3">STATUS</th>
                            <th class="text-secondary small fw-bold tracking-wider py-3 pe-4">REVIEW NOTES</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var request in myRequests)
                        {
                            <tr class="table-row-interactive">
                                <td class="ps-4 py-3">
                                    <div class="fw-bold text-dark text-heading-field">@request.AssetName</div>
                                    <div class="text-muted font-monospace small">@request.AssetCode</div>
                                </td>
                                <td class="py-3">
                                    <span class="badge @GetRequestTypeClass(request.RequestType)" style="font-size: 11px; padding: 4px 10px; border-radius: 6px; font-weight: 600;">
                                        <i class="@GetRequestTypeIcon(request.RequestType) me-1"></i> @request.RequestType
                                    </span>
                                </td>
                                <td class="py-3 text-muted small">
                                    @request.RequestedAt.ToLocalTime().ToString("MMM dd, yyyy h:mm tt")
                                </td>
                                <td class="py-3 text-secondary row-description-text" style="max-width: 240px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="@request.Reason">
                                    @request.Reason
                                </td>
                                <td class="py-3">
                                    <span class="status-indicator-pill @GetStatusPillClass(request.Status)">
                                        @request.Status
                                    </span>
                                </td>
                                <td class="pe-4 py-3">
                                    @if (!string.IsNullOrWhiteSpace(request.ReviewNotes))
                                    {
                                        <div class="text-dark small fw-medium" style="max-width: 280px; line-height: 1.3;">
                                            <i class="bi bi-chat-left-quote text-muted me-1"></i> @request.ReviewNotes
                                        </div>
                                        @if (request.ReviewedAt.HasValue)
                                        {
                                            <div class="text-muted" style="font-size: 11px; margin-top: 2px;">
                                                Processed on @request.ReviewedAt.Value.ToLocalTime().ToString("d")
                                            </div>
                                        }
                                    }
                                    else if (request.Status == AssetRequestStatus.Pending)
                                    {
                                        <span class="text-muted small fst-italic">
                                            <i class="bi bi-hourglass-split me-1 animate-pulse"></i> Awaiting review
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<style>
    .tracking-tight {
        letter-spacing: -0.025em;
    }

    .tracking-wider {
        letter-spacing: 0.04em;
        font-size: 11px;
    }

    .panel-container-card {
        border-radius: 14px;
        background-color: #ffffff;
        overflow: hidden;
    }

    .icon-shape {
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .bg-primary-subtle {
        background-color: rgba(92, 74, 199, 0.1);
    }

    .text-primary {
        color: #5c4ac7 !important;
    }

    .table thead th {
        background-color: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
    }

    .table-row-interactive:hover {
        background-color: #f8fafc;
    }

    .text-heading-field {
        font-size: 14px;
        color: #1e293b !important;
    }

    .row-description-text {
        font-size: 13.5px;
    }

    .btn-primary-action {
        background-color: #5c4ac7 !important;
        color: #ffffff !important;
        border: none !important;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
    }

        .btn-primary-action:hover {
            background-color: #4c3ca3 !important;
            transform: translateY(-1px);
        }

    .status-indicator-pill {
        font-size: 11px;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 6px;
        display: inline-block;
        min-width: 60px;
        text-align: center;
    }

    .pill-pending {
        background-color: #fffbeb;
        color: #92400e;
    }

    .pill-approved {
        background-color: #ecfdf5;
        color: #065f46;
    }

    .pill-rejected {
        background-color: #fef2f2;
        color: #991b1b;
    }

    .pill-completed {
        background-color: #eff6ff;
        color: #1e40af;
    }

    .pill-default {
        background-color: #f1f5f9;
        color: #475569;
    }

    .animate-pulse {
        animation: pulseOpacity 2s infinite ease-in-out;
    }

    @@keyframes pulseOpacity {
        0%, 100% {
            opacity: 0.6;
        }

        50% {
            opacity: 1;
        }
    }
</style>

@code {
    private bool loading = true;
    private List<AssetRequestDto> myRequests = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadMyRequestHistoryAsync();
    }

    private async Task LoadMyRequestHistoryAsync()
    {
        try
        {
            loading = true;
            var context = await CurrentUserService.GetEmployeeDashboardContextAsync();
            if (context != null)
            {
                var allOrgRequests = await AssetService.GetAssetRequestsAsync(
                    organizationId: context.OrganizationId,
                    status: null,
                    employeeId: null,
                    callerRole: null,
                    callerDepartmentId: null
                );

                myRequests = allOrgRequests
                    .Where(r => r.RequestedByEmployeeId == context.EmployeeId)
                    .OrderByDescending(r => r.RequestedAt)
                    .ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading asset requests: {ex.Message}");
        }
        finally
        {
            loading = false;
        }
    }

    private void NavigateToInventory() => Nav.NavigateTo("/employee/assets");

    private string GetRequestTypeClass(string type) => type switch
    {
        AssetRequestType.Repair => "bg-warning-subtle text-warning border border-warning-subtle",
        AssetRequestType.Replacement => "bg-primary-subtle text-primary border border-primary-subtle",
        AssetRequestType.Return => "bg-info-subtle text-info border border-info-subtle",
        _ => "bg-light text-dark border"
    };

    private string GetRequestTypeIcon(string type) => type switch
    {
        AssetRequestType.Repair => "bi bi-tools",
        AssetRequestType.Replacement => "bi bi-arrow-repeat",
        AssetRequestType.Return => "bi bi-arrow-return-left",
        _ => "bi bi-question-circle"
    };

    private string GetStatusPillClass(string status) => status switch
    {
        AssetRequestStatus.Pending => "pill-pending",
        AssetRequestStatus.Approved => "pill-approved",
        AssetRequestStatus.Rejected => "pill-rejected",
        AssetRequestStatus.Completed => "pill-completed",
        _ => "pill-default"
    };
}
