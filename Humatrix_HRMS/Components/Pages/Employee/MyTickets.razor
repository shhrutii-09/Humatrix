@* Pages/Employee/MyTickets.razor *@
@page "/employee/tickets"
@page "/employee/tickets/{TicketId:guid}"
@attribute [Authorize(Roles = "Employee,HR")]
@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Humatrix_HRMS.Services.AI
@using Microsoft.AspNetCore.Authorization
@using static Humatrix_HRMS.Services.AI.TicketService
@inject TicketService TicketService
@inject CurrentUserService CurrentUserService
@rendermode InteractiveServer

<PageTitle>My Support Tickets</PageTitle>

<div class="container-fluid px-4 mt-4" style="max-width: 1100px;">

    <!-- ── Header + New Ticket button ──────────────────────────────────── -->
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom row-gap-3 flex-wrap">
        <div>
            <h2 class="fw-bold tracking-tight text-dark mb-1">My Support Tickets</h2>
            <p class="text-muted small mb-0">Issues you've raised — HR will respond here</p>
        </div>
        <button class="btn btn-add-dept d-flex align-items-center gap-2 shadow-sm" @onclick="OpenNewTicketModal">
            <i class="bi bi-plus-circle"></i>NEW TICKET
        </button>
    </div>

    <!-- ── Body ────────────────────────────────────────────────────────── -->
    @if (_loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted small mb-0">Loading your tickets...</p>
        </div>
    }
    else if (!_tickets.Any())
    {
        <div class="card border-0 shadow-sm panel-container-card">
            <div class="text-center text-muted py-5">
                <div class="fs-2 text-light mb-2"><i class="bi bi-inbox"></i></div>
                <p class="mt-2 fw-medium mb-1">You haven't raised any tickets yet.</p>
                <p class="small mb-0">
                    Use the <strong>New Ticket</strong> button above, or the AI Assistant will
                    offer to create one automatically when it cannot solve your issue.
                </p>
            </div>
        </div>
    }
    else
    {
        <div class="row g-3">

            <!-- Ticket list -->
            <div class="col-md-5">
                <div class="card border-0 shadow-sm panel-container-card">
                    <div class="list-group list-group-flush">
                        @foreach (var t in _tickets)
                        {
                            <button class="list-group-item list-group-item-action ticket-list-item @(_selectedTicket?.TicketId == t.TicketId ? "active" : "")"
                                    @onclick="@(() => SelectTicket(t.TicketId))">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div class="me-2 overflow-hidden">
                                        <div class="fw-bold text-dark text-heading-field text-truncate">#@t.TicketNumber — @t.Category</div>
                                        <div class="small text-muted text-truncate" style="max-width:200px;">@t.Description</div>
                                        <div class="small text-muted mt-1">
                                            @t.CreatedAt.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")
                                        </div>
                                    </div>
                                    <span class="status-indicator-pill @StatusPill(t.Status) flex-shrink-0">@t.Status</span>
                                </div>
                            </button>
                        }
                    </div>
                </div>
            </div>

            <!-- Ticket detail / thread -->
            <div class="col-md-7">
                @if (_selectedTicket == null)
                {
                    <div class="card border-0 shadow-sm panel-container-card text-center text-muted py-5">
                        <p class="mb-0">Select a ticket to view the conversation.</p>
                    </div>
                }
                else
                {
                    <div class="card border-0 shadow-sm panel-container-card h-100 d-flex flex-column">

                        <!-- Card header -->
                        <div class="card-body border-bottom d-flex justify-content-between align-items-start py-3">
                            <div>
                                <strong class="text-dark text-heading-field">#@_selectedTicket.TicketNumber — @_selectedTicket.Category</strong>
                                <div class="small text-muted">
                                    @_selectedTicket.CreatedAt.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")
                                </div>
                            </div>
                            <span class="status-indicator-pill @StatusPill(_selectedTicket.Status)">
                                @_selectedTicket.Status
                            </span>
                        </div>

                        <div class="card-body d-flex flex-column">

                            <!-- Original issue -->
                            <div class="bg-light rounded p-3 mb-3">
                                <div class="small text-muted fw-semibold mb-1">YOUR ISSUE</div>
                                <p class="mb-0" style="white-space:pre-wrap;">@_selectedTicket.Description</p>
                            </div>

                            <!-- Resolution -->
                            @if (_selectedTicket.Status == "Resolved" && !string.IsNullOrWhiteSpace(_selectedTicket.Resolution))
                            {
                                <div class="alert alert-success py-2">
                                    <div class="fw-semibold small">✅ RESOLUTION FROM HR</div>
                                    <p class="mb-0" style="white-space:pre-wrap;">@_selectedTicket.Resolution</p>
                                </div>
                            }

                            <!-- Conversation thread -->
                            <!-- Conversation thread -->
                            <div class="small text-muted fw-semibold mb-2">CONVERSATION</div>
                            <div class="ticket-thread mb-3" id="employeeThread">
                                @if (!_replies.Any())
                                {
                                    <p class="text-muted small text-center py-3">
                                        No replies yet. HR will respond here soon.
                                    </p>
                                }
                                else
                                {
                                    @foreach (var r in _replies)
                                    {
                                        var isCurrentUser = r.UserId == _currentUserId;
                                        <div class="thread-msg @(r.IsStaff ? "staff" : "employee")">
                                            <div class="thread-meta">
                                                <strong>
                                                    @if (isCurrentUser)
                                                    {
                                                        <span>You</span>
                                                    }
                                                    else if (r.IsStaff)
                                                    {
                                                        @("HR Team")
                                                    }
                                                    else
                                                    {
                                                        @r.AuthorName
                                                    }
                                                    @if (!isCurrentUser && r.IsOrgAdmin)
                                                    {
                                                        <span class="badge bg-danger ms-1" style="font-size: 9px;">OrgAdmin</span>
                                                    }
                                                    else if (!isCurrentUser && r.IsHR)
                                                    {
                                                        <span class="badge bg-info ms-1" style="font-size: 9px;">HR</span>
                                                    }
                                                </strong>
                                                <span>@r.CreatedAt.ToLocalTime().ToString("dd MMM, hh:mm tt")</span>
                                            </div>
                                            <div class="thread-body">@r.Message</div>
                                        </div>
                                    }
                                }
                            </div>

                            <!-- Reply input (always available while not Closed) -->
                            @if (_selectedTicket.Status != "Closed")
                            {
                                @if (_errorMessage != null)
                                {
                                    <div class="alert alert-danger py-1 small mb-2">@_errorMessage</div>
                                }

                                <div class="input-group mt-auto">
                                    <textarea class="form-control"
                                              rows="2"
                                              placeholder="Type a message to HR…"
                                              @bind="_replyText"
                                              @bind:event="oninput"></textarea>
                                    <button class="btn btn-primary"
                                            @onclick="SendReplyAsync"
                                            disabled="@string.IsNullOrWhiteSpace(_replyText)">
                                        Send
                                    </button>
                                </div>

                                @if (_selectedTicket.Status == "Resolved")
                                {
                                    <div class="form-text">
                                        Replying will automatically reopen this ticket.
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="alert alert-secondary py-1 small mb-0">
                                    This ticket has been closed and is read-only.
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

<!-- ═══ New Ticket Modal ═════════════════════════════════════════════════ -->
@if (_showNewTicketModal)
{
    <div class="modal-backdrop-custom" @onclick="CloseNewTicketModal"></div>
    <div class="new-ticket-modal shadow-lg">
        <div class="modal-header border-bottom">
            <h5 class="modal-title fw-bold text-dark">Raise a Support Ticket</h5>
            <button class="btn-close" @onclick="CloseNewTicketModal"></button>
        </div>
        <div class="modal-body">

            @if (_createError != null)
            {
                <div class="alert alert-danger py-1 small">@_createError</div>
            }

            <div class="mb-3">
                <label class="form-label">Category <span class="text-danger">*</span></label>
                <select class="form-select" @bind="_newCategory">
                    <option value="">— Select a category —</option>
                    @foreach (var cat in TicketCategories.All)
                    {
                        <option>@cat</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Priority</label>
                <select class="form-select" @bind="_newPriority">
                    <option>Low</option>
                    <option selected>Medium</option>
                    <option>High</option>
                    <option>Urgent</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Describe your issue <span class="text-danger">*</span></label>
                <textarea class="form-control" rows="4"
                          placeholder="Please describe your issue in detail…"
                          @bind="_newDescription"></textarea>
            </div>
        </div>
        <div class="modal-footer border-top">
            <button class="btn btn-action-cancel px-3" @onclick="CloseNewTicketModal">Cancel</button>
            <button class="btn btn-add-dept"
                    @onclick="SubmitNewTicketAsync"
                    disabled="@(string.IsNullOrWhiteSpace(_newCategory) || string.IsNullOrWhiteSpace(_newDescription))">
                Submit Ticket
            </button>
        </div>
    </div>
}

<!-- ═══ Styles ═══════════════════════════════════════════════════════════ -->
<style>
    .tracking-tight {
        letter-spacing: -0.025em;
    }

    .panel-container-card {
        border-radius: 14px;
        background-color: #ffffff;
        overflow: hidden;
    }

    .text-heading-field {
        font-size: 14px;
        color: #1e293b !important;
    }

    .btn-add-dept {
        background-color: #5c4ac7 !important;
        color: #ffffff !important;
        border: none !important;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
    }

    .status-indicator-pill {
        font-size: 11px;
        font-weight: 600;
        padding: 2px 8px;
        border-radius: 6px;
        display: inline-block;
        min-width: 60px;
        text-align: center;
    }

    .pill-active {
        background-color: #ecfdf5;
        color: #065f46;
    }

    .pill-inactive {
        background-color: #fef2f2;
        color: #991b1b;
    }

    .pill-pending {
        background-color: #fffbeb;
        color: #92400e;
    }

    .pill-cancelled {
        background-color: #f1f5f9;
        color: #475569;
    }

    .pill-open {
        background-color: rgba(92, 74, 199, 0.08);
        color: #5c4ac7;
    }

    .btn-action-cancel {
        background-color: #f1f5f9;
        color: #475569;
        border: 1px solid #e2e8f0;
        border-radius: 6px;
        padding: 5px 14px;
        font-size: 12.5px;
    }

    .ticket-list-item {
        border: none;
        border-bottom: 1px solid #e2e8f0;
    }

        .ticket-list-item:hover {
            background-color: #f8fafc;
        }

        .ticket-list-item.active {
            background-color: rgba(92, 74, 199, 0.08);
            border-color: #e2e8f0;
            color: inherit;
        }

    .ticket-thread {
        max-height: 320px;
        overflow-y: auto;
    }

    .thread-msg {
        border-radius: 10px;
        padding: 8px 12px;
        margin-bottom: 8px;
        max-width: 90%;
    }

        .thread-msg.employee {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            margin-left: auto;
        }

        .thread-msg.staff {
            background: #f1f2f6;
        }

    .thread-meta {
        display: flex;
        justify-content: space-between;
        font-size: 11px;
        margin-bottom: 3px;
        opacity: .8;
    }

    .thread-body {
        font-size: 13.5px;
        white-space: pre-wrap;
    }

    /* New ticket modal */
    .modal-backdrop-custom {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.45);
        z-index: 1040;
    }

    .new-ticket-modal {
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: min(540px, 96vw);
        background: white;
        border-radius: 12px;
        z-index: 1050;
        overflow: hidden;
    }
</style>

@code {
    [Parameter] public Guid? TicketId { get; set; }

    private List<SupportTicket> _tickets = new();
    private SupportTicket? _selectedTicket;
    private List<TicketReplyViewDto> _replies = new();

    private string _replyText = "";
    private string? _errorMessage;
    private bool _loading = true;

    // New ticket modal
    private bool _showNewTicketModal = false;
    private string _newCategory = "";
    private string _newPriority = "Medium";
    private string _newDescription = "";
    private string? _createError;
    private string _currentUserId = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var currentUser = await CurrentUserService.GetUserAsync();
        _currentUserId = currentUser?.Id ?? string.Empty;

        _tickets = await TicketService.GetMyTicketsAsync();
        var target = TicketId.HasValue && _tickets.Any(t => t.TicketId == TicketId.Value)
            ? TicketId.Value
            : _tickets.FirstOrDefault()?.TicketId;

        if (target.HasValue)
            await SelectTicket(target.Value);

        _loading = false;
    }

    private async Task SelectTicket(Guid ticketId)
    {
        _errorMessage = null;
        _replyText = "";
        _selectedTicket = await TicketService.GetTicketByIdAsync(ticketId, isManagementView: false);

        // Employee view — internal notes excluded automatically
        _replies = _selectedTicket != null
            ? await TicketService.GetRepliesAsync(ticketId, includeInternalNotes: false)
            : new List<TicketReplyViewDto>();
    }



    private async Task SendReplyAsync()
    {
        if (_selectedTicket == null || string.IsNullOrWhiteSpace(_replyText)) return;
        _errorMessage = null;

        try
        {
            await TicketService.AddReplyAsync(
                _selectedTicket.TicketId,
                _replyText.Trim(),
                isInternalNote: false,
                isManagementView: false);

            _replyText = "";
            await SelectTicket(_selectedTicket.TicketId);
            _tickets = await TicketService.GetMyTicketsAsync();

            // Update the selected ticket reference (status may have changed)
            _selectedTicket = _tickets.FirstOrDefault(t => t.TicketId == _selectedTicket.TicketId);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    // ── New Ticket ──────────────────────────────────────────────────────

    private void OpenNewTicketModal()
    {
        _newCategory = "";
        _newPriority = "Medium";
        _newDescription = "";
        _createError = null;
        _showNewTicketModal = true;
    }

    private void CloseNewTicketModal() => _showNewTicketModal = false;

    private async Task SubmitNewTicketAsync()
    {
        if (string.IsNullOrWhiteSpace(_newCategory) || string.IsNullOrWhiteSpace(_newDescription))
            return;

        _createError = null;

        try
        {
            var ticket = await TicketService.CreateTicketAsync(
                _newCategory.Trim(),
                _newDescription.Trim(),
                _newPriority);

            _showNewTicketModal = false;
            _tickets = await TicketService.GetMyTicketsAsync();
            await SelectTicket(ticket.TicketId);
        }
        catch (Exception ex)
        {
            _createError = ex.Message;
        }
    }

    private static string StatusPill(string s) => s switch
    {
        "Open" => "pill-open",
        "InProgress" => "pill-pending",
        "Resolved" => "pill-active",
        "Closed" => "pill-cancelled",
        _ => "pill-cancelled"
    };
}
