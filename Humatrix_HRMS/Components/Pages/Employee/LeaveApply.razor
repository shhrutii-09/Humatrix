@page "/employee/leaves/apply"
@rendermode InteractiveServer
@using Humatrix_HRMS.Data
@using Humatrix_HRMS.Models
@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Services
@using Humatrix_HRMS.Helpers
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@attribute [Authorize(Roles = "Employee, HR")]
@inject LeaveService LeaveService
@inject CurrentUserService CurrentUser
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav

<PageTitle>Apply Leave | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom row-gap-3 flex-wrap">
        <div>
            <h2 class="fw-bold tracking-tight text-dark mb-1">Apply Leave</h2>
            <p class="text-muted small mb-0">Submit a new leave request for approval.</p>
        </div>
        <button class="btn btn-interactive-back shadow-sm" @onclick='() => Nav.NavigateTo("/employee/leaves")'>
            BACK TO LEAVES
        </button>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm form-container-card">
                <div class="card-body p-4">
                    @if (!string.IsNullOrEmpty(error))
                    {
                        <div class="alert alert-premium-danger d-flex align-items-center mb-4 border-0 shadow-sm" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
                            <div class="small fw-medium">@error</div>
                        </div>
                    }

                    @if (isPageLoading)
                    {
                        <div class="text-center py-4">
                            <div class="spinner-border text-primary"></div>
                            <p class="text-muted small mt-2">Loading...</p>
                        </div>
                    }
                    else
                    {
                        <EditForm Model="model" OnValidSubmit="Submit">
                            <DataAnnotationsValidator />

                            <div class="row g-3">
                                <div class="col-md-12 mb-2">
                                    <label class="form-label small fw-bold text-secondary tracking-wider mb-2">LEAVE TYPE</label>
                                    <select class="form-select premium-form-input @(model.LeaveTypeId == Guid.Empty && showValidation ? "is-invalid" : "")"
                                            @bind="model.LeaveTypeId"
                                            @bind:after="OnLeaveTypeChanged">
                                        <option value="@Guid.Empty">-- Select Leave Type --</option>
                                        @foreach (var lt in leaveTypes)
                                        {
                                            <option value="@lt.LeaveTypeId">@lt.Name</option>
                                        }
                                    </select>
                                </div>

                                @if (selectedLeaveType != null && selectedLeaveType.MinNoticeRequiredDays > 0)
                                {
                                    <div class="col-md-12">
                                        <div class="alert alert-info border-0 shadow-sm small mb-3">
                                            <i class="bi bi-info-circle me-2"></i>
                                            <strong>Notice Required:</strong> This leave type requires at least
                                            <strong>@selectedLeaveType.MinNoticeRequiredDays day(s)</strong> of advance notice.
                                        </div>
                                    </div>
                                }

                                @if (selectedBalance != null)
                                {
                                    <div class="col-md-12">
                                        <div class="alert alert-light border small mb-3">
                                            <div class="d-flex justify-content-between">
                                                <span><strong>Available:</strong> @(selectedBalance.Remaining + selectedBalance.CarriedForward) days</span>
                                                <span class="text-muted">Used: @selectedBalance.Used | Pending: @selectedBalance.Pending</span>
                                            </div>
                                        </div>
                                    </div>
                                }

                                <div class="col-md-6 mb-2">
                                    <label class="form-label small fw-bold text-secondary tracking-wider mb-2">FROM DATE</label>
                                    <InputDate class="form-control premium-form-input" @bind-Value="model.FromDate" @bind-Value:after="Recalculate" min="@today" />
                                </div>
                                <div class="col-md-6 mb-2">
                                    <label class="form-label small fw-bold text-secondary tracking-wider mb-2">TO DATE</label>
                                    <InputDate class="form-control premium-form-input" @bind-Value="model.ToDate" @bind-Value:after="Recalculate" min="@model.FromDate.ToString("yyyy-MM-dd")" />
                                </div>

                                @if (selectedLeaveType?.AllowHalfDay == true)
                                {
                                    <div class="col-md-12 mb-2">
                                        <div class="form-check">
                                            <InputCheckbox class="form-check-input" @bind-Value="model.IsHalfDay" @bind-Value:after="Recalculate" id="halfDayCheck" />
                                            <label class="form-check-label small" for="halfDayCheck">Request as Half Day</label>
                                        </div>
                                    </div>
                                }

                                <div class="col-md-12 mb-2">
                                    <label class="form-label small fw-bold text-secondary tracking-wider mb-2">REASON</label>
                                    <InputTextArea class="form-control premium-form-input" rows="3" placeholder="Briefly describe your reason..." @bind-Value="model.Reason" />
                                </div>

                                <div class="col-md-12">
                                    <div class="alert @GetCalcAlertClass() border-0 shadow-sm mt-3">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <span class="fw-semibold">Calculated Working Days:</span>
                                            <span class="fs-5 fw-bold">@calculatedDays</span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="border-top pt-4 mt-4 d-flex gap-2">
                                <button type="submit" class="btn btn-action-submit px-4 shadow-sm d-flex align-items-center gap-2" disabled="@(!CanSubmit || isSubmitting)" @onclick="() => showValidation = true">
                                    @if (isSubmitting)
                                    {
                                        <span class="spinner-border spinner-border-sm"></span>
                                    }
                                    <i class="bi bi-check-circle-fill"></i>
                                    <span>SUBMIT APPLICATION</span>
                                </button>
                                <button type="button" class="btn btn-action-cancel px-4" @onclick='() => Nav.NavigateTo("/employee/leaves")'>
                                    Cancel
                                </button>
                            </div>
                        </EditForm>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body p-4">
                    <h6 class="text-muted fw-bold text-uppercase mb-3" style="font-size:.7rem;letter-spacing:1px;">How It Works</h6>
                    <ul class="small text-muted mb-0 ps-3">
                        <li class="mb-2">Weekends & mandatory holidays are auto-excluded</li>
                        <li class="mb-2">Leave balance is verified before submission</li>
                        <li>Half-day option depends on leave type settings</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .tracking-tight {
        letter-spacing: -0.025em;
    }

    .tracking-wider {
        letter-spacing: 0.05em;
        font-size: 11px !important;
    }

    .premium-form-input {
        font-size: 14px;
        padding: 10px 14px;
        border-radius: 10px;
        border: 1px solid #cbd5e1;
        background-color: #f8fafc !important;
        transition: all 0.2s ease;
    }

        .premium-form-input:focus {
            border-color: #5c4ac7;
            background-color: #ffffff !important;
            box-shadow: 0 0 0 4px rgba(92, 74, 199, 0.12);
        }

    .btn-interactive-back {
        background: #ffffff !important;
        border: 1px solid #e5e7eb !important;
        color: #4b5563 !important;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
    }

        .btn-interactive-back:hover {
            background-color: #f8fafc !important;
            border-color: #5c4ac7 !important;
            color: #5c4ac7 !important;
            transform: translateY(-1px);
        }

    .btn-action-submit {
        background-color: #5c4ac7 !important;
        color: #ffffff !important;
        border: none !important;
        padding: 10px 20px;
        border-radius: 10px;
        font-size: 13.5px;
        font-weight: 600;
    }

    .btn-action-cancel {
        background-color: #ffffff;
        color: #475569;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 10px 20px;
        font-size: 13.5px;
        font-weight: 500;
    }

    .alert-premium-danger {
        background-color: #fef2f2;
        color: #991b1b;
        border-left: 4px solid #ef4444 !important;
        border-radius: 8px;
        padding: 12px 16px;
    }
</style>

@code {
    private LeaveRequest model = new() { FromDate = DateTime.Today, ToDate = DateTime.Today };
    private List<LeaveType> leaveTypes = new();
    private List<LeaveBalanceDto> balances = new();
    private List<DateTime> holidays = new();
    private WorkWeek? workWeek;
    private LeaveType? selectedLeaveType;
    private LeaveBalanceDto? selectedBalance;
    private decimal calculatedDays;
    private bool isInvalidRange;
    private bool isInsufficient;
    private bool isPageLoading = true;
    private bool isSubmitting;
    private bool showValidation;
    private string? error;
    private string today = DateTime.Today.ToString("yyyy-MM-dd");

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var user = await CurrentUser.GetUserAsync();
            if (user?.OrganizationId != null)
            {
                await using var db = await DbFactory.CreateDbContextAsync();
                leaveTypes = await db.LeaveTypes.Where(x => x.IsActive && x.OrganizationId == user.OrganizationId).OrderBy(x => x.Name).ToListAsync();
                holidays = await db.Holidays.Where(h => h.OrganizationId == user.OrganizationId && !h.IsOptional).Select(h => h.Date.Date).ToListAsync();
                workWeek = await db.WorkWeeks.FirstOrDefaultAsync(w => w.OrganizationId == user.OrganizationId);
            }
            balances = await LeaveService.GetMyBalancesAsync();
        }
        catch (Exception ex) { error = ex.Message; }
        finally { isPageLoading = false; Recalculate(); }
    }

    private void OnLeaveTypeChanged()
    {
        selectedLeaveType = leaveTypes.FirstOrDefault(x => x.LeaveTypeId == model.LeaveTypeId);
        selectedBalance = balances.FirstOrDefault(b => b.LeaveTypeName == selectedLeaveType?.Name);
        if (selectedLeaveType?.AllowHalfDay != true) model.IsHalfDay = false;
        Recalculate();
    }

    private void Recalculate()
    {
        isInvalidRange = false; isInsufficient = false;
        if (model.ToDate < model.FromDate) { calculatedDays = 0; isInvalidRange = true; return; }
        if (model.IsHalfDay) calculatedDays = 0.5m;
        else
        {
            calculatedDays = 0;
            for (var d = model.FromDate.Date; d <= model.ToDate.Date; d = d.AddDays(1))
            {
                if (workWeek != null && !DateHelper.IsWorkingDay(d, workWeek)) continue;
                if (workWeek == null && (d.DayOfWeek == DayOfWeek.Saturday || d.DayOfWeek == DayOfWeek.Sunday)) continue;
                if (holidays.Contains(d)) continue;
                calculatedDays++;
            }
        }
        if (selectedBalance != null && calculatedDays > (selectedBalance.Remaining + selectedBalance.CarriedForward)) isInsufficient = true;
    }

    private bool CanSubmit => !isInvalidRange && calculatedDays > 0 && !isInsufficient && model.LeaveTypeId != Guid.Empty && !string.IsNullOrWhiteSpace(model.Reason);

    private string GetCalcAlertClass()
    {
        if (isInvalidRange || isInsufficient) return "alert-danger";
        if (calculatedDays == 0) return "alert-warning";
        return "alert-success";
    }

    private async Task Submit()
    {
        showValidation = true; error = null; isSubmitting = true;
        try
        {
            await LeaveService.ApplyLeaveAsync(model);
            Nav.NavigateTo("/employee/leaves");
        }
        catch (Exception ex) { error = ex.Message; }
        finally { isSubmitting = false; }
    }
}