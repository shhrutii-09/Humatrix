@page "/employee/leaves/apply"
@rendermode InteractiveServer
@using Humatrix_HRMS.Data
@using Humatrix_HRMS.Models
@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Services
@using Humatrix_HRMS.Helpers
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@attribute [Authorize(Roles = "Employee, HR")]
@inject LeaveService LeaveService
@inject CurrentUserService CurrentUser
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav

<PageTitle>Apply Leave | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-0">Apply Leave</h4>
            <small class="text-muted">Submit a new leave request</small>
        </div>
        <button class="btn btn-outline-secondary btn-sm shadow-sm"
                @onclick='() => Nav.NavigateTo("/employee/leaves")'>
            <i class="bi bi-arrow-left me-1"></i>Back
        </button>
    </div>

    <!-- ERROR ALERT -->
    @if (!string.IsNullOrEmpty(error))
    {
        <div class="alert alert-danger alert-dismissible shadow-sm border-0 d-flex gap-2 mb-4">
            <i class="bi bi-exclamation-triangle-fill mt-1"></i>
            <div class="flex-grow-1">@error</div>
            <button class="btn-close" @onclick="() => error = null"></button>
        </div>
    }

    <div class="row g-4">

        <!-- FORM -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">

                    @if (isPageLoading)
                    {
                        <div class="text-center py-4">
                            <div class="spinner-border text-primary"></div>
                            <p class="text-muted small mt-2">Loading...</p>
                        </div>
                    }
                    else
                    {
                        <EditForm Model="model" OnValidSubmit="Submit">
                            <DataAnnotationsValidator />

                            <!-- LEAVE TYPE -->
                            <div class="mb-3">
                                <label class="form-label small fw-bold text-uppercase text-muted">
                                    Leave Type <span class="text-danger">*</span>
                                </label>
                                <select class="form-select @(model.LeaveTypeId == Guid.Empty && showValidation ? "is-invalid" : "")"
                                        @bind="model.LeaveTypeId"
                                        @bind:after="OnLeaveTypeChanged">
                                    <option value="@Guid.Empty">— Select Leave Type —</option>
                                    @foreach (var lt in leaveTypes)
                                    {
                                        <option value="@lt.LeaveTypeId">@lt.Name</option>
                                    }
                                </select>
                                @if (model.LeaveTypeId == Guid.Empty && showValidation)
                                {
                                    <div class="invalid-feedback">Please select a leave type.</div>
                                }
                            </div>

                            <!-- BALANCE INFO BANNER -->
                            @if (selectedBalance != null)
                            {
                                <div class="alert alert-light border small mb-3">
                                    <div class="d-flex justify-content-between">
                                        <span><strong>Available:</strong> @(selectedBalance.Remaining + selectedBalance.CarriedForward) days</span>
                                        <span class="text-muted">Used: @selectedBalance.Used &nbsp;|&nbsp; Pending: @selectedBalance.Pending</span>
                                    </div>
                                    @if (selectedBalance.CarriedForward > 0)
                                    {
                                        <div class="text-info small mt-1">
                                            <i class="bi bi-arrow-right me-1"></i>Includes @selectedBalance.CarriedForward day(s) carried forward
                                        </div>
                                    }
                                </div>
                            }

                            <!-- DATE RANGE -->
                            <div class="row g-3 mb-3">
                                <div class="col-md-6">
                                    <label class="form-label small fw-bold text-uppercase text-muted">
                                        From Date <span class="text-danger">*</span>
                                    </label>
                                    <InputDate class="form-control"
                                               @bind-Value="model.FromDate"
                                               @bind-Value:after="Recalculate"
                                               min="@today" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small fw-bold text-uppercase text-muted">
                                        To Date <span class="text-danger">*</span>
                                    </label>
                                    <InputDate class="form-control"
                                               @bind-Value="model.ToDate"
                                               @bind-Value:after="Recalculate"
                                               min="@model.FromDate.ToString("yyyy-MM-dd")" />
                                </div>
                            </div>

                            <!-- HALF DAY TOGGLE -->
                            @if (selectedLeaveType?.AllowHalfDay == true)
                            {
                                <div class="form-check mb-3">
                                    <InputCheckbox class="form-check-input"
                                                   @bind-Value="model.IsHalfDay"
                                                   @bind-Value:after="Recalculate"
                                                   id="halfDayCheck" />
                                    <label class="form-check-label" for="halfDayCheck">Half Day</label>
                                </div>
                            }

                            <!-- REASON -->
                            <div class="mb-3">
                                <label class="form-label small fw-bold text-uppercase text-muted">
                                    Reason <span class="text-danger">*</span>
                                </label>
                                @* <InputTextArea class="form-control @(string.IsNullOrWhiteSpace(model.Reason) && showValidation ? "is-invalid" : "")"
                                               rows="3"
                                               placeholder="Briefly describe your reason for leave..."
                                               @bind-Value="model.Reason" /> *@
                                <InputTextArea class="@($"form-control {(string.IsNullOrWhiteSpace(model.Reason) && showValidation ? "is-invalid" : "")}")"
                                               rows="3"
                                               placeholder="Briefly describe your reason for leave..."
                                               @bind-Value="model.Reason" />
                                @if (string.IsNullOrWhiteSpace(model.Reason) && showValidation)
                                {
                                    <div class="invalid-feedback">Reason is required.</div>
                                }
                            </div>

                            <!-- CALCULATION PANEL -->
                            <div class="alert @GetCalcAlertClass() border mb-4">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="fw-semibold">Calculated Working Days:</span>
                                    <span class="fs-5 fw-bold">@calculatedDays</span>
                                </div>
                                @if (isInvalidRange)
                                {
                                    <div class="small text-danger mt-1">
                                        <i class="bi bi-exclamation-circle me-1"></i>Invalid date range — To Date must be on or after From Date.
                                    </div>
                                }
                                else if (calculatedDays == 0)
                                {
                                    <div class="small text-warning mt-1">
                                        <i class="bi bi-calendar-x me-1"></i>All selected days are holidays or non-working days.
                                    </div>
                                }
                                else if (isInsufficient)
                                {
                                    <div class="small text-danger mt-1">
                                        <i class="bi bi-exclamation-circle me-1"></i>
                                        Insufficient balance. Available: @(selectedBalance != null ? selectedBalance.Remaining + selectedBalance.CarriedForward : 0) day(s).
                                    </div>
                                }
                                else
                                {
                                    <div class="small text-success mt-1">
                                        <i class="bi bi-check-circle me-1"></i>Ready to submit.
                                    </div>
                                }
                            </div>

                            <!-- ACTIONS -->
                            <div class="d-flex gap-2">
                                <button type="submit"
                                        class="btn btn-success px-4"
                                        disabled="@(!CanSubmit || isSubmitting)"
                                        @onclick="() => showValidation = true">
                                    @if (isSubmitting)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1"></span>
                                    }
                                    <i class="bi bi-send me-1"></i>Submit Application
                                </button>
                                <button type="button"
                                        class="btn btn-outline-secondary"
                                        @onclick='() => Nav.NavigateTo("/employee/leaves")'>
                                    Cancel
                                </button>
                            </div>

                        </EditForm>
                    }
                </div>
            </div>
        </div>

        <!-- SIDE PANEL -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body p-4">
                    <h6 class="text-muted fw-bold text-uppercase mb-3" style="font-size:.7rem;letter-spacing:1px;">
                        How It Works
                    </h6>
                    <ul class="small text-muted mb-0 ps-3">
                        <li class="mb-2">Weekends &amp; mandatory holidays are auto-excluded from day count</li>
                        <li class="mb-2">Leave balance is verified before submission</li>
                        <li class="mb-2">Overlapping leave or WFH requests are blocked</li>
                        <li class="mb-2">Half-day option depends on leave type settings</li>
                        <li>Some leave types require advance notice</li>
                    </ul>
                </div>
            </div>

            <!-- BALANCE QUICK-VIEW -->
            @if (balances.Any())
            {
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <h6 class="text-muted fw-bold text-uppercase mb-3" style="font-size:.7rem;letter-spacing:1px;">
                            Your Balances
                        </h6>
                        @foreach (var b in balances)
                        {
                            <div class="d-flex justify-content-between small mb-2">
                                <span class="text-muted">@b.LeaveTypeName</span>
                                <strong>@(b.Remaining + b.CarriedForward) days</strong>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

    </div>
</div>

@code {

    // ── State ────────────────────────────────────────────────────────────────────
    private LeaveRequest model = new() { FromDate = DateTime.Today, ToDate = DateTime.Today };

    private List<LeaveType> leaveTypes = new();
    private List<LeaveBalanceDto> balances = new();
    private List<DateTime> holidays = new();
    private WorkWeek? workWeek;

    private LeaveType? selectedLeaveType;
    private LeaveBalanceDto? selectedBalance;

    private decimal calculatedDays;
    private bool isInvalidRange;
    private bool isInsufficient;
    private bool isPageLoading = true;
    private bool isSubmitting;
    private bool showValidation;
    private string? error;

    private string today = DateTime.Today.ToString("yyyy-MM-dd");

    // ── Lifecycle ────────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        try
        {
            // 1. Fetch the current user first so we have their OrganizationId
            var user = await CurrentUser.GetUserAsync();

            if (user?.OrganizationId != null)
            {
                await using var db = await DbFactory.CreateDbContextAsync();

                // 2. Fetch leave types scoped strictly to this user's organization
                leaveTypes = await db.LeaveTypes
                    .Where(x => x.IsActive && x.OrganizationId == user.OrganizationId)
                    .OrderBy(x => x.Name)
                    .ToListAsync();

                // 3. Fetch holidays for this organization
                holidays = await db.Holidays
                    .Where(h => h.OrganizationId == user.OrganizationId && !h.IsOptional)
                    .Select(h => h.Date.Date)
                    .ToListAsync();

                // 4. Fetch the work week configuration for this organization
                workWeek = await db.WorkWeeks
                    .FirstOrDefaultAsync(w => w.OrganizationId == user.OrganizationId);
            }

            // 5. Fetch balances via the service
            balances = await LeaveService.GetMyBalancesAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isPageLoading = false;
            Recalculate();
        }
    }

    // ── Leave type change ─────────────────────────────────────────────────────────
    private void OnLeaveTypeChanged()
    {
        selectedLeaveType = leaveTypes.FirstOrDefault(x => x.LeaveTypeId == model.LeaveTypeId);
        selectedBalance = balances.FirstOrDefault(b => b.LeaveTypeName == selectedLeaveType?.Name);

        if (selectedLeaveType?.AllowHalfDay != true)
            model.IsHalfDay = false;

        Recalculate();
    }

    // ── Day calculation (UX preview only — real validation is in service) ─────────
    private void Recalculate()
    {
        isInvalidRange = false;
        isInsufficient = false;

        if (model.ToDate < model.FromDate)
        {
            calculatedDays = 0;
            isInvalidRange = true;
            return;
        }

        if (model.IsHalfDay)
        {
            calculatedDays = 0.5m;
        }
        else
        {
            calculatedDays = 0;
            for (var d = model.FromDate.Date; d <= model.ToDate.Date; d = d.AddDays(1))
            {
                if (workWeek != null && !DateHelper.IsWorkingDay(d, workWeek)) continue;
                if (workWeek == null && (d.DayOfWeek == DayOfWeek.Saturday || d.DayOfWeek == DayOfWeek.Sunday)) continue;
                if (holidays.Contains(d)) continue;
                calculatedDays++;
            }
        }

        if (selectedBalance != null)
        {
            var available = selectedBalance.Remaining + selectedBalance.CarriedForward;
            if (calculatedDays > available)
                isInsufficient = true;
        }
    }

    private bool CanSubmit =>
        !isInvalidRange &&
        calculatedDays > 0 &&
        !isInsufficient &&
        model.LeaveTypeId != Guid.Empty &&
        !string.IsNullOrWhiteSpace(model.Reason);

    private string GetCalcAlertClass()
    {
        if (isInvalidRange || isInsufficient) return "alert-danger";
        if (calculatedDays == 0) return "alert-warning";
        return "alert-success";
    }

    // ── Submit ────────────────────────────────────────────────────────────────────
    private async Task Submit()
    {
        showValidation = true;
        error = null;
        isSubmitting = true;

        try
        {
            await LeaveService.ApplyLeaveAsync(model);
            Nav.NavigateTo("/employee/leaves");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }
}