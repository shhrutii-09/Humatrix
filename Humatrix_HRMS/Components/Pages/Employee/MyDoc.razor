@page "/employee/docu"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Employee,HR")]
@using Humatrix_HRMS.Models.Documents
@using Humatrix_HRMS.Services
@using Humatrix_HRMS.Services.Documents
@using Microsoft.AspNetCore.Authorization
@inject IOrgDocumentGenerationService DocumentService
@inject EmployeeService EmployeeService
@inject CurrentUserService CurrentUserService

<h3>📁 My Organization Documents</h3>

@if (isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p>Loading documents...</p>
    </div>
}
else if (documents == null || !documents.Any())
{
    <div class="alert alert-info mt-4">
        <i class="bi bi-info-circle"></i> No organization documents have been issued to you yet.
    </div>
}
else
{
    <div class="table-responsive mt-4">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Document Name</th>
                    <th>Document Number</th>
                    <th>Issue Date</th>
                    <th>Issued By</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var doc in documents)
                {
                    <tr>
                        <td>
                            <strong>@doc.DocumentName</strong>
                            @if (!string.IsNullOrEmpty(doc.Description))
                            {
                                <br />
                                <small class="text-muted">@doc.Description</small>
                            }
                        </td>
                        <td>@doc.DocumentNumber</td>
                        <td>@doc.GeneratedAt.ToString("dd MMM yyyy")</td>
                        <td>@doc.GeneratedByRole</td>
                        <td>
                            @if (doc.Status == "Issued")
                            {
                                <span class="badge bg-primary">Issued</span>
                            }
                            else if (doc.Status == "Acknowledged")
                            {
                                <span class="badge bg-success">Acknowledged</span>
                            }
                            else if (doc.Status == "Revoked")
                            {
                                <span class="badge bg-danger">Revoked</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@doc.Status</span>
                            }
                        </td>
                        <td>
                            <a href="@doc.FilePath" target="_blank" class="btn btn-sm btn-primary me-2">
                                <i class="bi bi-download"></i> Download
                            </a>
                            @if (doc.Status == "Issued")
                            {
                                <button class="btn btn-sm btn-outline-success" @onclick="() => AcknowledgeDocument(doc.DocumentId)">
                                    <i class="bi bi-check2"></i> Acknowledge
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
        <i class="bi bi-check-circle"></i> @message
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
        <i class="bi bi-exclamation-triangle"></i> @errorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@code {
    private List<OrgGeneratedDocument>? documents;
    private bool isLoading = true;
    private string message = "";
    private string errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadDocuments();
    }

    private async Task LoadDocuments()
    {
        try
        {
            isLoading = true;
            message = "";
            errorMessage = "";

            var user = await CurrentUserService.GetUserAsync();
            if (user?.OrganizationId == null)
            {
                errorMessage = "User not authenticated. Please login again.";
                return;
            }

            var employee = await EmployeeService.GetEmployeeByUserIdAsync(user.Id);
            if (employee == null)
            {
                errorMessage = "Employee profile not found.";
                return;
            }

            documents = await DocumentService.GetDocumentsForEmployeeAsync(employee.EmployeeId, user.OrganizationId.Value);
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading documents: {ex.Message}";
            Console.WriteLine($"Error loading documents: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }


//     {
//   "JoiningDate": "2024-06-15",
//   "Designation": "Software Engineer",
//   "Department": "Engineering"
// }

    private async Task AcknowledgeDocument(Guid documentId)
    {
        try
        {
            var user = await CurrentUserService.GetUserAsync();
            var employee = await EmployeeService.GetEmployeeByUserIdAsync(user.Id);

            if (employee != null)
            {
                var result = await DocumentService.AcknowledgeDocumentAsync(documentId, employee.EmployeeId, "Acknowledged via portal");
                if (result)
                {
                    message = "Document acknowledged successfully!";
                    await LoadDocuments(); // Refresh the list
                }
                else
                {
                    errorMessage = "Failed to acknowledge document. Please try again.";
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error acknowledging document: {ex.Message}";
            Console.WriteLine($"Error acknowledging document: {ex.Message}");
        }
    }
}