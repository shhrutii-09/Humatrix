@* Pages/Employee/MyDoc.razor *@
@page "/employee/docu"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Employee,HR")]
@using Humatrix_HRMS.Models.Documents
@using Humatrix_HRMS.Services
@using Humatrix_HRMS.Services.Documents
@using Microsoft.AspNetCore.Authorization
@inject IOrgDocumentGenerationService DocumentService
@inject EmployeeService EmployeeService
@inject CurrentUserService CurrentUserService

<PageTitle>My Documents — Humatrix HRMS</PageTitle>

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="mb-0 fw-semibold">My Documents</h4>
        <small class="text-muted">Documents issued to you by the organisation</small>
    </div>
    @if (documents?.Any() == true)
    {
        <span class="badge bg-primary rounded-pill">
            @documents.Count document@(documents.Count == 1 ? "" : "s")
        </span>
    }
</div>

<!-- Toast -->
@if (!string.IsNullOrEmpty(toastMessage))
{
    <div class="alert @(toastIsError ? "alert-danger" : "alert-success") alert-dismissible fade show d-flex align-items-center gap-2 mb-4"
         role="alert">
        <span>@(toastIsError ? "❌" : "✅")</span>
        <div>@toastMessage</div>
        <button type="button" class="btn-close ms-auto"
                @onclick="() => toastMessage = string.Empty"></button>
    </div>
}

@if (isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-2 text-muted">Loading your documents...</p>
    </div>
}
else if (documents == null || !documents.Any())
{
    <div class="text-center py-5">
        <div class="display-6 mb-3">📁</div>
        <h5 class="text-muted">No documents yet</h5>
        <p class="text-muted small">
            Documents issued to you by HR or your organisation will appear here.
        </p>
    </div>
}
else
{
    <!-- Filter bar -->
    <div class="d-flex flex-wrap gap-2 mb-4">
        @foreach (var status in new[] { "All", "Issued", "Acknowledged", "Revoked" })
        {
            <button class="btn btn-sm @(activeFilter == status ? "btn-primary" : "btn-outline-secondary")"
                    @onclick="() => activeFilter = status">
                @status
                @if (status != "All")
                {
                    var count = documents.Count(d => d.Status == status);
                    if (count > 0)
                    {
                        <span class="badge bg-white text-primary ms-1">@count</span>
                    }
                }
            </button>
        }
    </div>

    var filtered = activeFilter == "All"
        ? documents
        : documents.Where(d => d.Status == activeFilter).ToList();

    @if (!filtered.Any())
    {
        <div class="alert alert-info">No documents with status "@activeFilter".</div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var doc in filtered)
            {
                <div class="col-md-6 col-xl-4">
                    <div class="card h-100 shadow-sm border-0 @(doc.Status == "Revoked" ? "opacity-75" : "")">
                        <div class="card-body">

                            <!-- Header row -->
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <span class="badge text-bg-light border small">
                                    @(doc.Template?.Category ?? "Document")
                                </span>
                                @switch (doc.Status)
                                {
                                    case "Issued":
                                        <span class="badge bg-primary-subtle text-primary border border-primary-subtle">Issued</span>
                                        break;
                                    case "Acknowledged":
                                        <span class="badge bg-success-subtle text-success border border-success-subtle">Acknowledged</span>
                                        break;
                                    case "Revoked":
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle">Revoked</span>
                                        break;
                                    default:
                                        <span class="badge bg-secondary-subtle text-secondary">@doc.Status</span>
                                        break;
                                }
                            </div>

                            <!-- Document name -->
                            <h6 class="fw-semibold mb-1">@doc.DocumentName</h6>
                            <div class="text-muted small mb-3">
                                <span>Ref: @doc.DocumentNumber</span>
                                <span class="mx-1">·</span>
                                <span>@doc.GeneratedAt.ToString("dd MMM yyyy")</span>
                            </div>

                            @if (!string.IsNullOrEmpty(doc.Description))
                            {
                                <p class="text-muted small mb-3">@doc.Description</p>
                            }

                            @if (doc.Status == "Acknowledged" && doc.AcknowledgedAt.HasValue)
                            {
                                <div class="text-muted small mb-2">
                                    Acknowledged on @doc.AcknowledgedAt.Value.ToString("dd MMM yyyy")
                                </div>
                            }

                        </div>

                        <!-- Actions -->
                        <div class="card-footer bg-transparent border-top-0 pt-0 pb-3 px-3">
                            <div class="d-flex gap-2">
                                <a href="@doc.FilePath" target="_blank"
                                   class="btn btn-sm btn-outline-primary flex-fill">
                                    View / Download
                                </a>

                                @if (doc.Status == "Issued")
                                {
                                    <button class="btn btn-sm btn-outline-success flex-fill"
                                            @onclick="() => AcknowledgeDocument(doc.DocumentId)"
                                            disabled="@(acknowledgingDocId == doc.DocumentId)">
                                        @if (acknowledgingDocId == doc.DocumentId)
                                        {
                                            <span class="spinner-border spinner-border-sm"></span>
                                        }
                                        else
                                        {
                                            <span>Acknowledge</span>
                                        }
                                    </button>
                                }
                            </div>
                        </div>

                    </div>
                </div>
            }
        </div>
    }
}

@code {
    private List<OrgGeneratedDocument>? documents;
    private bool isLoading = true;
    private string activeFilter = "All";
    private string toastMessage = "";
    private bool toastIsError = false;
    private Guid? acknowledgingDocId;

    protected override async Task OnInitializedAsync() => await LoadDocuments();

    private async Task LoadDocuments()
    {
        try
        {
            isLoading = true;

            var user = await CurrentUserService.GetUserAsync();
            if (user?.OrganizationId == null)
            {
                ShowToast("Your session has expired. Please log in again.", isError: true);
                return;
            }

            var employee = await EmployeeService.GetEmployeeByUserIdAsync(user.Id);
            if (employee == null)
            {
                ShowToast("Employee profile not found. Please contact HR.", isError: true);
                return;
            }

            documents = await DocumentService.GetDocumentsForEmployeeAsync(
                employee.EmployeeId, user.OrganizationId.Value);
        }
        catch (Exception ex)
        {
            ShowToast($"Unable to load documents: {ex.Message}", isError: true);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task AcknowledgeDocument(Guid documentId)
    {
        acknowledgingDocId = documentId;
        toastMessage = "";

        try
        {
            var user = await CurrentUserService.GetUserAsync();
            if (user == null) return;

            var employee = await EmployeeService.GetEmployeeByUserIdAsync(user.Id);
            if (employee == null) return;

            var success = await DocumentService.AcknowledgeDocumentAsync(
                documentId, employee.EmployeeId, "Acknowledged via employee portal");

            if (success)
            {
                ShowToast("Document acknowledged successfully.");
                await LoadDocuments();
            }
            else
            {
                ShowToast("Could not acknowledge document. Please try again.", isError: true);
            }
        }
        catch (Exception ex)
        {
            ShowToast($"Error: {ex.Message}", isError: true);
        }
        finally
        {
            acknowledgingDocId = null;
        }
    }

    private void ShowToast(string msg, bool isError = false)
    {
        toastMessage = msg;
        toastIsError = isError;
    }
}
