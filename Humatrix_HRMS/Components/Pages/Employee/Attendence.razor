@page "/employee/attendance"
@rendermode InteractiveServer

@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Helpers
@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Humatrix_HRMS.Data
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore

@attribute [Authorize(Roles = "Employee,HR")]

@inject AttendanceService AttendanceService
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject CurrentUserService CurrentUserService
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Attendance | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">
    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom row-gap-3 flex-wrap">
        <div>
            <h2 class="fw-bold tracking-tight text-dark mb-1">
                Attendance Dashboard
            </h2>
            <p class="text-muted small mb-0">
                Monitor work logs, attendance history and overtime.
            </p>
        </div>

        <div class="d-flex align-items-center gap-2">
            <!-- MONTH SELECTOR -->
            <div class="input-group dropdown-box-wrapper shadow-sm" style="max-width: 220px;">
                <span class="input-group-text bg-white border-end-0 text-muted">
                    <i class="bi bi-calendar-month"></i>
                </span>
                <input type="month" class="form-control border-start-0 ps-0 premium-dropdown-select" value="@selectedMonth" @onchange="OnMonthChanged" />
            </div>

            <button class="btn btn-add-dept d-flex align-items-center gap-2 shadow-sm" @onclick="LoadAttendance">
                <i class="bi bi-search"></i>LOAD
            </button>
        </div>
    </div>

    <!-- ERROR ALERT -->
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            @errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
        </div>
    }

    <!-- TODAY'S PUNCH CARD -->
    <div class="card border-0 shadow-sm mb-4 metric-panel-card overflow-hidden">
        <div class="card-body p-4">
            <div class="row align-items-center">
                <!-- CLOCK -->
                <div class="col-lg-4 text-center text-lg-start">
                    <div class="clock-display fw-bold">@currentTime.ToString("hh:mm:ss tt")</div>
                    <div class="text-muted">@currentTime.ToString("dddd, dd MMMM yyyy")</div>
                </div>

                <!-- PUNCH BUTTONS -->
                <div class="col-lg-4 text-center mt-4 mt-lg-0">
                    @if (!isCheckedIn)
                    {
                        <button class="btn btn-primary btn-lg px-5 punch-btn shadow-sm" @onclick="HandleCheckIn" disabled="@isActionLoading">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Punch In
                        </button>
                    }
                    else if (!isCheckedOut)
                    {
                        <button class="btn btn-danger btn-lg px-5 punch-btn shadow-sm" @onclick="HandleCheckOut" disabled="@isActionLoading">
                            <i class="bi bi-box-arrow-left me-2"></i>Punch Out
                        </button>
                    }
                    else
                    {
                        <div class="alert alert-success mb-0">✓ Shift completed successfully.</div>
                    }
                </div>

                <!-- TODAY'S STATUS -->
                <div class="col-lg-4 mt-4 mt-lg-0">
                    @if (todayRecord != null)
                    {
                        <div class="small text-muted mb-1">Today's Status</div>
                        <span class="badge @GetStatusClass(todayRecord.Status) px-3 py-2 mb-2">@todayRecord.Status</span>
                        <div class="mt-2 small">
                            <div><i class="bi bi-clock-history me-1"></i> <strong>Check-In:</strong> @FormatLocalTime(todayRecord.CheckIn)</div>
                            <div><i class="bi bi-clock-history me-1"></i> <strong>Check-Out:</strong> @FormatLocalTime(todayRecord.CheckOut)</div>
                            <div><i class="bi bi-hourglass-split me-1"></i> <strong>Total Hours:</strong> @(todayRecord.TotalHours?.ToString("F1") ?? "0.0")h</div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- STATISTICS CARDS -->
    <div class="row g-3 mb-4">
        <div class="col-md-3 col-sm-6">
            <div class="card border-0 shadow-sm metric-panel-card" style="border-left: 4px solid #10b981 !important;">
                <div class="card-body d-flex align-items-center justify-content-between p-3">
                    <div>
                        <span class="text-secondary small fw-bold tracking-wider text-uppercase d-block mb-1">Present</span>
                        <h3 class="fw-bold text-dark mb-0">@PresentCount</h3>
                    </div>
                    <div class="metric-icon-box" style="background-color: rgba(16, 185, 129, 0.08); color: #10b981;">
                        <i class="bi bi-check-circle-fill"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="card border-0 shadow-sm metric-panel-card" style="border-left: 4px solid #f59e0b !important;">
                <div class="card-body d-flex align-items-center justify-content-between p-3">
                    <div>
                        <span class="text-secondary small fw-bold tracking-wider text-uppercase d-block mb-1">Late</span>
                        <h3 class="fw-bold text-dark mb-0">@LateCount</h3>
                    </div>
                    <div class="metric-icon-box" style="background-color: rgba(245, 158, 11, 0.08); color: #f59e0b;">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="card border-0 shadow-sm metric-panel-card" style="border-left: 4px solid #ef4444 !important;">
                <div class="card-body d-flex align-items-center justify-content-between p-3">
                    <div>
                        <span class="text-secondary small fw-bold tracking-wider text-uppercase d-block mb-1">Absent</span>
                        <h3 class="fw-bold text-dark mb-0">@AbsentCount</h3>
                    </div>
                    <div class="metric-icon-box" style="background-color: rgba(239, 68, 68, 0.08); color: #ef4444;">
                        <i class="bi bi-x-circle-fill"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="card border-0 shadow-sm metric-panel-card" style="border-left: 4px solid #5c4ac7 !important;">
                <div class="card-body d-flex align-items-center justify-content-between p-3">
                    <div>
                        <span class="text-secondary small fw-bold tracking-wider text-uppercase d-block mb-1">Total Hours</span>
                        <h3 class="fw-bold text-dark mb-0">@TotalHoursWorked.ToString("F1")h</h3>
                    </div>
                    <div class="metric-icon-box" style="background-color: rgba(92, 74, 199, 0.08); color: #5c4ac7;">
                        <i class="bi bi-clock-fill"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ATTENDANCE HISTORY CARD -->
    <div class="card border-0 shadow-sm panel-container-card">
        <div class="card-body pb-0 pt-3">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <h5 class="fw-bold text-dark mb-0">Attendance History</h5>
                </div>
                <div class="col-md-6">
                    <div class="position-relative search-wrapper ms-md-auto">
                        <i class="bi bi-search search-icon text-muted"></i>
                        <input type="text" class="form-control premium-search-input" placeholder="Search by date or status..." @bind="searchQuery" @bind:event="oninput" />
                    </div>
                </div>
            </div>
        </div>

        <div class="table-responsive mt-3">
            <table class="table align-middle table-hover mb-0">
                <thead>
                    <tr>
                        <th class="ps-4 text-secondary small fw-bold tracking-wider py-3">DATE</th>
                        <th class="text-secondary small fw-bold tracking-wider py-3">CHECK-IN</th>
                        <th class="text-secondary small fw-bold tracking-wider py-3">CHECK-OUT</th>
                        <th class="text-secondary small fw-bold tracking-wider py-3">HOURS</th>
                        <th class="text-secondary small fw-bold tracking-wider py-3">STATUS</th>
                        <th class="text-secondary small fw-bold tracking-wider py-3 pe-4">OT</th>
                    </tr>
                </thead>
                <tbody>
                    @if (isLoading)
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5">
                                <div class="spinner-border text-primary" role="status"></div>
                                <p class="mt-2 text-muted small">Loading records...</p>
                            </td>
                        </tr>
                    }
                    else if (!PagedAttendance.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="bi bi-calendar-x fs-1 d-block mb-2"></i>
                                No attendance records found for this month.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var att in PagedAttendance)
                        {
                            <tr class="table-row-interactive">
                                <td class="ps-4">
                                    <div class="fw-bold text-dark text-heading-field">@att.Date.ToString("dd MMM yyyy")</div>
                                    <div class="small text-muted">@att.Date.ToString("dddd")</div>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark fw-normal px-3 py-2">
                                        <i class="bi bi-box-arrow-in-right me-1"></i> @FormatLocalTime(att.CheckIn)
                                    </span>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark fw-normal px-3 py-2">
                                        <i class="bi bi-box-arrow-left me-1"></i> @FormatLocalTime(att.CheckOut)
                                    </span>
                                </td>
                                <td><strong>@(att.TotalHours?.ToString("F1") ?? "0.0")h</strong></td>
                                <td><span class="badge @GetStatusClass(att.Status) px-3 py-2">@att.Status</span></td>
                                <td class="pe-4">
                                    @if (att.ApprovedOvertimeHours > 0)
                                    {
                                        <span class="text-success fw-semibold">+@att.ApprovedOvertimeHours.ToString("F1")h</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">--</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- PAGINATION -->
        @if (FilteredAttendance.Any())
        {
            <div class="d-flex justify-content-between align-items-center p-3 border-top bg-light">
                <span class="small text-muted">
                    Showing @PagedAttendance.Count() of @FilteredAttendance.Count() records
                </span>
                <div class="d-flex align-items-center gap-1 core-pagination-wrapper shadow-sm rounded-3 p-1 bg-white border">
                    <button class="btn btn-paging-arrow @(currentPage == 1 ? "disabled" : "")" @onclick="PreviousPage">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                    <div class="premium-page-state-text px-2 fw-semibold text-secondary select-none">
                        Page <span class="text-indigo-premium">@currentPage</span>/<span>@(TotalPages == 0 ? 1 : TotalPages)</span>
                    </div>
                    <button class="btn btn-paging-arrow @(currentPage >= TotalPages ? "disabled" : "")" @onclick="NextPage">
                        <i class="bi bi-chevron-right"></i>
                    </button>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .tracking-tight {
        letter-spacing: -0.025em;
    }

    .tracking-wider {
        letter-spacing: 0.04em;
        font-size: 11px;
    }

    .panel-container-card {
        border-radius: 14px;
        background-color: #ffffff;
        overflow: hidden;
    }

    .metric-panel-card {
        border-radius: 12px;
        background-color: #ffffff;
        overflow: hidden;
    }

    .metric-icon-box {
        width: 42px;
        height: 42px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
    }

    .search-wrapper {
        max-width: 320px;
    }

    .search-icon {
        position: absolute;
        top: 50%;
        left: 14px;
        transform: translateY(-50%);
        font-size: 14px;
        pointer-events: none;
    }

    .premium-search-input {
        padding: 10px 16px 10px 38px;
        font-size: 13.5px;
        border-radius: 10px;
        border: 1px solid #cbd5e1;
        transition: all 0.2s ease;
    }

        .premium-search-input:focus {
            border-color: #5c4ac7;
            box-shadow: 0 0 0 4px rgba(92, 74, 199, 0.12);
        }

    .dropdown-box-wrapper {
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid #cbd5e1;
    }

    .premium-dropdown-select {
        font-size: 13.5px;
        padding: 9px 12px;
        border: none;
        height: 40px;
        cursor: pointer;
    }

    .btn-add-dept {
        background-color: #5c4ac7 !important;
        color: #ffffff !important;
        border: none !important;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
    }

    .table thead th {
        background-color: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
    }

    .table-row-interactive:hover {
        background-color: #f8fafc;
    }

    .text-heading-field {
        font-size: 14px;
        color: #1e293b !important;
    }

    .btn-paging-arrow {
        border: none;
        background: transparent;
        color: #475569;
        padding: 4px 10px;
        border-radius: 6px;
    }

        .btn-paging-arrow.disabled {
            color: #cbd5e1;
            pointer-events: none;
        }

    .premium-page-state-text {
        font-size: 12.5px;
        min-width: 75px;
        text-align: center;
    }

    .text-indigo-premium {
        color: #5c4ac7;
        font-weight: 700;
    }

    .core-pagination-wrapper {
        background-color: #ffffff;
    }

    .clock-display {
        font-size: 2.8rem;
        font-weight: 800;
        letter-spacing: -1px;
        font-family: 'Segoe UI', 'Monaco', monospace;
    }

    .punch-btn {
        border-radius: 14px;
        padding: 12px 28px;
        font-weight: 600;
        transition: all 0.2s ease;
    }

        .punch-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.1);
        }

    .badge {
        font-weight: 500;
        border-radius: 30px;
        font-size: 0.75rem;
    }

    .bg-light.badge {
        background-color: #f8f9fa !important;
        border: 1px solid #e9ecef;
    }

    /* Custom status badge colors */
    .bg-success.text-white {
        background-color: #198754 !important;
    }

    .bg-warning.text-dark {
        background-color: #ffc107 !important;
        color: #000 !important;
    }

    .bg-danger.text-white {
        background-color: #dc3545 !important;
    }

    .bg-info.text-white {
        background-color: #0dcaf0 !important;
        color: #000 !important;
    }

    .bg-primary.text-white {
        background-color: #0d6efd !important;
    }

    .bg-secondary.text-white {
        background-color: #6c757d !important;
    }

    @@media (max-width: 768px) {
        .clock-display {
            font-size: 2rem;
        }
    }
</style>

@code {
    private List<AttendanceListDto> displayAttendanceList = new();
    private AttendanceListDto? todayRecord;
    private bool isCheckedIn;
    private bool isCheckedOut;

    private string errorMessage = "";

    private bool isLoading;
    private bool isActionLoading;
    private string searchQuery = "";
    private int currentPage = 1;
    private int pageSize = 10;
    private DateTime currentTime = DateTime.Now;
    private Timer? timer;
    private TimeZoneInfo orgTimeZone = TimeZoneInfo.Utc;
    private string selectedMonth = DateTime.Now.ToString("yyyy-MM");

    private IEnumerable<AttendanceListDto> FilteredAttendance =>
        string.IsNullOrWhiteSpace(searchQuery)
        ? displayAttendanceList
        : displayAttendanceList.Where(x =>
            x.Date.ToString("dd MMM yyyy").Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
            (x.Status ?? "").Contains(searchQuery, StringComparison.OrdinalIgnoreCase));

    private IEnumerable<AttendanceListDto> PagedAttendance =>
        FilteredAttendance.Skip((currentPage - 1) * pageSize).Take(pageSize);

    private int TotalPages => (int)Math.Ceiling((double)FilteredAttendance.Count() / pageSize);
    private int PresentCount => displayAttendanceList.Count(x => x.Status == AttendanceStatuses.Present);
    private int LateCount => displayAttendanceList.Count(x => x.Status == AttendanceStatuses.Late);
    private int AbsentCount => displayAttendanceList.Count(x => x.Status == AttendanceStatuses.Absent);
    private double TotalHoursWorked => displayAttendanceList.Sum(x => x.TotalHours ?? 0);

    protected override async Task OnInitializedAsync()
    {
        await LoadOrgTimezone();
        StartClock();
        await LoadData();
    }

    private async Task LoadData()
    {
        await LoadTodayStatus();
        await LoadAttendance();
    }

    private async Task LoadTodayStatus()
    {
        todayRecord = await AttendanceService.GetTodayStatusAsync();
        isCheckedIn = todayRecord?.CheckIn != null;
        isCheckedOut = todayRecord?.CheckOut != null;
        StateHasChanged();
    }

    private void StartClock()
    {
        timer = new Timer(_ => { currentTime = DateTime.Now; InvokeAsync(StateHasChanged); }, null, 0, 1000);
    }

    private async Task OnMonthChanged(ChangeEventArgs e)
    {
        selectedMonth = e.Value?.ToString() ?? DateTime.Now.ToString("yyyy-MM");
        await LoadAttendance();
    }

    private async Task LoadAttendance()
    {
        isLoading = true;
        try
        {
            var parts = selectedMonth.Split('-');
            var year = int.Parse(parts[0]);
            var month = int.Parse(parts[1]);

            var attendanceList = await AttendanceService.GetMyAttendanceByMonthAsync(year, month);
            displayAttendanceList = attendanceList.ToList();
            currentPage = 1;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadOrgTimezone()
    {
        try
        {
            var user = await CurrentUserService.GetUserAsync();
            if (user?.OrganizationId == null) return;

            await using var db = await DbFactory.CreateDbContextAsync();
            var tzId = await db.Organizations
                .AsNoTracking()
                .Where(o => o.OrganizationId == user.OrganizationId)
                .Select(o => o.TimeZoneId)
                .FirstOrDefaultAsync();

            if (!string.IsNullOrWhiteSpace(tzId))
            {
                orgTimeZone = TimeHelper.GetOrgTimeZone(tzId);
            }
        }
        catch
        {
            orgTimeZone = TimeZoneInfo.Utc;
        }
    }

    private async Task HandleCheckIn()
    {
        try
        {
            errorMessage = "";
            isActionLoading = true;
            var loc = await JS.InvokeAsync<LocationDto>("getLocation");
            await AttendanceService.CheckInAsync(loc.Latitude, loc.Longitude);
            await LoadData();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            Console.WriteLine($"CheckIn Error: {ex.Message}");
            Console.WriteLine($"Stack Trace: {ex.StackTrace}");
        }
        finally
        {
            isActionLoading = false;
        }
    }

    private async Task HandleCheckOut()
    {
        try
        {
            isActionLoading = true;
            var loc = await JS.InvokeAsync<LocationDto>("getLocation");
            await AttendanceService.CheckOutAsync(loc.Latitude, loc.Longitude);
            await LoadData();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isActionLoading = false;
        }
    }

    private void NextPage()
    {
        if (currentPage < TotalPages) currentPage++;
    }

    private void PreviousPage()
    {
        if (currentPage > 1) currentPage--;
    }

    private string FormatLocalTime(DateTime? utcTime)
    {
        if (utcTime == null) return "--:--";
        return TimeHelper.FormatOrgTime(utcTime, orgTimeZone);
    }

    private string GetStatusClass(string? status) => status switch
    {
        AttendanceStatuses.Present => "bg-success text-white",
        AttendanceStatuses.Late => "bg-warning text-dark",
        AttendanceStatuses.Absent => "bg-danger text-white",
        AttendanceStatuses.HalfDay => "bg-info text-white",
        AttendanceStatuses.ShortHours => "bg-info text-white",
        "On Leave" => "bg-primary text-white",
        _ => "bg-secondary text-white"
    };

    public void Dispose()
    {
        timer?.Dispose();
    }
}