    /// <summary>
    /// Converts a UTC timestamp (EF returns Unspecified) to org-local display time.
    /// NEVER use .ToLocalTime() — that uses the server OS timezone.
    /// </summary>
    private string FormatOrgTime(DateTime? utcTime)
        => TimeHelper.FormatOrgTime(utcTime, orgTimeZone);

    private async Task HandleCheckIn()
    {
        isActionLoading = true;
        error = null;
        try
        {
            var loc = await JS.InvokeAsync<LocationDto>("getLocation");
            await AttendanceService.CheckInAsync(loc.Latitude, loc.Longitude);
            await RefreshUI();
        }
        catch (Exception ex) { error = ex.Message; }
        finally { isActionLoading = false; }
    }

    private async Task HandleCheckOut()
    {
        isActionLoading = true;
        error = null;
        try
        {
            var loc = await JS.InvokeAsync<LocationDto>("getLocation");
            await AttendanceService.CheckOutAsync(loc.Latitude, loc.Longitude);
            await RefreshUI();
        }
        catch (Exception ex) { error = ex.Message; }
        finally { isActionLoading = false; }
    }

    private static string GetStatusClass(string? status) => status switch
    {
        AttendanceStatuses.Present => "bg-success",
        AttendanceStatuses.Late => "bg-warning text-dark",
        AttendanceStatuses.HalfDay => "bg-info text-dark",
        AttendanceStatuses.EarlyExit => "bg-info text-dark",
        AttendanceStatuses.ShortHours => "bg-secondary",
        AttendanceStatuses.Absent => "bg-danger",
        AttendanceStatuses.WorkFromHome => "bg-primary",
        "Not Started" => "bg-light text-dark border",
        _ => "bg-secondary"
    };

    public void Dispose() => _timer?.Dispose();
}
