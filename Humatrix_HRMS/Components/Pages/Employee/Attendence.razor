@page "/employee/attendance"
@rendermode InteractiveServer

@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Helpers
@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize(Roles = "Employee,HR")]

@inject AttendanceService AttendanceService
@inject IJSRuntime JS

<PageTitle>My Attendance | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="fw-normal">My Attendance</h2>
            <p class="text-muted small">Track your daily work hours and check-in history.</p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(error))
    {
        <div class="alert alert-danger shadow-sm border-0 d-flex align-items-center">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <div>@error</div>
        </div>
    }

    <div class="row g-4">

        <!-- LEFT PANEL -->
        <div class="col-xl-4 col-md-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body text-center p-5">

                    <i class="bi bi-clock-history text-primary display-4 mb-3"></i>

                    <!-- ✅ LIVE CLOCK -->
                    <h4 class="fw-bold mb-1">@currentTime.ToString("hh:mm tt")</h4>
                    <p class="text-muted small mb-4">@currentTime.ToString("dddd, MMMM dd")</p>

                    @if (!string.IsNullOrEmpty(message))
                    {
                        <div class="badge @(isCheckedIn ? "bg-success-subtle text-success" : "bg-light text-dark") p-2 mb-4 w-100">
                            <i class="bi bi-info-circle me-1"></i> @message
                        </div>
                    }

                    <div class="d-grid gap-2">
                        @if (!isCheckedIn)
                        {
                            <button class="btn btn-primary py-3 fw-bold shadow-sm"
                                    style="background-color: #5c4ac7; border: none;"
                                    @onclick="HandleCheckIn"
                                    disabled="@isLoading">
                                @if (isLoading)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                CHECK IN NOW
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-outline-danger py-3 fw-bold shadow-sm"
                                    @onclick="HandleCheckOut"
                                    disabled="@(isCheckedOut || isLoading)">
                                @if (isLoading)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                @(isCheckedOut ? "WORK COMPLETED" : "CHECK OUT")
                            </button>
                        }
                    </div>

                </div>
            </div>
        </div>

        <!-- RIGHT PANEL -->
        <div class="col-xl-8 col-md-6">

            <!-- STATS -->
            <div class="row g-3">
                <div class="col-sm-6 col-lg-4">
                    <div class="card shadow-sm border-0 border-start border-success border-4">
                        <div class="card-body">
                            <small class="text-muted fw-bold">PRESENT DAYS</small>
                            <h3 class="mb-0">
                                @attendanceList.Count(x =>
                                x.Status == AttendanceStatuses.Present ||
                                x.Status == AttendanceStatuses.Late)
                            </h3>
                        </div>
                    </div>
                </div>

                <div class="col-sm-6 col-lg-4">
                    <div class="card shadow-sm border-0 border-start border-warning border-4">
                        <div class="card-body">
                            <small class="text-muted fw-bold">LATE ARRIVALS</small>
                            <h3 class="mb-0">
                                @attendanceList.Count(x => x.Status == AttendanceStatuses.Late)
                            </h3>
                        </div>
                    </div>
                </div>

                <div class="col-sm-6 col-lg-4">
                    <div class="card shadow-sm border-0 border-start border-danger border-4">
                        <div class="card-body">
                            <small class="text-muted fw-bold">ABSENT</small>
                            <h3 class="mb-0">
                                @attendanceList.Count(x => x.Status == AttendanceStatuses.Absent)
                            </h3>
                        </div>
                    </div>
                </div>
            </div>

            <!-- HISTORY -->
            <div class="card shadow-sm border-0 mt-4">
                <div class="card-header bg-white py-3 border-0">
                    <h5 class="mb-0 fw-bold">Recent History</h5>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4 border-0 text-muted small">DATE</th>
                                <th class="text-center border-0 text-muted small">CHECK IN</th>
                                <th class="text-center border-0 text-muted small">CHECK OUT</th>
                                <th class="border-0 text-muted small">STATUS</th>
                            </tr>
                        </thead>

                        <tbody>
                            @if (!attendanceList.Any())
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-4 text-muted">
                                        No attendance history found.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var att in attendanceList
                                                            .OrderByDescending(x => x.Date)
                                                            .Take(10))
                                {
                                    <tr>
                                        <td class="ps-4 fw-bold">
                                            @att.Date.ToString("dd MMM yyyy")

                                            @if (att.IsManual)
                                            {
                                                <i class="bi bi-pencil-square ms-1 text-muted"
                                                   title="Manually Edited"></i>
                                            }
                                        </td>

                                        <td class="text-center font-monospace small">
                                            @* @(att.CheckIn?.ToLocalTime().ToString("hh:mm tt") ?? "--:--") *@
                                            @TimeHelper.FormatOrgTime(att.CheckIn)
                                        </td>

                                        <td class="text-center font-monospace small">
                                            @* @(att.CheckOut?.ToLocalTime().ToString("hh:mm tt") ?? "--:--") *@
                                            @TimeHelper.FormatOrgTime(att.CheckOut)
                                        </td>

                                        <td>
                                            <span class="badge rounded-pill @GetStatusClass(att.Status)">
                                                @att.Status
                                            </span>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>
</div>

@code {
    private bool isCheckedIn;
    private bool isCheckedOut;
    private bool isLoading;
    private string? error;
    private string? message;
    private List<AttendanceListDto> attendanceList = new();

    private DateTime currentTime = DateTime.Now;
    private Timer? timer;

    protected override async Task OnInitializedAsync()
    {
        StartClock();
        await RefreshUI();
    }

    private void StartClock()
    {
        timer = new Timer(_ =>
        {
            currentTime = DateTime.Now;
            InvokeAsync(StateHasChanged);
        }, null, 0, 1000);
    }

    private async Task RefreshUI()
    {
        try
        {
            error = null;

            var status = await AttendanceService.GetTodayStatusAsync();

            if (status != null)
            {
                isCheckedIn = status.CheckIn != null;
                isCheckedOut = status.CheckOut != null;

                if (isCheckedOut)
                    message = $"Checked out at {status.CheckOut?.ToLocalTime():hh:mm tt}";
                else if (isCheckedIn)
                    message = $"Checked in at {status.CheckIn?.ToLocalTime():hh:mm tt}";
                else
                    message = "Ready to start your day?";
            }
            else
            {
                isCheckedIn = false;
                isCheckedOut = false;
                message = "Ready to start your day?";
            }

            attendanceList = await AttendanceService.GetMyAttendanceAsync();
        }
        catch
        {
            error = "Failed to load attendance data.";
        }
    }

    private async Task HandleCheckIn()
    {
        try
        {
            isLoading = true;
            error = null;

            var location = await JS.InvokeAsync<LocationDto>("getLocation");
            await AttendanceService.CheckInAsync(location.Latitude, location.Longitude);

            await RefreshUI();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleCheckOut()
    {
        try
        {
            isLoading = true;
            error = null;

            var location = await JS.InvokeAsync<LocationDto>("getLocation");
            await AttendanceService.CheckOutAsync(location.Latitude, location.Longitude);

            await RefreshUI();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetStatusClass(string status) => status switch
    {
        AttendanceStatuses.Present => "bg-success",
        AttendanceStatuses.Late => "bg-warning text-dark",
        AttendanceStatuses.HalfDay => "bg-info",
        AttendanceStatuses.ShortHours => "bg-secondary",
        AttendanceStatuses.Absent => "bg-danger",
        AttendanceStatuses.WorkFromHome => "bg-primary",
        "Not Started" => "bg-light text-dark border",
        _ => "bg-secondary"
    };

    public void Dispose()
    {
        timer?.Dispose();
    }
}