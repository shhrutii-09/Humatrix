@page "/employee/attendance"
@rendermode InteractiveServer
@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Employee")]

@inject AttendanceService AttendanceService
@inject IJSRuntime JS

<PageTitle>My Attendance | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="fw-normal">My Attendance</h2>
            <p class="text-muted small">Track your daily work hours and check-in history.</p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(error))
    {
        <div class="alert alert-danger shadow-sm border-0 d-flex align-items-center" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <div>@error</div>
        </div>
    }

    <div class="row g-4">
        <div class="col-xl-4 col-md-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body text-center p-5">
                    <div class="mb-3">
                        <i class="bi bi-clock-history text-primary display-4"></i>
                    </div>
                    <h4 class="fw-bold mb-1">@DateTime.Now.ToString("hh:mm tt")</h4>
                    <p class="text-muted small mb-4">@DateTime.Now.ToString("dddd, MMMM dd")</p>

                    @if (!string.IsNullOrEmpty(message) && isCheckedIn)
                    {
                        <div class="badge bg-soft-success text-success p-2 mb-4 w-100">
                            <i class="bi bi-check-circle-fill me-1"></i> @message
                        </div>
                    }

                    <div class="d-grid gap-2">
                        @if (!isCheckedIn)
                        {
                            <button class="btn btn-primary py-3 fw-bold shadow-sm"
                                    style="background-color: #5c4ac7; border: none;"
                                    @onclick="CheckIn" disabled="@isLoading">
                                @if (isLoading)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                CHECK IN NOW
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-outline-danger py-3 fw-bold shadow-sm"
                                    @onclick="CheckOut" disabled="@(isCheckedOut || isLoading)">
                                @if (isLoading)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                @(isCheckedOut ? "WORK COMPLETED" : "CHECK OUT")
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-8 col-md-6">
            <div class="row g-3">
                <div class="col-sm-6 col-lg-4">
                    <div class="card shadow-sm border-0 border-start border-success border-4">
                        <div class="card-body">
                            <small class="text-muted fw-bold">PRESENT DAYS</small>
                            <h3 class="mb-0">@attendanceList.Count(x => x.Status == "Present" || x.Status == "Checked In")</h3>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6 col-lg-4">
                    <div class="card shadow-sm border-0 border-start border-warning border-4">
                        <div class="card-body">
                            <small class="text-muted fw-bold">LATE ARRIVALS</small>
                            <h3 class="mb-0">@attendanceList.Count(x => x.Status.Contains("Late"))</h3>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6 col-lg-4">
                    <div class="card shadow-sm border-0 border-start border-danger border-4">
                        <div class="card-body">
                            <small class="text-muted fw-bold">ABSENT</small>
                            <h3 class="mb-0">@attendanceList.Count(x => x.Status == "Absent")</h3>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0 mt-4">
                <div class="card-header bg-white py-3 border-0">
                    <h5 class="mb-0 fw-bold">Recent History</h5>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4 border-0 text-muted small">DATE</th>
                                <th class="border-0 text-muted small text-center">CHECK IN</th>
                                <th class="border-0 text-muted small text-center">CHECK OUT</th>
                                <th class="border-0 text-muted small">STATUS</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (attendanceList == null || !attendanceList.Any())
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-4 text-muted">No attendance history found.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var att in attendanceList.OrderByDescending(x => x.Date).Take(10))
                                {
                                    <tr class="@(att.Status == "Absent" ? "bg-light-danger" : "")">
                                        <td class="ps-4 fw-bold">@att.Date.ToString("dd MMM yyyy")</td>
                                        <td class="text-center font-monospace small">@(att.CheckIn?.ToLocalTime().ToString("hh:mm tt") ?? "--:--")</td>
                                        <td class="text-center font-monospace small">@(att.CheckOut?.ToLocalTime().ToString("hh:mm tt") ?? "--:--")</td>
                                        <td>
                                            <span class="badge rounded-pill @GetStatusClass(att.Status)">@att.Status</span>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-soft-success {
        background-color: rgba(25, 135, 84, 0.1);
    }

    .bg-light-danger {
        background-color: rgba(220, 53, 69, 0.02);
    }

    .font-monospace {
        letter-spacing: -0.5px;
    }

    .badge {
        padding: 0.5em 0.8em;
    }
</style>

@code {
    private bool isCheckedIn;
    private bool isCheckedOut;
    private bool isLoading;
    private string? error;
    private string? message;
    private List<AttendanceListDto> attendanceList = new();

    protected override async Task OnInitializedAsync() => await RefreshUI();

    private async Task RefreshUI()
    {
        var status = await AttendanceService.GetTodayStatusAsync();
        if (status != null)
        {
            isCheckedIn = status.CheckIn != null;
            isCheckedOut = status.CheckOut != null;
            message = isCheckedIn
                ? $"Checked in today at {status.CheckIn?.ToLocalTime():hh:mm tt}"
                : "Not checked in yet";
        }
        else
        {
            isCheckedIn = false;
            isCheckedOut = false;
            message = "Ready to start your day?";
        }

        attendanceList = await AttendanceService.GetMyAttendanceAsync();
    }

    private string GetStatusClass(string status) => status switch
    {
        "Present" => "bg-success",
        "Late" => "bg-warning text-dark",
        "Late (Active)" => "bg-warning text-dark",
        "Half Day" => "bg-info",
        "Short Hours" => "bg-secondary",
        "Absent" => "bg-danger",
        "Checked In" => "bg-primary",
        "Not Started" => "bg-light text-dark border",
        _ => "bg-secondary"
    };

    // private async Task CheckIn()
    // {
    //     try
    //     {
    //         isLoading = true; error = null;
    //         await AttendanceService.CheckInAsync();
    //         await RefreshUI();
    //     }
    //     catch (Exception ex) { error = ex.Message; }
    //     finally { isLoading = false; }
    // }

    private async Task CheckIn()
    {
        try
        {
            isLoading = true;
            error = null;

            // 🔥 Get location from browser
            var location = await JS.InvokeAsync<LocationResult>("getLocation");

            // 🔥 Send to backend
            await AttendanceService.CheckInAsync(location.Latitude, location.Longitude);

            await RefreshUI();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task CheckOut()
    {
        try
        {
            isLoading = true;
            error = null;

            // 🔥 Get location again
            var location = await JS.InvokeAsync<LocationResult>("getLocation");

            // 🔥 Send to backend
            await AttendanceService.CheckOutAsync(location.Latitude, location.Longitude);

            await RefreshUI();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }


    public class LocationResult
    {
        public double Latitude { get; set; }
        public double Longitude { get; set; }
    }
}