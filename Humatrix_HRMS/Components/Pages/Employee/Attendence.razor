@page "/employee/attendance"
@rendermode InteractiveServer

@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Helpers
@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize(Roles = "Employee,HR")]

@inject AttendanceService AttendanceService
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Attendance | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 py-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
        <div>
            <h3 class="fw-bold mb-1">Attendance Dashboard</h3>
            <p class="text-muted mb-0">
                Monitor work logs, attendance history and overtime.
            </p>
        </div>

        <div class="d-flex gap-2">
            <input type="month"
                   class="form-control"
                   style="max-width:220px"
                   @bind-value="selectedMonth"
                   @bind-value:format="yyyy-MM" />

            <button class="btn btn-primary"
                    @onclick="LoadAttendance">
                <i class="bi bi-search me-2"></i>Load
            </button>
        </div>
    </div>

    <!-- CLOCK CARD -->
    <div class="card border-0 shadow-sm mb-4 overflow-hidden">
        <div class="card-body p-4">

            <div class="row align-items-center">

                <div class="col-lg-4 text-center text-lg-start">
                    <div class="clock-display">
                        @currentTime.ToString("hh:mm:ss tt")
                    </div>

                    <div class="text-muted">
                        @currentTime.ToString("dddd, dd MMMM yyyy")
                    </div>
                </div>

                <div class="col-lg-4 text-center mt-4 mt-lg-0">

                    @if (!isCheckedIn)
                    {
                        <button class="btn btn-primary btn-lg px-5 punch-btn"
                                @onclick="HandleCheckIn"
                                disabled="@isActionLoading">
                            <i class="bi bi-box-arrow-in-right me-2"></i>
                            Punch In
                        </button>
                    }
                    else if (!isCheckedOut)
                    {
                        <button class="btn btn-danger btn-lg px-5 punch-btn"
                                @onclick="HandleCheckOut"
                                disabled="@isActionLoading">
                            <i class="bi bi-box-arrow-left me-2"></i>
                            Punch Out
                        </button>
                    }
                    else
                    {
                        <div class="alert alert-success mb-0">
                            Shift completed successfully.
                        </div>
                    }

                </div>

                <div class="col-lg-4 mt-4 mt-lg-0">

                    @if (todayRecord != null)
                    {
                        <div class="small text-muted mb-1">
                            Today's Status
                        </div>

                        <span class="badge @GetStatusClass(todayRecord.Status)">
                            @todayRecord.Status
                        </span>

                        <div class="mt-3 small">
                            <div>
                                <strong>Check-In:</strong>
                                @FormatOrgTime(todayRecord.CheckIn)
                            </div>

                            <div>
                                <strong>Check-Out:</strong>
                                @FormatOrgTime(todayRecord.CheckOut)
                            </div>

                            <div>
                                <strong>Total Hours:</strong>
                                @(todayRecord.TotalHours?.ToString("F1") ?? "0.0")h
                            </div>
                        </div>
                    }

                </div>

            </div>

        </div>
    </div>

    <!-- STATS -->
    <div class="row g-4 mb-4">

        <div class="col-md-3">
            <div class="card border-0 shadow-sm stat-card">
                <div class="card-body">
                    <div class="text-muted small mb-2">Present Days</div>
                    <h3 class="fw-bold mb-0">@PresentCount</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm stat-card">
                <div class="card-body">
                    <div class="text-muted small mb-2">Late Days</div>
                    <h3 class="fw-bold text-warning mb-0">@LateCount</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm stat-card">
                <div class="card-body">
                    <div class="text-muted small mb-2">Absent Days</div>
                    <h3 class="fw-bold text-danger mb-0">@AbsentCount</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm stat-card">
                <div class="card-body">
                    <div class="text-muted small mb-2">Total Work Hours</div>
                    <h3 class="fw-bold text-primary mb-0">
                        @TotalHoursWorked.ToString("F1")h
                    </h3>
                </div>
            </div>
        </div>

    </div>

    <!-- SEARCH -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">

            <div class="row align-items-center">

                <div class="col-md-6">
                    <div class="search-box">
                        <i class="bi bi-search"></i>

                        <input type="text"
                               class="form-control ps-5"
                               placeholder="Search attendance..."
                               @bind="searchQuery"
                               @bind:event="oninput" />
                    </div>
                </div>

                <div class="col-md-6 text-md-end mt-3 mt-md-0">
                    <span class="text-muted small">
                        Showing @PagedAttendance.Count() of @FilteredAttendance.Count()
                    </span>
                </div>

            </div>

        </div>
    </div>

    <!-- TABLE -->
    <div class="card border-0 shadow-sm">

        <div class="table-responsive">

            <table class="table align-middle table-hover mb-0">

                <thead class="table-light">
                    <tr>
                        <th>Date</th>
                        <th>Check-In</th>
                        <th>Check-Out</th>
                        <th>Hours</th>
                        <th>Status</th>
                        <th>OT</th>
                    </tr>
                </thead>

                <tbody>

                    @if (isLoading)
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5">
                                <div class="spinner-border text-primary"></div>
                            </td>
                        </tr>
                    }
                    else if (!PagedAttendance.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                No attendance records found.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var att in PagedAttendance)
                        {
                            <tr>

                                <td>
                                    <div class="fw-semibold">
                                        @att.Date.ToString("dd MMM yyyy")
                                    </div>

                                    <div class="small text-muted">
                                        @att.Date.ToString("dddd")
                                    </div>
                                </td>

                                <td>
                                    @(FormatOrgTime(att.CheckIn) ?? "--")
                                </td>

                                <td>
                                    @(FormatOrgTime(att.CheckOut) ?? "--")
                                </td>

                                <td>
                                    <strong>
                                        @(att.TotalHours?.ToString("F1") ?? "0.0")h
                                    </strong>
                                </td>

                                <td>
                                    <span class="badge @GetStatusClass(att.Status)">
                                        @att.Status
                                    </span>
                                </td>

                                <td>
                                    @if (att.ApprovedOvertimeHours > 0)
                                    {
                                        <span class="text-success fw-semibold">
                                            +@att.ApprovedOvertimeHours.ToString("F1")h
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">--</span>
                                    }
                                </td>

                            </tr>
                        }
                    }

                </tbody>

            </table>

        </div>

        <!-- PAGINATION -->
        <div class="card-footer bg-white border-0 py-3">

            <div class="d-flex justify-content-between align-items-center">

                <button class="btn btn-outline-secondary"
                        disabled="@(currentPage == 1)"
                        @onclick="PreviousPage">
                    Previous
                </button>

                <span class="small text-muted">
                    Page @currentPage of @TotalPages
                </span>

                <button class="btn btn-outline-secondary"
                        disabled="@(currentPage >= TotalPages)"
                        @onclick="NextPage">
                    Next
                </button>

            </div>

        </div>

    </div>

</div>

<style>

    .clock-display {
        font-size: 2.8rem;
        font-weight: 800;
        letter-spacing: -1px;
    }

    .punch-btn {
        border-radius: 14px;
        padding: 14px 28px;
        font-weight: 700;
        transition: 0.2s;
    }

        .punch-btn:hover {
            transform: translateY(-2px);
        }

    .stat-card {
        border-radius: 18px;
    }

    .search-box {
        position: relative;
    }

        .search-box i {
            position: absolute;
            top: 50%;
            left: 15px;
            transform: translateY(-50%);
            color: #999;
        }

    .badge {
        padding: 10px 14px;
        font-size: 0.8rem;
        border-radius: 10px;
    }

</style>

@code {

    private List<AttendanceListDto> attendanceList = new();

    private AttendanceListDto? todayRecord;

    private bool isCheckedIn;
    private bool isCheckedOut;

    private bool isLoading;
    private bool isActionLoading;

    private string searchQuery = "";

    private int currentPage = 1;
    private int pageSize = 10;

    private DateTime currentTime = DateTime.Now;

    private Timer? timer;

    // private string selectedMonthString =
    //     DateTime.Now.ToString("yyyy-MM");

    private DateTime selectedMonth = DateTime.Today;

    private IEnumerable<AttendanceListDto> FilteredAttendance =>
        string.IsNullOrWhiteSpace(searchQuery)
        ? attendanceList
        : attendanceList.Where(x =>
            x.Date.ToString("dd MMM yyyy")
            .Contains(searchQuery, StringComparison.OrdinalIgnoreCase)
            ||
            (x.Status ?? "")
            .Contains(searchQuery, StringComparison.OrdinalIgnoreCase));

    private IEnumerable<AttendanceListDto> PagedAttendance =>
        FilteredAttendance
        .Skip((currentPage - 1) * pageSize)
        .Take(pageSize);

    private int TotalPages =>
        (int)Math.Ceiling((double)FilteredAttendance.Count() / pageSize);

    private int PresentCount =>
        attendanceList.Count(x => x.Status == AttendanceStatuses.Present);

    private int LateCount =>
        attendanceList.Count(x => x.Status == AttendanceStatuses.Late);

    private int AbsentCount =>
        attendanceList.Count(x => x.Status == AttendanceStatuses.Absent);

    private double TotalHoursWorked =>
        attendanceList.Sum(x => x.TotalHours ?? 0);

    protected override async Task OnInitializedAsync()
    {
        StartClock();

        await LoadAttendance();

        todayRecord = await AttendanceService.GetTodayStatusAsync();

        isCheckedIn = todayRecord?.CheckIn != null;
        isCheckedOut = todayRecord?.CheckOut != null;
    }

    private void StartClock()
    {
        timer = new Timer(_ =>
        {
            currentTime = DateTime.Now;
            InvokeAsync(StateHasChanged);

        }, null, 0, 1000);
    }

    private async Task LoadAttendance()
    {
        isLoading = true;

        try
        {
            attendanceList =
    await AttendanceService
    .GetMyAttendanceByMonthAsync(
        selectedMonth.Year,
        selectedMonth.Month);

            currentPage = 1;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleCheckIn()
    {
        try
        {
            isActionLoading = true;

            var loc = await JS.InvokeAsync<LocationDto>("getLocation");

            await AttendanceService.CheckInAsync(
                loc.Latitude,
                loc.Longitude);

            await LoadAttendance();

            todayRecord =
                await AttendanceService.GetTodayStatusAsync();

            isCheckedIn = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isActionLoading = false;
        }
    }

    private async Task HandleCheckOut()
    {
        try
        {
            isActionLoading = true;

            var loc = await JS.InvokeAsync<LocationDto>("getLocation");

            await AttendanceService.CheckOutAsync(
                loc.Latitude,
                loc.Longitude);

            await LoadAttendance();

            todayRecord =
                await AttendanceService.GetTodayStatusAsync();

            isCheckedOut = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isActionLoading = false;
        }
    }

    private void NextPage()
    {
        if (currentPage < TotalPages)
            currentPage++;
    }

    private void PreviousPage()
    {
        if (currentPage > 1)
            currentPage--;
    }

    private string? FormatOrgTime(DateTime? utcTime)
    {
        if (utcTime == null)
            return null;

        return utcTime.Value.ToLocalTime()
            .ToString("hh:mm tt");
    }

    private string GetStatusClass(string? status) => status switch
    {
        AttendanceStatuses.Present => "bg-success text-white",
        AttendanceStatuses.Late => "bg-warning text-dark",
        AttendanceStatuses.Absent => "bg-danger text-white",
        AttendanceStatuses.HalfDay => "bg-info text-white",
        "On Leave" => "bg-primary text-white",
        _ => "bg-secondary text-white"
    };

    public void Dispose()
    {
        timer?.Dispose();
    }
}