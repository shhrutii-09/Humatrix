@page "/employee/overtime"
@rendermode InteractiveServer
@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Data
@using Humatrix_HRMS.Helpers
@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@attribute [Authorize(Roles = "Employee,HR,OrgAdmin")]
@inject OvertimeService OvertimeService
@inject CurrentUserService CurrentUserService
@inject ApplicationDbContext DbContext
@inject AttendanceService AttendanceService
@inject NavigationManager Nav

<PageTitle>My Overtime | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">

    <!-- HEADER with Dashboard Button -->
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom row-gap-3 flex-wrap">
        <div>
            <h2 class="fw-bold tracking-tight text-dark mb-1">Overtime Requests</h2>
            <p class="text-muted small mb-0">Claim overtime for days you worked beyond shift hours</p>
        </div>
        <div class="d-flex align-items-center gap-2">
            @* <button class="btn btn-refresh-custom shadow-sm d-flex align-items-center gap-2" @onclick="LoadData" disabled="@isLoading">
                <i class="bi bi-arrow-clockwise"></i>REFRESH
            </button> *@
            <button class="btn btn-interactive-back shadow-sm" @onclick='() => Nav.NavigateTo(dashboardPath)'>
                <i class="bi bi-speedometer2"></i>
                DASHBOARD
            </button>
        </div>
    </div>

    <!-- ALERT BANNER -->
    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert alert-@(isError ? "danger" : "success") alert-dismissible fade show shadow-sm border-0" role="alert">
            <i class="bi bi-@(isError ? "exclamation-triangle-fill" : "check-circle-fill") me-2"></i>
            @message
            <button type="button" class="btn-close" @onclick="() => message = null"></button>
        </div>
    }

    <div class="row g-4">

        <!-- ══════════════════════════════════════════════
             LEFT — Claimable Records
        ══════════════════════════════════════════════ -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm metric-panel-card h-100">
                <div class="card-header bg-white border-bottom py-3 px-4">
                    <h5 class="fw-semibold mb-0">
                        <i class="bi bi-clock-history text-primary me-2"></i>Claimable Overtime
                    </h5>
                    <p class="text-muted small mb-0 mt-1">
                        Days where you worked beyond scheduled shift hours.
                    </p>
                </div>
                <div class="card-body p-3">

                    @if (isLoading)
                    {
                        <div class="text-center py-5">
                            <div class="spinner-border text-primary" role="status"></div>
                            <p class="text-muted small mt-2">Loading...</p>
                        </div>
                    }
                    else if (!eligibleRecords.Any())
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-check2-circle fs-1 d-block mb-2 opacity-25"></i>
                            <p>No pending overtime to claim.</p>
                        </div>
                    }
                    else
                    {
                        <div class="vstack gap-2">
                            @foreach (var record in eligibleRecords)
                            {
                                var isSelected = selectedRecord?.AttendanceId == record.AttendanceId;
                                <div class="border rounded-3 p-3 @(isSelected ? "border-primary bg-primary-subtle" : "bg-light border-0")">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <div class="fw-bold text-dark">@record.Date.ToString("ddd, MMM dd yyyy")</div>
                                            <span class="badge bg-info-subtle text-info border border-info-subtle mt-1 px-3 py-1">
                                                Worked: @(record.TotalHours?.ToString("F2")) hrs
                                            </span>
                                        </div>
                                        @if (isSelected)
                                        {
                                            <button class="btn btn-outline-secondary btn-sm" @onclick="() => selectedRecord = null">
                                                Cancel
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-primary btn-sm px-3" @onclick="() => SelectRecord(record)">
                                                CLAIM
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    <!-- CLAIM FORM — shown inline when a record is selected -->
                    @if (selectedRecord != null)
                    {
                        <div class="mt-4 p-3 border border-primary rounded-3 bg-white shadow-sm">
                            <h6 class="fw-bold text-primary mb-3">
                                <i class="bi bi-pencil-square me-2"></i>Claim — @selectedRecord.Date.ToString("ddd, MMM dd")
                            </h6>

                            <div class="mb-3">
                                <label class="form-label small fw-bold text-uppercase text-muted">Shift / Scheduled End</label>
                                <input class="form-control bg-light" value="@FormatTime(selectedRecord.CheckOut)" readonly />
                                <div class="form-text">Your official shift end time.</div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label small fw-bold text-uppercase text-muted">
                                    Actual Time You Left <span class="text-danger">*</span>
                                </label>
                                <input type="time" class="form-control @(showFormValidation && actualCheckOutTime == default ? "is-invalid" : "")" @bind="actualCheckOutTime" />
                                <div class="form-text">Must be after your scheduled shift end.</div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label small fw-bold text-uppercase text-muted">
                                    Reason <span class="text-danger">*</span>
                                </label>
                                <textarea class="form-control @(showFormValidation && string.IsNullOrWhiteSpace(requestReason) ? "is-invalid" : "")" rows="3" placeholder="What task kept you working longer?" @bind="requestReason"></textarea>
                                @if (showFormValidation && string.IsNullOrWhiteSpace(requestReason))
                                {
                                    <div class="invalid-feedback d-block">Reason is required.</div>
                                }
                            </div>

                            <div class="d-grid gap-2">
                                <button class="btn btn-primary" disabled="@isSubmitting" @onclick="HandleSubmit">
                                    @if (isSubmitting)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                    }
                                    <i class="bi bi-send me-1"></i>Submit OT Request
                                </button>
                                <button class="btn btn-link btn-sm text-muted text-decoration-none" @onclick="() => { selectedRecord = null; showFormValidation = false; }">
                                    Cancel
                                </button>
                            </div>
                        </div>
                    }

                </div>
            </div>
        </div>

        <!-- ══════════════════════════════════════════════
             RIGHT — Request History
        ══════════════════════════════════════════════ -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm panel-container-card">
                <div class="card-header bg-white border-bottom py-3 px-4 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-semibold">My Overtime History</h5>
                    <span class="badge bg-secondary text-white">@myRequests.Count total</span>
                </div>
                <div class="table-responsive">
                    <table class="table align-middle table-hover mb-0">
                        <thead class="bg-light border-bottom">
                            <tr>
                                <th class="ps-4 text-secondary small fw-bold tracking-wider py-3">DATE</th>
                                <th class="text-secondary small fw-bold tracking-wider py-3">REQ. HOURS</th>
                                <th class="text-secondary small fw-bold tracking-wider py-3">ACTUAL OUT</th>
                                <th class="text-secondary small fw-bold tracking-wider py-3">STATUS</th>
                                <th class="text-secondary small fw-bold tracking-wider py-3 pe-4">REASON</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!myRequests.Any())
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted">
                                        <i class="bi bi-clock fs-1 d-block mb-2 opacity-25"></i>
                                        No overtime requests yet.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var req in myRequests)
                                {
                                    <tr class="table-row-interactive">
                                        <td class="ps-4 fw-semibold text-dark">@req.Date.ToString("dd MMM yyyy")</td>
                                        <td>
                                            <span class="badge bg-warning text-dark px-3 py-1">@req.RequestedHours.ToString("F2") hrs</span>
                                        </td>
                                        <td class="font-monospace small">@FormatTime(req.ActualCheckOut)</td>
                                        <td>
                                            <span class="badge @GetStatusClass(req.Status) px-3 py-1">@req.Status</span>
                                        </td>
                                        <td class="text-muted small pe-4" style="max-width:250px;" title="@req.Reason">
                                            @TruncateText(req.Reason, 50)
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
</div>

<style>
    .tracking-tight {
        letter-spacing: -0.025em;
    }

    .tracking-wider {
        letter-spacing: 0.04em;
        font-size: 11px;
    }

    .panel-container-card {
        border-radius: 14px;
        background-color: #ffffff;
        overflow: hidden;
    }

    .metric-panel-card {
        border-radius: 12px;
        background-color: #ffffff;
        overflow: hidden;
    }

    .btn-interactive-back {
        background: #ffffff !important;
        border: 1px solid #e5e7eb !important;
        color: #4b5563 !important;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
        transition: all 0.2s ease;
    }

        .btn-interactive-back:hover {
            border-color: #5c4ac7 !important;
            color: #5c4ac7 !important;
            transform: translateY(-1px);
        }

    .btn-refresh-custom {
        background: #ffffff !important;
        border: 1px solid #e5e7eb !important;
        color: #4b5563 !important;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
        transition: all 0.2s ease;
    }

        .btn-refresh-custom:hover {
            border-color: #5c4ac7 !important;
            color: #5c4ac7 !important;
            transform: translateY(-1px);
        }

    .table thead th {
        background-color: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
    }

    .table-row-interactive:hover {
        background-color: #f8fafc;
    }

    .bg-primary-subtle {
        background-color: rgba(92, 74, 199, 0.08) !important;
    }

    .bg-info-subtle {
        background-color: rgba(13, 202, 240, 0.1) !important;
    }
</style>

@code {

    private List<AttendanceListDto> eligibleRecords = new();
    private List<OvertimeRequest> myRequests = new();
    private AttendanceListDto? selectedRecord;

    private TimeOnly actualCheckOutTime = TimeOnly.MinValue;
    private string requestReason = string.Empty;

    private bool isLoading;
    private bool isSubmitting;
    private bool showFormValidation;
    private bool isError;
    private string? message;

    private TimeZoneInfo orgTimeZone = TimeZoneInfo.Utc;
    private string orgTimeZoneId = "UTC";
    private string dashboardPath = "/employee/dashboard";

    protected override async Task OnInitializedAsync()
    {
        await LoadOrgTimezone();

        // Set dashboard path based on role
        var currentUser = await CurrentUserService.GetUserAsync();
        if (currentUser != null)
        {
            var isHR = await CurrentUserService.IsInRoleAsync("HR");
            dashboardPath = isHR ? "/hr/dashboard" : "/employee/dashboard";
        }

        await LoadData();
    }

    private async Task LoadOrgTimezone()
    {
        try
        {
            var user = await CurrentUserService.GetUserAsync();
            if (user?.OrganizationId != null)
            {
                var org = await DbContext.Organizations
                    .AsNoTracking()
                    .FirstOrDefaultAsync(o => o.OrganizationId == user.OrganizationId);

                orgTimeZoneId = org?.TimeZoneId ?? "UTC";
                orgTimeZone = TimeHelper.GetOrgTimeZone(orgTimeZoneId);
            }
        }
        catch
        {
            orgTimeZoneId = "UTC";
            orgTimeZone = TimeZoneInfo.Utc;
        }
    }

    private async Task LoadData()
    {
        isLoading = true;
        message = null;
        selectedRecord = null;

        try
        {
            var allAttendance = await AttendanceService.GetMyAttendanceAsync();

            var orgToday = TimeHelper.GetOrgDate(orgTimeZoneId);

            eligibleRecords = allAttendance
                .Where(a =>
                    a.NeedsOvertimeApproval == true &&
                    (a.OvertimeStatus == null || a.OvertimeStatus == "Rejected") &&
                    a.Date.Date < orgToday.Date)
                .OrderByDescending(a => a.Date)
                .ToList();

            myRequests = await OvertimeService.GetMyRequestsAsync();
        }
        catch (Exception ex)
        {
            isError = true;
            message = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void SelectRecord(AttendanceListDto record)
    {
        selectedRecord = record;
        requestReason = string.Empty;
        showFormValidation = false;

        if (record.CheckOut.HasValue)
        {
            var localCheckout = TimeHelper.ToOrgLocal(record.CheckOut.Value, orgTimeZone);
            actualCheckOutTime = TimeOnly.FromDateTime(localCheckout);
        }
        else
        {
            var orgNow = TimeZoneInfo.ConvertTimeFromUtc(DateTime.UtcNow, orgTimeZone);
            actualCheckOutTime = TimeOnly.FromDateTime(orgNow);
        }
    }

    private async Task HandleSubmit()
    {
        showFormValidation = true;
        if (selectedRecord == null) return;
        if (string.IsNullOrWhiteSpace(requestReason)) return;
        if (actualCheckOutTime == TimeOnly.MinValue) return;

        isSubmitting = true;
        isError = false;
        message = null;

        try
        {
            var workDate = selectedRecord.Date;

            var actualLocal = new DateTime(
                workDate.Year, workDate.Month, workDate.Day,
                actualCheckOutTime.Hour, actualCheckOutTime.Minute, 0,
                DateTimeKind.Unspecified);

            await OvertimeService.RaiseRequestAsync(new CreateOvertimeRequestDto
            {
                AttendanceId = selectedRecord.AttendanceId ?? Guid.Empty,
                ActualCheckOut = actualLocal,
                Reason = requestReason
            });

            isError = false;
            message = "Overtime request submitted. Pending HR review.";
            selectedRecord = null;
            requestReason = string.Empty;
            await LoadData();
        }
        catch (Exception ex)
        {
            isError = true;
            message = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private string FormatTime(DateTime? utcDt)
        => TimeHelper.FormatOrgTime(utcDt, orgTimeZone);

    private string GetStatusClass(string? status) => status switch
    {
        "Approved" => "bg-success text-white",
        "Rejected" => "bg-danger text-white",
        _ => "bg-warning text-dark"
    };

    private static string TruncateText(string? text, int max) =>
        string.IsNullOrEmpty(text) ? "—" :
        text.Length <= max ? text : text[..max] + "…";
}