    private async Task SetPassword()
    {
        try
        {
            isLoading = true;
            error = null;
            successMessage = null;

            if (string.IsNullOrEmpty(userId) || string.IsNullOrEmpty(token))
            {
                error = "Invalid activation link.";
                return;
            }

            var user = await UserManager.FindByIdAsync(userId);

            if (user == null)
            {
                error = "User not found.";
                return;
            }

            var invite = await Db.UserInvites
                .FirstOrDefaultAsync(x => x.UserId == userId && !x.IsUsed);

            if (invite == null)
            {
                error = "Invalid or expired activation link.";
                return;
            }

            // Decode token from URL
            var decodedToken = Uri.UnescapeDataString(token);

            // Set password using original token
            var passwordResult = await UserManager.ResetPasswordAsync(
                user,
                decodedToken,
                model.Password);

            if (passwordResult.Succeeded)
            {
                using var transaction = await Db.Database.BeginTransactionAsync();

                try
                {
                    // IMPORTANT: Activate the user
                    user.IsActive = true;
                    var updateResult = await UserManager.UpdateAsync(user);

                    if (!updateResult.Succeeded)
                    {
                        throw new Exception(string.Join(", ", updateResult.Errors.Select(e => e.Description)));
                    }

                    // Check if user is OrgAdmin
                    if (await UserManager.IsInRoleAsync(user, "OrgAdmin"))
                    {
                        // Find ANY other users with OrgAdmin role in same organization
                        var otherAdmins = await (
                            from u in Db.Users
                            join ur in Db.UserRoles on u.Id equals ur.UserId
                            join r in Db.Roles on ur.RoleId equals r.Id
                            where u.OrganizationId == user.OrganizationId
                                  && r.Name == "OrgAdmin"
                                  && u.Id != user.Id
                            select u
                        ).ToListAsync();

                        foreach (var oldAdmin in otherAdmins)
                        {
                            // Remove role
                            await UserManager.RemoveFromRoleAsync(oldAdmin, "OrgAdmin");

                            // Deactivate old admin
                            oldAdmin.IsActive = false;
                            await UserManager.UpdateAsync(oldAdmin);
                        }
                    }

                    // Mark invite as used
                    invite.IsUsed = true;
                    await Db.SaveChangesAsync();

                    await transaction.CommitAsync();
                }
                catch (Exception ex)
                {
                    await transaction.RollbackAsync();
                    throw;
                }

                successMessage = "Account activated successfully! Redirecting to login...";
                StateHasChanged();
                await Task.Delay(2000);
                Nav.NavigateTo("/Account/Login", true);
            }
            else
            {
                error = string.Join(", ", passwordResult.Errors.Select(x => x.Description));
            }
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }



    public class SetupModel
    {
        [Required(ErrorMessage = "Password is required")]
        [StringLength(100, MinimumLength = 6, ErrorMessage = "Password must be at least 6 characters")]
        public string Password { get; set; } = string.Empty;
    }
