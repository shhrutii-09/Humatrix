@page "/setup-account"
@layout LoginLayout
@rendermode InteractiveServer

@using Humatrix_HRMS.Components.Account.Shared
@using Humatrix_HRMS.Data
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Forms
@using System.ComponentModel.DataAnnotations
@using Microsoft.EntityFrameworkCore

@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Nav
@inject ApplicationDbContext Db

<PageTitle>Set Password | Humatrix</PageTitle>

<div class="container-fluid vh-100 d-flex align-items-center justify-content-center bg-light">
    <div class="row w-100 shadow-sm"
         style="max-width: 650px; border-radius:20px; overflow:hidden;">

        <div class="col-12 bg-white p-5">
            <div class="text-center mb-4">
                <div class="icon-circle mx-auto mb-3">
                    <i class="bi bi-shield-lock-fill"></i>
                </div>
                <h1 class="fw-bold mb-2">Set Your Password</h1>
                <p class="text-muted fs-5">Please create a secure password for your account.</p>
            </div>

            @if (!string.IsNullOrEmpty(error))
            {
                <div class="alert alert-danger border-0 shadow-sm py-3 mb-4">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    @error
                </div>
            }

            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="alert alert-success border-0 shadow-sm py-3 mb-4">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    @successMessage
                </div>
            }

            <EditForm Model="model" OnValidSubmit="SetPassword" FormName="setupPasswordForm">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger small mb-3" />

                <div class="mb-4">
                    <label class="form-label fw-bold text-secondary fs-5 mb-3">New Password</label>
                    <div class="position-relative">
                        <InputText type="@(showPassword ? "text" : "password")"
                                   @bind-Value="model.Password"
                                   class="form-control custom-input pe-5"
                                   placeholder="Enter password" />
                        <button type="button" class="password-toggle-btn" @onclick="TogglePassword">
                            <i class="bi @(showPassword ? "bi-eye-slash-fill" : "bi-eye-fill")"></i>
                        </button>
                    </div>
                    <ValidationMessage For="() => model.Password" class="text-danger small mt-2 d-block" />
                </div>

                <button type="submit" class="btn submit-btn w-100 py-3 fw-bold fs-5" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        <span>Activating...</span>
                    }
                    else
                    {
                        <span>SUBMIT & ACTIVATE</span>
                    }
                </button>
            </EditForm>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f5f6fa;
    }

    .icon-circle {
        width: 80px;
        height: 80px;
        background: rgba(92, 74, 199, 0.1);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .icon-circle i {
            font-size: 35px;
            color: #5c4ac7;
        }

    .custom-input {
        height: 60px;
        border-radius: 14px;
        border: none;
        background: #f5f5f7;
        font-size: 18px;
        padding-left: 18px;
        padding-right: 55px;
    }

        .custom-input:focus {
            background: #fff;
            border: 1px solid #5c4ac7;
            box-shadow: 0 0 0 0.15rem rgba(92,74,199,.15);
        }

    .password-toggle-btn {
        position: absolute;
        top: 50%;
        right: 18px;
        transform: translateY(-50%);
        border: none;
        background: transparent;
        color: #6c757d;
        font-size: 20px;
        cursor: pointer;
        padding: 0;
    }

        .password-toggle-btn:hover {
            color: #5c4ac7;
        }

    .submit-btn {
        background: #5c4ac7;
        color: white;
        border: none;
        border-radius: 14px;
        transition: 0.3s;
    }

        .submit-btn:hover {
            background: #4b3bb0;
            color: white;
        }
</style>

