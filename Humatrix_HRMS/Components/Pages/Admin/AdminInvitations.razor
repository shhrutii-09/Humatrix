@page "/admin/invitations"
@rendermode InteractiveServer

@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize(Roles = "SuperAdmin")]

@inject OrganizationService OrgService

<PageTitle>Invitations | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">

    
    <div class="mb-4">
        <h2 class="fw-bold">Invitation Management</h2>
        <p class="text-muted small">Track all system invitations and their status.</p>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
            <p class="mt-2 text-muted">Loading invitations...</p>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">

                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 text-muted small">EMAIL</th>
                            <th class="text-muted small">ROLE</th>
                            <th class="text-muted small">ORGANIZATION</th>
                            <th class="text-muted small">STATUS</th>
                            <th class="text-muted small">CREATED</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (!invites.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    No invitations found.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var invite in invites)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold">@invite.Email</td>

                                    <td>
                                        <span class="badge bg-light text-dark border">
                                            @invite.Role
                                        </span>
                                    </td>

                                    <td>
                                        <span class="text-muted small">
                                            @invite.Organization?.Name
                                        </span>
                                    </td>

                                    <td>
                                        <span class="badge @(invite.IsUsed ? "bg-success-subtle text-success" : "bg-warning-subtle text-warning")">
                                            @(invite.IsUsed ? "Used" : "Pending")
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge @(invite.IsUsed
                                                      ? "bg-success-subtle text-success"
                                                      : invite.IsExpired
                                                          ? "bg-danger-subtle text-danger"
                                                          : "bg-warning-subtle text-warning")">

                                @(invite.IsUsed ? "Used" : invite.IsExpired ? "Expired" : "Pending")
                            </span>
                        </td>

                                    <td>
                                        <span class="text-muted small">
                                            @invite.CreatedAt.ToString("dd MMM yyyy")
                                        </span>
                                    </td>
                                </tr>
                            }
                        }

                    </tbody>

                </table>
            </div>
        </div>
    }
</div>

<style>
    .card {
        border-radius: 12px;
    }
</style>

@code {
    private List<UserInvite> invites = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        invites = await OrgService.GetAllInvitationsAsync();
        isLoading = false;
    }
}