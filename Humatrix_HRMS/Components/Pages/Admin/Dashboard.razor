@page "/admin/dashboard"
@rendermode InteractiveServer

@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize(Roles = "SuperAdmin")]

@inject OrganizationService OrgService
@inject NavigationManager Nav

<PageTitle>Dashboard | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">

    <div class="mb-4 pb-2 border-bottom">
        <h2 class="fw-bold tracking-tight text-dark mb-1">Super Admin Dashboard</h2>
        <p class="text-muted small mb-0">Overview and quick actions for platform management.</p>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5 my-5">
            <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status"></div>
            <p class="mt-3 text-muted fw-medium">Loading dashboard...</p>
        </div>
    }
    else
    {
        <div class="row g-4 mb-4">
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm p-4 metric-card">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <h6 class="text-muted small fw-bold text-uppercase mb-2">Total Organizations</h6>
                            <h3 class="fw-bold mb-0 text-dark">@totalOrgs</h3>
                        </div>
                        <div class="icon-shape bg-primary-subtle text-primary rounded-circle fs-3">
                            <i class="bi bi-buildings"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm p-4 metric-card">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <h6 class="text-muted small fw-bold text-uppercase mb-2">Active Organizations</h6>
                            <h3 class="fw-bold mb-0 text-success">@activeOrgs</h3>
                        </div>
                        <div class="icon-shape bg-success-subtle text-success rounded-circle fs-3">
                            <i class="bi bi-check-circle"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm p-4 metric-card">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <h6 class="text-muted small fw-bold text-uppercase mb-2">Inactive Organizations</h6>
                            <h3 class="fw-bold mb-0 text-danger">@inactiveOrgs</h3>
                        </div>
                        <div class="icon-shape bg-danger-subtle text-danger rounded-circle fs-3">
                            <i class="bi bi-x-circle"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm p-4 metric-card">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <h6 class="text-muted small fw-bold text-uppercase mb-2">Total Users</h6>
                            <h3 class="fw-bold mb-0 text-dark">@totalUsers</h3>
                        </div>
                        <div class="icon-shape bg-dark-subtle text-dark rounded-circle fs-3">
                            <i class="bi bi-people"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm p-4 metric-card">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <h6 class="text-muted small fw-bold text-uppercase mb-2">Employees</h6>
                            <h3 class="fw-bold mb-0 text-primary">@totalEmployees</h3>
                        </div>
                        <div class="icon-shape bg-blue-subtle text-blue rounded-circle fs-3">
                            <i class="bi bi-person-workspace"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm p-4 metric-card">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <h6 class="text-muted small fw-bold text-uppercase mb-2">HRs</h6>
                            <h3 class="fw-bold mb-0 text-info">@totalHRs</h3>
                        </div>
                        <div class="icon-shape bg-info-subtle text-info rounded-circle fs-3">
                            <i class="bi bi-shield-lock"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-md-6">
                <div class="card border-0 shadow-sm p-4 action-card h-100" @onclick='() => Nav.NavigateTo("/admin/create-organization")'>
                    <div class="d-flex align-items-start gap-3">
                        <div class="icon-shape bg-primary text-white rounded-3 fs-4 shadow-sm p-3 d-flex align-items-center justify-content-center" style="width:54px; height:54px;">
                            <i class="bi bi-building-add"></i>
                        </div>
                        <div class="w-100">
                            <div class="d-flex align-items-center justify-content-between">
                                <h5 class="fw-bold mb-1 text-dark">Create Organization</h5>
                                <i class="bi bi-arrow-right-short text-muted fs-4 arrow-icon"></i>
                            </div>
                            <p class="text-muted small mb-0">Onboard new organizations into the system.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card border-0 shadow-sm p-4 action-card h-100" @onclick='() => Nav.NavigateTo("/admin/organizations")'>
                    <div class="d-flex align-items-start gap-3">
                        <div class="icon-shape bg-primary text-white rounded-3 fs-4 shadow-sm p-3 d-flex align-items-center justify-content-center" style="width:54px; height:54px;">
                            <i class="bi bi-list-ul"></i>
                        </div>
                        <div class="w-100">
                            <div class="d-flex align-items-center justify-content-between">
                                <h5 class="fw-bold mb-1 text-dark">Manage Organizations</h5>
                                <i class="bi bi-arrow-right-short text-muted fs-4 arrow-icon"></i>
                            </div>
                            <p class="text-muted small mb-0">View, edit, and manage all registered organizations.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-12">
                <div class="card border-0 shadow-sm p-4">
                    <h5 class="fw-bold text-dark mb-3">Recently Added Organization</h5>

                    @if (!recentOrgs.Any())
                    {
                        <p class="text-muted small mb-0">No organizations added today.</p>
                    }
                    else
                    {
                        <div class="d-flex flex-column gap-2">
                            @foreach (var org in recentOrgs)
                            {
                                <div class="d-flex justify-content-between align-items-center p-3 rounded-3 border bg-light-subtle hover-bg-light transition-all">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="icon-shape bg-secondary-subtle text-secondary rounded-circle d-flex align-items-center justify-content-center fs-5" style="width:40px; height:40px;">
                                            <i class="bi bi-building"></i>
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark">@org.Name</div>
                                            <div class="small text-muted"><i class="bi bi-envelope me-1"></i>@org.Email</div>
                                        </div>
                                    </div>

                                    <div class="d-flex align-items-center gap-3">
                                        <span class="status-badge @(org.IsActive ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")">
                                            @(org.IsActive ? "Active" : "Inactive")
                                        </span>

                                        <button class="btn btn-sm btn-white border shadow-sm text-primary rounded-2 px-2.5 py-1.5"
                                                @onclick='() => Nav.NavigateTo($"/admin/organizations/{org.OrganizationId}")'>
                                            <i class="bi bi-eye"></i>
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

<style>
    .card {
        border-radius: 14px;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .metric-card {
        background-color: #ffffff;
    }

    .action-card {
        cursor: pointer;
        background-color: #ffffff;
        border: 1px solid transparent !important;
    }

        .action-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 .5rem 1.5rem rgba(0,0,0,.08) !important;
            border-color: rgba(92, 74, 199, 0.15) !important;
        }

            .action-card:hover .arrow-icon {
                color: #5c4ac7 !important;
                transform: translateX(3px);
            }

    .arrow-icon {
        transition: all 0.2s ease;
    }

    .icon-shape {
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .bg-blue-subtle {
        background-color: #e0f2fe;
    }

    .text-blue {
        color: #0369a1;
    }

    .tracking-tight {
        letter-spacing: -0.025em;
    }

    .status-badge {
        padding: 4px 12px;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
    }

    .btn-white {
        background-color: #ffffff;
        color: #4b5563;
    }

        .btn-white:hover {
            background-color: #f9fafb;
            color: #5c4ac7;
        }

    .hover-bg-light:hover {
        background-color: #f8f9fa;
    }

    .transition-all {
        transition: all 0.15s ease-in-out;
    }

    /* Global Primary override to ensure consistency */
    .bg-primary {
        background-color: #5c4ac7 !important;
    }
</style>

@code {
    private bool isLoading = true;
    private int totalOrgs;
    private int activeOrgs;
    private int inactiveOrgs;
    private int totalUsers;
    private int totalEmployees;
    private int totalHRs;
    private List<Organization> recentOrgs = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboard();
    }

    private async Task LoadDashboard()
    {
        var orgs = await OrgService.GetAllOrganizationsAsync();
        var userStats = await OrgService.GetUserStatsAsync();

        totalOrgs = orgs.Count;
        activeOrgs = orgs.Count(o => o.IsActive);
        inactiveOrgs = orgs.Count(o => !o.IsActive);

        totalUsers = userStats.totalUsers;
        totalEmployees = userStats.totalEmployees;
        totalHRs = userStats.totalHRs;

        recentOrgs = orgs
            .Where(o => o.CreatedAt.Date == DateTime.Today)
            .OrderByDescending(o => o.CreatedAt)
            .Take(5)
            .ToList();

        isLoading = false;
    }
}