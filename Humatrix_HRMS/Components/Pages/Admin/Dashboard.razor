@page "/admin/dashboard"
@rendermode InteractiveServer

@using Humatrix_HRMS.Data
@using Humatrix_HRMS.Models
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore

@attribute [Authorize(Roles = "SuperAdmin")]

@inject ApplicationDbContext _context
@inject NavigationManager Nav

<PageTitle>Organizations | SuperAdmin</PageTitle>

<div class="container-fluid px-4 mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark m-0">Organizations</h2>
            <p class="text-muted small mb-0">Overview and management of all registered companies.</p>
        </div>
        <button class="btn btn-primary shadow-sm px-4 fw-bold py-2" @onclick='() => Nav.NavigateTo("/admin/create-organization")'>
            <i class="bi bi-plus-lg me-2"></i>ADD ORGANIZATION
        </button>
    </div>

    <div class="row mb-4 align-items-center g-3">
        <div class="col-md-8">
            <div class="d-flex gap-3">
                <div class="d-inline-flex align-items-center bg-white border shadow-sm px-3 py-2 rounded-pill">
                    <span class="text-muted small fw-bold me-2">Total Entities:</span>
                    <span class="badge bg-primary rounded-pill">@organizations.Count</span>
                </div>

                <div class="d-inline-flex align-items-center bg-white border shadow-sm px-3 py-2 rounded-pill">
                    <span class="text-muted small fw-bold me-2 text-success">Active:</span>
                    <span class="badge bg-success rounded-pill">@ActiveCount</span>
                </div>
            </div>
        </div>
        <div class="col-md-4 ms-auto">
            <div class="input-group bg-white border rounded-pill px-3 shadow-sm">
                <span class="input-group-text bg-transparent border-0"><i class="bi bi-search text-muted"></i></span>
                <input type="text" class="form-control border-0 shadow-none bg-transparent py-2"
                       placeholder="Search by name or email..."
                       @bind="searchTerm" @bind:event="oninput" />
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr class="text-muted small text-uppercase">
                            <th class="ps-4 border-0 py-3" style="width: 25%;">Organization</th>
                            <th class="border-0 py-3" style="width: 25%;">Contact Email</th>
                            <th class="border-0 py-3" style="width: 15%;">Phone</th>
                            <th class="border-0 py-3 text-center" style="width: 10%;">Status</th>
                            <th class="border-0 py-3 text-end pe-4" style="width: 25%;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!FilteredOrganizations.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5">
                                    <i class="bi bi-inbox text-muted fs-1 d-block mb-2"></i>
                                    <span class="text-muted">No records found matching your criteria.</span>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var org in FilteredOrganizations)
                            {
                                <tr class="border-bottom-custom">
                                    <td class="ps-4 py-3">
                                        <div class="fw-bold text-dark">@org.Name</div>
                                        <div class="text-muted x-small">ID: @org.OrganizationId.ToString().Substring(0, 8)...</div>
                                    </td>
                                    <td class="py-3 text-muted">@org.Email</td>
                                    <td class="py-3 text-muted">@org.Phone</td>
                                    <td class="py-3 text-center">
                                        <span class="status-badge @(org.IsActive ? "active" : "inactive")">
                                            <i class="bi bi-circle-fill me-1" style="font-size: 8px;"></i>
                                            @(org.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td class="py-3 text-end pe-4">
                                        <div class="d-flex justify-content-end gap-2">
                                            <button class="btn btn-sm btn-action-edit px-3 rounded-pill"
                                                    @onclick="() => StartEdit(org)">
                                                <i class="bi bi-pencil-square me-1"></i> Edit
                                            </button>

                                            @if (org.IsActive)
                                            {
                                                <button class="btn btn-sm btn-action-deactivate px-3 rounded-pill"
                                                        @onclick="() => ToggleStatus(org)">
                                                    <i class="bi bi-slash-circle me-1"></i> Deactivate
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-sm btn-action-activate px-3 rounded-pill"
                                                        @onclick="() => ToggleStatus(org)">
                                                    <i class="bi bi-check-circle me-1"></i> Activate
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (editOrg != null)
    {
        <div class="mt-4 p-4 card border-0 shadow-lg rounded-4 border-top border-primary border-4 animate-in">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="fw-bold m-0 text-primary">Edit Organization Details</h4>
                <button class="btn-close" @onclick="CancelEdit"></button>
            </div>

            <EditForm Model="editOrg" OnValidSubmit="UpdateOrganization">
                <DataAnnotationsValidator />
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label small fw-bold">Organization Name</label>
                        <InputText @bind-Value="editOrg.Name" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-bold">Official Email</label>
                        <InputText @bind-Value="editOrg.Email" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-bold">Phone Number</label>
                        <InputText @bind-Value="editOrg.Phone" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label class="form-label small fw-bold">Full Address</label>
                        <InputTextArea @bind-Value="editOrg.Address" class="form-control" rows="2" />
                    </div>
                </div>
                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-5 py-2 fw-bold">UPDATE DATA</button>
                    <button type="button" class="btn btn-light px-4 py-2" @onclick="CancelEdit">DISCARD</button>
                </div>
            </EditForm>
        </div>
    }

</div>

<style>
    :root {
        --main-purple: #5c4df2;
        --bg-light: #f4f7fe;
    }

    body {
        background-color: var(--bg-light);
    }

    .btn-primary {
        background-color: var(--main-purple);
        border: none;
    }

        .btn-primary:hover {
            background-color: #4a3dd1;
        }

    .status-badge {
        font-size: 11px;
        font-weight: 700;
        padding: 6px 14px;
        border-radius: 20px;
        text-transform: uppercase;
        display: inline-flex;
        align-items: center;
    }

        .status-badge.active {
            background-color: #e6f4ea;
            color: #1e7e34;
        }

        .status-badge.inactive {
            background-color: #fce8e6;
            color: #d93025;
        }

    .btn-action-edit {
        color: var(--main-purple);
        border: 1px solid var(--main-purple);
        background: transparent;
        transition: 0.3s;
    }

        .btn-action-edit:hover {
            background: var(--main-purple);
            color: white;
        }

    .btn-action-deactivate {
        color: #d93025;
        border: 1px solid #d93025;
        background: transparent;
        transition: 0.3s;
    }

        .btn-action-deactivate:hover {
            background: #d93025;
            color: white;
        }

    .btn-action-activate {
        color: #1e7e34;
        border: 1px solid #1e7e34;
        background: transparent;
        transition: 0.3s;
    }

        .btn-action-activate:hover {
            background: #1e7e34;
            color: white;
        }

    .border-bottom-custom {
        border-bottom: 1px solid #f0f0f5 !important;
    }

    .x-small {
        font-size: 10px;
    }

    .animate-in {
        animation: fadeInUp 0.4s ease-out;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

@code {
    private List<Organization> organizations = new();
    private Organization? editOrg;
    private string searchTerm = "";

    // Stats Logic
    private int ActiveCount => organizations.Count(o => o.IsActive);

    private IEnumerable<Organization> FilteredOrganizations =>
        organizations.Where(o => string.IsNullOrWhiteSpace(searchTerm) ||
                                 o.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                                 o.Email.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync() => await LoadOrganizations();

    private async Task LoadOrganizations()
    {
        organizations = await _context.Organizations.AsNoTracking().ToListAsync();
    }

    private void StartEdit(Organization org)
    {
        editOrg = new Organization
        {
            OrganizationId = org.OrganizationId,
            Name = org.Name,
            Email = org.Email,
            Phone = org.Phone,
            Address = org.Address,
            IsActive = org.IsActive
        };
    }

    private async Task UpdateOrganization()
    {
        var dbOrg = await _context.Organizations.FindAsync(editOrg!.OrganizationId);
        if (dbOrg != null)
        {
            dbOrg.Name = editOrg.Name; dbOrg.Email = editOrg.Email;
            dbOrg.Phone = editOrg.Phone; dbOrg.Address = editOrg.Address;
            await _context.SaveChangesAsync();
        }
        editOrg = null;
        await LoadOrganizations();
    }

    private void CancelEdit() => editOrg = null;

    private async Task ToggleStatus(Organization org)
    {
        var dbOrg = await _context.Organizations.FindAsync(org.OrganizationId);
        if (dbOrg != null)
        {
            dbOrg.IsActive = !dbOrg.IsActive;
            await _context.SaveChangesAsync();
        }
        await LoadOrganizations();
    }
}