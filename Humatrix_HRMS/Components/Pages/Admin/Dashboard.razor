@page "/admin/dashboard"
@rendermode InteractiveServer

@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize(Roles = "SuperAdmin")]

@inject OrganizationService OrgService
@inject NavigationManager Nav

<PageTitle>Dashboard | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">

    @* Header *@
    <div class="mb-4">
        <h2 class="fw-bold">Super Admin Dashboard</h2>
        <p class="text-muted small">Overview and quick actions for platform management.</p>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
            <p class="mt-2 text-muted">Loading dashboard...</p>
        </div>
    }
    else
    {
        @* ===== STATS ===== *@
        <div class="row g-4 mb-4">

            <div class="col-md-4">
                <div class="card border-0 shadow-sm p-4 border-start border-primary border-4">
                    <h6 class="text-muted small fw-bold text-uppercase">Total Organizations</h6>
                    <h3 class="fw-bold mb-0">@totalOrgs</h3>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 shadow-sm p-4 border-start border-success border-4">
                    <h6 class="text-muted small fw-bold text-uppercase">Active Organizations</h6>
                    <h3 class="fw-bold mb-0">@activeOrgs</h3>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 shadow-sm p-4 border-start border-danger border-4">
                    <h6 class="text-muted small fw-bold text-uppercase">Inactive Organizations</h6>
                    <h3 class="fw-bold mb-0">@inactiveOrgs</h3>
                </div>
            </div>

        </div>

        <div class="row g-4 mb-4">

            <div class="col-md-4">
                <div class="card border-0 shadow-sm p-4 border-start border-dark border-4">
                    <h6 class="text-muted small fw-bold text-uppercase">Total Users</h6>
                    <h3 class="fw-bold mb-0">@totalUsers</h3>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 shadow-sm p-4 border-start border-primary border-4">
                    <h6 class="text-muted small fw-bold text-uppercase">Employees</h6>
                    <h3 class="fw-bold mb-0">@totalEmployees</h3>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 shadow-sm p-4 border-start border-info border-4">
                    <h6 class="text-muted small fw-bold text-uppercase">HRs</h6>
                    <h3 class="fw-bold mb-0">@totalHRs</h3>
                </div>
            </div>

        </div>

        @* ===== QUICK ACTIONS ===== *@
        <div class="row g-4 mb-4">

            <div class="col-md-6">
                <div class="card border-0 shadow-sm p-4 h-100 text-center"
                     style="cursor:pointer"
                     @onclick='() => Nav.NavigateTo("/admin/create-organization")'>

                    <div class="mb-3">
                        <i class="bi bi-building-add fs-2 text-primary"></i>
                    </div>

                    <h5 class="fw-bold">Create Organization</h5>
                    <p class="text-muted small mb-0">Onboard a new company into the system</p>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card border-0 shadow-sm p-4 h-100 text-center"
                     style="cursor:pointer"
                     @onclick='() => Nav.NavigateTo("/admin/organizations")'>

                    <div class="mb-3">
                        <i class="bi bi-list-ul fs-2 text-success"></i>
                    </div>

                    <h5 class="fw-bold">Manage Organizations</h5>
                    <p class="text-muted small mb-0">View, edit and manage all organizations</p>
                </div>
            </div>

        </div>

        @* ===== RECENT ORGANIZATIONS (DASHBOARD STYLE, NOT TABLE) ===== *@
        <div class="card border-0 shadow-sm p-4">
            <h5 class="fw-bold mb-3">Recently Added Organizations</h5>

            @if (!recentOrgs.Any())
            {
                <p class="text-muted small mb-0">No organizations found.</p>
            }
            else
            {
                @foreach (var org in recentOrgs)
                {
                    <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                        <div>
                            <div class="fw-bold">@org.Name</div>
                            <div class="small text-muted">@org.Email</div>
                        </div>

                        <div class="d-flex align-items-center gap-2">
                            <span class="badge @(org.IsActive ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")">
                                @(org.IsActive ? "Active" : "Inactive")
                            </span>

                            <button class="btn btn-sm btn-light border text-primary"
                                    @onclick='() => Nav.NavigateTo($"/admin/organizations/{org.OrganizationId}")'>
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                    </div>
                }
            }
        </div>
    }
</div>

<style>
    .card {
        border-radius: 12px;
    }

    .border-start {
        border-left-width: 4px !important;
    }
</style>

@code {
    private bool isLoading = true;

    private int totalOrgs;
    private int activeOrgs;
    private int inactiveOrgs;

    private int totalUsers;
    private int totalEmployees;
    private int totalHRs;

    private List<Organization> recentOrgs = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboard();
    }

    private async Task LoadDashboard()
    {
        var orgs = await OrgService.GetAllOrganizationsAsync();
        var userStats = await OrgService.GetUserStatsAsync();

        totalOrgs = orgs.Count;
        activeOrgs = orgs.Count(o => o.IsActive);
        inactiveOrgs = orgs.Count(o => !o.IsActive);

        totalUsers = userStats.totalUsers;
        totalEmployees = userStats.totalEmployees;
        totalHRs = userStats.totalHRs;

        recentOrgs = orgs
            .OrderByDescending(o => o.CreatedAt)
            .Take(5)
            .ToList();

        isLoading = false;
    }
}