@page "/admin/organizations/{id:guid}/departments"
@rendermode InteractiveServer

@using Humatrix_HRMS.Models
@using Humatrix_HRMS.DTOs
@using Humatrix_HRMS.Services
@using Humatrix_HRMS.Data
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore

@attribute [Authorize(Roles = "SuperAdmin")]

@inject OrganizationService OrgService
@inject EmployeeService EmpService
@inject NavigationManager Nav
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Departments - @orgName</PageTitle>

<div class="container-fluid px-4 mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-normal">Departments</h2>
            <nav aria-label="breadcrumb">
                <small class="text-muted">Organization: <span class="fw-bold">@orgName</span></small>
            </nav>
        </div>
        <button class="btn btn-interactive-back shadow-sm"
                @onclick='() => Nav.NavigateTo($"/admin/organizations/{id}")'>
            <i class="bi bi-arrow-left"></i> BACK TO DETAILS
        </button>
    </div>

    @if (_departments == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <div class="mt-2 text-muted">Loading departments list...</div>
        </div>
    }
    else
    {
        <div class="row g-3 mb-4 align-items-center">
            <div class="col-md-6">
                <div class="input-group shadow-sm">
                    <span class="input-group-text bg-white border-end-0 text-muted">
                        <i class="bi bi-search"></i>
                    </span>
                    <input type="text"
                           class="form-control border-start-0"
                           placeholder="Search department by name..."
                           @bind="_searchQuery"
                           @bind:event="oninput" />
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(_searchQuery))
            {
                <div class="col-md-3">
                    <button class="btn btn-link text-decoration-none text-danger p-0" @onclick="ClearFilters">
                        <i class="bi bi-x-circle-fill me-1"></i> Clear Filter
                    </button>
                </div>
            }
        </div>

        @if (!GetFilteredDepartments().Any())
        {
            <div class="alert alert-info text-center shadow-sm border-0 py-4">
                <i class="bi bi-info-circle-fill fs-4 me-2 align-middle"></i>
                No matching department records found.
            </div>
        }
        else
        {
            <div class="card shadow-sm border-0 p-4 mb-4">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th scope="col" class="ps-3">Department Name</th>
                                <th scope="col" class="text-center">Total Staff Count</th>
                                <th scope="col" class="text-center">System Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var dept in GetFilteredDepartments())
                            {
                                <tr>
                                    <td class="fw-bold ps-3">
                                        <i class="bi bi-building me-2 text-muted"></i> @dept.DepartmentName
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-secondary-subtle text-secondary px-3 py-2 fs-7">
                                            @dept.TotalStaff Members
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <span class="status-badge-compact active-badge">
                                            <i class="bi bi-check-circle-fill me-1"></i> Active
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
</div>

<style>
    /* Button Style consistent with Details page */
    .btn-interactive-back {
        background: #ffffff !important;
        border: 1px solid #e5e7eb !important;
        color: #4b5563 !important;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
        transition: all 0.2s ease;
    }

        .btn-interactive-back:hover {
            background-color: #f8fafc !important;
            border-color: #5c4ac7 !important;
            color: #5c4ac7 !important;
            transform: translateY(-1px);
        }

    .card {
        border-radius: 12px;
    }

    .table th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.5px;
        color: #6c757d;
    }

    .fs-7 {
        font-size: 0.85rem;
    }

    .status-badge-compact {
        padding: 5px 12px;
        border-radius: 50px;
        font-size: 0.78rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
    }

    .active-badge {
        background: linear-gradient(135deg, #d1fae5, #ecfdf5);
        color: #047857;
        border: 1px solid #a7f3d0;
    }

    .input-group-text, .form-control {
        border-radius: 8px;
        padding: 0.75rem 1rem;
    }

        .form-control:focus {
            border-color: #5c4ac7;
            box-shadow: 0 0 0 0.2rem rgba(92, 74, 199, 0.1);
        }
</style>

@code {
    [Parameter] public Guid id { get; set; }
    private List<DepartmentSummaryDto>? _departments;
    private string orgName = "Loading...";
    private string _searchQuery = string.Empty;

    public class DepartmentSummaryDto
    {
        public string DepartmentName { get; set; } = string.Empty;
        public int TotalStaff { get; set; }
    }

    protected override async Task OnInitializedAsync() => await LoadOrganizationDepartments();

    private async Task LoadOrganizationDepartments()
    {
        try
        {
            var result = await OrgService.GetOrganizationDetailsAsync(id);
            if (result.Organization == null) { Nav.NavigateTo("/admin/organizations"); return; }
            orgName = result.Organization.Name;

            var rawEmployees = await EmpService.GetEmployeesByOrganizationIdAsync(id);
            var employeeCountMap = rawEmployees
                .Where(x => x != null && !string.IsNullOrWhiteSpace(x.Department) && x.Department != "N/A")
                .GroupBy(x => x.Department!.Trim().ToLower())
                .ToDictionary(g => g.Key, g => g.Count());

            using var context = await DbFactory.CreateDbContextAsync();
            var structuralDepartments = await context.Departments
                .Where(x => x.OrganizationId == id)
                .OrderByDescending(x => x.CreatedAt)
                .ToListAsync();

            _departments = structuralDepartments
                .Where(d => d != null && !string.IsNullOrWhiteSpace(d.Name))
                .Select(d =>
                {
                    var cleanName = d.Name.Trim();
                    return new DepartmentSummaryDto
                    {
                        DepartmentName = cleanName,
                        TotalStaff = employeeCountMap.TryGetValue(cleanName.ToLower(), out var count) ? count : 0
                    };
                }).ToList();
        }
        catch { Nav.NavigateTo("/admin/organizations"); }
    }

    private IEnumerable<DepartmentSummaryDto> GetFilteredDepartments()
    {
        if (_departments == null) return Enumerable.Empty<DepartmentSummaryDto>();
        if (!string.IsNullOrWhiteSpace(_searchQuery))
        {
            var cleanSearch = _searchQuery.Trim().ToLower();
            return _departments.Where(x => x.DepartmentName.ToLower().Contains(cleanSearch));
        }
        return _departments;
    }

    private void ClearFilters() => _searchQuery = string.Empty;
}