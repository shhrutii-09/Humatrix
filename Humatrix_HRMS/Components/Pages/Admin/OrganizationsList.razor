@page "/admin/organizations"
@rendermode InteractiveServer

@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize(Roles = "SuperAdmin")]

@inject OrganizationService OrgService
@inject NavigationManager Nav

<PageTitle>Organizations | Humatrix HRMS</PageTitle>

@* Toast Notifications *@
<div class="position-fixed top-0 end-0 p-3" style="z-index: 1080;">
    @if (!string.IsNullOrEmpty(message))
    {
        <div class="toast show align-items-center border-0 shadow-lg mb-2" role="alert" style="background-color: #f0fdf4; color: #166534; border-left: 4px solid #10b981 !important; border-radius: 10px;">
            <div class="d-flex p-3">
                <div class="toast-body d-flex align-items-center p-0">
                    <i class="bi bi-check-circle-fill me-2 fs-5" style="color: #10b981;"></i>
                    <span class="small fw-medium">@message</span>
                </div>
                <button type="button" class="btn-close m-auto me-0 shadow-none" @onclick="() => message = null"></button>
            </div>
        </div>
    }
    @if (!string.IsNullOrEmpty(error))
    {
        <div class="toast show align-items-center border-0 shadow-lg mb-2" role="alert" style="background-color: #fef2f2; color: #991b1b; border-left: 4px solid #ef4444 !important; border-radius: 10px;">
            <div class="d-flex p-3">
                <div class="toast-body d-flex align-items-center p-0">
                    <i class="bi bi-exclamation-triangle-fill me-2 fs-5" style="color: #ef4444;"></i>
                    <span class="small fw-medium"><strong>Error:</strong> @error</span>
                </div>
                <button type="button" class="btn-close m-auto me-0 shadow-none" @onclick="() => error = null"></button>
            </div>
        </div>
    }
</div>

<div class="container-fluid px-4 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom row-gap-3 flex-wrap">
        <div>
            <h2 class="fw-bold tracking-tight text-dark mb-1">Organization Management</h2>
            <p class="text-muted small mb-0">Oversee system-wide organization profiles and business units.</p>
        </div>
        <button class="btn btn-interactive-back shadow-sm" @onclick='() => Nav.NavigateTo("/admin/dashboard")'>
            <i class="bi bi-speedometer2"></i> DASHBOARD
        </button>
    </div>

    @* Search Bar *@
    <div class="mb-4 position-relative search-wrapper" style="max-width: 450px;">
        <i class="bi bi-search search-icon text-muted"></i>
        <input type="text" class="form-control premium-search-input" placeholder="Search organization by name or email..." @bind="searchTerm" @bind:event="oninput" />
    </div>

    @* Table View *@
    <div class="card border-0 shadow-sm panel-container-card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4 text-secondary small fw-bold tracking-wider py-3">ORGANIZATION NAME</th>
                        <th class="text-secondary small fw-bold tracking-wider py-3">Email and Contact</th>
                        <th class="text-secondary small fw-bold tracking-wider py-3">ADDRESS</th>
                        <th class="text-secondary small fw-bold tracking-wider py-3 text-center" style="width: 180px;">STATUS</th>
                        <th class="text-secondary small fw-bold tracking-wider py-3 text-end pe-4" style="width: 160px;">ACTIONS</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var org in FilteredOrganizations)
                    {
                        <tr class="table-row-interactive">
                            <td class="ps-4 fw-bold text-dark">@org.Name</td>
                            <td>
                                <div class="small text-dark">@org.Email</div>
                                <div class="small text-muted">@org.Phone</div>
                            </td>
                            <td><span class="small text-muted">@(string.IsNullOrEmpty(org.Address) ? "—" : org.Address)</span></td>
                            <td class="text-center">
                                <div class="form-check form-switch d-inline-flex align-items-center gap-2 justify-content-center protocol-switch">
                                    <input class="form-check-input shadow-none" type="checkbox" checked="@org.IsActive" @onchange="() => ToggleStatus(org)" />
                                    <span class="status-indicator-pill @(org.IsActive ? "pill-active" : "pill-inactive")">
                                        @(org.IsActive ? "Active" : "Inactive")
                                    </span>
                                </div>
                            </td>
                            <td class="text-end pe-4">
                                <button class="btn btn-sm btn-action-edit me-1" @onclick="() => StartEdit(org)"><i class="bi bi-pencil-square"></i></button>
                                <button class="btn btn-sm btn-action-edit" @onclick='() => Nav.NavigateTo($"/admin/organizations/{org.OrganizationId}")'><i class="bi bi-eye"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* Edit Modal *@
@if (editOrg != null)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.4); backdrop-filter: blur(4px);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 12px;">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Edit Organization Profile</h5>
                    <button type="button" class="btn-close shadow-none" @onclick="CancelEdit"></button>
                </div>
                <div class="modal-body p-4">
                    <EditForm Model="editOrg" OnValidSubmit="UpdateOrganization">
                        <DataAnnotationsValidator />
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label small fw-bold">Organization Name</label>
                                <InputText @bind-Value="editOrg.Name" class="form-control premium-edit-input" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold">Official Email</label>
                                <InputText @bind-Value="editOrg.Email" class="form-control premium-edit-input" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold">Phone Number</label>
                                <InputText @bind-Value="editOrg.Phone" class="form-control premium-edit-input" />
                            </div>
                            <div class="col-12">
                                <label class="form-label small fw-bold">Full Address</label>
                                <InputTextArea @bind-Value="editOrg.Address" class="form-control premium-edit-input" rows="2" />
                            </div>
                        </div>
                        <div class="mt-4 pt-3 border-top d-flex justify-content-end gap-2">
                            <button type="button" class="btn btn-action-cancel" @onclick="CancelEdit">Discard</button>
                            <button type="submit" class="btn btn-action-save">Save Changes</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

<style>
    /* Reuse Department Styles */
    .panel-container-card {
        border-radius: 14px;
        background-color: #ffffff;
        overflow: hidden;
    }

    .search-wrapper {
        max-width: 450px;
    }

    .search-icon {
        position: absolute;
        top: 50%;
        left: 14px;
        transform: translateY(-50%);
        font-size: 14px;
    }

    .premium-search-input {
        padding: 10px 40px;
        font-size: 13.5px;
        border-radius: 10px;
        border: 1px solid #cbd5e1;
    }

    .table-row-interactive:hover {
        background-color: #f8fafc;
    }

    .btn-interactive-back {
        background: #ffffff !important;
        border: 1px solid #e5e7eb !important;
        color: #4b5563 !important;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
    }

    .btn-action-edit {
        background: #f1f5f9;
        border: 1px solid #e2e8f0;
        color: #475569;
        border-radius: 8px;
        padding: 5px 10px;
    }

    .btn-action-save {
        background-color: #10b981;
        color: white;
        border: none;
        border-radius: 6px;
        padding: 6px 16px;
        font-size: 12.5px;
        font-weight: 500;
    }

    .btn-action-cancel {
        background-color: #f1f5f9;
        color: #475569;
        border: 1px solid #e2e8f0;
        border-radius: 6px;
        padding: 6px 16px;
        font-size: 12.5px;
    }

    .status-indicator-pill {
        font-size: 11px;
        font-weight: 600;
        padding: 2px 8px;
        border-radius: 6px;
        min-width: 60px;
    }

    .pill-active {
        background-color: #ecfdf5;
        color: #065f46;
    }

    .pill-inactive {
        background-color: #fef2f2;
        color: #991b1b;
    }

    .protocol-switch .form-check-input:checked {
        background-color: #10b981;
    }
</style>

@code {
    private List<Organization> organizations = new();
    private Organization? editOrg;
    private string searchTerm = "";
    private string? message;
    private string? error;

    private IEnumerable<Organization> FilteredOrganizations =>
        organizations.Where(o => string.IsNullOrWhiteSpace(searchTerm) || o.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
                     .OrderByDescending(o => o.CreatedAt);

    protected override async Task OnInitializedAsync() => await LoadOrganizations();

    private async Task LoadOrganizations() => organizations = (await OrgService.GetAllOrganizationsAsync()).OrderByDescending(o => o.CreatedAt).ToList();

    private void StartEdit(Organization org) => editOrg = new Organization { OrganizationId = org.OrganizationId, Name = org.Name, Email = org.Email, Phone = org.Phone, Address = org.Address, IsActive = org.IsActive };
    private void CancelEdit() => editOrg = null;

    private async Task UpdateOrganization()
    {
        try
        {
            await OrgService.UpdateOrganizationAsync(editOrg!);
            message = "Organization updated successfully!";
            editOrg = null;
            await LoadOrganizations();
        }
        catch (Exception ex) { error = ex.Message; }
    }

    private async Task ToggleStatus(Organization org)
    {
        try
        {
            await OrgService.ToggleOrganizationStatusAsync(org.OrganizationId);
            message = "Status updated successfully.";
            await LoadOrganizations();
        }
        catch (Exception ex) { error = ex.Message; }
    }
}