@page "/admin/organizations"
@rendermode InteractiveServer

@using Humatrix_HRMS.Models
@using Humatrix_HRMS.Services
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize(Roles = "SuperAdmin")]

@inject OrganizationService OrgService
@inject NavigationManager Nav

<PageTitle>Organizations | Humatrix HRMS</PageTitle>

<div class="container-fluid px-4 mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-normal">Organization Management</h2>
        </div>

        <button class="btn btn-primary shadow-sm"
                style="background-color: #5c4ac7; border: none;"
                @onclick='() => Nav.NavigateTo("/admin/dashboard")'>
            BACK TO DASHBOARD
        </button>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-3">
            <div class="row g-3 align-items-center">

                <div class="col-md-5">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 text-muted">
                            <i class="bi bi-search"></i>
                        </span>

                        <input class="form-control border-start-0 shadow-none"
                               placeholder="Search by name or email..."
                               @bind="searchTerm"
                               @bind:event="oninput" />
                    </div>
                </div>

                <div class="col-md-7 text-end">
                    <div class="d-inline-flex gap-3">

                        <div class="px-3 py-1 bg-light rounded-pill border">
                            <span class="text-muted small fw-bold">TOTAL:</span>
                            <span class="ms-1 fw-bold text-dark">@organizations.Count</span>
                        </div>

                        <div class="px-3 py-1 bg-light rounded-pill border">
                            <span class="text-success small fw-bold">ACTIVE:</span>
                            <span class="ms-1 fw-bold text-success">@ActiveCount</span>
                        </div>

                    </div>
                </div>

            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 border-0 text-muted small">NAME</th>
                        <th class="border-0 text-muted small">EMAIL AND CONTACT</th>
                        <th class="border-0 text-muted small">ADDRESS</th>
                        <th class="border-0 text-muted small text-center">STATUS</th>
                        <th class="border-0 text-muted small text-end pe-4">ACTIONS</th>
                    </tr>
                </thead>

                <tbody>

                    @if (!FilteredOrganizations.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <i class="bi bi-building text-muted display-4 d-block mb-3"></i>
                                <span class="text-muted">No organizations found.</span>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var org in FilteredOrganizations)
                        {
                            <tr>

                                <td class="ps-4">
                                    <div class="d-flex align-items-center">

                                        <div class="avatar-sm me-3 bg-light d-flex align-items-center justify-content-center rounded-circle fw-bold"
                                             style="width: 40px; height: 40px; border: 1px solid #eee; color: #5c4ac7;">
                                            @org.Name[0]
                                        </div>

                                        <div>
                                            <div class="fw-bold mb-0">@org.Name</div>

                                            <div class="small text-muted" style="font-size: 10px;">
                                                ID: @org.OrganizationId.ToString().Substring(0, 8)
                                            </div>
                                        </div>

                                    </div>
                                </td>

                                <td>
                                    <div class="small text-dark">@org.Email</div>
                                    <div class="small text-muted">@org.Phone</div>
                                </td>

                                <td>
                                    <span class="text-muted small">
                                        @(org.Address?.Length > 30
                                                                        ? org.Address.Substring(0, 30) + "..."
                                                                        : org.Address)
                            </span>
                        </td>

                                <td class="text-center">
                                    <div class="form-check form-switch d-flex justify-content-center align-items-center gap-2">

                                        @* Updated configuration to utilize native Blazor server-side status synchronization *@
                                        <input class="form-check-input shadow-none"
                                               type="checkbox"
                                               @bind="org.IsActive"
                                               @bind:after="() => ToggleStatus(org)">

                                        <span class="small @(org.IsActive ? "text-success" : "text-danger")"
                                              style="min-width: 50px; text-align: left;">
                                            @(org.IsActive ? "Active" : "Inactive")
                                        </span>

                                    </div>
                                </td>

                                <td class="text-end pe-4">

                                    <button class="btn btn-sm btn-light border text-primary"
                                            title="Edit Organization"
                                            @onclick="() => StartEdit(org)">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>

                                    <button class="btn btn-sm btn-light border text-info me-1"
                                            title="View Details"
                                            @onclick='() => Nav.NavigateTo($"/admin/organizations/{org.OrganizationId}")'>
                                        <i class="bi bi-eye"></i>
                                    </button>

                                </td>

                            </tr>
                                        }
                    }

                </tbody>

            </table>

        </div>
    </div>

</div>

@if (editOrg != null)
{
    <div class="modal fade show d-block"
         style="background: rgba(0,0,0,0.4); backdrop-filter: blur(4px);"
         tabindex="-1">

        <div class="modal-dialog modal-dialog-centered modal-lg">

            <div class="modal-content border-0 shadow-lg"
                 style="border-radius: 12px;">

                <div class="modal-header border-0 pb-0">

                    <h5 class="modal-title fw-bold">
                        Edit Organization Profile
                    </h5>

                    <button type="button"
                            class="btn-close shadow-none"
                            @onclick="CancelEdit">
                    </button>

                </div>

                <div class="modal-body p-4">

                    <EditForm Model="editOrg"
                              OnValidSubmit="UpdateOrganization">

                        <DataAnnotationsValidator />

                        <div class="row g-3">

                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted">
                                    Organization Name
                                </label>

                                <InputText @bind-Value="editOrg.Name"
                                           class="form-control bg-light" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted">
                                    Official Email
                                </label>

                                <InputText @bind-Value="editOrg.Email"
                                           class="form-control bg-light" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted">
                                    Phone Number
                                </label>

                                <InputText @bind-Value="editOrg.Phone"
                                           class="form-control bg-light" />
                            </div>

                            <div class="col-12">
                                <label class="form-label small fw-bold text-muted">
                                    Full Address
                                </label>

                                <InputTextArea @bind-Value="editOrg.Address"
                                               class="form-control bg-light"
                                               rows="2" />
                            </div>

                        </div>

                        <div class="mt-4 pt-3 border-top d-flex justify-content-end gap-2">

                            <button type="button"
                                    class="btn btn-light"
                                    @onclick="CancelEdit">
                                Discard
                            </button>

                            <button type="submit"
                                    class="btn btn-primary px-4"
                                    style="background-color: #5c4ac7; border: none;">
                                Save Changes
                            </button>

                        </div>

                    </EditForm>

                </div>
            </div>
        </div>
    </div>
}

<style>
    .form-switch .form-check-input {
        width: 2.5em;
        height: 1.25em;
        cursor: pointer;
    }

        .form-switch .form-check-input:checked {
            background-color: #5c4ac7;
            border-color: #5c4ac7;
        }

    .form-control:focus {
        border-color: #5c4ac7;
        box-shadow: 0 0 0 0.2rem rgba(92, 74, 199, 0.1);
    }

    .bg-light {
        background-color: #f8f9fa !important;
    }
</style>

@code {

    private List<Organization> organizations = new();

    private Organization? editOrg;

    private string searchTerm = "";

    private int ActiveCount =>
        organizations.Count(o => o.IsActive);

    // ✅ Keeps filtered data cleanly displayed with newest creations at the top
    private IEnumerable<Organization> FilteredOrganizations =>
        organizations
            .Where(o =>
                string.IsNullOrWhiteSpace(searchTerm)
                || o.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)
                || o.Email.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(o => o.CreatedAt); // <-- Sorts sequentially by date added

    protected override async Task OnInitializedAsync()
    {
        await LoadOrganizations();
    }

    // ✅ Primary data load sorted chronologically (Latest records hit the top lines first)
    private async Task LoadOrganizations()
    {
        organizations = (await OrgService.GetAllOrganizationsAsync())
            .OrderByDescending(o => o.CreatedAt) // <-- Sorts sequentially by date added
            .ToList();
    }

    private void StartEdit(Organization org)
    {
        editOrg = new Organization
        {
            OrganizationId = org.OrganizationId,
            Name = org.Name,
            Email = org.Email,
            Phone = org.Phone,
            Address = org.Address,
            IsActive = org.IsActive
        };
    }

    private async Task UpdateOrganization()
    {
        await OrgService.UpdateOrganizationAsync(editOrg!);

        editOrg = null;

        await LoadOrganizations();
    }

    private void CancelEdit()
    {
        editOrg = null;
    }

    private async Task ToggleStatus(Organization org)
    {
        await OrgService.ToggleOrganizationStatusAsync(org.OrganizationId);

        await LoadOrganizations();
    }

}