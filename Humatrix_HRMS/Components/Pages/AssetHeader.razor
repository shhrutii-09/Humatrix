@using Humatrix_HRMS.Infrastructure.Constants

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">

    <div>
        <h3 class="fw-bold mb-1">Asset Inventory</h3>

        <p class="text-muted mb-0 small">
            @Subtitle
        </p>
    </div>

    <div class="d-flex flex-wrap gap-2">

        @if (IsOrgAdmin)
        {
            <a href="/orgadmin/asset-analytics"
               class="btn btn-light border shadow-sm">
                <i class="bi bi-bar-chart-line me-2"></i>
                Analytics
            </a>
        }

        @if (IsOrgAdmin)
        {
            <button class="btn btn-primary shadow-sm"
                    @onclick="OnAddAsset">

                <i class="bi bi-plus-lg me-2"></i>
                Add Asset
            </button>
        }

        @if (IsHr)
        {
            <button class="btn btn-warning shadow-sm"
                    @onclick="OnRequestAsset">

                <i class="bi bi-box-seam me-2"></i>
                Request Asset
            </button>
        }

    </div>

</div>

@code {

    [Parameter]
    public bool IsOrgAdmin { get; set; }

    [Parameter]
    public bool IsHr { get; set; }

    [Parameter]
    public EventCallback OnAddAsset { get; set; }

    [Parameter]
    public EventCallback OnRequestAsset { get; set; }

    private string Subtitle =>
        IsOrgAdmin
            ? "Manage organization-wide assets and assignments"
            : "Manage department assets and requests";
}